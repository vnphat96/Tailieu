			\draw[thick] (B) -- (B') -- (A');
			\draw[thick] (B') -- (C');
			
			% --- Vẽ mặt nước (IJKL) ---
			\coordinate (I) at (0,2.5);
			\coordinate (J) at (4,2.5);
			\coordinate (K) at (5.5,4);
