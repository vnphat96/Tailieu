\begin{ex}%[2H5N2-1]
	Trong không gian với hệ tọa độ $Oxyz$, đường thẳng $\Delta\colon\heva{& x=2-t\\& y=1\\& z=-2+3t}$ không đi qua điểm nào sau đây?
	\choice
	{\True $\mathrm{P}(4; 1;-4)$}
	{$N(0; 1; 4)$}
	{$Q(3; 1;-5)$}
	{$M(2; 1;-2)$}
	\loigiai{
		Thay tọa độ điểm $P(4; 1;-4)$ vào phương trình của $\Delta$. Ta có $\heva{& 4=2-t\\& 1=1\\&-4=-2+3t}\Leftrightarrow\heva{&t=-2\\& t=\dfrac{-2}{3}}$.\\
		Hệ vô nghiệm vậy đường thẳng $\Delta$ không đi qua điểm $P(4; 1;-4)$.
	}
\end{ex}

\begin{ex}%[2D6N1-2]
	Nếu hai biến cố $A$, $B$ thỏa mãn $\mathrm{P}(B)=0{,}7$; $\mathrm{P}(A\cap B)=0{,}2$ thì $\mathrm{P}(A\mid B)$ bằng
	\choice
	{$\dfrac{1}{2}$}
	{\True $\dfrac{2}{7}$}
	{$\dfrac{7}{50}$}
	{$\dfrac{5}{7}$}
	\loigiai{
		Ta có $\mathrm{P}(A\mid B)=\dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)}=\dfrac{2}{7}$.
	}
\end{ex}

\begin{ex}%[1H8N7-2]
	Cho lăng trụ tam giác $ABC.A'B'C'$ có thể tích bằng $6a^3$. Thể tích của hình chóp $A.A'B'C'$ bằng
	\choice
	{\True $2a^3$}
	{$4a^3$}
	{$3a^3$}
	{$a^3$}
	\loigiai{
	Gọi $h$ và $S$ lần lượt là đường cao và diện tích đáy của lăng trụ $ABC.A'B'C'$.\\
	Ta có $V_{ABC.A'B'C'}=h\cdot S=6a^3$, suy ra $V_{A.A'B'C'}=\dfrac{1}{3}h\cdot S=2a^3$.
	}
\end{ex}

\begin{ex}%[2D1H4-1]
	Cho hàm số $y=f(x)$ liên tục trên $\mathbb{R}$ và có bảng biến thiên như hình bên dưới. Tổng số đường tiệm cận đứng và tiệm cận ngang của đồ thị hàm số $y=f(x)$ là
	\begin{center}
		\begin{tikzpicture}[font=\normalsize,t style/.style={style=solid}]
			\tkzTabInit[nocadre=false, lgt=1.2, espcl=2.5, deltacl=0.5]
			{$x$/0.75, $f(x)$/3}
			{$-\infty$, $1$, $3$, $5$, $+\infty$}
			\tkzTabVar{+/ $+\infty$, -D-/ $-\infty$/$-\infty$, +D+/ $-3$/$2$, -D-/$-\infty$/$0$ , +/ $4$}
		\end{tikzpicture}
	\end{center}
	\choice
	{\True $3$}
	{$4$}
	{$2$}
	{$5$}
	\loigiai{
		Ta có 
		\begin{itemize}
			\item $\lim\limits_{x\to 1^{+}}f(x)=-\infty$ suy ra tiệm cận đứng là $x=1$.
			\item $\lim\limits_{x\rightarrow 5^{-}}f(x)=-\infty$ suy ra tiệm cận đứng là $x=5$.
			\item $\lim\limits_{x\rightarrow+\infty}f(x)=4$ suy ra tiệm cận ngang là $y=4$.
		\end{itemize}
	}
\end{ex}

\begin{ex}%[2D4N1-2]
	Tìm họ nguyên hàm $F(x)$ của hàm số $f(x)=x^3+x+1$
	\choice
	{$F(x)=\dfrac{x^4}{4}+\dfrac{x^3}{2}+C$}
	{$F(x)=3x^3+C$}
	{$F(x)=x^4+\dfrac{x^3}{2}+x+C$}
	{\True $F(x)=\dfrac{x^4}{4}+\dfrac{x^2}{2}+x+C$}
	\loigiai{
	Ta có $\displaystyle\int\left(x^3+x+1\right)\mathrm{\,d}x=\dfrac{x^4}{4}+\dfrac{x^2}{2}+x+C$.
	}
\end{ex}

\begin{ex}%[2D4H3-1]
	Tính diện tích hình phẳng được giới hạn bởi các đường $y=x^2$, $y=x$.
	\choice
	{$S=\dfrac{1}{2}$}
	{$S=\dfrac{1}{3}$}
	{\True $S=\dfrac{1}{6}$}
	{$S=\dfrac{5}{6}$}
	\loigiai{
		Phương trình hoành độ giao điểm $x^2=x\Leftrightarrow \hoac{&x=0\\& x=1.}$\\
		Diện tích hình phẳng là $S=\displaystyle\int\limits_0^1\left|x^2-x\right| \mathrm{\,d}x=\dfrac{1}{6}$.
	}
\end{ex}

\begin{ex}%[2D1N2-2]
	Cho hàm số $y=f(x)$ có đồ thị như hình vẽ dưới đây. Hàm số đã cho có mấy điểm cực trị?
	\begin{center}
		\begin{tikzpicture}[line cap=butt,line join=miter,>=stealth,xscale=0.83,yscale=0.83] 
			\tikzset{declare function={xmin=-3; xmax=3;
					ymin=-2; ymax=4; 
					a=-1; b=0; c=3; d=1; 
					xm=-1; ym=-1;
					xh=1; yh=3;
					f (\x)=a*(\x)^3+b*(\x)^2+c*(\x)+d;
				}, 
				smooth,samples=50
			}
			\draw[->] (xmin-0.25,0)--(xmax+0.5,0)
			node[shift={(-100:7pt)},font=\normalsize]{$ x $};
			\draw[->] (0,ymin-0.25)--(0,ymax+0.5)
			node[shift={(-5:7pt)},font=\normalsize]{$ y $};
			\fill (0,0) node[shift={(-45:9pt)},font=\normalsize]{$ O $};
			\begin{scope} 
				\clip (xmin,ymin) rectangle (xmax,ymax); 
				\draw plot[domain=xmin:xmax] (\x,{f (\x)});
			\end{scope}
		\end{tikzpicture} 
	\end{center}
	\choice
	{$0$}
	{$1$}
	{$4$}
	{\True $2$}
	\loigiai{
	Dựa vào đồ thị hàm số ta thấy hàm số có 1 điểm cực đại và 1 điểm cực tiểu.
	}
\end{ex}

\begin{ex}%[1D2N2-3]
	Cho dãy số có các số hạng đầu là $5$; $10$; $15$; $20$; $25$; $\ldots$. Số hạng tổng quát của dãy số này là
	\choice
	{$u_n=5(n-1)$}
	{$u_n=5n+1$}
	{\True $u_n=5n$}
	{$u_n=5+n$}
	\loigiai{
		Dãy số đã cho là một cấp số cộng với $u_1=5$ công sai $d=5$.\\
		Số hạng tổng quát của dãy là $u_n=5+5(n-1)=5n$.
	}
\end{ex}

\begin{ex}%[1D6H1-2]
	Cho biểu thức $P=\sqrt[6]{x\cdot\sqrt[4]{x^5\cdot\sqrt{x^3}}}$, với $x>0$. Mệnh đề nào dưới đây đúng?
	\choice
	{$P=x^{\tfrac{47}{48}}$}
	{$P=x^{\tfrac{15}{16}}$}
	{\True $P=x^{\tfrac{7}{16}}$}
	{$P=x^{\tfrac{5}{42}}$}
	\loigiai{
	$P=\sqrt[6]{x\cdot\sqrt[4]{x^5\cdot\sqrt{x^3}}}=x^{\left[\left(\tfrac{3}{2}+5\right)\tfrac{1}{4}+1\right]\tfrac{1}{6}}=x^{\tfrac{7}{16}}$.	
	}
\end{ex}

\begin{ex}%[1D6N4-3]
	Tập nghiệm của bất phương trình $3^{2x-1}>27$ là
	\choice
	{$(3;+\infty)$}
	{$\left(\dfrac{1}{3};+\infty\right)$}
	{$\left(\dfrac{1}{2};+\infty\right)$}
	{\True $(2;+\infty)$}
	\loigiai{
		$3^{2x-1}>27\Leftrightarrow 3^{2x-1}>3^3\Leftrightarrow 2x-1>3\Leftrightarrow x>2$.\\
		Vậy tập nghiệm của bất phương trình là $S=(2;+\infty)$.
	}
\end{ex}

\begin{ex}%[2D4N2-2]
	Tính tích phân $I=\displaystyle\int\limits_1^2\dfrac{1}{2x-1}\mathrm{\,d}x$
	\choice
	{$I=\ln 3-1$}
	{$I=\ln 2-1$}
	{$I=\ln 2+1$}
	{\True $I=\ln\sqrt{3}$}
	\loigiai{
		$I=\displaystyle\int\limits_1^2\dfrac{1}{2x-1}\mathrm{\,d}x=\left.\dfrac{1}{2}\ln |2x-1|\right|_1^2=\dfrac{1}{2}(\ln 3-\ln 1)=\ln\sqrt{3}$.
	}
\end{ex}

\begin{ex}%[2D4N1-2]
	Tìm nguyên hàm của hàm số $f(x)=\dfrac{2}{4x-3}$.
	\choice
	{$\displaystyle\int\dfrac{2}{4x-3}\mathrm{\,d}x=2\ln\left|2x-\dfrac{3}{2}\right|+C$}
	{$\displaystyle\int\dfrac{2}{4x-3}\mathrm{\,d}x=\dfrac{1}{2}\ln\left(2x-\dfrac{3}{2}\right)+C$}
	{\True $\displaystyle\int\dfrac{2}{4x-3}\mathrm{\,d}x=\dfrac{1}{2}\ln\left|2x-\dfrac{3}{2}\right|+C$}
	{$\displaystyle\int\dfrac{2}{4x-3}\mathrm{\,d}x=\dfrac{1}{4}\ln |4x-3|+C$}
	\loigiai{
	Ta có $\displaystyle\int\dfrac{2}{4x-3}\mathrm{\,d}x=\displaystyle\int\dfrac{\mathrm{\,d}x}{2x-\dfrac{3}{2}}=\dfrac{1}{2}\ln\left|2x-\dfrac{3}{2}\right|+C$.
	}
\end{ex}


