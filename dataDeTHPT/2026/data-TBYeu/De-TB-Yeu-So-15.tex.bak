			\coordinate (H1) at (2.5, 6.1);
			\coordinate (H2) at (3.2, 6.1);
			\coordinate (H3) at (3.5, 5.7);
			\coordinate (H4) at (2.8, 5.7);
			\draw[thick] (H1) -- (H2) -- (H3) -- (H4) -- cycle;
			
