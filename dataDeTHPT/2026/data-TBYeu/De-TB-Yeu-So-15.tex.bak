					\fill (\x) circle(1pt);
				}
				\path 
				node at (O) [above left]{$O$}
				node at (A) [above] {$A$}
				node at (A1) [above]{B}
				node at (A2) [above right]{$C$}
				node at (A3) [above]{$d$}
				node at (Oz) [left]{$z$}
				node at (O5) [below]{$y$}
				node at (Ox')[below]{$x$}
				;
			\end{tikzpicture}
		\end{center}
		Ranh giới vùng phủ sóng của đài kiểm soát không lưu là mặt cầu $\left( S \right)$ tâm $O\left( 0;0;0 \right)$ bán kính $R=600$ km.\\
		Vậy $\left( S \right)\colon x^2+y^2+z^2=600^2$.\\
		Thay $d\colon\heva{& x=-1000+100t \\ & y=-200+80t \\ & z=10}$ vào $\left( S \right)\colon x^2+y^2+z^2=600^2$, ta có 
		\begin{eqnarray*}
			\left( 100t-1000 \right)^2+\left( 80t-200 \right)^2+10^2=600^2
			&\Leftrightarrow& 16400t^2-232000t+680100=0\\
			&\Leftrightarrow& \hoac{& t \approx 10 \Rightarrow B\left( 0;600;10 \right) \\ & t \approx 4{,}15 \Rightarrow C\left( -585;132;10 \right).}
		\end{eqnarray*}
		Suy ra $BC=\sqrt{\left( -585-0 \right)^2+\left( 132-600 \right)^2+\left( 10-10 \right)^2} \approx 749~ \text{(km)}.$\\
		Vậy quãng đường mà máy bay nhận được tín hiệu của đài kiểm soát không lưu khoảng $749$ km.
	}
\end{ex}


