		\end{center}
		Mặt cầu $(S)$ có phương trình
		$(x-22)^2+(y-4)^2+(z-13)^2=194$ nên có tâm $I(22 ; 4 ; 13)$, bán kính $R=\sqrt{194}$.\\
		Trong không gian $Oxyz$, mặt sân có phương trình $z=0$ trùng với mặt phẳng toạ độ $(Oxy)$, suy ra hình chiếu vuông góc của điểm $I(22 ; 4 ; 13)$ xuống mặt sân có toạ độ $J(22 ; 4 ; 0)$.\\
		Trong tam giác vuông $IJM$, ta có $IJ=13, IM=R=\sqrt{194}$.\\
		Suy ra: $JM=\sqrt{I M^2-I J^2}=\sqrt{194-169}=5$.\\
		Vậy khoảng cách từ vị trí $M$ của quả bóng đến điểm $J$ là $5$ m.	
	}
\end{ex}

\begin{ex}%[2D4H3-4]
	\immini{Một chiếc đèn cói có hình như hình bên. Nếu cắt đèn bằng một mặt phẳng song song với đáy và cách đáy một khoảng $x$ (dm) $(0\le x\le 4)$ thì được thiết diện là một hình tròn có bán kính $\sqrt{4-x}$ (dm). Thể tích của chiếc đèn cói là bao nhiêu?
	}{
		\definecolor{ashgrey}{rgb}{0.7, 0.75, 0.71}
		\definecolor{brown(traditional)}{rgb}{0.59, 0.29, 0.0}
		\definecolor{bronze}{rgb}{0.8, 0.5, 0.2}
		\definecolor{buff}{rgb}{0.94, 0.86, 0.51}
		\begin{tikzpicture}[line join=round, line cap=round,scale=1,transform shape]
			%--------------
			\tikzset{den_tron/.pic={
					\draw[fill=ashgrey] (.5,2)
					..controls +(150:.2) and +(30:.2) ..(-.5,2)--(-.5,1)--(.5,1)--cycle;
					\def\N{ 
						(.65,1)
						..controls +(150:.2) and +(30:.2) ..(-.65,1)
						..controls +(-90:.7) and +(90:.7) ..(-1.25,-1)
						..controls +(-90:1.6) and +(-90:1.6) ..(1.25,-1)
						..controls +(90:.7) and +(-90:.7) ..cycle
						;
					}
					
					\fill[buff] \N;
					\draw[black]\N;
			}}
			
			%---------------------------------
			\tikzset{coi/.pic={
					\draw[brown(traditional),line width=.6mm,name path=duoi_phia_sau](-2.3,-1.5)
					..controls +(60:1) and +(120:1) ..(2.3,-1.5);
					
					\draw[brown(traditional),line width=.4mm,name path=tren](-.7,1.3)
					..controls +(30:.2) and +(150:.2) ..(.6,1.3)
					foreach \i in{0,1,2,...,10}{coordinate[pos=\i/10](A\i)};
					
					\draw[brown(traditional),line width=.4mm,name path=duoi](-2.3,-1.5)
					..controls +(-60:.8) and +(-120:.8) ..(2.3,-1.5)
					foreach \i in{0,1,2,...,10}{coordinate[pos=\i/10](B\i)};
					
					\foreach \i in{0,1,2,...,10}
					\draw[brown(traditional),line width=.5mm] (A\i)--(B\i);
					
					\draw[name path=trai](A0)--(B0)
					foreach \i in{0,1,2,...,10}{coordinate[pos=\i/10](C\i)};
					
					\draw[name path=phai](A10)--(B10)
					foreach \i in{0,1,2,...,10}{coordinate[pos=\i/10](D\i)};
					
					\foreach \i in{1,2,...,5}
					\draw[brown(traditional),line width=.4mm] (C\i) ..controls +(20:.2) and +(160:.2) ..(D\i);
					\draw[brown(traditional),line width=.4mm] (C6) ..controls +(-10:.6) and +(-170:.6) ..(D6);
					\foreach \i in{7,8}
					\draw[brown(traditional),line width=.4mm] (C\i) ..controls +(-60:.4) and +(-120:.4) ..(D\i);
					\draw[brown(traditional),line width=.4mm] (C9) ..controls +(-60:.6) and +(-120:.6) ..(D9);
					
					\foreach \i in{2,...,8}
					\draw[brown(traditional),line width=.4mm] (C\i) ..controls +(60:.4) and +(120:.4) ..(D\i);
					%-----------------
					\foreach \i in{0,1,2,...,5,6,7,8}
					\draw[bronze,line width=.4mm,name path=vien_cheo_1](B\i)..controls +(20:.4) and +(-80:.4) ..(D\i);
					\foreach \i in{2,3,...,5,6,7,8}
					\draw[bronze,line width=.4mm,name path=vien_cheo_2](C\i)..controls +(0:.2) and +(-80:.2) ..(A\i);
					%---------
					\draw[name path=vien_tren_trai](C0)--(C1)
					foreach \i in{0,1,2,...,5}{coordinate[pos=\i/5](X\i)};
					
					\draw[name path=vien_tren_phai](D0)--(D1)
					foreach \i in{0,1,2,...,5}{coordinate[pos=\i/5](Y\i)};
					
					\foreach \i in{0,1,2,...,5}
					\draw[brown(traditional),line width=.4mm] (X\i) ..controls +(20:.2) and +(160:.2) ..(Y\i);
					%---------
					\draw[name path=vien_duoi_trai](C9)--(C10)
					foreach \i in{0,1,2,...,5}{coordinate[pos=\i/5](Z\i)};
					
					\draw[name path=vien_duoi_phai](D9)--(D10)
					foreach \i in{0,1,2,...,5}{coordinate[pos=\i/5](T\i)};
					
					\foreach \i in{0,1,2,...,5}
					\draw[brown(traditional),line width=.4mm] (Z\i) ..controls +(-70:.6) and +(-110:.6) .. (T\i);
					%-----------------
					\draw[name path=vien_duoi](-.7,1.3)
					..controls +(30:.2) and +(150:.2) ..(.6,1.3)
					foreach \i in{0,1,2,...,10}{coordinate[pos=\i/10](A\i)};
					
			}}
			\draw[black,line width=.4mm](0,0)--(0,1.2);
			\path (0,0)pic[scale=.3]{den_tron}
			(0,0)pic[scale=1]{coi};
			
		\end{tikzpicture}
	}
	\shortans[oly]{25{,}1}
	\loigiai{
		Diện tích thiết diện là $S(x)=\pi \cdot R^2=\pi (4-x)$ (dm$^2$).\\
		Thể tích đèn cói là 
		\begin{eqnarray*}
			V&=&\displaystyle\int\limits_0^4 S(x)\mathrm{\,d}x=\pi \displaystyle\int\limits_0^4(4-x)\mathrm{\,d}x\\
			&=&\pi \left(4x-\dfrac{x^2}{2}\right)\bigg|_0^4=8\pi \approx 25{,}1\,(\text{dm}^3).
		\end{eqnarray*}
	}
\end{ex}

\begin{ex}%[1H4H5-4]
	Phần trong của một bể đựng nước được xây có dạng hình hộp chữ nhật có chiều cao $2$ m như hình vẽ. Bạn Minh lấy một thanh thước thẳng đủ dài cắm vào bể sao cho một đầu chạm đáy bể và để thước tựa vào mép dưới của thành miệng bể, đánh dấu điểm tựa. Sau đó rút thước lên, bạn Minh đo được độ dài của phần thước chìm trong nước là $1{,}55$ và độ dài của phần thước từ điểm được đánh dấu đến điểm đầu chạm đáy bề là $2{,}5$ m. Tính mực nước còn lại trong bể.
