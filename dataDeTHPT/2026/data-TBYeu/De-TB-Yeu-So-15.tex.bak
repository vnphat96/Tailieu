				\coordinate (M) at (2.8, 5.7); % Điểm tựa miệng bể
				\coordinate (N) at (intersection of M--O and I--K); % Giao điểm với mặt nước
				\coordinate (P) at (2.8, 3.2);
				\coordinate (H) at (2.8, 0.5);
				\draw[thick, blue] (T) -- (M); % Phần thước trên mặt nước
				\draw[thick, blue, dashed] (M) -- (O); % Phần thước chìm trong nước
				\draw[thick, blue, dashed] (M) -- (H) (N)--(P) (O)--(H);
				% --- Đánh dấu chấm đậm tại M, N, O ---
				\fill (M) circle (1.5pt);
				\fill (N) circle (1.5pt);
				\fill (O) circle (1.5pt);
				\fill (P) circle (1.5pt);
				\fill (H) circle (1.5pt);
				
				% --- Đánh dấu các nhãn chữ ---
				\node[below] at (A) {$A$};
				\node[below] at (B) {$B$};
				\node[right] at (C) {$C$};
				\node[left] at (D) {$D$};
				\node[left] at (A') {$A'$};
				\node[right] at (B') {$B'$};
				\node[above right] at (C') {$C'$};
				\node[above] at (D') {$D'$};
				
				\node[left] at (I) {$I$};
				\node[below right] at (J) {$J$};
				\node[right] at (K) {$K$};
				\node[above left] at (L) {$L$};
				
				\node[below left] at (M) {$M$}; % Chỉnh lại vị trí nhãn M cho đẹp
				\node[right] at (N) {$N$}; % Chỉnh lại vị trí nhãn N cho đẹp
				\node[below] at (O) {$O$};
				\node[left] at (P) {$P$};
				\node[left] at (H) {$H$};
				
			\end{tikzpicture}
		\end{center}
	Gọi $ABCD.A'B'C'D'$ là hình hộp chữ nhật phần trong của bể, $(IJKL)$ là mặt nước, $M$ là điểm tựa của thước vào mép dưới của thành miệng bể, $O$ là điểm chạm đáy bể, $ON=1{,}55$ m là phần thước chìm trong nước.\\
	Ta có $3$ mặt phẳng $(ABCD)$, $(IJKL)$, $(A'B'C'D')$ đôi một song song.\\
	Áp dụng định lý Thales trong không gian, ta có:
	$$\dfrac{A'I}{AA'}=\dfrac{ON}{OM} \Rightarrow \dfrac{A'I}{2}=\dfrac{1{,}55}{2{,}5} \Rightarrow A'I=2 \cdot \dfrac{1{,}55}{2{,}5}=1{,}24\,(\mathrm{m}).$$
	Vậy mực nước còn lại trong bể là $1{,}24$ m.
}
\end{ex}

\begin{ex}%[2D1V1-5]
	Sau khi phát hiện một bệnh dịch, các chuyên gia y tế ước tính số người nhiễm bệnh kể từ ngày xuất hiện bệnh nhân đầu tiên đến ngày thứ $t$ là $f(t)=45t^2-t^3$, $t=0,1,2, \ldots, 25$. Nếu coi $f(t)$ là hàm số xác định trên đoạn $[0; 25]$ thì đạo hàm $f'(t)$ được xem là tốc độ truyền bệnh (người/ngày) tại thời điểm $t$. Xác định ngày mà tốc độ truyền bệnh là lớn nhất?
	\par
	\shortans{15}
	\loigiai{
		Số người nhiễm bệnh kể từ ngày xuất hiện bệnh nhân đầu tiên đến bệnh nhân thứ $t$ là
		$$	f(t)=-t^3+45 t^2, t \in[0; 25].$$
		Tốc độ truyền bệnh tại thời điểm $t$ là $f'(t)=-3 t^2+90 t,t \in[0; 25]$.\\
		Ta có $f''(t)=-6 t+90$; $f''(t)=0 \Leftrightarrow t=15$.\\
		Bảng biến thiên
		\begin{center}
			\begin{tikzpicture}
				\tkzTabInit[nocadre=false,lgt=1.5,espcl=2.5,deltacl=0.6]
				{$x$/0.7,$f''(t)$/0.7,$f'(t)$/2}
				{$0$,$15$,$25$}
				\tkzTabLine{,+,0,-,}
				\tkzTabVar{-/$f'(0)$,+/$f'(15)$,-/$f'(25)$}
			\end{tikzpicture}
		\end{center}
		Vậy tốc độ truyền bệnh lớn nhất vào ngày thứ $15$.
	}
\end{ex}

\begin{ex}%[2D4V3-2]
	\immini{Một mảnh đất hình chữ nhật có chiều dài $60$ m, chiều rộng $20$ m. Người ta muốn trồng cỏ ở hai đầu của mảnh đất hai hình bằng nhau giới hạn bởi hai đường parabol có hai đỉnh cách nhau $40$ m (như hình vẽ bên). Phần còn lại của mảnh đất người ta lát gạch. Biết chi phí lát gạch là $200\,000$ đồng/m$^2$ và tiền nhân công trồng cỏ là $100\,000$ đồng/m$^2$. Tính tổng số tiền để lát gạch và trồng cỏ trên mảnh đất đó (làm tròn kết quả đến hàng nghìn, đơn vị nghìn đồng).}
	{\begin{tikzpicture}[line cap=butt,line join=miter,>=stealth,xscale=.15,yscale=.07,font=\normalsize]
			\tikzset{declare function={xmin=0;xmax=25;ymin=0;ymax=65;
					f(\x)=-.1*(\x)^2+2*(\x);
					g(\x)=.1*(\x)^2-2*(\x)+60;
				},
				smooth,samples=450
			}
			\draw(0,60)--(20,60)--(20,0);
			\draw[<->,dashed](22,0)--(22,60)node[pos=0.5,sloped,below]{$60$m};
			\draw[<->,dashed](10,10)--(10,50)node[pos=0.5,sloped,above]{$40$m};
			\draw[<->,dashed](0,65)--(20,65)node[pos=0.5,sloped,above]{$20$m};
			\draw (20,0)--(0,0)node[left]{$O$} circle(1.2pt)--(0,60)node[left]{$A$} circle(1.2pt)
			(20,60)node[above right]{$B$} circle(1.2pt)
			(20,0)node[below]{$C$} circle(1.2pt)
			(10,10)node[above right]{$F$} circle(1.2pt)
			(10,50)node[below right]{$E$} circle(1.2pt);
			\fill[pattern=north west lines]plot[domain=0:20] (\x, {f(\x)})--(0,0)--(20,0);
			\fill[pattern=north west lines]plot[domain=0:20] (\x, {g(\x)})--(0,60)--(20,60);
			\clip (xmin,ymin) rectangle (xmax,ymax);
			\draw  plot[domain=0:20] (\x, {f(\x)});
			\draw[violet]  plot[domain=0:20] (\x, {g(\x)});
	\end{tikzpicture}}
	\shortans{213}
	\loigiai{
		Gán hệ trục tọa độ như hình vẽ
		\begin{center}
			\begin{tikzpicture}[line cap=butt,line join=miter,>=stealth,xscale=.2,yscale=.08,font=\normalsize]
				\tikzset{declare function={xmin=-5;xmax=30;ymin=-5;ymax=70;
						f(\x)=-.1*(\x)^2+2*(\x);
						g(\x)=.1*(\x)^2-2*(\x)+60;
					},
					smooth,samples=450
				}
				\draw[->] (xmin,0)--(xmax,0) node[shift={(-100:7pt)}]{$ x $};
				\draw[->] (0,ymin)--(0,ymax) node[shift={(190:7pt)}]{$ y $};
				\fill (0,0) node[shift={(225:10pt)}]{$ O $};
				\draw(0,60)--(20,60)--(20,0);
				\draw[<->,dashed](22,0)--(22,60)node[pos=0.5,sloped,below]{$60$m};
				\draw[<->,dashed](10,10)--(10,50)node[pos=0.5,sloped,above]{$40$m};
				\draw[<->,dashed](0,65)--(20,65)node[pos=0.5,sloped,above]{$20$m};
				\draw (0,60)node[left]{$A$} circle(1.2pt)
				(20,60)node[above right]{$B$} circle(1.2pt)
				(20,0)node[below]{$C$} circle(1.2pt)
				(10,10)node[above right]{$F$} circle(1.2pt)
				(10,50)node[below right]{$E$} circle(1.2pt);
				\fill[pattern=north west lines]plot[domain=0:20] (\x, {f(\x)})--(0,0)--(20,0);
				\fill[pattern=north west lines]plot[domain=0:20] (\x, {g(\x)})--(0,60)--(20,60);
				\clip (xmin,ymin) rectangle (xmax,ymax);
				\draw  plot[domain=0:20] (\x, {f(\x)});
				\draw[violet]  plot[domain=0:20] (\x, {g(\x)});
			\end{tikzpicture}
		\end{center}
		Tọa độ các điểm  $O(0;0)$, $A(0;60)$, $B(20;60)$, $C(20;0)$; $E(10;50)$; $F(10;10)$.\\
		Parabol $(P)$ có đỉnh $F(10;10)$, có phương trình dạng $y=a(x-10)^2+10$.\\
		$(P)$ đi qua $C(20;0)$ $\Leftrightarrow a\cdot(20-10)^2+10=0\Leftrightarrow a=-\dfrac{1}{10}$.\\
		Vậy $(P)\colon y=-\dfrac{1}{10} (x-10)^2+10$.\\
		Diện tích trồng cỏ là $S=2\displaystyle\int\limits_0^{20}\left[-\dfrac{1}{10} (x-10)^2+10\right]\mathrm{\,d}x=\dfrac{800}{3}$~(m$^2$).\\
		Diện tích lát gạch $S_g=20\cdot 60-S=1200-\dfrac{800}{3}=\dfrac{2800}{3}$~(m$^2$).\\
		Tổng số tiền để lát gạch và trồng cỏ là $\dfrac{2800}{3}\cdot 200\,000+\dfrac{800}{3}\cdot 100\,000\approx 213\,333$ nghìn đồng. 
	}
\end{ex}

\begin{ex}%[2H5V3-4]
	Trong không gian hệ trục tọa độ $Oxyz$(đơn vị trên mỗi trục là kilômét), đài kiểm soát không lưu sân bay Cam Ranh – Khánh Hòa ở vị trí $O\left( 0;0;0 \right)$ và được thiết kế phát hiện máy bay ở khoảng cách tối đa $600$ km. Một máy bay của hãng Việt Nam Airlines đang chuyển động theo đường thẳng $d$ có phương trình $\heva{& x=-1000+100t \\ & y=-200+80t \\ & z=10}\, \left( t\in \mathbb{R} \right)$, và hướng về đài kiểm soát không lưu (như hình vẽ). Xác định quãng đường mà máy bay nhận được tín hiệu của đài kiểm soát không lưu. (làm tròn kết quả đến hàng đơn vị, đơn vị km)
	\begin{center}
		\begin{tikzpicture}[scale=0.8]
			\def\r{3}
			\def \x{3}  %bán kính trục lớn elip
			\def \y{1.2} 
			\coordinate (o1) at (-\r,0);
			\coordinate (o2) at (\r,0);
			\coordinate (O) at (0,0);
			
			% ve mp
			\coordinate (P) at (-5,2);
			\coordinate (Q) at ($(P)+(240:6)$);
			\coordinate (R) at ($(Q)+(12,0)$);
			\coordinate (S) at ($(R)+(60:6)$);
			\fill[cyan!20] (P)--(Q)--(R)--(S)--cycle;
			
			
			\draw (O) circle(\r); 
			\path[fill=orange!20] (O) circle(\r); 
			\fill[orange!80] (o2) arc (0:-180:\x cm and \y cm) arc (180:360:\x cm and \x cm);
			\draw[dashed] (o2) arc (0:180:\x cm and \y cm);
			\draw (o2) arc (0:-180:\x cm and \y cm);
			
			% truc oz
			\coordinate (Oz) at (0,4.5);
			\coordinate (Oz') at (0,2.5);
			\coordinate (Oz'') at (0,-3.5);
			\draw[dashed] (Oz'')--(Oz');
			\draw[->] (Oz')--(Oz);
			% tru  ox
			\def\t{240}
			\coordinate (Ox) at ({\x*cos(\t)},{\y*sin(\t)});
			\coordinate (Ox') at ($(O)!2!(Ox)$);
			\coordinate (Ox'') at ($(Ox)!2.2!(O)$);
			\draw[dashed] (O)--(Ox);
			\draw[->] (Ox)--(Ox');
			\draw[dashed] (O)--(Ox'');
