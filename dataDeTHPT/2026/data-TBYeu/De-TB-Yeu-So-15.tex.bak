\begin{ex}%[2H5H2-4]
	Trong không gian $Oxyz$, cho điểm $A(1;-1; 2)$ và đường thẳng $d\colon\heva{&x=1+2t\\&y=2-t\\&z=-1+t}(t\in\mathbb{R})$.
	\choiceTF
	{\True Đường thẳng $\Delta$ đi qua điểm $A$ và song song với đường thẳng $d$ là: $\dfrac{x+1}{2}=\dfrac{y-1}{-1}=\dfrac{z+2}{1}$}
	{\True Đường thẳng $d$ có một vectơ chỉ phương $\vec{u}=(2;-1; 1)$}
	{Điểm $M(1; 2;-1)$ thuộc đường thẳng $d$}
	{\True Hình chiếu vuông góc của điểm $A$ lên đường thẳng $d$ là: $H(3; 1; 0)$}
	\loigiai{
		\begin{itemchoice}
			\itemch Đường thẳng $\Delta$ qua $A$ và song song với đường thẳng $d$ nên có một vectơ chỉ phương $\overrightarrow{u}_{\Delta}=\vec{u}=(2;-1; 1)$.\\
			Suy ra phương trình đường thẳng $\Delta\colon\dfrac{x-1}{2}=\dfrac{y+1}{-1}=\dfrac{z-2}{1}$.
			\itemch Thay tọa độ điểm $M(1; 2;-1)$ vào phương trình đường thẳng $d$ ta được
			$$\heva{&1=1+2t\\&2=2-t\\&-1=-1+t}\Leftrightarrow\heva{&t=0\\&t=0\\&t=0}\Rightarrow M(1; 2;-1)\in d.$$
			\itemch Đường thẳng $d$ có một vectơ chỉ phương $\vec{u}=(2;-1; 1)$.
			\itemch
			Ta có $\overrightarrow{AH}=(2t; 3-t;-3+t)$,\\
			$AH\perp d\Rightarrow\overrightarrow{AH}\cdot\vec{u}=0\Leftrightarrow 2\cdot 2t-1\cdot(3-t)+1\cdot(-3+t)=0\Leftrightarrow t=1$.\\
			Vậy $H(3; 1; 0)$.
		\end{itemchoice}
		
	}
\end{ex}

\begin{ex}%[2D1H5-1]
	\immini{Cho hàm số $y=\dfrac{ax^2+bx+c}{dx+e}, (a, b, c, d, e\in\mathbb{R})$ có đồ thị như hình vẽ bên.
	Xét tính đúng - sai của các mệnh đề sau
	\choiceTF
	{\True $ad>0$}
	{\True $ce<0$}
	{$bd>0$}
	{$de>0$}
}{
	\begin{tikzpicture}[scale=0.4,font=\footnotesize,line join=round
	,line cap=round,>=stealth]
	\tikzset{every node/.style={scale=0.8}}
	\draw[->] (-4,0)--(7,0) node[below left] {$x$};
	\draw[->] (0,-4)--(0,7) node[below left] {$y$};
	\draw (0,0) node [above left] {$O$};
	\begin{scope}
		\clip (-4,-4) rectangle (7,7);
		\draw[samples=200,domain=-5:0.99,smooth,variable=\x] plot (\x,{\x-1+1/(1*(\x)+-1)});
		\draw[samples=200,domain=1.01:7,smooth,variable=\x] plot (\x,{\x-1+1/(1*(\x)+-1)});
		%	\draw[,thin] (-5.1,-7.1)--(7.1,5.1);
		\draw (-4,-5)--(7,6) (1,-4)--(1,7);
	\end{scope}
\end{tikzpicture}
}
	\loigiai{
		\begin{itemchoice}
			\itemch Dựa vào hình dáng đồ thị ta có $\lim\limits_{x\to+\infty}y=+\infty$ nên $\dfrac{a}{d}>0$ hay $ad>0$.
			\itemch Đồ thị hàm số cắt trục tung tại điểm có tung độ âm nên $\dfrac{c}{e}<0\Rightarrow ce<0$.
			\itemch Đường thẳng đi qua 2 điểm cực trị của hàm số đã cho là $y=\dfrac{2ax+b}{d}$.\\
			Mà đường thẳng cắt trục tung tại điểm có tung độ âm nên $\dfrac{b}{d}<0\Rightarrow b d<0$.
			\itemch Đồ thị có tiệm đường tiệm cận đứng $x=\dfrac{-e}{d}>0\Rightarrow ed<0$.
			
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2H2H2-2]
	Trong không gian với hệ tọa độ $Oxyz$, cho bốn vệ tinh $A(0;4;5)$, $B(0;5;4)$, $C(1;3;3)$, $D(1;- 1;3)$. Điểm	$M(a,b;c)$ trong không gian, biết khoảng cách từ các vệ tinh đến điểm $M$ lần lượt là	$AM= 5$, $BM = 5$, $CM = 3$, $DM = 3$.
	\choiceTF
	{Tọa độ điểm $M(1;1;1)$}
	{\True $a^2 + \left(b-4\right)^2 + \left(c-5\right)^2=a^2+\left(b-5\right)^2+\left(c-4\right)^2= 25$}
	{\True $(a-1)^2+(b-3)^2+(c-3)^2=(a-1)^2+(b+1)^2+(c-3)^2=9$}
	{\True $b=c$}
	\loigiai{
		\begin{itemchoice}
			\itemch Ta có \begin{eqnarray*}
				&&CM^2-DM^2=0\\
				&\Leftrightarrow& (a-1)^2+(b-3)^2+(c-3)^2-\left[(a-1)^2+(b+1)^2+(c-3)^2\right]=0\\
				&\Leftrightarrow& (b-3)^2 -(b+1)^2=0\\
				&\Leftrightarrow& -8b+8=0 \Rightarrow b=1 \Rightarrow c=1.\quad (\text{Vì } b=c)
			\end{eqnarray*}
			Thay $b=c=1$ vào $a^2+(b-4)^2+(c-5)^2=25$, ta có $a^2+(1-4)^2+(1-5)^2=25 \Rightarrow a=0$.\\
			Vậy $M(0;1;1)$.
			\itemch Ta có $AM^2=BM^2=25$, suy ra $a^2+(b-4)^2+(c-5)^2=a^2+(b-5)^2+(c-4)^2=25$.
			\itemch Ta có $CM^2=DM^2=9$, suy ra $(a-1)^2+(b-3)^2+(c-3)^2=(a-1)^2+(b+1)^2+(c-3)^2=9$.
			\itemch Từ đẳng thức $a^2+(b-4)^2+(c-5)^2=a^2+(b-5)^2+(c-4)^2$ suy ra $b=c$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D6H1-2]
	Gieo hai con xúc xắc cân đối và đồng chất. Gọi $A$ là biến cố: \lq\lq Tích số chấm xuất hiện trên hai con xúc xắc là số chẵn\rq\rq, $B$ là biến cố: \lq\lq Có ít nhất một con xúc xắc xuất hiện mặt 3 chấm\rq\rq. Các khẳng định sau đây đúng hay sai?
	\choiceTF
	{\True $\mathrm{P}(AB)=\dfrac{1}{6}$}
	{\True $\mathrm{P}(B)=\dfrac{11}{36}$}
	{$\mathrm{P}(A\mid B)=\dfrac{5}{6}$}
	{$\mathrm{P}\left(\overline{A}\mid B\right)=\dfrac{4}{11}$}
	\loigiai{
		\begin{itemchoice}
			\itemch $n(\Omega)=6\cdot 6=36$.\\
			$AB=\{(3,2);(3,4);(3,6);(2,3);(4,3);(6,3)\} \Rightarrow n(AB)=6$.\\
			Do đó $\mathrm{P}(AB)=\dfrac{6}{36}=\dfrac{1}{6}$.
			\itemch Ta có $\overline{B}=\{(i; j)\mid i, j\in\{1, 2, 4, 5,6\}\}\Rightarrow n(\overline{B})=5\cdot5=25\Rightarrow n(B)=36-n(\overline{B})=11$.\\
			Do đó $\mathrm{P}(B)=\dfrac{11}{36}$.
			\itemch
			Ta có $\mathrm{P}(A\mid B)=\dfrac{\mathrm{P}(AB)}{\mathrm{P}(B)}=\dfrac{1}{6}:\dfrac{11}{36}=\dfrac{6}{11}$.
			\itemch Ta có $\overline{A}B=\{(3, 1);(3, 5);(1, 3); (3, 3);(5, 3)\}\Rightarrow n(\overline{A}B)=5$.\\
			Do đó $\mathrm{P}(\overline{A}\mid B)=\dfrac{n(\overline{A}B)}{n(B)}=\dfrac{5}{11}$.
		\end{itemchoice}
	}
\end{ex}


