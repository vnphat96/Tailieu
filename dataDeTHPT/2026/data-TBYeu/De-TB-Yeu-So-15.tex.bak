	\loigiai{
		\begin{center}
			\begin{tikzpicture}
				\path
				(0,0) coordinate (O)
				(6,0) coordinate (J)
				(8,2) coordinate (C)
				(2,2) coordinate (D)
				(5,1) coordinate (M)
				(6,3) coordinate (I);
				\draw[fill=purple,opacity=0.3] (O)--(J)--(C)--(D)--cycle;
