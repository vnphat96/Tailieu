\begin{ex}%[Văn Minh Thoại]%[2D4V2-6]
Một công trình xây dựng dự kiến hoàn thành trong $50$ ngày. Gọi $M(t)$ là số ngày công được tính đến hết ngày thứ $t$. Trong kinh tế xây dựng, người ta đã biết rằng $M'(t)=m(t)$ với $m(t)$ là số lượng công nhân được sử dụng tại thời điểm $t$. Biết rằng $m(t)=100+8\sqrt{t}-2t$.
\choiceTF
{Tổng cộng cần $4\,000$ ngày công để hoàn thành công trình xây dựng đó theo dự kiến}
{\True Trong $10$ ngày đầu tiên, công trình đã cần hơn $1\,000$ ngày công}
{\True Số công nhân được sử dụng nhiều nhất vào ngày thứ $4$}
{Có $72$ công nhân được sử dụng vào ngày thứ $49$}
\loigiai{
\begin{itemchoice}
\itemch Để hoàn thành công trình cần tổng cộng số ngày công theo dự kiến là
\[\displaystyle\int \limits_0^{50}\left(100+8\sqrt{t}-2t\right)\mathrm{\,d}t\approx4385{,}62>4\,000\;\text{(ngày công).}\]
\itemch Trong $10$ ngày đầu tiên, công trình đã cần số ngày công là
\[\displaystyle\int \limits_0^{10}\left(100+8\sqrt{t}-2t\right)\mathrm{\,d}t\approx1068{,}65>1\,000\;\text{(ngày công).}\]
\itemch Xét hàm số $m(t)=100+8\sqrt{t}-2t$ trên $[0;50]$, ta có $m'(t)=\dfrac{4}{\sqrt{t}}-2$. \\
Cho $m'(t)=0\Leftrightarrow \dfrac{4}{\sqrt{t}}=2\Leftrightarrow \sqrt{t}=2\Leftrightarrow t=4$.nKhi đó
\begin{itemize}
\item $m(0)=100$;
\item $m(4)=108$;
\item $m(50)=100+40\sqrt{2}-100=40\sqrt{2}\approx56{,}5$.
\end{itemize}
Do đó số công nhân được sử dụng nhiều nhất là $108$ công nhân vào ngày thứ $4$.
\itemch Vào ngày thứ $49$ có $m(49)=100+8\sqrt{49}-2\cdot 49=100+56-98=58\ne72$ công nhân được sử dụng.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5H2-3]
	Trong không gian $Oxyz$, cho điểm $A(-1;0;4)$ và đường thẳng $d$ có phương trình \break
	$\dfrac{x+1}{1}=\dfrac{y}{1}=\dfrac{z-1}{2}$. Gọi $\Delta$ là đường thẳng đi qua $A$, vuông góc và cắt $d$.
	\choiceTF
	{\True Đường thẳng $\Delta$ đi qua điểm $B(2;3;1)$}
	{Đường thẳng $\Delta$ có phương trình $\heva{&x=1+t\\&y=t\\&z=-4-t}$}
	{\True Một vectơ chỉ phương của $\Delta$ là $(1;1;-1)$}
	{\True Đường thẳng $\Delta$ có phương trình $\dfrac{x+1}{1}=\dfrac{y}{1}=\dfrac{z-4}{-1}$}
	\loigiai{
		Phương trình tham số của đường thẳng $d\colon \heva{&x=-1+t\\&y=t\\&z=1+2t.}$\\
		Gọi $M=d\cap \Delta \Rightarrow M(-1+t;t;1+2t)$.\\
		Khi đó $\overrightarrow{AM}=(t;t;2t-3)$ là một vectơ chỉ phương của đường thẳng $\Delta$.\\
		Đường thẳng $d$ có một vectơ chỉ phương là $\overrightarrow{u}_d=(1;1;2)$.\\
		Theo đề bài $\Delta \perp d\Leftrightarrow \overrightarrow{AM}\cdot \overrightarrow{u}_d=0\Leftrightarrow 1\cdot t+1\cdot t+2(2t-3)=0\Leftrightarrow 6t-6=0\Leftrightarrow t=1$.\\
		Với $t=1\Rightarrow \overrightarrow{AM}=(1;1;-1)$.\\
		Phương trình đường thẳng $\Delta$ đi qua $A(-1;0;4)$ và có một vectơ chỉ phương $\overrightarrow{AM}=(1;1;-1)$ là
		\[\dfrac{x+1}{1}=\dfrac{y}{1}=\dfrac{z-4}{-1}\quad\text{hoặc}\quad\heva{&x=-1+s\\&y=s\\&z=4-s.}\]
		\begin{itemchoice}
			\itemch Thay tọa độ điểm $B(2;3;1)$ vào phương trình đường thẳng $\Delta$ ta được $\dfrac{2+1}{1}=\dfrac{3}{1}=\dfrac{1-4}{-1}=3$ (thỏa mãn). \\
			Vậy $\Delta$ đi qua $B(2;3;1)$.
			\itemch Đường thẳng có phương trình $\heva{&x=1+t\\&y=t\\&z=-4-t}$ đi qua điểm $(1;0;-4)$.\\
			Thay tọa độ điểm này vào phương trình $\Delta$ ta có $\dfrac{1+1}{1}\ne\dfrac{0}{1}$, nên $\Delta$ không có phương trình như trên.
			\itemch Vì $\overrightarrow{AM}=(1;1;-1)$ nên đường thẳng $\Delta$ nhận $(1;1;-1)$ làm một vectơ chỉ phương.
			\itemch Đường thẳng $\Delta$ có phương trình chính tắc là $\dfrac{x+1}{1}=\dfrac{y}{1}=\dfrac{z-4}{-1}$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1H4-1]
	Cho hàm số $y=\dfrac{x^2-x-1}{x-2}$ có đồ thị là $(C)$.
	\choiceTF
	{Đồ thị không cắt trục $Ox$}
	{Đồ thị hàm số có một tiệm cận ngang}
	{Đồ thị $(C)$ có hai điểm cực trị nằm $2$ phía đối với $Oy$}
	{\True Đồ thị hàm số cắt trục tung tại điểm $M$. Phương trình tiếp tuyến của đồ thị hàm số tại $M$ là $3x-4y+2=0$}
	\loigiai{
		Tập xác định $\mathscr{D}=\mathbb{R}\setminus\{2\}$.\\
		Ta có $y=\dfrac{x^2-x-1}{x-2}$, suy ra $y'=\dfrac{x^2-4x+3}{(x-2)^2}$. Cho $y'=0\Leftrightarrow \hoac{&x=1\\&x=3.}$\\
		Bảng biến thiên
		\begin{center}
			\begin{tikzpicture}
				\tkzTabInit[nocadre=false,lgt=1.2,espcl=2]{$x$ /1,$y'$ /1,$y$ /2}{$-\infty$,$1$,$2$,$3$,$+\infty$}
				\tkzTabLine{,+,0,-,d,-,0,+,}
				\tkzTabVar{-/ $-\infty$ ,+/ $1$ ,-D+ / $-\infty$ / $+\infty$ ,-/ $5$ ,+/ $+\infty$}
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Xét phương trình hoành độ giao điểm
			\[y=0\Leftrightarrow \dfrac{x^2-x-1}{x-2}=0\Leftrightarrow x^2-x-1=0\Leftrightarrow \hoac{&x=\dfrac{1-\sqrt{5}}{2}\\&x=\dfrac{1+\sqrt{5}}{2}.}\]
			Do đó đồ thị hàm số cắt trục hoành tại hai điểm phân biệt.
			\itemch Ta có $\lim \limits_{x\to+\infty}y=+\infty$, $\lim \limits_{x\to-\infty}y=-\infty$ nên đồ thị hàm số không có đường tiệm cận ngang.
			\itemch Hàm số đạt cực trị tại $x=1$ và $x=3$.\\
			Hai điểm cực trị có hoành độ cùng mang dấu dương nên nằm cùng phía đối với trục tung $Oy$.
			\itemch Giao điểm của đồ thị hàm số với trục tung là điểm $M\left(0;\dfrac{1}{2}\right)$.\\
			Hệ số góc của tiếp tuyến tại $M$ là $y'(0)=\dfrac{3}{4}$.\\
			Phương trình tiếp tuyến của đồ thị hàm số tại $M$ là
			\[y=\dfrac{3}{4}(x-0)+\dfrac{1}{2}\Leftrightarrow y=\dfrac{3}{4}x+\dfrac{1}{2}\Leftrightarrow 3x-4y+2=0.\]
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1H8V7-8]
Một mô hình kim tự tháp có dạng hình chóp tứ giác đều $S.ABCD$ có cạnh đáy bằng $12$ (cm) và chiều cao bằng $16$ (cm).
\choiceTF
{Khoảng cách giữa $AD$ và mặt phẳng $(SBC)$ bằng $11{,}23$ (cm)}
{\True $AB\parallel (SCD)$}
{Gọi $M$ là điểm nằm trên cạnh $SD$ sao cho $SM=3MD$. Mặt phẳng $(ABM)$ cắt $SC$ tại $N$. Thể tích của khối chóp $S.ABNM$ bằng $426{,}67$ (cm$^3$)}
{Góc nhị diện $[S,BC,D]$ có độ lớn bằng $69^\circ26'$}
\loigiai{
\begin{center}
\begin{tikzpicture}[declare function={goc=-150; a=5; b=a/2; h=6;},line join=round,line cap=round,>=stealth,scale=1]
\path (0,0) coordinate (A)
(a,0) coordinate (D)
(goc:b) coordinate (B)
+(a,0) coordinate (C)
($(A)!.5!(C)$) coordinate (O)
+(0,h) coordinate (S)
($(B)!.5!(C)$) coordinate (K)
($(S)!.7!(K)$) coordinate (H)
($(S)!.75!(D)$) coordinate (M)
($(S)!.75!(C)$) coordinate (N);
\draw[dashed] (S)--(A)
(B)--(A)--(D)
(S)--(O)
(A)--(C)
(B)--(D)
(O)--(K)
(O)--(H)
(A)--(M);
\draw (S)--(B)--(C)--(S)--(D)--(C)--cycle (S)--(K)
(M)--(N)--(B);
\foreach \x/\goc in {S/90,A/150,D/0,C/-60,B/-180,O/-90,K/-90,H/20,M/50,N/-30}
\fill (\x) node[shift={(\goc:9pt)},font = \footnotesize]{$\x$} circle (1pt);
\foreach \x/\y/\z in {O/H/K,S/O/B}{
\path (\y) pic[draw,angle radius=5pt]{right angle = \x--\y--\z};
}
\end{tikzpicture}
\end{center}
Gọi $O$ là tâm của hình vuông $ABCD$. Do $S.ABCD$ là hình chóp tứ giác đều nên $SO\perp (ABCD)$.\\
Theo giả thiết, ta có $SO=16$ (cm) và $AB=BC=CD=DA=12$ (cm).
\begin{itemchoice}
\itemch Ta có $AD\parallel BC\Rightarrow AD\parallel (SBC)$.\\
Do đó $\mathrm{d}\big(AD,(SBC)\big)=2\mathrm{d}\big(O,(SBC)\big)$.\\
Gọi $K$ là trung điểm của $BC$, kẻ $OH\perp SK$ tại $H$. \\
Ta có $BC\perp OK$ và $BC\perp SO\Rightarrow BC\perp (SOK)\Rightarrow BC\perp OH$.\\
Suy ra $OH\perp (SBC)$, hay $\mathrm{d}\big(O,(SBC)\big)=OH$.\\
Trong tam giác vuông $SOK$ có $OK=\dfrac{AB}{2}=6$ (cm), ta có
\[\dfrac{1}{OH^2}=\dfrac{1}{SO^2}+\dfrac{1}{OK^2}=\dfrac{1}{16^2}+\dfrac{1}{6^2}=\dfrac{73}{2304}\Rightarrow OH=\dfrac{48\sqrt{73}}{73}\;(\text{cm}).\]
Vậy $\mathrm{d}\big(AD,(SBC)\big)=2OH=\dfrac{96\sqrt{73}}{73}\approx11{,}2356\;(\text{cm})\ne11{,}23\;(\text{cm})$.
\itemch Ta có $\heva{&AB\parallel CD\\&CD\subset (SCD)}\Rightarrow AB\parallel (SCD)$.
\itemch Ba mặt phẳng $(SCD)$, $(ABNM)$ và $(ABCD)$ lần lượt cắt nhau theo ba giao tuyến phân biệt là $AB$, $CD$, $MN$. \\
Vì $AB\parallel CD$ nên $MN\parallel CD\parallel AB$.\\
Ta có $MN\parallel CD\Rightarrow \dfrac{SN}{SC}=\dfrac{SM}{SD}$.\\
Vì $SM=3MD\Rightarrow \dfrac{SM}{SD}=\dfrac{3}{4}\Rightarrow \dfrac{SN}{SC}=\dfrac{3}{4}$.\\
Thể tích khối chóp $S.ABCD$ là $V=\dfrac{1}{3}SO\cdot S_{ABCD}=\dfrac{1}{3}\cdot 16\cdot 12^2=768$ (cm$^3$).\\
Ta có $\dfrac{V_{S.ABM}}{V_{S.ABD}}=\dfrac{SM}{SD}=\dfrac{3}{4}\Rightarrow V_{S.ABM}=\dfrac{3}{4}\cdot \dfrac{768}{2}=288$ (cm$^3$).\\
$\dfrac{V_{S.BMN}}{V_{S.BCD}}=\dfrac{SM}{SD}\cdot \dfrac{SN}{SC}=\left(\dfrac{3}{4}\right)^2=\dfrac{9}{16}\Rightarrow V_{S.BMN}=\dfrac{9}{16}\cdot \dfrac{768}{2}=216$ (cm$^3$).\\
Thể tích khối chóp $S.ABNM$ là $V_{S.ABNM}=V_{S.ABM}+V_{S.BMN}=288+216=504$ (cm$^3$) $\ne426{,}67$ (cm$^3$).
\itemch Gọi $K$ là trung điểm của $BC$. Ta có $BC\perp (SOK)\Rightarrow \widehat{SKO}$ là góc phẳng của góc nhị diện $[S,BC,D]$.\\
Trong tam giác vuông $SOK$ vuông tại $O$ có
\[\tan \widehat{SKO}=\dfrac{SO}{OK}=\dfrac{16}{6}=\dfrac{8}{3}\Rightarrow \widehat{SKO}\approx69^\circ26'38''\approx69^\circ27'.\]
Vì $69^\circ26'38''$ làm tròn đến phút phải là $69^\circ27'$, nên số đo $69^\circ26'$ là chưa chính xác.
\end{itemchoice}
}
\end{ex}


\Closesolutionfile{ans}


\caukq
\Opensolutionfile{ans}[ans/SA-De-TB-Yeu-So-7]
\begin{ex}%[Văn Minh Thoại]%[2H5V2-6]
Trong không gian $Oxyz$, cho đường thẳng $d\colon \dfrac{x-1}{-1}=\dfrac{y+2}{1}=\dfrac{z}{2}$ và hai điểm $A(0;1;1)$, $B(-5;0;5)$. Điểm $M$ thuộc $d$ sao cho $\left|\overrightarrow{MA}-3\overrightarrow{MB}\right|$ có giá trị nhỏ nhất và giá trị đó bằng $\sqrt{a}$, với $a$ là số tự nhiên. Khi đó $a$ bằng
\shortans[]{110}
\loigiai{
Ta có phương trình tham số của đường thẳng đã cho là $d\colon \heva{&x=1-t\\&y=-2+t\\&z=2t.}$ \\
Vì $M$ là điểm thuộc đường thẳng $d$, nên tọa độ điểm $M$ có dạng $M(1-t;-2+t;2t)$, với $t\in \mathbb{R}$. \\
Lại có $\overrightarrow{MA}=(t-1;-t+3;-2t+1)$ và $\overrightarrow{MB}=(t-6;-t+2;-2t+5)$. \\
Do đó $\overrightarrow{MA}-3\overrightarrow{MB}=(-2t+17;2t-3;4t-14)$. \\
Suy ra
\begin{eqnarray*}
\left|\overrightarrow{MA}-3\overrightarrow{MB}\right|&=&\sqrt{(-2t+17)^2+(2t-3)^2+(4t-14)^2}\\&=&\sqrt{24t^2-192t+494}\\&=&\sqrt{24(t-4)^2+110}\ge\sqrt{110}.
\end{eqnarray*}
Dấu \lq\lq=\rq\rq\ xảy ra khi và chỉ khi $t=4$.\\
Vậy $\left|\overrightarrow{MA}-3\overrightarrow{MB}\right|_{\min }=\sqrt{110}$. Nên $a=110$.
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D6V2-3]
	Trong một đợt nghiên cứu tỷ lệ ung thư do hút thuốc lá gây nên, người ta thấy rằng tại tỉnh Hà Nam tỉ lệ người dân của tỉnh nghiện thuốc lá là $20$\%; tỉ lệ người bị bệnh ung thư trong số người nghiện thuốc lá là $70$\%, trong số người không nghiện thuốc lá là $15$\%. Hỏi khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là bao nhiêu? \textit{(làm tròn kết quả đến hai chữ số thập phân)}
	\shortans[]{0,54}
	\loigiai{
		Gọi $A$ là biến cố \lq\lq người nghiện thuốc lá\rq\rq, suy ra $\overline{A}$ là biến cố \lq\lq người không nghiện thuốc lá\rq\rq. \\
		Gọi $B$ là biến cố \lq\lq người bị bệnh ung thư\rq\rq. \\
		Theo giả thiết ta có\\
		\begin{itemize}
			\item $\mathrm{P}(A)=0{,}2\Rightarrow \mathrm{P}\left(\overline{A}\right)=0{,}8$;
			\item $\mathrm{P}(B\mid A)=0{,}7$;
			\item $\mathrm{P}\left(B\mid \overline{A}\right)=0{,}15$.
		\end{itemize}
		Áp dụng công thức xác suất toàn phần ta có
		\[\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}(B\mid A)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B\mid \overline{A}\right)=0{,}2\cdot 0{,}7+0{,}8\cdot 0{,}15=0{,}26.\]
		Xác suất mà người đó là nghiện thuốc lá khi biết bị bệnh ung thư là $\mathrm{P}(A\mid B)$. \\
		Theo công thức Bayes, ta có
		\[\mathrm{P}(A\mid B)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}(B\mid A)}{\mathrm{P}(B)}=\dfrac{0{,}2\cdot 0{,}7}{0{,}26}=\dfrac{7}{13}\approx0{,}54.\]
		Vậy khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là $0{,}54$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1V4-4]
	Người ta muốn làm một cái bể dạng hình hộp chữ nhật không nắp có thể tích bằng $1$ (m$^3$). Chiều cao của bể là $5$ (dm), các kích thước khác là $x$ (m), $y$ (m) với $x>0$ và $y>0$. Diện tích toàn phần của bể là hàm số $S(x)$ trên khoảng $(0;+\infty)$. Đường tiệm cận xiên của đồ thị hàm số $S(x)$ là đường thẳng $y=ax+b$. Tính giá trị của biểu thức $P=a^2+b^2$.
	\shortans[]{5}
	\loigiai{
		Đổi $5$ (dm)$=0{,}5$ (m).\\
		Do thể tích của bể là $1$ (m$^3$) nên $0{,}5xy=1\Leftrightarrow xy=2\Rightarrow y=\dfrac{2}{x}$. \\
		Diện tích toàn phần của bể (không nắp) là $S(x)=xy+2\cdot 0{,}5\cdot y+2\cdot 0{,}5\cdot x=2+x+\dfrac{2}{x}$, $(x>0)$. \\
		Ta có $\lim \limits_{x\to+\infty}\left[S(x)-(x+2)\right]=\lim \limits_{x\to+\infty}\dfrac{2}{x}=0$. \\
		Suy ra đồ thị hàm số $S(x)$ có đường tiệm cận xiên là $y=x+2\Rightarrow a=1$; $b=2$. \\
		Vậy $P=a^2+b^2=1^2+2^2=5$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1H8V6-2]
	Cho hình chóp $S.ABC$ có đáy tam giác đều cạnh $2a$, hai mặt phẳng $(SAB)$ và $(SAC)$ cùng vuông góc với mặt phẳng đáy, $SA=3a$. Tính số đo góc giữa hai mặt phẳng $(SBC)$ và $(SAB)$ \textit{(làm tròn kết quả đến hàng phần mười của độ)}.
	\shortans[]{64,3}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[declare function={goc=-45; a=7; b=0.45*a; h=6;},line join=round,line cap=round,>=stealth,scale=1]
				\path
				(0,0) coordinate (A)--+(0,h) coordinate (S)
				(a,0) coordinate (C)
				(goc:b) coordinate (B)
				($(A)!0.5!(B)$) coordinate (E)
				($(S)!0.8!(B)$) coordinate (F);
				\draw[dashed] (A)--(C)--(E);
				\draw (S)--(B)
				(S)--(A)--(B)--(C)--cycle (E)--(F)--(C);
				\foreach \x/\goc in {S/90,A/240,C/-60,B/-90,E/200,F/180}
				\fill (\x) node[shift={(\goc:9pt)},font = \footnotesize]{$\x$} circle (1pt);
				
				\foreach \x/\y/\z in {S/A/B,S/A/C,E/F/B,C/E/B}{
					\path (\y) pic[draw,angle radius=5pt]{right angle = \x--\y--\z};
				}
			\end{tikzpicture}
		\end{center}
		Hai mặt phẳng $(SAB)$ và $(SAC)$ cùng vuông góc với đáy và cắt nhau theo giao tuyến $SA$ nên $SA\perp (ABC)$.\\
		Kẻ $CE\perp AB$ tại $E$, ta có $\heva{&CE\perp AB\\&CE\perp SA}\Rightarrow CE\perp (SAB)\Rightarrow CE\perp SB$.\\
		Kẻ $EF\perp SB$ tại $F$, ta có $\heva{&SB\perp CE\\&SB\perp EF}\Rightarrow SB\perp (CEF)\Rightarrow SB\perp CF$.\\
		Góc giữa hai mặt phẳng $(SBC)$ và $(SAB)$ là góc giữa hai đường thẳng $CF$ và $EF$, tức là $\widehat{CFE}$ (do $\triangle CEF$ vuông tại $E$ nên $\widehat{CFE}<90^\circ$).\\
		Tam giác $ABC$ đều cạnh $2a$, $CE$ là đường cao nên $CE=\dfrac{2a\sqrt{3}}{2}=\sqrt{3}a$.\\
		Vì $E$ là trung điểm $AB$ nên $EB=a$ ($\triangle ABC$ đều cạnh $a$).\\
		Trong tam giác vuông $SAB$ có $\sin \widehat{SBA}=\dfrac{SA}{SB}=\dfrac{3a}{\sqrt{(3a)^2+(2a)^2}}=\dfrac{3}{\sqrt{13}}$.\\
		Trong tam giác vuông $EFB$ có $EF=EB\cdot \sin \widehat{SBA}=a\cdot \dfrac{3}{\sqrt{13}}=\dfrac{3\sqrt{13}}{13}a$.\\
		Xét $\triangle CEF$ vuông tại $E$, có
		\[\tan \widehat{CFE}=\dfrac{CE}{EF}=\dfrac{\sqrt{3}a}{\dfrac{3\sqrt{13}}{13}a}=\dfrac{13\sqrt{3}}{3\sqrt{13}}=\dfrac{\sqrt{39}}{3}\Rightarrow \widehat{CFE}\approx64{,}3^\circ.\]
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D4V3-3]
	Cho hình phẳng được giới hạn bởi đường cong $y=\sqrt{m^2-x^2}$ và trục hoành. Khi quay xung quanh trục hoành được khối tròn xoay có thể tích $V$. Có bao nhiêu giá trị nguyên của $m$ để $V<1000\pi$.
	\shortans[]{18}
	\loigiai{
		Phương trình hoành độ giao điểm của đường cong và trục hoành là $\sqrt{m^2-x^2}=0\Leftrightarrow x=\pm|m|$.\\
		Thể tích vật thể tròn xoay cần tính là thể tích của hình cầu bán kính $R=|m|$ là
		\[V=\pi\displaystyle\int \limits_{-|m|}^{|m|}(m^2-x^2)\mathrm{\,d}x=\pi\left.\left(m^2x-\dfrac{x^3}{3}\right)\right|_{-|m|}^{|m|}=\dfrac{4\pi|m|^3}{3}.\]
		Ta có
		\begin{eqnarray*}
&&V<1000\pi\\&\Leftrightarrow &\dfrac{4\pi|m|^3}{3}<1000\pi\\&\Leftrightarrow &|m|^3<750\\&\Leftrightarrow &-\sqrt[3]{750}<m<\sqrt[3]{750}.
\end{eqnarray*}
		Ta có $\sqrt[3]{750}\approx9{,}08$ và $m\ne0$ (nếu $m=0$ thì không giới hạn ra hình phẳng).\\
		Do đó $m\in \{-9;-8;\dots;-1;1;\dots;8;9\}$.\\
		Vậy có $18$ giá trị nguyên của $m$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H2V2-6]
Sân cầu lông có tiêu chuẩn quốc tế chiều dài là $13{,}4$ m và chiều rộng là $6{,}1$ m. Ta chọn hệ trục $Oxyz$ cho sân đó sao cho mặt sân thuộc mặt phẳng $(Oxy)$. Giả sử $AB$ là một trụ cầu lông để căng lưới, với điểm $B$ nằm trên mặt sân và điểm $A$ là đỉnh trụ. Biết tọa độ của vectơ $\overrightarrow{AB}=(a;b;c)$ và chiều cao trụ tiêu chuẩn là $1{,}55$ (m). Khi đó $S=a-b+2c$ bằng bao nhiêu?
	\shortans[]{3,1}
	\loigiai{
		Trụ cầu lông $AB$ vuông góc với mặt sân nên vectơ $\overrightarrow{AB}$ cùng hướng với vectơ đơn vị $\overrightarrow{k}$ của trục $Oz$. \\
		Độ dài $AB=1{,}55$ nên $\overrightarrow{AB}=1{,}55\overrightarrow{k}$. \\
		Do đó $\overrightarrow{AB}=(0;0;1{,}55)\Rightarrow a=0$, $b=0$, $c=1{,}55$. \\
		Suy ra $S=a-b+2c=0-0+2(1{,}55)=3{,}1$.
	}
\end{ex}


\Closesolutionfile{ans}
