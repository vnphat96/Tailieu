\begin{ex}%[Văn Minh Thoại]%[2D1H3-1]
	Cho hàm số $y=f(x)$ liên tục trên $\mathbb{R}$ và có đồ thị là đường cong như hình vẽ dưới đây.
	\begin{center}
		\begin{tikzpicture}[line join=round,line cap=round,>=stealth,font=\footnotesize,scale=1]
			\draw[->] (-1.6,0) -- (3.5,0) node[below] {$x$};
			\draw[->] (0,-1.5) -- (0,4.8) node[right] {$y$};
			\node at (0,0) [below left] {$O$};
			\clip (-2,-1.5) rectangle (3,5);
			\draw (-1,1).. controls +(77.4:9.79) and +(-94.2:15.27).. (2.55,4.7);
			\draw[dashed] (-1,0)--(-1,1)--(0,1);
			\draw[dashed] (1.75,0)|-(0,-1);
			\draw[dashed] (2.5,0)--(2.5,4)--(0,4);
			% ===== Nhãn =====
			\node at (-1,0) [below=2pt] {$-1$};
			\node at (2.5,0) [below=2pt] {$\dfrac{5}{2}$};
			\node at (0,1) [right=2pt] {$1$};
			\node at (0,4) [left=2pt] {$4$};
			\node at (0,-1) [left=2pt] {$-1$};
			% ===== Chấm xanh =====
			\foreach \p in {(-1,0),(0,0),(2.5,0),(1.75,0),(0,1),(0,4),(-1,1),(2.5,4),(1.75,-1),(0,-1)}{
				\filldraw[fill=blue!60,draw=black] \p circle (1.2pt);
			}
		\end{tikzpicture}
	\end{center}
	Gọi $M$ và $m$ lần lượt là giá trị lớn nhất và nhỏ nhất của hàm số $f(x)$ trên đoạn $\left[-1;\dfrac{5}{2}\right]$. Giá trị của $M+m$ bằng
	\choice
	{$\dfrac{1}{2}$}
	{\True $3$}
	{$5$}
	{$4$}
	\loigiai{
		Hàm số $y=f(x)$ liên tục trên $\mathbb{R}$ và có đồ thị là đường cong như hình vẽ.\\
		Dựa vào đồ thị, ta thấy trên đoạn $\left[-1;\dfrac{5}{2}\right]$:\\
		Hàm số đạt giá trị lớn nhất $M=\max \limits_{x\in \left[-1;\frac{5}{2}\right]}f(x)=f(-1)=4$.\\
		Hàm số đạt giá trị nhỏ nhất $m=\min \limits_{x\in \left[-1;\frac{5}{2}\right]}f(x)=f(2)=-1$.\\
		Vậy $M+m=4+(-1)=3$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1D5N1-2]
	Phát biểu nào sau đây đúng về số trung vị của mẫu số liệu ghép nhóm?
	\choice
	{Một mẫu số liệu ghép nhóm có thể có nhiều số trung vị}
	{Số trung vị của mẫu số liệu ghép nhóm luôn bằng số trung vị của mẫu số liệu gốc}
	{\True Số trung vị của mẫu số liệu ghép nhóm là giá trị xấp xỉ cho mẫu số liệu gốc và có thể lấy làm giá trị đại diện cho mẫu số liệu}
	{Số trung vị của mẫu số liệu ghép nhóm là giá trị xấp xỉ cho mẫu số liệu gốc và không thể lấy làm giá trị đại diện cho mẫu số liệu}
	\loigiai{
		Theo lý thuyết thống kê, số trung vị của mẫu số liệu ghép nhóm là một giá trị xấp xỉ cho số trung vị của mẫu số liệu gốc và thường được dùng làm giá trị đại diện cho mẫu số liệu. Mỗi mẫu số liệu ghép nhóm có đúng một số trung vị.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5N3-2]
Trong không gian $Oxyz$, mặt cầu $x^2+y^2+z^2+2x-4y-2z-3=0$ có bán kính bằng
\choice
{\True $3$}
{$\sqrt{3}$}
{$9$}
{$3\sqrt{3}$}
\loigiai{
Phương trình mặt cầu có dạng $x^2+y^2+z^2-2ax-2by-2cz+d=0$ với $a=-1$, $b=2$, $c=1$ và $d=-3$.\\
Tâm mặt cầu là $I(-1;2;1)$.\\
Bán kính mặt cầu là $R=\sqrt{a^2+b^2+c^2-d}=\sqrt{(-1)^2+2^2+1^2-(-3)}=\sqrt{1+4+1+3}=\sqrt{9}=3$.
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1H1-2]
	Cho hàm số $y=f(x)$ có bảng biến thiên như sau
	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[nocadre=false,lgt=1.2,espcl=2]{$x$ /0.6,$f'(x)$ /0.6,$f(x)$ /2}{$-\infty$,$-1$,$1$,$3$,$+\infty$}
			\tkzTabLine{,+,0,-,0,+,0,-,}
			\tkzTabVar{-/ $-\infty$ ,+/ $2$ ,-/ $1$ ,+/ $2$ ,-/ $-\infty$}
		\end{tikzpicture}
	\end{center}
	Hỏi hàm số đã cho đồng biến trên khoảng nào dưới đây?
	\choice
	{$(-1;1)$}
	{$(-2;0)$}
	{\True $(-3;-2)$}
	{$(-\infty;1)$}
	\loigiai{
		Từ bảng biến thiên ta có $f'(x)>0\Leftrightarrow \hoac{&x<-1\\&1<x<3.}$\\
		Do đó hàm số đồng biến trên các khoảng $(-\infty;-1)$ và $(1;3)$.\\
		Mà $(-3;-2)\subset (-\infty;-1)$ nên hàm số đã cho đồng biến trên khoảng $(-3;-2)$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1D2N2-2]
Cho một cấp số cộng có $u_1=-3$; $u_6=27$. Công sai bằng
\choice
{$d=5$}
{$d=8$}
{$d=7$}
{\True $d=6$}
\loigiai{
Gọi $d$ là công sai của cấp số cộng.\\
Ta có công thức số hạng tổng quát $u_n=u_1+(n-1)d$.\\
Thay $n=6$ ta được \[u_6=u_1+5d\Leftrightarrow 27=-3+5d\Leftrightarrow 5d=30\Leftrightarrow d=6.\]
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D4N3-1]
Gọi $S$ là diện tích của hình phẳng giới hạn bởi các đường $y=2^x$, $y=0$, $x=0$, $x=2$. Mệnh đề nào dưới đây đúng?
\choice
{$S=\pi\displaystyle\int \limits_0^22^{2x}\mathrm{\,d}x$}
{$S=\displaystyle\int \limits_0^22^{2x}\mathrm{\,d}x$}
{\True $S=\displaystyle\int \limits_0^22^x\mathrm{\,d}x$}
{$S=\pi\displaystyle\int \limits_0^22^x\mathrm{\,d}x$}
\loigiai{
Diện tích hình phẳng cần tìm là $S=\displaystyle\int \limits_0^2\left|2^x\right|\mathrm{\,d}x$.\\
Vì $2^x>0$ với mọi $x\in [0;2]$ nên $S=\displaystyle\int \limits_0^22^x\mathrm{\,d}x$.
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1D6N3-2]
Tìm tập xác định $\mathscr{D}$ của hàm số $f(x)=x^{-\tfrac{1}{3}}$.
\choice
{$\mathscr{D}=\mathbb{R}$}
{$\mathscr{D}=\mathbb{R}\setminus\{0\}$}
{$\mathscr{D}=[0;+\infty)$}
{\True $\mathscr{D}=(0;+\infty)$}
\loigiai{
Hàm số $f(x)=x^{-\tfrac{1}{3}}$ là hàm số lũy thừa với số mũ $\alpha=-\dfrac{1}{3}\notin\mathbb{Z}$.\\
Điều kiện xác định của hàm số là $x>0$.\\
Vậy tập xác định của hàm số là $\mathscr{D}=(0;+\infty)$.
}
\end{ex}


