\begin{ex}%[Văn Minh Thoại]%[1D6H4-2]
Gọi $x_1$, $x_2$ là nghiệm của phương trình $7^{x^2-5x+9}=343$. Tính $x_1+x_2$.
\choice
{\True $x_1+x_2=5$}
{$x_1+x_2=4$}
{$x_1+x_2=3$}
{$x_1+x_2=6$}
\loigiai{
Ta có
\begin{eqnarray*}
&&7^{x^2-5x+9}=343\\&\Leftrightarrow &7^{x^2-5x+9}=7^3\\&\Leftrightarrow &x^2-5x+9=3\\&\Leftrightarrow &x^2-5x+6=0\\&\Leftrightarrow &\hoac{&x=2\\&x=3.}
\end{eqnarray*}
Do đó tổng hai nghiệm là $x_1+x_2=2+3=5$.
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1N4-1]
	Các đường tiệm cận đứng và ngang của đồ thị hàm số $y=\dfrac{2x+1}{x-1}$ là
	\choice
	{\True $x=1$, $y=2$}
	{$x=-1$, $y=-2$}
	{$x=1$, $y=-2$}
	{$x=2$, $y=1$}
	\loigiai{
		Tập xác định $\mathscr{D}=\mathbb{R}\setminus\{1\}$.
		\begin{itemize}
			\item $\lim \limits_{x\to\pm\infty}\dfrac{2x+1}{x-1}=\lim \limits_{x\to\pm\infty}\dfrac{x\left(2+\dfrac{1}{x}\right)}{x\left(1-\dfrac{1}{x}\right)}=\lim \limits_{x\to\pm\infty}\dfrac{2+\dfrac{1}{x}}{1-\dfrac{1}{x}}=2$.\\
			Suy ra $y=2$ là đường tiệm cận ngang.
			\item $\lim \limits_{x\to1^+}\dfrac{2x+1}{x-1}=+\infty$ vì $\lim \limits_{x\to1^+}(2x+1)=3>0$ và $\lim \limits_{x\to1^+}(x-1)=0$, $x-1>0$ khi $x\to1^+$.\\
			Suy ra $x=1$ là đường tiệm cận đứng.
		\end{itemize}
		Vậy đồ thị hàm số có tiệm cận đứng là $x=1$ và tiệm cận ngang là $y=2$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D4N1-4]
Hàm số nào sau đây là một nguyên hàm của hàm số $f(x)=\sin x+e^x-5x$?
\choice
{$F(x)=-\cos x+\dfrac{e^x}{x+1}-\dfrac{5}{2}x^2$}
{\True $F(x)=-\cos x+e^x-\dfrac{5}{2}x^2+1$}
{$F(x)=\cos x+e^x-\dfrac{5}{2}x^2$}
{$F(x)=\cos x+e^x-5x+3$}
\loigiai{
Áp dụng công thức nguyên hàm cơ bản, ta có \\
\[\displaystyle\int f(x)\mathrm{\,d}x=\displaystyle\int \left(\sin x+e^x-5x\right)\mathrm{\,d}x=-\cos x+e^x-\dfrac{5}{2}x^2+C.\]
Vậy $F(x)=-\cos x+e^x-\dfrac{5}{2}x^2+1$ là một nguyên hàm của hàm số $f(x)=\sin x+e^x-5x$ (ứng với $C=1$).
}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1D9H2-4]
	Cho hai biến cố $A$ và $B$ xung khắc, biết $\mathrm{P}(A)=\dfrac{1}{3}$, $\mathrm{P}\left(A\cup B\right)=\dfrac{5}{6}$. Xác suất của biến cố $B$ bằng
	\choice
	{$\dfrac{1}{6}$}
	{$\dfrac{1}{12}$}
	{\True $\dfrac{1}{2}$}
	{$\dfrac{1}{4}$}
	\loigiai{
		Vì hai biến cố $A$ và $B$ xung khắc nên ta có
		$\mathrm{P}\left(A\cup B\right)=\mathrm{P}(A)+\mathrm{P}(B)$. \\
		$\Rightarrow \mathrm{P}(B)=\mathrm{P}\left(A\cup B\right)-\mathrm{P}(A)=\dfrac{5}{6}-\dfrac{1}{3}=\dfrac{3}{6}=\dfrac{1}{2}$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5N1-2]
Trong không gian $Oxyz$, một vectơ pháp tuyến $\overrightarrow{n}$ của mặt phẳng $2x+3y-z+1=0$ là
\choice
{$\overrightarrow{n}=(2;3;1)$}
