\begin{ex}%[1D2N2-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho cấp số cộng $\left(u_n\right)$ có số hạng đầu $u_1=-5$ và công sai $d=2$. Năm số hạng đầu của cấp số cộng này là
\choice
{\True $-5;-3;-1;1;3$}
{$-5;-7;-9;-11;-13$}
{$-5;-3;-1;3;5$}
{$-5;-10;-20;-40;-80$}
\loigiai{
Ta có
\begin{multicols}{2}
\begin{itemize}
\item $u_2=u_1+d=-5+2=-3$;
\item $u_3=u_2+d=-3+2=-1$;
\item $u_4=u_3+d=-1+2=1$;
\item $u_5=u_4+d=1+2=3$.
\end{itemize}
\end{multicols}
Vậy năm số hạng đầu của cấp số cộng đã cho là $-5;-3;-1;1;3$.
}
\end{ex}

\begin{ex}%[2H5H3-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$ cho hai điểm $A(-1;1;2)$ và $M(1;2;1)$. Mặt cầu tâm $A$ đi qua $M$ có phương trình là
\choice
{$(x+1)^2+(y-1)^2+(z-2)^2=1$}
{\True $(x+1)^2+(y-1)^2+(z-2)^2=6$}
{$(x-1)^2+(y+1)^2+(z+2)^2=6$}
{$(x+1)^2+(y-1)^2+(z-2)^2=\sqrt{6}$}
\loigiai{
Mặt cầu tâm $A$ đi qua $M$ suy ra bán kính $R=AM=\sqrt{(1+1)^2+(2-1)^2+(1-2)^2}=\sqrt{6}$.\\
Phương trình mặt cầu là $(x+1)^2+(y-1)^2+(z-2)^2=6$.
}
\end{ex}

\begin{ex}%[1D5N1-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho mẫu số liệu ghép nhóm về lương và số nhân viên như sau
\begin{center}
\begin{tabular}{|c|c|c|c|c|c|c|}
\hline
Lương & $[8;12)$ & $[12;16)$ & $[16;20)$ & $[20;24)$ & $[24;28)$ & $[28;32)$ \\ \hline
Số nhân viên & 14 & 9 & 15 & 7 & 8 & 14 \\ \hline
\end{tabular}
\end{center}
Tính giá trị đại diện của nhóm $[28;32)$.
\choice
{$28$}
{$32$}
{\True $30$}
{$15$}
\loigiai{
Giá trị đại diện của nhóm $[28;32)$ là $\dfrac{28+32}{2}=30$.
}
\end{ex}

\begin{ex}%[1H8N6-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hình chóp $S.ABC$ có $SA\perp \left(ABC\right)$. Góc giữa đường thẳng $SB$ và mặt phẳng $\left(ABC\right)$ là góc nào?
\choice
{$\widehat{SCA}$}
{$\widehat{BCA}$}
{$\widehat{SBA}$}
{$\widehat{SAC}$}
\loigiai{
	\begin{center}
		\begin{tikzpicture}[declare function={a=4; b=0.45*a; h=0.75*a;goc=-40;}]
			\path
			(0,0) coordinate (A)
			(a,0) coordinate (C)
			(goc:b) coordinate (B)
			(0,h)coordinate (S)
			pic[draw,angle radius=18pt,fill=cyan!35]{angle= S--B--A};
			\draw[dashed] (A)--(C);
			\draw (S)--(A)--(B)--cycle--(C)--(B)
			\foreach \x/\y/\z in {S/A/C,S/A/B}{
				pic[draw, angle radius = 5pt]{right angle = \x--\y--\z}};
			\foreach \x/\goc in {A/160,B/-90,C/0,S/90}{
				\fill (\x) circle (1pt) node[shift={(\goc:7pt)},font=\small]{$\x$};
			}
		\end{tikzpicture}
	\end{center}
Ta có $SA\perp \left(ABC\right)$ nên $AB$ là hình chiếu vuông góc của $SB$ xuống mặt phẳng $\left(ABC\right)$.\\
Do đó góc giữa đường thẳng $SB$ và mặt phẳng $\left(ABC\right)$ là \[\left(SB,\left(ABC\right)\right)=\left(SB,AB\right)=\widehat{SBA}.\]
}
\end{ex}

\begin{ex}%[1D6H4-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Nghiệm của phương trình $\log _3\left(2x-1\right)=2$ là
\choice
{$x=5$}
{$x=3$}
{$x=\dfrac{7}{2}$}
{$x=\dfrac{9}{2}$}
\loigiai{
Ta có
\begin{eqnarray*}
&&\log _3\left(2x-1\right)=2\\&\Rightarrow &2x-1=3^2\\&\Rightarrow &x=5.
\end{eqnarray*}
Vậy phương trình có nghiệm $x=5$.
}
\end{ex}


