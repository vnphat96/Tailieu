\begin{ex}%[2D6H1-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Hai công nhân cần phải hoàn thành số sản phẩm nhất định. Công nhân thứ nhất phải làm $45\%$ số sản phẩm, công nhân thứ hai phải làm $55\%$ số sản phẩm. Khả năng xảy ra sai sót của công nhân thứ nhất là $3\%$ và của công nhân thứ hai là $1\%$. Chọn ngẫu nhiên $1$ sản phẩm. Gọi $A$ là biến cố \lq\lq Sản phẩm được chọn là của công nhân thứ nhất\rq\rq, $B$ là biến cố \lq\lq Sản phẩm được chọn bị lỗi\rq\rq.
\choiceTF
{\True Xác suất để sản phẩm được chọn là sản phẩm của công nhân thứ nhất bị lỗi là\break $\mathrm{P}\left(A\mid B\right)=\dfrac{27}{38}$}
{\True Xác suất sản phẩm được chọn là sản phẩm bị lỗi của công nhân thứ nhất là $\mathrm{P}\left(B\mid A\right)=0{,}03$}
{$\mathrm{P}(A)=0{,}5$}
{$\mathrm{P}(B)=0{,}02$}
\loigiai{
Ta có\\
$\mathrm{P}(A)=45\%=0{,}45\Rightarrow \mathrm{P}\left(\overline{A}\right)=1-\mathrm{P}\left(A\right)=0{,}55$.\\
Do tỉ lệ sản phẩm lỗi của công nhân thứ nhất là $3\%$ nên $\mathrm{P}\left(B\mid A\right)=0{,}03$.\\
Do tỉ lệ sản phẩm của công nhân số hai là $1\%$ nên $\mathrm{P}\left(B\mid \overline{A}\right)=0{,}01$.\\
Vậy $\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}\left(B\mid A\right)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B\mid \overline{A}\right)=0{,}45\cdot 0{,}03+0{,}55\cdot 0{,}01=0{,}019$.
\begin{itemchoice}
\itemch Xác suất để sản phẩm được chọn là sản phẩm của công nhân thứ nhất bị lỗi là
\[\mathrm{P}\left(A\mid B\right)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}\left(B\mid A\right)}{\mathrm{P}(B)}=\dfrac{0{,}45\cdot 0{,}03}{0{,}019}=\dfrac{27}{38}.\]
\itemch Vì $\mathrm{P}\left(B\mid A\right)=0{,}03$.
\itemch Vì $\mathrm{P}(A)=0{,}45$.
\itemch Vì $\mathrm{P}(B)=0{,}019$.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[2H5H2-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$, cho đường thẳng $d\colon \heva{&x=2-5t\\&y=2t\\&z=-3},t\in \mathbb{R}$.
\choiceTF
{\True Điểm $N(7;-2;3)$ không nằm trên đường thẳng $d$}
{\True Đường thẳng $d$ nhận $\overrightarrow{u}=(-5;2;0)$ làm một véc-tơ chỉ phương}
{Điểm $M(2;2;-3)$ thuộc đường thẳng $d$}
{\True Khi $t=-2$ đường thẳng $d$ đi qua điểm $A$ có tọa độ $(12;-4;-3)$}
\loigiai{
\begin{itemchoice}
\itemch Thay $N(7;-2;3)$ vào đường thẳng $d$, ta có
\[\heva{&7=2-5t\\&-2=2t\\&3=-3}\Rightarrow N\notind.\]
\itemch Đường thẳng $d$ có một véc-tơ  chỉ phương là $\overrightarrow{u}=(-5;2;0)$.
\itemch Thay $M(2;2;-3)$ vào đường thẳng $d$, ta có
\[\heva{&2=2-5t\\&2=2t\\&-3=-3}\Rightarrow \heva{&t=0\\&t=1}\Rightarrow M\notind.\]
\itemch Thay $t=-2$ đường thẳng $d$ ta được
\[\heva{&x=2-5t=2-5\cdot (-2)=12\\&y=2t=2\cdot (-2)=-4\\&z=-3}\]
Vậy $A(12;-4;-3)\in d$.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[2D4V1-6]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Một bác thợ xây bơm nước vào bể chứa nước. Gọi $h(t)$ là thể tích nước bơm được sau $t$ phút. Cho $h'(t)=6at^2+2bt$ và ban đầu bể không có nước. Sau $3$ phút thì thể tích nước trong bể là $90$ m$^3$, sau $6$ phút thì thể tích nước trong bể là $504$ m$^3$.
\choiceTF
{\True $h(3)=\displaystyle\int \limits_0^3\left(6at^2+2bt\right)\mathrm{d}t=90$}
{Sau $9$ phút thể tích nước trong bể là $V=1\,460$ m$^3$}
{\True $a$, $b$ là nghiệm của hệ phương trình $\heva{&54a+9b=90\\&432a+36b=504}$}
{\True $h(t)=\displaystyle\int \left(6at^2+2bt\right)\mathrm{d}t$}
\loigiai{
Vì ban đầu bể không có nước nên $h(0)=0$,\\
Sau $3$ phút thì thể tích nước trong bể là $90$ m$^3$ nên $h(3)=90$ m$^3$.
Ta có
\begin{eqnarray*}
&&\displaystyle\int \limits_0^3\left(6at^2+2bt\right)\mathrm{d}t=90\\&\Leftrightarrow &\left(2at^3+bt^2\right)\bigg|_0^3=90\\&\Leftrightarrow &54a+9b=90.\qquad(1)
\end{eqnarray*}
Vì sau $6$ phút thì thể tích nước trong bể là $504$ m$^3$ nên
\begin{eqnarray*}
&&\displaystyle\int \limits_0^6\left(6at^2+2bt\right)\mathrm{d}t=504\\&\Leftrightarrow &\left(2at^3+bt^2\right)\bigg|_0^6=504\\&\Leftrightarrow &432a+36b=504.\qquad(2)
\end{eqnarray*}
Từ $(1)$ và $(2)$ suy ra $a$, $b$ là nghiệm của hệ phương trình $\heva{&54a+9b=90\\&432a+36b=504}\Leftrightarrow \heva{&a=\dfrac{2}{3}\\&b=6.}$\\
Do đó $h'(t)=6at^2+2bt=6\cdot \dfrac{2}{3}t^2+2\cdot 6t=4t^2+12t$.
\begin{itemchoice}
\itemch Vì $\displaystyle\int \limits_0^3\left(6at^2+2bt\right)\mathrm{d}t=h(t)\bigg|_0^3=h(3)-h(0)\Rightarrow h(3)=90$.
\itemch Sau khi bơm $9$ phút thì thể tích nước trong bể là
\[h(9)=\displaystyle\int \limits_0^9\left(4t^2+12t\right)\mathrm{d}t=\left(\dfrac{4}{3}t^3+6t^2\right)\bigg|_0^9=1\,458\,(m^3).\]
\itemch Vì theo lập luận phía trên.
\itemch Vì $h(t)=\displaystyle\int h'(t)\mathrm{\,d}t=\displaystyle\int \left(6at^2+2bt\right)\mathrm{d}t$.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[2D1H4-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hàm số $y=\dfrac{x^2-2x+2}{x-1}$ và có bảng biến thiên như hình sau
\begin{center}
\begin{tikzpicture}
\tkzTabInit[lgt=1, espcl=2.5, deltacl=0.5]
{$x$/0.6,$y'$/0.6,$y$/2}
{$-\infty$,$0$,$1$,$2$,$+\infty$}
\tkzTabLine{,-,0,+,d,+,0,-,}
\tkzTabVar{+/$+\infty$,-/$-2$,+D-/$+\infty$/$-\infty$,+/$2$,-/$-\infty$}
\end{tikzpicture}
\end{center}
\choiceTF
{\True Tập xác định của hàm số $\mathscr{D}=\mathbb{R}\setminus\{1\}$}
{Đạo hàm của hàm số đã cho là $y'=\dfrac{x^2+2x}{\left(x-1\right)^2}$}
{\True Tiệm cận xiên của đồ thị hàm số đã cho có phương trình là $y=x-1$}
{Bảng biến thiên của hàm số đã cho có dạng như hình trên}
\loigiai{
\begin{itemchoice}
\itemch Tập xác định của hàm số $\mathscr{D}=\mathbb{R}\setminus\{1\}$.
\itemch Ta có $y=\dfrac{x^2-2x+2}{x-1}=x-1+\dfrac{1}{x-1}$.\\
Khi đó $y'=1-\dfrac{1}{(x-1)^2}=\dfrac{x^2-2x}{(x-1)^2}$.
\itemch Vì $\lim \limits_{x\to\pm\infty}\dfrac{1}{x-1}=0$ nên đồ thị hàm số đã cho có đường tiệm cận xiên là $y=x-1$.
\itemch Vì $y'=\dfrac{x^2-2x}{(x-1)^2}$.\\
Cho $y'=0\Rightarrow x^2-2x=0\Rightarrow \hoac{&x=0\\&x=2.}$\\
Bảng biến thiên
\begin{center}
\begin{tikzpicture}
\tkzTabInit[lgt=1.2, espcl=2.5, deltacl=0.5]
{$x$/0.7,$y’$/0.7,$y$/2}
{$-\infty$,$0$,$1$,$2$,$+\infty$}
\tkzTabLine{,+,0,-,d,-,0,+,}
\tkzTabVar{-/$-\infty$,+/$-2$,-D+/$-\infty$/$+\infty$,-/$2$,+/$+\infty$}
\end{tikzpicture}
\end{center}
\end{itemchoice}
}
\end{ex}
\caukq
\begin{ex}%[2D6V2-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong một đợt nghiên cứu tỷ lệ ung thư do hút thuốc lá gây nên, người ta thấy rằng tại tỉnh Hà Nam tỉ lệ người dân của tỉnh nghiện thuốc lá là $20\%$; tỉ lệ người bị bệnh ung thư trong số người nghiện thuốc lá là $70\%$, trong số người không nghiện thuốc lá là $15\%$. Hỏi khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là bao nhiêu?
\shortans[]{0,54}
\loigiai{
Gọi $A$ là biến cố \lq\lq người nghiện thuốc lá\rq\rq;\\
và $B$ là biến cố \lq\lq người bị bệnh ung thư\rq\rq.\\
Theo giả thiết, ta có
\begin{itemize}
\item Tỉ lệ người dân của tỉnh nghiện thuốc lá là $20\%$ nên $\mathrm{P}(A)=0{,}2\Rightarrow \mathrm{P}\left(\overline{A}\right)=1-\mathrm{P}(A)=0{,}8$.
\item Tỉ lệ người bị bệnh ung thư trong số người nghiện thuốc lá là $70\%$ nên $\mathrm{P}\left(B\mid A\right)=0{,}7$.
\item Tỉ lệ người bị bệnh ung thư trong số người không nghiện thuốc lá là \break$15\%$ nên $\mathrm{P}\left(B\mid \overline{A}\right)=0{,}15$.
\end{itemize}
Áp dụng công thức xác suất toàn phần ta có \[\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}\left(B\mid A\right)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B\mid \overline{A}\right)=0{,}2\cdot 0{,}7+0{,}8\cdot 0{,}15=0{,}26.\]
Theo công thức Bayes, ta có
\[\mathrm{P}\left(A\mid B\right)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}\left(B\mid A\right)}{\mathrm{P}(B)}=\dfrac{0{,}2\cdot 0{,}7}{0{,}26}\approx0{,}54.\]
Như vậy khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là $0{,}54$.
}
\end{ex}

\begin{ex}%[2H5V1-7]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Từ mặt nước trong một bể nước, tại ba vị trí đôi một cách nhau $4$ m, người ta lần lượt thả dây dọi để quả dọi chạm đáy bể. Phần dây dọi nằm trong nước tại ba vị trí đó lần lượt có độ dài $8$ m; $8{,}8$ m; $9{,}6$ m. Biết đáy bể là phẳng. Đáy bể nghiêng so với mặt phẳng nằm ngang một góc là bao nhiêu độ {\it (làm tròn kết quả đến hàng phần chục)}?
\shortans[]{21,8}
\loigiai{
Gọi $3$ điểm ở trên mặt nước lần lượt là $A$, $B$, $C$ và ba điểm tương ứng ở đáy bể là $A'$, $B'$, $C'$ sao cho $AA'=8$ m, $BB'=8{,}8$ m, $CC'=9{,}6$ m. Chọn hệ trục tọa độ như hình vẽ với $O$ là trung điểm của $AC$.
\begin{center}
\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round, >=stealth]
\tikzset{declare function={a=4;b=0.4*a;goc=-40;h=0.65*a;}}
\path (0:0) coordinate (A)
(a,0) coordinate (C)
(goc:b) coordinate (B)
(0,-h) coordinate (A')
(B)++(0,-h-0.5)coordinate (B')
(C)++(0,-h-1)coordinate (C')
($(A)!0.5!(C)$)coordinate (O);
\draw[dashed] (A')--(C') (O)--($(O)+(0,-h-0.8)$);
\draw (A)--(A')--(B')--(C')--(C)--cycle--(B)--(C) (O)--(B)--(B');
\draw[->] (B)--($(O)!1.45!(B)$)node[left]{$x$};
\draw[->] (C)--($(O)!1.45!(C)$)node[below]{$y$};
\draw[->] (O)--++(0,1)node[left]{$z$};
\foreach \x /\gN in {A/180,B/-50,C/90,O/130,A'/180,B'/-30,C'/0}
\fill (\x) circle (1pt)($(\x)+(\gN:2.5mm)$) node {$\x$};
\end{tikzpicture}
\end{center}
Khi đó $A(0;-2;0)$, $B(2\sqrt{3};0;0)$, $C(0;2;0)$, $A'(0;-2;-8)$, $B'(2\sqrt{3};0;-8{,}8)$, $C'(0;2;-9,6)$.\\
Suy ra $\overrightarrow{A'B'}=(2\sqrt{3};2;-0{,}8)$, $\overrightarrow{A'C'}=(0;4;-1{,}6)$.\\
Vì $\left[\overrightarrow{A'B'},\overrightarrow{A'C'}\right]=\left(0;\dfrac{16\sqrt{3}}{5};8\sqrt{3}\right)=\dfrac{8\sqrt{3}}{5}\left(0;2;5\right)$.\\
Mặt phẳng đáy bể là mặt phẳng $\left(A'B'C'\right)$ có một véc-tơ pháp tuyến là $\overrightarrow{n}=(0;2;5)$.
Mặt phẳng nằm ngang chính là mặt phẳng $(Oxy)$ có một véc-tơ pháp tuyến là: $\vec{k}=(0;0;1)$.\\
Do đó $\cos \left(\left(A'B'C'\right),(Oxy)\right)=\left|\cos \left(\overrightarrow{n},\overrightarrow{k}\right)\right|=\dfrac{|0\cdot 0+2\cdot 0+5\cdot 1|}{\sqrt{0^2+2^2+5^2}\cdot \sqrt{1}}=\dfrac{5\sqrt{29}}{29}$.\\
Suy ra $\left(\left(A'B'C'\right),(Oxy)\right)\approx21{,}8^\circ$.\\
Vậy đáy bể nghiêng so với mặt phẳng nằm ngang một góc $21{,}8^\circ$.
}
\end{ex}

\begin{ex}%[2D4V3-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho $D$ là diện tích hình phẳng giới hạn bởi đồ thị hàm số $y=\sqrt{9-x}$ ($x\le9$), trục hoành và trục tung. Tính thể tích khối tròn xoay tạo thành khi quay $D$ xung quanh trục $Ox$ {\it (làm tròn kết quả đến hàng đơn vị)}.
\shortans[]{127}
\loigiai{
Xét phương trình hoành độ giao điểm của đồ thị hàm số $y=\sqrt{9-x}$ và trục hoành \[\sqrt{9-x}=0\Leftrightarrow x=9.\]
Thể tích khối tròn xoay tạo thành khi quay $D$ xung quanh trục $Ox$ là \[V=\pi\displaystyle\int \limits_0^9\left(9-x\right)\mathrm{d}x=\pi\left(9x-\dfrac{x^2}{2}\right)\bigg|_0^9=\dfrac{81\pi}{2}\approx127.\]
}
\end{ex}

\begin{ex}%[1C2V1-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Có $4$ người và $1$ đèn pin muốn qua sông phải đi qua một cây cầu. Biết cây cầu chỉ cho phép đi một lần tối đa được $2$ người và phải có đèn pin mới có thể di chuyển trên cầu. $A$ đi qua cầu hết $1$ phút, $B$ hết $2$ phút, $C$ hết $5$ phút, $D$ hết $10$ phút. Hai người đi cùng nhau thì phải đi với tốc độ của người đi chậm hơn. Hỏi mất ít nhất bao nhiêu phút để tất cả đều qua được sông?
\shortans[]{17}
\loigiai{
Để mất ít thời gian nhất ta sẽ cho $4$ người đi theo lộ trình sau:
\begin{center}
\begin{tabular}{|l|l|l|}
\hline
Đi qua cầu & $A$ ($1$ phút) - $B$ ($2$ phút) & Mất $2$ phút \\ \hline
Về đưa đèn pin & $A$ ($1$ phút) & Mất $1$ phút \\ \hline
Đi qua cầu & $C$ ($5$ phút) - $D$ ($10$ phút) & Mất $10$ phút \\ \hline
Về đưa đèn pin & $B$ ($2$ phút) & Mất $2$ phút \\ \hline
Đi qua cầu & $A$ ($1$ phút) - $B$ ($2$ phút) & Mất $2$ phút \\ \hline
\end{tabular}
\end{center}
Tổng thời gian để tất cả đều qua được sông là
$2+1+10+2+2=17$ phút.
}
\end{ex}

\begin{ex}%[2H2H1-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
\immini[thm]{
Biết rằng trọng tâm của tứ diện $ABCD$ là một điểm $I$ thỏa mãn \break $\overrightarrow{AI}=3\overrightarrow{IG}$, ở đó $G$ là trọng tâm của tam giác $BCD$. Áp dụng tính chất trên để tính khoảng cách từ trọng tâm của một khối rubik hình tứ diện đều đến một mặt của nó, biết rằng chiều cao của khối rubik là $8$ cm.
\shortans[]{2}
}
{
\begin{tikzpicture}[scale=.6, line join=round, line cap=round, >=stealth]
\path
(0,0) coordinate (A)
++(30:3) coordinate (B)
++(120:4) coordinate (C)
++(-130:4) coordinate (D);
\foreach \i in {1,2}{
\path
($(A)!\i/3!(B)$) coordinate (X\i)
($(B)!\i/3!(C)$) coordinate (Y\i)
($(C)!\i/3!(A)$) coordinate (Z\i)
($(A)!\i/3!(D)$) coordinate (M\i)
($(D)!\i/3!(C)$) coordinate (N\i)
;}
\fill[cyan] (A)--(B)--(C)--cycle;
\fill[green!50] (A)--(C)--(D)--cycle;
\draw (A)--(B)--(C)--cycle (A)--(C)--(D)--cycle;
\path ($(X1)+(Z2)-(A)$) coordinate (G);
\foreach \a in {X,Y,Z}{
\foreach \b in {X,Y,Z}{
\ifthenelse{\equal{\a}{\b}}{}{
\fill[xslant=2, line width=1, black!20!white, draw=white!20] (\a1)--(\b2);
\draw[gray] (\a1)--(\b2);
}
}
}

\foreach \a in {M,N,Z}{
\foreach \b in {M,N,Z}{
\ifthenelse{\equal{\a}{\b}}{}{
\fill[xslant=2, line width=1, black!20!white, draw=white!20] (\a1)--(\b2);
\draw[gray] (\a1)--(\b2);
}
}
}
\draw[<->]($(B)+(-80:1.5cm)$)--++(0,5)node[midway,right]{$8$ cm};
\end{tikzpicture}
}
\loigiai{
Ta có $\overrightarrow{AI}=3\overrightarrow{IG}\Leftrightarrow \overrightarrow{AG}=4\overrightarrow{IG}$.\\
Chiều cao của khối rubik là $AG=8$ cm.\\ Khoảng cách từ trọng tâm của một khối rubik hình tứ diện đều đến một mặt của nó là đoạn $IG=\dfrac{1}{4}AG=\dfrac{1}{4}\cdot 8=2$ (cm).
}
\end{ex}

\begin{ex}%[1D7V2-8]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong $8$ giây đầu tiên, một chất điểm chuyển động theo phương trình $S(t)=t^3-9t^2+15t+2$ trong đó $t\ge0$ là khoảng thời gian tính từ lúc chất điểm bắt đầu chuyển động và $S$ tính bằng mét. Biết rằng trong khoảng thời gian từ $0$ giây đến $a$ giây, vận tốc của chất điểm giảm; còn từ $a$ giây đến $8$ giây, vận tốc của chất điểm tăng. Tìm $a$.
\shortans[]{3}
\loigiai{
Một chất điểm chuyển động theo phương trình $S(t)=t^3-9t^2+15t+2$ ($t\ge0$) thì vận tốc của chất điểm là $v(t)=S'(t)=3t^2-18t+15$ và gia tốc $a(t)=v'(t)=6t-18$.\\
Ta có $a(t)=0\Leftrightarrow t=3$.\\
Vận tốc của chất điểm giảm khi $a(t)\le0\Leftrightarrow 0\let\le3$.\\
Vận tốc của chất điểm tăng khi $a(t)\ge0\Leftrightarrow 3\let\le8$.\\
Vậy $a=3$ là giá trị cần tìm.
}
\end{ex}


\Closesolutionfile{ans}
