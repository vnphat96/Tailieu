\begin{ex}%[1D6H2-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Tính $M=\log _41\,250$ theo $a$ biết $a=\log _25$.
\choice
{\True $M=\dfrac{1}{2}+2a$}
{$M=2\left(1+4a\right)$}
{$M=2\left(1+2a\right)$}
{$M=\dfrac{1}{2}+a$}
\loigiai{
Ta có $M=\log _41\,250=\dfrac{1}{2}\log _2\left(5^4\cdot 2\right)=\dfrac{1}{2}\left(4\log _25+1\right)=\dfrac{1}{2}+2a$.
}
\end{ex}

\begin{ex}%[1H8N7-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho tứ diện $OABC$ có $OA$, $OB$, $OC$ đôi một vuông góc với nhau và $OA=OB=OC=a$. Khi đó thể tích của khối tứ diện $OABC$ là
\choice
{$\dfrac{a^3}{2}$}
{$\dfrac{a^3}{12}$}
{$\dfrac{a^3}{3}$}
{\True $\dfrac{a^3}{6}$}
\loigiai{
Thể tích khối tứ diện $OABC$ là $V=\dfrac{1}{6}\cdot OA\cdot OB\cdot OC=\dfrac{a^3}{6}$ (đvtt).
}
\end{ex}

\begin{ex}%[2H5H1-5]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$, khoảng cách từ điểm $A\left(1;-2;3\right)$ đến $\left(P\right)\colon x+3y-4z+9=0$ là
\choice
{$\dfrac{\sqrt{26}}{13}$}
{$\sqrt{8}$}
{\True $\dfrac{4\sqrt{26}}{13}$}
{$\dfrac{17}{\sqrt{26}}$}
\loigiai{
Khoảng cách từ điểm $A\left(1;-2;3\right)$ đến $\left(P\right)\colon x+3y-4z+9=0$ là
\[\mathrm{d}\left(A;\left(P\right)\right)=\dfrac{\left|1+3\cdot (-2)-4\cdot 3+9\right|}{\sqrt{1+9+16}}=\dfrac{8}{\sqrt{26}}=\dfrac{4\sqrt{26}}{13}.\]
}
\end{ex}

\begin{ex}%[2D4H1-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Họ nguyên hàm của hàm số $y=\cos 3x$ là
\choice
{$-\sin 3x+C$ ($C$ là hằng số)}
{$\sin 3x+C$ ($C$ là hằng số)}
{\True $\dfrac{\sin 3x}{3}+C$ ($C$ là hằng số)}
{$-\dfrac{\sin 3x}{3}+C$ ($C$ là hằng số)}
\loigiai{
Ta có $\displaystyle\int \cos 3x\mathrm{\,d}x=\dfrac{1}{3}\displaystyle\int \cos 3x\mathrm{\,d}(3x)=\dfrac{1}{3}\sin 3x+C$.
}
\end{ex}

\begin{ex}%[2D1H4-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hàm số $y=f(x)$ liên tục trên $\mathbb{R}$ và có bảng biến thiên như sau
\begin{center}
\begin{tikzpicture}
\tkzTabInit[lgt=1.2, espcl=2.5, deltacl=0.5]
{$x$/0.7,$f’(x)$/0.7,$f(x)$/2}
{$-\infty$,$-1$,$1$,$2$,$+\infty$}
\tkzTabLine{,-,d,+,0,+,d,-,}
\tkzTabVar{+/$+\infty$,-/$3$,R/,+/$2$,-/$-4$}
\end{tikzpicture}
\end{center}
Trong các mệnh đề sau, mệnh đề nào \textbf{sai}?
\choice
{Hàm số có hai điểm cực trị}
{\True Hàm số đạt giá trị lớn nhất bằng $2$ và giá trị nhỏ nhất bằng $-3$}
{Hàm số nghịch biến trên các khoảng $\left(-\infty;-1\right)$ và $\left(2;+\infty\right)$}
{Đồ thị hàm số có đúng một đường tiệm cận}
\loigiai{
Dựa vào bảng biến thiên của hàm số ta có $\lim \limits_{x\to-\infty}f(x)=+\infty$, nên hàm số không có giá trị lớn nhất.
}
\end{ex}

\begin{ex}%[2D6H1-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Nếu hai biến cố $A$, $B$ thỏa mãn $\mathrm{P}\left(A\right)=0{,}4$; $\mathrm{P}\left(B\mid A\right)=0{,}6$ thì $\mathrm{P}\left(A\cap B\right)$ bằng
\choice
{$\dfrac{6}{25}$}
{$\dfrac{1}{5}$}
{$1$}
{$\dfrac{2}{3}$}
\loigiai{
Ta có $\mathrm{P}\left(A\mid B\right)=\dfrac{\mathrm{P}\left(A\cap B\right)}{\mathrm{P}\left(B\right)}\Rightarrow \mathrm{P}\left(A\cap B\right)=\mathrm{P}\left(A\mid B\right)\cdot \mathrm{P}\left(B\right)=\dfrac{6}{25}$.
}
\end{ex}

