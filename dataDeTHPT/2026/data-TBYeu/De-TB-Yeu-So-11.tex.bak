			\tkzTabInit[nocadre=false,lgt=1,espcl=3.5]
			{$x$ /0.6, $y$ /2.5}
			{$-\infty$ , $1$ , $+\infty$}
			\tkzTabVar{-/ $2$ , +D- / $+\infty$ / $3$ , +/ $5$}
		\end{tikzpicture}
	\end{center}
	Tổng số tiệm cận ngang và tiệm cận đứng của đồ thị hàm số đã cho là
	\choice
	{$2$}
	{$1$}
	{\True $3$}
	{$4$}
	\loigiai{
		Vì $\lim \limits_{x\to+\infty}f(x)=5\Rightarrow$ đường thẳng $y=5$ là tiệm cận ngang của đồ thị hàm số.\\
		Vì $\lim \limits_{x\to-\infty}f(x)=2\Rightarrow$ đường thẳng $y=2$ là tiệm cận ngang của đồ thị hàm số.\\
		Vì $\lim \limits_{x\to1^-}f(x)=+\infty\Rightarrow$ đường thẳng $x=1$ là tiệm cận đứng của đồ thị hàm số.\\
		Vậy đồ thị hàm số có tổng số ba đường tiệm cận.
	}
\end{ex}

\begin{ex}%[2D4H3-1]
	\immini[thm]
	{Cho đồ thị $y=f(x)$ như hình vẽ. Diện tích $S$ của hình phẳng được gạch chéo trong hình dưới đây bằng
	\choice
	{$\displaystyle\int \limits_{-1}^{2}f(x)\mathrm{\,d}x$}
	{$-\displaystyle\int \limits_{-1}^{1}f(x)\mathrm{\,d}x+\displaystyle\int \limits_{1}^{2}f(x)\mathrm{\,d}x$}
	{\True $\displaystyle\int \limits_{-1}^{1}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{1}^{2}f(x)\mathrm{\,d}x$}
	{$\displaystyle\int \limits_{-1}^{1}f(x)\mathrm{\,d}x+\displaystyle\int \limits_{1}^{2}f(x)\mathrm{\,d}x$}}
	{\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round, >=stealth]
		\draw[->] (-1.5,0) -- (3,0) node[below] {$x$};
		\draw[->] (0,-1) -- (0,2.5) node[right] {$y$};
		\node[below left] at (0,0) {$O$};
		\node[below left] at (-1,0) {$-1$};
		\node[below] at (1,0) {$1$};
		\node[below right] at (2,0) {$2$};
		\node[right] at (0,2) {$2$};
		\draw[domain=-1.1:2.3, smooth, variable=\x] plot ({\x}, {(\x+1)*(\x-1)*(\x-2)});
		\fill[pattern=north east lines] (-1,0) -- plot[domain=-1:1, smooth] ({\x}, {(\x+1)*(\x-1)*(\x-2)}) -- (1,0) -- cycle;
		\fill[pattern=north east lines] (1,0) -- plot[domain=1:2, smooth] ({\x}, {(\x+1)*(\x-1)*(\x-2)}) -- (2,0) -- cycle;
	\end{tikzpicture}}
	\loigiai{
		Diện tích cần tìm là $S=\displaystyle\int \limits_{-1}^{2}|f(x)|\mathrm{\,d}x=\displaystyle\int \limits_{-1}^{1}|f(x)|\mathrm{\,d}x+\displaystyle\int \limits_{1}^{2}|f(x)|\mathrm{\,d}x=\displaystyle\int \limits_{-1}^{1}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{1}^{2}f(x)\mathrm{\,d}x$.
	}
\end{ex}

\begin{ex}%[1D2N2-3]
