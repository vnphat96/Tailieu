\begin{ex}%[1D6N1-2]
	Biến đổi biểu thức $x^{\tfrac{4}{3}}\cdot x^{\tfrac{7}{3}}\cdot \sqrt[3]{x^{2}}$ ($x>0$) thành dạng lũy thừa với số mũ hữu tỉ ta được
	\choice
	{\True $x^{\tfrac{13}{3}}$}
	{$x^{\tfrac{56}{27}}$}
	{$x^{\tfrac{13}{27}}$}
	{$x^{\tfrac{11}{9}}$}
	\loigiai{
		Ta có $x^{\tfrac{4}{3}}\cdot x^{\tfrac{7}{3}}\cdot \sqrt[3]{x^{2}}=x^{\tfrac{4}{3}}\cdot x^{\tfrac{7}{3}}\cdot x^{\tfrac{2}{3}}=x^{\tfrac{4}{3}+\tfrac{7}{3}+\tfrac{2}{3}}=x^{\tfrac{13}{3}}$.
	}
\end{ex}

\begin{ex}%[2D4N1-2]
	Họ nguyên hàm của hàm số $f(x)=5x^4+4x^3-1$ là
	\choice
	{\True $x^5+x^4-x+C$}
	{$20x^3+12x^2+C$}
	{$x^5+x^4+C$}
	{$x^5+x^4-1+C$}
	\loigiai{
		Áp dụng công thức tính nguyên hàm, ta được
		\[\displaystyle\int f(x)\mathrm{\,d}x=\displaystyle\int \left(5x^4+4x^3-1\right)\mathrm{\,d}x=x^5+x^4-x+C.\]
	}
\end{ex}

\begin{ex}%[2D1N4-1]
