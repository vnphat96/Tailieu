\begin{ex}%[2D6N1-1]
	Cho hai biến cố $A$ và $B$ bất kì với $\mathrm{P}(A)>0$, $\mathrm{P}(B)>0$. Chọn khẳng định đúng trong các khẳng định sau.
	\choice
	{$\mathrm{P}(A\cup B)=\mathrm{P}(A|B)\cdot \mathrm{P}(B)$}
	{$\mathrm{P}(A|B)\cdot \mathrm{P}(A)=\mathrm{P}(B|A)\cdot \mathrm{P}(B)$}
	{$\mathrm{P}(A\cap B)=\mathrm{P}(A|B)\cdot \mathrm{P}(A)$}
	{\True $\mathrm{P}(A|B)\cdot \mathrm{P}(B)=\mathrm{P}(B|A)\cdot \mathrm{P}(A)$}
	\loigiai{
		Nếu $A$ và $B$ là hai biến cố bất kì thì $\mathrm{P}(A\cap B)=\mathrm{P}(A|B)\cdot \mathrm{P}(B)=\mathrm{P}(B|A)\cdot \mathrm{P}(A)$.
	}
\end{ex}

\begin{ex}%[2D4N1-1]
	Cho hàm số $F(x)=\cos 2x-\sin x+C$ là nguyên hàm của hàm số $f(x)$. Tính $f(\pi)$.
	\choice
	{$-1$}
	{$-3$}
	{\True $1$}
	{$0$}
	\loigiai{
		Vì $F(x)$ là nguyên hàm của hàm số $f(x)$ nên $F'(x)=f(x)\Rightarrow f(x)=-2\sin 2x-\cos x$.\\
		Vậy $f(\pi)=-2\sin 2\pi-\cos \pi=1$.
	}
\end{ex}

\begin{ex}%[2D4N2-1]
	Cho $\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x=5$ và $\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x=-3$, khi đó $\displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x$ bằng
	\choice
	{\True $-8$}
	{$-15$}
	{$8$}
	{$15$}
	\loigiai{
		Ta có $\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x=\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x+\displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x\Leftrightarrow \displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x=\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x=-3-5=-8$.
	}
\end{ex}

\begin{ex}%[2H5N2-1]
	Trong không gian $Oxyz$, cho đường thẳng $d\colon \heva{&x=1+t\\&y=-1\\&z=2-t}$. Điểm nào dưới đây thuộc $d$?
	\choice
	{$M(3;2;0)$}
	{\True $N(-1;-1;4)$}
	{$P(2;-1;1)$}
	{$Q(5;1;-2)$}
	\loigiai{
		Để kiểm tra điểm thuộc hay không thuộc đường thẳng ta thay tọa độ điểm vào phương trình đường thẳng.\\
		Thay tọa độ $N(-1;-1;4)$ vào phương trình đường thẳng ta được\\
		$\heva{&-1=1+t\\&-1=-1\\&4=2-t}\Leftrightarrow t=-2\Rightarrow N\in d$.\\
		Làm tương tự, các điểm $M$, $P$, $Q$ đều không thỏa mãn phương trình.
	}
\end{ex}

