\begin{ex}%[1C2V2-1]
	\immini[thm]
	{Một khu vực dân cư gồm $5$ giao lộ ($A$, $B$, $C$, $D$, $E$) được nối với nhau bằng các tuyến đường như sau được mô tả như hình bên. Công ty vệ sinh cần lập lộ trình sao cho đi qua tất cả các tuyến đường đúng một lần. Tính tổng thời gian để hoàn thành lộ trình thu gom rác.
	\shortans[]{31}
	}
	{\begin{tikzpicture}[scale=0.75, font=\footnotesize, line join=round, line cap=round, >=stealth]
			\node (A) at (0, 1.5) {$A$};
			\node (B) at (2.5, 3) {$B$};
			\node (C) at (2.5, 0) {$C$};
			\node (D) at (5, 3) {$D$};
			\node (E) at (5, 0) {$E$};		
			\draw[<->] (A) -- (B) node[midway, above left, black] {$4$};
			\draw[<->] (A) -- (C) node[midway, below left, black] {$3$};
			\draw[<->] (B) -- (C) node[midway, right, pos=0.6, black] {$6$};
			\draw[<->] (B) -- (D) node[midway, above, black] {$7$};
			\draw[<->] (C) -- (D) node[midway, above left, pos=0.7, black] {$2$};
			\draw[<->] (C) -- (E) node[midway, below, black] {$4$};
			\draw[<->] (A) -- (E) node[midway, above, pos=0.3, black] {$5$};
	\end{tikzpicture}}
	\loigiai{
		Bài toán yêu cầu tìm một đường đi bao trùm tất cả các cạnh của đồ thị đúng một lần, tức là tìm đường đi Euler.\\
		Bậc của các đỉnh trong đồ thị là: $\deg (A)=3$, $\deg (B)=3$, $\deg (C)=4$, $\deg (D)=2$, $\deg (E)=2$.\\
		Đồ thị liên thông và có đúng $2$ đỉnh bậc lẻ là $A$ và $B$. Do đó, đồ thị tồn tại đường đi Euler xuất phát từ $A$ và kết thúc ở $B$ (hoặc ngược lại).\\
		Một lộ trình hợp lệ có thể là: $A\rightarrowE\rightarrowC\rightarrowA\rightarrowB\rightarrowC\rightarrowD\rightarrowB$.\\
		Vì xe thu gom rác đi qua tất cả các tuyến đường đúng một lần, nên tổng thời gian hoàn thành lộ trình chính là tổng trọng số của tất cả các cạnh trong đồ thị.\\
		Tổng thời gian là:
		$$T=4+3+6+7+2+4+5=31.$$
		Vậy, tổng thời gian để hoàn thành lộ trình thu gom rác là $31$.
	}
\end{ex}

\begin{ex}%[2D1V3-6]
	Một ông nông dân có $2\,000$ m hàng rào và muốn rào lại cánh đồng hình chữ nhật tiếp giáp với một con sông. Ông không cần rào cho phía giáp bờ sông. Hỏi ông có thể rào được cánh đồng với diện tích lớn nhất là bao nhiêu nghìn mét vuông?
	\shortans[]{500}
	\loigiai{
		Gọi cạnh hình chữ nhật là $y$ ($0<y<2\,000$). Cạnh còn lại của hình chữ nhật là $x$.\\
		Theo đề bài $2x+y=2\,000$.\\
		Diện tích hình chữ nhật $f(x)=x\cdot y=x(2\,000-2x)=-2x^2+2\,000x$.\\
		Bảng biến thiên của $f(x)$
		\begin{center}
			\begin{tikzpicture}
				\tkzTabInit[nocadre=false,lgt=1.2,espcl=2.5,deltacl=0.6]
				{$x$ /0.6, $f'(x)$ /0.6, $f(x)$ /2}
				{$0$ , $500$ , $1\,000$}
				\tkzTabLine{ , + , $0$ , - , }
				\tkzTabVar{-/ $0$ , +/ $500\,000$ , -/ $0$}
			\end{tikzpicture}
		\end{center}
		Giá trị lớn nhất của nó là $500$.\\
		Vậy ông có thể rào được cánh đồng với diện tích lớn nhất là $500$ nghìn mét vuông.
	}
\end{ex}

\begin{ex}%[2D4V1-6]
	Một khinh khí cầu bay với độ cao tại thời điểm $t$ là $h(t)$, trong đó $t$ tính bằng phút, $h(t)$ tính bằng mét. Tốc độ bay của khinh khí cầu được cho bởi hàm số $v(t)=-0{,}12t^2+1{,}2t$, với $t$ tính bằng phút, $v(t)$ tính bằng mét/phút. Tại thời điểm xuất phát ($t=0$), khinh khí cầu ở độ cao $520$ m và $5$ phút sau khi xuất phát, khinh khí cầu đã ở độ cao $530$ m. Độ cao tối đa của khinh khí cầu khi bay là bao nhiêu?
	\shortans[]{540}
	\loigiai{
		Độ cao tối đa của khinh khí cầu khi bay chính là giá trị lớn nhất của hàm số $h(t)$ trên đoạn $[0;29]$.\\
		Ta có $h'(t)=v(t)=-0{,}12t^2+1{,}2t$.\\
		$h'(t)=0\Leftrightarrow \hoac{&t=10\\&t=0.}$\\
		Có $h(0)=520$; $h(10)=540$; $h(29)=49{,}04$ nên $\max \limits_{[0;29]}h(t)=540$ khi $t=10$.\\
		Độ cao tối đa của khinh khí cầu khi bay là $540$ m.
	}
\end{ex}

\begin{ex}%[2H5H2-7]
	Trong hệ trục tọa độ $Oxyz$, sàn nhà của một công trình thuộc mặt phẳng $(Oxy)$, tay vịn của lan can cầu thang là một đường thẳng đi qua hai điểm $A(5;1;9)$ và $B(2;1;12)$. Góc tạo bởi tay vịn của lan can cầu thang và mặt sàn nhà bằng bao nhiêu độ?
	\shortans[]{45}
	\loigiai{
		Mặt phẳng $(Oxy)$ có một vectơ pháp tuyến là $\vec{k}=(0;0;1)$.\\
		Đường thẳng $AB$ đi qua hai điểm $A(5;1;9)$ và $B(2;1;12)$ nên nhận $\overrightarrow{AB}=(-3;0;3)$ làm một vectơ chỉ phương.\\
		Gọi $\alpha$ là góc tạo bởi tay vịn của lan can cầu thang (đường thẳng $AB$) và mặt sàn nhà (mặt phẳng $(Oxy)$). Ta có\\
		$\sin \alpha=\sin (AB,(Oxy))=|\cos (\overrightarrow{AB},\vec{k})|=\dfrac{|-3\cdot 0+0\cdot 0+3\cdot 1|}{\sqrt{(-3)^2+0^2+3^2}\cdot \sqrt{0^2+0^2+1^2}}=\dfrac{3}{3\sqrt{2}}=\dfrac{1}{\sqrt{2}}$.\\
		Suy ra $\alpha=45^\circ$.\\
		Vậy góc tạo bởi tay vịn lan can cầu thang và mặt sàn nhà bằng $45^\circ$.
	}
\end{ex}

\begin{ex}%[2D6H2-3]
	Trong một đợt nghiên cứu tỷ lệ ung thư do hút thuốc lá gây nên, người ta thấy rằng tại tỉnh Hà Nam tỉ lệ người dân của tỉnh nghiện thuốc lá là $20\%$; tỉ lệ người bị bệnh ung thư trong số người nghiện thuốc lá là $70\%$, trong số người không nghiện thuốc lá là $15\%$. Hỏi khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là bao nhiêu?
	\shortans[]{0,54}
	\loigiai{
		Gọi $A$ là biến cố \lq\lq người nghiện thuốc lá\rq\rq, suy ra $\overline{A}$ là biến cố \lq\lq người không nghiện thuốc lá\rq\rq.\\
		Gọi $B$ là biến cố \lq\lq người bị bệnh ung thư\rq\rq.\\
		Theo giả thiết ta có:\\
		$\mathrm{P}(A)=0{,}2\Rightarrow \mathrm{P}(\overline{A})=0{,}8$.\\
		$\mathrm{P}(B|A)=0{,}7$.\\
		$\mathrm{P}(B|\overline{A})=0{,}15$.\\
		Áp dụng công thức xác suất toàn phần ta có:\\
		$\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}(B|A)+\mathrm{P}(\overline{A})\cdot \mathrm{P}(B|\overline{A})=0{,}2\cdot 0{,}7+0{,}8\cdot 0{,}15=0{,}26$.\\
		Xác suất để người đó nghiện thuốc lá khi biết người đó bị bệnh ung thư là $\mathrm{P}(A|B)$.\\
		Theo công thức Bayes, ta có:\\
		$\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}(B|A)}{\mathrm{P}(B)}=\dfrac{0{,}2\cdot 0{,}7}{0{,}26}=\dfrac{7}{13}\approx0{,}54$.\\
		Như vậy khi gặp một người bị bệnh ung thư tại tỉnh này thì xác suất người đó nghiện thuốc lá là $0{,}54$.
	}
\end{ex}

\begin{ex}%[0H5H3-9]
	Nếu một vật có khối lượng $m$ thì lực hấp dẫn $\vec{P}$ của Trái Đất tác dụng lên vật được xác định theo công thức $\vec{P}=m\vec{g}$, trong đó $\vec{g}$ là gia tốc rơi tự do có độ lớn $g=9{,}8$ m/s$^2$. Tính độ lớn của lực hấp dẫn của Trái Đất tác dụng lên một quả táo có khối lượng $100$ gam.
	\shortans[]{0,98}
	\loigiai{
		\immini
		{Đổi đơn vị khối lượng của quả táo: $m=100$ gam $=0{,}1$ kg.\\
			Độ lớn của lực hấp dẫn của Trái Đất tác dụng lên quả táo đó là:\\
			$|\vec{P}|=m|\vec{g}|=0{,}1\cdot 9{,}8=0{,}98$ (N).\\
			Vậy độ lớn của lực hấp dẫn là $0{,}98$ N.}
		{\begin{tikzpicture}[>=stealth]
				% Vẽ quả táo
				\draw[fill=yellow!70!green, draw=green!40!black, thick] (0,0) .. controls (-1.5,0.5) and (-1,-1.5) .. (0,-1.5) .. controls (1,-1.5) and (1.5,0.5) .. (0,0);
				% Vẽ cuống táo
				\draw[thick, brown] (0,0) .. controls (0.1,0.3) and (0.2,0.4) .. (0.3,0.5);
				
				% Trọng tâm m
				\fill (0,-0.7) circle (1.5pt) node[above right] {$m$};
				
				% Vectơ trọng lực P (vẽ ngay tại tâm, hướng xuống)
				\draw[->, red!80!black, very thick] (0,-0.7) -- (0,-2.5) node[right, black] {$\vec{P}$};
				
				% Vectơ gia tốc g (vẽ lệch sang trái một chút để không bị đè nét)
				\draw[->, blue, thick] (-0.5,-0.7) -- (-0.5,-1.7) node[left, black] {$\vec{g}$};
		\end{tikzpicture}}
	}
\end{ex}


\Closesolutionfile{ans}
