\begin{ex}%[2H5H2-3]
	Trong không gian $Oxyz$, cho đường thẳng $d\colon \dfrac{x+1}{1}=\dfrac{3-y}{2}=\dfrac{z+4}{2}$.
	\choiceTF
	{Đường thẳng $d$ có một vectơ chỉ phương $\vec{v}=(1;2;2)$}
	{\True Đường thẳng $d$ có phương trình tham số $\heva{&x=-2+t\\&y=5-2t\\&z=-6+2t}\quad(t\in \mathbb{R})$}
	{Đường thẳng $d$ đi qua điểm $M(1;2;0)$}
	{Đường thẳng $d$ song song với đường thẳng $\Delta \colon \dfrac{x-2}{3}=\dfrac{y+3}{-6}=\dfrac{z-2}{6}$}
	\loigiai{
		\begin{itemchoice}
			\itemch Viết lại phương trình $d\colon \dfrac{x+1}{1}=\dfrac{y-3}{-2}=\dfrac{z+4}{2}$.\\
			Đường thẳng $d$ có một vectơ chỉ phương là $\vec{u}=(1;-2;2)$. Dễ thấy $\vec{u}$ và $\vec{v}=(1;2;2)$ không cùng phương nên mệnh đề sai.
			\itemch Đường thẳng $d$ có vectơ chỉ phương $\vec{u}=(1;-2;2)$.\\
			Kiểm tra điểm $N(-2;5;-6)$, thay vào phương trình $d$ ta được $\dfrac{-2+1}{1}=\dfrac{5-3}{-2}=\dfrac{-6+4}{2}=-1$ (thỏa mãn).\\
			Do đó $d$ đi qua $N(-2;5;-6)$ nên có phương trình tham số là $\heva{&x=-2+t\\&y=5-2t\\&z=-6+2t}\quad(t\in \mathbb{R})$. Mệnh đề đúng.
			\itemch Thay tọa độ $M(1;2;0)$ vào phương trình $d$, ta có $\dfrac{1+1}{1}\ne\dfrac{3-2}{2}$. Suy ra $M(1;2;0)\notind$. Mệnh đề sai.
			\itemch Đường thẳng $\Delta$ có vectơ chỉ phương $\vec{u}_{\Delta }=(3;-6;6)=3(1;-2;2)=3\vec{u}$. Hai đường thẳng cùng phương.\\
			Hơn nữa, $\Delta$ đi qua điểm $A(2;-3;2)$. Thay tọa độ điểm $A$ vào phương trình của $d$, ta được $\dfrac{2+1}{1}=\dfrac{3-(-3)}{2}=\dfrac{2+4}{2}=3$ (đúng), suy ra $A\in d$.\\
			Vậy $d\equiv\Delta$. Mệnh đề sai.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D1V5-4]
	Cho hàm số $y=\dfrac{3x+2}{x+2}$ có đồ thị là $(C)$.
	\choiceTF
	{Đường thẳng $y=3$ là tiệm cận đứng của đồ thị $(C)$}
	{\True Đường thẳng $y=x$ cắt $(C)$ tại hai điểm $A$, $B$. Biết đường thẳng $y=x+k$ cắt $(C)$ tại $C$, $D$ thì $ABCD$ là hình bình hành khi đó $k>5$}
	{Đồ thị $(C)$ cắt đường thẳng $y=x+2$ tại hai điểm phân biệt}
	{\True Điểm $I(-2;3)$ là giao điểm của các đường tiệm cận của đồ thị $(C)$}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[scale=0.8, font=\footnotesize, line join=round, line cap=round, >=stealth]
				\draw[step=1cm, gray!30, very thin] (-6.5,-2.5) grid (3.5,8.5);
				\draw[->] (-6.5,0) -- (4,0) node[below] {$x$};
				\draw[->] (0,-2.5) -- (0,9) node[right] {$y$};
				\fill (0,0) circle (1.5pt) node[below right] {$O$};
				\foreach \x in {-6,-5,-4,-3,-2,-1,1,2,3} 
				\draw (\x,0.1) -- (\x,-0.1) node[below] {$\x$};
				\foreach \y in {-2,-1,1,2,3,4,5,6,7,8} 
				\draw (0.1,\y) -- (-0.1,\y) node[left] {$\y$};
				\clip (-6.5,-2.5) rectangle (3.5,8.5);
				\draw[dashed, thick, black] (-2,-2.5) -- (-2,8.5);
				\draw[dashed, thick, black] (-6.5,3) -- (3.5,3);
				\draw[thick, blue, samples=150, domain=-6.5:-2.1] plot (\x, {(3*\x+2)/(\x+2)});
				\draw[thick, blue, samples=150, domain=-1.9:3.5] plot (\x, {(3*\x+2)/(\x+2)});
				\draw[thick, red] (-4.5,-2.5) -- (3.5,5.5);
				\node[red, above left] at (3.5,5.5) {$y=x+2$};
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Ta có $\lim \limits_{x\to-2^+}\dfrac{3x+2}{x+2}=-\infty$ và $\lim \limits_{x\to-2^-}\dfrac{3x+2}{x+2}=+\infty$ nên đường thẳng $x=-2$ là tiệm cận đứng của đồ thị $(C)$. Đường thẳng $y=3$ là tiệm cận ngang. Mệnh đề sai.
			\itemch Phương trình hoành độ giao điểm của $(C)$ và đường thẳng $y=x$ là\\
			$\dfrac{3x+2}{x+2}=x\Rightarrow x^2-x-2=0\Leftrightarrow \hoac{&x=-1\\&x=2}\Rightarrow A(-1;-1),B(2;2)$.\\
			Độ dài đoạn $AB=\sqrt{(2-(-1))^2+(2-(-1))^2}=3\sqrt{2}$.\\
			Phương trình hoành độ giao điểm của $(C)$ và đường thẳng $y=x+k$ là\\
			$\dfrac{3x+2}{x+2}=x+k\Rightarrow x^2+(k-1)x+2k-2=0\quad(1)$.\\
			Đường thẳng $y=x+k$ cắt $(C)$ tại hai điểm phân biệt $C$, $D\Leftrightarrow (1)$ có hai nghiệm phân biệt khác $-2$\\
			$\Leftrightarrow \heva{&\Delta =(k-1)^2-4(2k-2)>0\\&(-2)^2+(k-1)(-2)+2k-2\ne0}\Leftrightarrow \heva{&k^2-10k+9>0\\&4\ne0}\Leftrightarrow k\in (-\infty;1)\cup (9;+\infty)$.\\
			Gọi $x_C,x_D$ là hai nghiệm của $(1)$, theo Vi-ét ta có $x_C+x_D=1-k$ và $x_C\cdot x_D=2k-2$.\\
			Khi đó $C(x_C;x_C+k)$, $D(x_D;x_D+k)$. Độ dài đoạn $CD=\sqrt{2(x_D-x_C)^2}=\sqrt{2\Delta }=\sqrt{2(k^2-10k+9)}$.\\
			Vì $A,B\in d_1\colon y=x$ và $C,D\in d_2\colon y=x+k$ nên $AB\parallel CD$ (với $k\ne0$).\\
			Để $ABCD$ là hình bình hành thì $AB=CD\Leftrightarrow 3\sqrt{2}=\sqrt{2(k^2-10k+9)}$\\
			$\Leftrightarrow 9=k^2-10k+9\Leftrightarrow k^2-10k=0\Leftrightarrow \hoac{&k=0\quad\text{(loại vì trùng với đường thẳng }AB\text{)}\\&k=10\quad\text{(thỏa mãn điều kiện)}}$.\\
			Với $k=10$ thì $k>5$ là đúng. Mệnh đề đúng.
			\itemch Phương trình hoành độ giao điểm của $(C)$ và đường thẳng $y=x+2$ là\\
			$\dfrac{3x+2}{x+2}=x+2\Rightarrow 3x+2=x^2+4x+4\Leftrightarrow x^2+x+2=0$ (phương trình vô nghiệm).\\
			Vậy $(C)$ và đường thẳng $y=x+2$ không cắt nhau. Mệnh đề sai.
			\itemch Đồ thị $(C)$ có đường tiệm cận đứng $x=-2$ và tiệm cận ngang $y=3$.\\
			Giao điểm của hai đường tiệm cận này có tọa độ là $(-2;3)$, trùng với điểm $I$. Mệnh đề đúng.
		\end{itemchoice}
	}
\end{ex}

