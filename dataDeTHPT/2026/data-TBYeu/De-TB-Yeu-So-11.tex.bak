				\draw (C) -- (C');
				\draw (D) -- (D');
				\fill (A) circle (1pt) node[below right] {$A\equivO$};
				\fill (B) circle (1pt) node[left] {$B$};
				\fill (C) circle (1pt) node[below right] {$C$};
				\fill (D) circle (1pt) node[above right] {$D$};
				\fill (A') circle (1pt) node[above right] {$A'$};
				\fill (B') circle (1pt) node[left] {$B'$};
				\fill (C') circle (1pt) node[right] {$C'$};
				\fill (D') circle (1pt) node[right] {$D'$};
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Ta có $A(0;0;0)\equivO$. Vì $ABCD.A'B'C'D'$ là hình hộp chữ nhật nên $A,B,D$ cùng nằm trên mặt phẳng $(Oxy)$.\\
			Từ giả thiết $B(2;0;0)\Rightarrow \overrightarrow{AB}=(2;0;0)$.\\
			Mà $\overrightarrow{DC}=\overrightarrow{AB}\Rightarrow (2-x_D;4-y_D;0-z_D)=(2;0;0)\Rightarrow D(0;4;0)$.\\
			Lại có $D'(0;4;3)\Rightarrow \overrightarrow{DD'}=(0;0;3)$.\\
			Suy ra $A'(0;0;3)$ vì $\overrightarrow{AA'}=\overrightarrow{DD'}=(0;0;3)$.\\
			Mặt khác $\overrightarrow{BB'}=\overrightarrow{AA'}=(0;0;3)\Rightarrow B'(2;0;3)$.\\
			Khi đó $\overrightarrow{B'D}=(0-2;4-0;0-3)=(-2;4;-3)$.\\
			Do đó mệnh đề đúng.
			\itemch Theo phân tích trên ta có $D(0;4;0)$.\\
			Do đó mệnh đề đúng.
			\itemch Ta có $\overrightarrow{CC'}=\overrightarrow{AA'}=(0;0;3)\Rightarrow C'(2;4;3)$.\\
			Do đó mệnh đề sai.
			\itemch Theo phân tích trên ta có $\overrightarrow{AA'}=(0;0;3)$.\\
			Do đó mệnh đề đúng.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D6H1-2]
	Trong một hộp có $18$ quả bóng bàn loại I và $2$ quả bóng bàn loại II, các quả bóng bàn có hình dạng và kích thước như nhau. Một học sinh lấy ngẫu nhiên lần lượt $2$ quả bóng bàn trong hộp. Xét tính đúng sai của các mệnh đề sau
	\choiceTF
	{Xác suất để lần thứ nhất lấy được quả bóng bàn loại II là $\dfrac{9}{10}$}
	{\True Xác suất để lần thứ hai lấy được quả bóng bàn loại II, biết lần thứ nhất lấy được quả bóng bàn loại II là $\dfrac{1}{19}$}
	{\True Xác suất để ít nhất $1$ lần lấy được quả bóng bàn loại I là $\dfrac{189}{190}$}
	{Xác suất để cả hai lần đều lấy được quả bóng bàn loại II là $\dfrac{9}{190}$}
	\loigiai{
		\begin{itemchoice}
			\itemch Tổng số bóng bàn trong hộp là $18+2=20$ quả.\\
			Gọi $A$ là biến cố: \lq\lq Lần thứ nhất lấy được quả bóng bàn loại II\rq\rq.\\
			Xác suất để lần thứ nhất lấy được quả bóng bàn loại II là $\mathrm{P}(A)=\dfrac{2}{20}=\dfrac{1}{10}$.\\
			Do đó mệnh đề sai.
			\itemch Gọi $B$ là biến cố: \lq\lq Lần thứ hai lấy được quả bóng bàn loại II\rq\rq.\\
			Sau khi lấy $1$ quả bóng bàn loại II ở lần thứ nhất, trong hộp chỉ còn lại $19$ quả bóng bàn, trong đó có đúng $1$ quả loại II.\\
			Xác suất để lần thứ hai lấy được quả bóng bàn loại II, biết lần thứ nhất lấy được quả bóng bàn loại II là $\mathrm{P}(B|A)=\dfrac{1}{19}$.\\
			Do đó mệnh đề đúng.
			\itemch Gọi $C$ là biến cố \lq\lq Cả hai lần đều lấy được quả bóng bàn loại II\rq\rq.\\
			Ta có $\mathrm{P}(C)=\mathrm{P}(A\cap B)=\mathrm{P}(A)\cdot \mathrm{P}(B|A)=\dfrac{1}{10}\cdot \dfrac{1}{19}=\dfrac{1}{190}$.\\
			Biến cố \lq\lq Ít nhất $1$ lần lấy được quả bóng bàn loại I\rq\rq\, chính là biến cố đối $\overline{C}$.\\
			Xác suất cần tìm là $\mathrm{P}(\overline{C})=1-\mathrm{P}(C)=1-\dfrac{1}{190}=\dfrac{189}{190}$.\\
			Do đó mệnh đề đúng.
			\itemch Xác suất để cả hai lần đều lấy được quả bóng bàn loại II là $\mathrm{P}(C)=\dfrac{1}{190}$.\\
			Do đó mệnh đề sai.
		\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


\caukq
