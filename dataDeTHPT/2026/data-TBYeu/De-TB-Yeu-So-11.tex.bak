			\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round, >=stealth, x={(-0.5cm,-0.4cm)}, y={(1cm,0cm)}, z={(0cm,1cm)}]
				\coordinate (A) at (0,0,0);
