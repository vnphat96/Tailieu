			;
			\draw[dashed]
			(A) to[out=90,in=175] (S)
			(D)--(A)--(B)
			(c)circle(.8pt) (d)circle(.8pt)--(a)circle(.8pt)--(b)circle(.8pt)
			(O)--(S)
			;
			\draw pic[draw, angle radius=2.5mm]{right angle=a--d--c};
		\end{tikzpicture}
	}
	\shortans[oly]{9}
	\loigiai
	{
		Diện tích mặt cắt là $S(x)=x\sqrt{9-x^2}$.\\
		Thể tích của cái lều là
		$$V=\displaystyle\int\limits_0^2S(x)\mathrm{\,d}x=\displaystyle\int\limits_0^3x\sqrt{9-x^2}\mathrm{\,d}x=9\ (\text{m}^3).$$
	}
\end{ex}

\begin{ex}%[2D6H2-3]
	Xác suất bắn trúng đích của xạ thủ hạng I là $0{,}8$ và của xạ thủ hạng II là $0{,}7$. Chọn ngẫu nhiên $1$ xạ thủ từ một nhóm gồm $4$ xạ thủ hạng I và $6$ xạ thủ hạng II. Biết rằng xạ thủ này bắn $2$ viên đạn một cách độc lập và chỉ có một viên trúng đích, tính xác suất để đó là xạ thủ hạng I.
	\shortans[oly]{0,34}
	\loigiai{
		Gọi $A$ là biến cố \lq\lq Xạ thủ được chọn thuộc hạng I\rq\rq.\\
		$B$ là biến cố \lq\lq Xạ thủ được chọn thuộc hạng II\rq\rq.\\
		$C$ là biến cố \lq\lq Xạ thủ chỉ bắn một viên đạn trúng đích\rq\rq.\\ Ta cần tính $\mathrm{P}(A\mid C)$.\\
		Ta có
		$$\mathrm{P}(A\mid C)=\dfrac{\mathrm{P}(A)\mathrm{P}(C \mid A)}{\mathrm{P}(A)\mathrm{P}(C \mid A)+\mathrm{P}(B)\mathrm{P}(C \mid B)}=\dfrac{0{,}4\cdot 0{,}8\cdot0{,}2}{0{,}4\cdot 0{,}8\cdot0{,}2+0{,}6\cdot0{,}3\cdot0{,}7}=\dfrac{32}{95} \approx 0{,}34.$$
	}
\end{ex}

\begin{ex}%[1C2H3-1]
	Một công ty vận tải cần giao hàng đến tất cả các thành phố $A$, $B$, $C$, $D$, $E$ (hình vẽ bên dưới). Chi phí di chuyển giữa các thành phố được mô tả trên hình. Xe giao hàng của công ty xuất phát từ một thành phố trong năm thành phố trên đi qua tất cả các thành phố còn lại đúng một lần sau đó trở lại thành phố ban đầu. Tìm chi phí thấp nhất của xe giao hàng.
	\begin{center}
		\begin{tikzpicture}[scale=1.2, font=\bfseries, label distance=1mm]
			
			% Tọa độ các điểm
			\coordinate (A) at (0, 0);
			\coordinate (B) at (4, 2);
			\coordinate (C) at (6, -1);
			\coordinate (D) at (3, -4);
			\coordinate (E) at (3, -1);
			\node[draw=blue, circle, minimum size=8mm, inner sep=0pt] (A) at (A) {A};
			\node[draw=blue, circle, minimum size=8mm, inner sep=0pt] (B) at (B) {B};
			\node[draw=blue, circle, minimum size=8mm, inner sep=0pt] (C) at (C) {C};
			\node[draw=blue, circle, minimum size=8mm, inner sep=0pt] (D) at (D) {D};
			\node[draw=blue, circle, minimum size=8mm, inner sep=0pt] (E) at (E) {E};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (A) -- (B) node[midway, above] {9};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (A) -- (E) node[midway, above right] {10};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (A) -- (D) node[midway, left] {11};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (B) -- (E) node[midway, right] {8};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (B) -- (C) node[midway, right] {14};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (C) -- (E) node[midway, above] {12};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (C) -- (D) node[midway, right] {13};
			\draw[thick, blue, shorten >=4pt, shorten <=4pt] (D) -- (E) node[midway, right] {14};
			
		\end{tikzpicture}
	\end{center}	
	\shortans[oly]{53}
	\loigiai{\begin{center}			
			\begin{tabular}{|c|c|}
				\hline
				Đường đi & Tổng số chi phí \\
				\hline
				$A\to B\to C\to E\to D\to A$ & $9+14+12+14+11=60$ \\
				\hline
				$A\to B\to E\to C\to D\to A$ & $9+8+12+13+11=53$ \\
				\hline
				$A\to E\to B\to C\to D\to A$ & $10+8+14+13+11=56$ \\
				\hline
				$A\to E\to D\to C\to B\to A$ & $10+14+13+14+9=60$ \\
				\hline
				$A\to D\to C\to E\to B\to A$ & $11+13+12+8+9=53$ \\
				\hline
				$A\to D\to E\to C\to B\to A$ & $11+14+12+14+9=60$ \\
				\hline
			\end{tabular}
		\end{center}
		Do đó, tổng số thử thách của đường đi nhận giá trị nhỏ nhất là $53$.
	}
\end{ex}

\begin{ex}%[1D7H2-8]
	Sau khi phát hiện một dịch bệnh, các chuyên gia y tế ước tính số người nhiễm bệnh kể từ ngày phát hiện bệnh nhân đầu tiên đến ngày thứ $t$ là $f(t)=-t^3+45t^2+600t$, $t \in \mathbb{N}, t \leq 30$. Nếu coi $f(t)$ là hàm số xác định trên đoạn $[0; 30]$ thì $f'(t)$ được xem là tốc độ truyền bệnh tại thời điểm $t$. Trong 30 ngày đầu tiên, có bao nhiêu ngày mà tốc độ truyền bệnh lớn hơn $1\,200$?
	\shortans[oly]{9}
	\loigiai{
		Ta có $f(t)=-t^3+45t^2+600t \Rightarrow f'(t)=-3t^2+90t+600$.\\
		Tốc độ truyền bệnh lớn hơn $1\,200$ nên
		$$f'(t) > 1200 \Leftrightarrow-3 t^2+90 t+600>1\,200 \Leftrightarrow-3t^2+90 t-600 > 0 \Leftrightarrow 10<t<20.$$
		Vậy có $9$ ngày tốc độ truyền bệnh lớn hơn 1200.
	}
\end{ex}


\Closesolutionfile{ans}
