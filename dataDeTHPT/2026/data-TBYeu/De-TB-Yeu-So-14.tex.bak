\begin{ex}%[2D4N3-1]
	Diện tích của hình phẳng giới hạn bởi đồ thị hàm số $y=x^2+x-2$ và trục hoành bằng
	\choice
	{$9$}
	{$\dfrac{13}{6}$}
	{$\dfrac{3}{2}$}
	{\True $\dfrac{9}{2}$}
	\loigiai{
		Hoành độ giao điểm của đồ thị hàm số và trục hoành là nghiệm của phương trình
		$x^2+x-2=0\Leftrightarrow\hoac{&x=1\\&x=-2.}$\\
		Diện tích hình phẳng $S=\displaystyle\int\limits_{-2}^1\left|x^2+x-2\right|\mathrm{\,d}x=-\displaystyle\int\limits_{-2}^1\left(x^2+x-2\right) \mathrm{\,d}x=\dfrac{9}{2}$.
	}
\end{ex}

