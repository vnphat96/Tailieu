\begin{ex}%[2D6H1-4]
	Một hộp chứa ba tấm thẻ cùng loại được ghi số lần lượt từ $1$ đến $3$. Bạn An lấy ra một cách ngẫu nhiên $1$ thẻ tử hộp, bỏ thẻ đó ra ngoài rồi lại lấy ra một cách ngẫu nhiên thêm một thẻ nữa. Xét các biến cố
	\begin{itemize}
		\item $A\colon$ \lq\lq Thẻ lấy ra lần thứ nhất ghi số $1$\rq\rq.
		\item $B\colon$ \lq\lq Thẻ lấy ra lần thứ nhất ghi số $2$\rq\rq.
		\item $C\colon$ \lq\lq Thẻ lấy ra lần thứ hai ghi số lẻ \rq\rq.
	\end{itemize}
	\choiceTF
	{\True Không gian mẫu của phép thử là $\Omega=\{(1; 2);(1; 3);(2; 1);(2; 3);(3; 1);(3; 2)\}$. Trong đó $(i; j)$ là kết quả lần thứ nhất lấy được thẻ ghi số $i$, lần thứ hai lấy được thẻ ghi số $j$}
	{Xác suất để thẻ lấy ra lần $2$ ghi số lẻ biết rằng thẻ lấy ra lần thứ nhất ghi số $2$ là $\dfrac{1}{2}$}
	{\True Tập hợp các kết quả thuận lợi cho biến cố $C$ là $\{(1; 3);(2; 3);(2; 1);(3; 1)\}$}
	{Xác suất để thẻ lấy ra lần hai ghi số lẻ biết rằng thẻ lấy ra lần thứ nhất ghi số $1$ là $\dfrac{1}{3}$}
	\loigiai{
		\begin{itemchoice}
			\itemch Không gian mẫu của phép thử là $\Omega=\{(1; 2);(1; 3);(2; 1);(2; 3);(3; 1);(3; 2)\}$.\\ Trong đó $(i; j)$ là kết quả lần thứ nhất lấy được thẻ ghi số $i$, lần thứ $2$ lấy được thẻ ghi số $j$.
			\itemch Ta cần tính xác suất $\mathrm{P}(C\mid B)$.\\
			Ta có $B=\{(2;1); (2;3)\}$; $B\cap C=\{(2;1);(2;3)\}$.\\
			Suy ra $\mathrm{P}(C\mid B)=\dfrac{n(C\cap B)}{n(B)}=\dfrac{2}{2}=1$.
			\itemch Tập hợp các kết quả thuận lợi cho biến cố $C$ là $\{(1; 3);(2; 3);(2; 1);(3; 1)\}$.
			\itemch Ta cần tính xác suất $\mathrm{P}(C\mid A)$.\\
			Ta có $A=\{(1;2); (1;3)\}$; $A\cap C=\{(1;3)\}$.\\
			Suy ra $\mathrm{P}(C\mid A)=\dfrac{n(C\cap A)}{n(A)}=\dfrac{1}{2}$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2H5H2-3]
	Trong không gian $Oxyz$, cho điểm $M(1; 0; 1)$ và đường thẳng $d\colon\dfrac{x-1}{1}=\dfrac{y-2}{2}=\dfrac{z-3}{3}$. Gọi $\Delta$ là đường thẳng đi qua $M$, vuông góc với $d$ và cắt $Oz$.
	\choiceTF
	{\True Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u}=(-3; 0; 1)$}
	{\True Đường thẳng $\Delta$ có phương trình $\heva{&x=1-3t\\&y=0\\&z=1+t}$}
	{Đường thẳng $\Delta$ có phương trình $\dfrac{x-1}{-3}=y=\dfrac{z-1}{1}$}
	{Đường thẳng $\Delta$ đi qua điểm $K(4;-1; 0)$}
	\loigiai{
		Gọi $N=\Delta \cap Oz \Rightarrow N\in Oz \Rightarrow N(0; 0; c)$.\\
		Đường thẳng $\Delta$ đi qua $M$ và $N$ nên $\Delta$ có $1$ vectơ chỉ phương là $\overrightarrow{MN}=(-1; 0; c-1)$.\\
		Đường thẳng $d$ có $1$ vectơ chỉ phương $\overrightarrow{u}=(1; 2; 3)$.\\
		$\Delta$ vuông góc với $d \Leftrightarrow \overrightarrow{u} \overrightarrow{MN}=0\Leftrightarrow 1\cdot(-1)+2\cdot0+3(c-1)=0\Leftrightarrow c=\dfrac{4}{3}$.\\
		Suy ra $\Delta$ có $1$ vectơ chỉ phương $\overrightarrow{u}_\Delta=3\overrightarrow{MN}=(-3; 0; 1)$.\\
		Vậy $\Delta$ có phương trình $\heva{&x=1-3t\\&y=0\\&z=1+t}$. Khi đó ta có
		\begin{itemchoice}
			\itemch Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u}=(-3; 0; 1)$.
			\itemch Đường thẳng $\Delta$ có phương trình $\heva{&x=1-3t \\&y=0\\&z=1+t.}$
			\itemch Đường thẳng $\Delta$ không tồn tại phương trình chính tắc do $\overrightarrow{u}=(-3; 0; 1)$.
			\itemch Thay tọa độ điểm $K(4;-1; 0)$ vào phương trình đường thẳng $\Delta$ không thoả mãn.
			
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D1H5-3]
	Cho hình hộp $ABCD.A'B'C'D'$ có $A(1; 0; 1)$, $B(2;-1; 2)$, $D(-1; 0; 1)$, $C'(3; 4; 5)$.
	\choiceTF
	{\True $C(0;-1; 2)$}
	{\True Hình chiếu vuông góc của đỉnh $D$ trên trục $Ox$ có tọa độ là $D_1(-1; 0; 0)$}
	{$A'(4; 5; 3)$}
	{\True $\overrightarrow{OC}=(0;-1; 2)$}
	\loigiai{
	\immini{
	\begin{itemchoice}
		\itemch Ta có $\overrightarrow{AB}=\overrightarrow{DC} \Rightarrow C(0;-1; 2)$.
		\itemch Hình chiếu vuông góc của đỉnh $D$ trên $Ox$ là $D_1(-1; 0; 0)$
		\itemch Ta có $\overrightarrow{AA'}=\overrightarrow{CC'} \Rightarrow A'(4; 5; 4)$.
		\itemch $C(0;-1; 2)$ suy ra $\overrightarrow{OC}=(0;-1; 2)$.
	\end{itemchoice}
	}{
		\begin{tikzpicture}
		\def\bc{3} 
		\def\ba{2}
		\def\h{3} 
		\def\gocB{40}
		\coordinate[label=below left:$B$] (B) at (0,0);
		\coordinate[label=above left:$A$] (A) at (\gocB:\ba);
		\coordinate[label=below:$C$] (C) at (\bc,0);
		\coordinate[label=right:$D$] (D) at ($(C)-(B)+(A)$);
		\coordinate[label=above left:$A'$] (A') at ($(A)+(90:\h)$);
		\coordinate[label=left:$B'$] (B') at ($(B)-(A)+(A')$);
		\coordinate[label=below right:$C'$] (C') at ($(C)-(A)+(A')$); 
		\coordinate[label=right:$D'$] (D') at ($(D)-(A)+(A')$); 
		\draw (B')--(B)--(C)--(D)--(D')--(A')--(B')--(C')--(D')
		(C)--(C'); 
		\draw[dashed] (A')--(A)--(D) 
		(A)--(B);
		\foreach \diem in {A,B,C,D,A',B',C',D'} \fill (\diem) circle (1pt); 
	\end{tikzpicture}
	}
	}
\end{ex}

\begin{ex}%[2D1H5-3]
	Cho hàm số $y=f(x)$ xác định trên $\mathbb{R} \setminus\{1\}$, liên tục trên mỗi khoảng xác định và có bảng biến thiên như sau
	\begin{center}
		\begin{tikzpicture} 
			\tkzTabInit[lgt=1.5,espcl=2] 
			{$x$/.7,$y'$ /.7,$y$ /3}
			{$-\infty$,$0$,$1$,$+\infty$}
			\tkzTabLine{,-,d,-,0,+,} 
			\tkzTabVar{+/$3$,-D+/$-\infty$ / $+\infty$,-/$-2$,+/$5$}
		\end{tikzpicture} 
	\end{center}
	\choiceTF
	{\True Hàm số $f(x)$ đồng biến trên khoảng $(2;+\infty)$}
	{\True Đồ thị hàm số $y=f(x)$ có một đường tiệm cận đứng là $x=1$}
	{Đồ thị hàm số $y=f(x)$ chỉ có một đường tiệm cận ngang là $y=3$}
	{\True Phương trình $f(x)+2=0$ có hai nghiệm phân biệt}
	\loigiai{
	\begin{itemchoice}
			\itemch Hàm số đã cho đồng biến trên khoảng $(2;+\infty)$.
			\itemch Do $\lim\limits_{x \to 1^{-}} y=-\infty$ nên đồ thị hàm số có một đường tiệm cận đứng là $x=1$
			\itemch Do $\lim\limits_{x \to-\infty} y=3$ và $\lim\limits_{x \to+\infty} y=5$ nên đồ thị hàm số có hai đường tiệm cận ngang là $y=3$ và $y=5$
			\itemch Dựa vào bảng biến thiên, ta có $f(x)+2=0\Leftrightarrow f(x)=-2\Leftrightarrow\hoac{&x=2\\&x=x_0\in(-\infty; 1).}$
		\end{itemchoice}
	}
\end{ex}


