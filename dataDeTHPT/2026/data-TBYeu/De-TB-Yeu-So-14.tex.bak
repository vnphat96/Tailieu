\begin{ex}%[2D4N1-2]
	Tính $\displaystyle\int\left(x^2+\dfrac{3}{x}-2\sqrt{x}\right) \mathrm{\,d}x$ ta được kết quả là.
	\choice
	{\True $\dfrac{x^3}{3}+3\ln|x|-\dfrac{4}{3} \sqrt{x^3}+C$}
	{$\dfrac{x^3}{3}-3\ln|x|-\dfrac{4}{3} \sqrt{x^3}+C$}
	{$\dfrac{x^3}{3}+3\ln|x|+\dfrac{4}{3} \sqrt{x^3}+C$}
	{$\dfrac{x^3}{3}-3\ln|x|+\dfrac{4}{3} \sqrt{x^3}+C$}
	\loigiai{Ta có $\displaystyle\int\left(x^2+\dfrac{3}{x}-2\sqrt{x}\right) \mathrm{\,d}x=\dfrac{x^3}{3}+3\ln|x|-\dfrac{4}{3} \sqrt{x^3}+C$.
	}
\end{ex}

\begin{ex}%[1D6N1-2]
	Cho $a$ là số thực dương tùy ý, biểu thức $a^{\tfrac{2}{3}} \cdot a^{\tfrac{2}{5}}$ viết dưới dạng lũy thừa với số mũ hữu tỉ là
	\choice
	{$a^{\tfrac{4}{15}}$}
	{\True $a^{\tfrac{16}{15}}$}
	{$a^{\tfrac{5}{3}}$}
	{$a^{\tfrac{1}{2}}$}
	\loigiai{
	Ta có $a^{\tfrac{2}{3}} \cdot a^{\tfrac{2}{5}}=a^{\tfrac{2}{3}+\tfrac{2}{5}}=a^{\tfrac{16}{15}}$.
	}
\end{ex}

\begin{ex}%[2D4N1-3]
