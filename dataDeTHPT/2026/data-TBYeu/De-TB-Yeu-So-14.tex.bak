\begin{ex}%[2D4H2-2]
	Tích phân $\displaystyle\int\limits_0^1\sqrt{2x+1} \mathrm{\,d}x$ có giá trị bằng
	\choice
	{\True $\dfrac{3\sqrt{3}-1}{3}$}
	{$3\sqrt{3}-\dfrac{2}{3}$}
	{$3\sqrt{3}-\dfrac{3}{2}$}
	{$2\sqrt{3}-\dfrac{3}{2}$}
	\loigiai{Ta có $\displaystyle\int\limits_0^1\sqrt{2x+1} \mathrm{\,d}x=\dfrac{1}{2} \displaystyle\int\limits_0^1\sqrt{2x+1}\mathrm{\,d}(2x+1)=\left.\dfrac{1}{2} \cdot\dfrac{(2x+1)^{\tfrac{3}{2}}}{\tfrac{3}{2}}\right|_0^1=\left.\dfrac{1}{3}(2x+1)^{\tfrac{3}{2}}\right|_0^1=\dfrac{3\sqrt{3}-1}{3}$.
	}
\end{ex}

\begin{ex}%[2D6N1-2]
	Nếu hai biến cố $A$, $B$ thỏa mãn $P(A)=0{,}4$; $P(B\mid A)=0{,}3$ thì $P(AB)$ bằng
	\choice
	{\True $\dfrac{3}{25}$}
	{$\dfrac{7}{10}$}
	{$\dfrac{3}{4}$}
	{$\dfrac{1}{10}$}
	\loigiai{Ta có $\mathrm{P}(AB)=P(A)\cdot \mathrm{P}(B\mid A)=\dfrac{3}{25}$.
	}
\end{ex}

\begin{ex}%[1D2N2-3]
	Cho cấp số cộng $(u_n)$ biết số hạng đầu $u_1=5$ và công sai $d=3$. Tìm công thức số hạng tổng quát của $u_n$.
	\choice
	{\True $u_n=2+3n$}
	{$u_n=8+n$}
	{$u_n=5+3n$}
	{$u_n=7-3n$}
	\loigiai{Ta có $u_n=u_1+(n-1)d \Leftrightarrow u_n=5+(n-1)\cdot3\Leftrightarrow u_n=2+3n$.
	}
\end{ex}

