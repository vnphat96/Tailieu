	\choice
	{\True $2x-\sin x+C$}
	{$x^2+\sin x+C$}
	{$2-\sin x+C$}
	{$2x-\cos x+C$}
	\loigiai{Ta có: $\displaystyle\int(2-\cos x) \mathrm{\,d}x=2x-\sin x+C$.
	}
