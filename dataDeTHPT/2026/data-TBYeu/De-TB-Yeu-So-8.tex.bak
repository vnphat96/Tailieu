\begin{ex}%[2D4H1-6]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Một công trình xây dựng dự kiến hoàn thành trong $50$ ngày. Gọi $M(t)$ là số ngày công được tính đến hết ngày thứ $t$. Trong kinh tế xây dựng, người ta đã biết rằng $M'(t)=m(t)$ với $m(t)$ là số lượng công nhân được sử dụng tại thời điểm $t$. Biết rằng $m(t)=100+8\sqrt{t}-2t$.
\choiceTF
{\True Số công nhân được sử dụng nhiều nhất vào ngày thứ $4$}
{\True Trong $10$ ngày đầu tiên, công trình đã cần hơn $1\,000$ ngày công}
{Tổng cộng cần $4\,000$ ngày công để hoàn thành công trình xây dựng đó theo dự kiến}
{Có $72$ công nhân được sử dụng vào ngày thứ $49$}
\loigiai{
Ta có
\begin{eqnarray*}
M(t)&=&\displaystyle\int m(t)\mathrm{d}t\\&=&\displaystyle\int \left(100+8\sqrt{t}-2t\right)\mathrm{d}t\\&=&100t+\dfrac{16}{3}t\sqrt{t}-t^2+C.
\end{eqnarray*}
Vì $M(0)=0\Rightarrow C=0$.\\
Do đó $M(t)=100t+\dfrac{16}{3}t\sqrt{t}-t^2$.
\begin{itemchoice}
\itemch Xét hàm số $m(t)=100+8\sqrt{t}-2t$ trên $\left[0;50\right]$, ta có
\[m(t)=100+8\sqrt{t}-2t\Rightarrow m'(t)=\dfrac{4}{\sqrt{t}}-2.\]
Cho $m'(t)=0\Leftrightarrow \dfrac{4}{\sqrt{t}}-2=0\Leftrightarrow \sqrt{t}=2\Leftrightarrow t=4$.\\
Khi đó $m(0)=100$; $m(4)=108$; $m(50)=8\sqrt{50}$.\\
Suy ra $\max \limits_{[0;50]}m(t)=108$.\\
Do đó số công nhân được sử dụng nhiều nhất vào ngày thứ $4$.
\itemch Trong $10$ ngày đầu tiên, công trình đã cần số ngày công là
\[M(10)=100\cdot 10+\dfrac{16}{3}\cdot 10\sqrt{10}-10^2\approx1\,068{,}65\text{ (ngày công)}.\]
\itemch Để hoàn thành công trình cần tổng cộng số ngày công theo dự kiến là
\[M(50)=100\cdot 50+\dfrac{16}{3}\cdot 50\sqrt{50}-50^2\approx4\,385{,}6\text{ (ngày công)}.\]
\itemch Vào ngày thứ $49$ có $m(49)=100+8\sqrt{49}-2\cdot 49=58$ công nhân được sử dụng.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[2D1H4-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hàm số $y=f(x)$ có bảng biến thiên như hàm số dưới đây.
\begin{center}
\begin{tikzpicture}
\tkzTabInit[nocadre=false, lgt=1.2, espcl=2.5, deltacl=0.5]
{$x$/0.6,$f’(x)$/0.6,$f(x)$/2}
{$-\infty$,$-2$,$-1$,$3$,$+\infty$}
\tkzTabLine{,+,d,-,d,-,d,+,}
\tkzTabVar{-/$-\infty$,+/$-4$,-D+/$-\infty$/$+\infty$,-/$0$,+/$+\infty$}
\end{tikzpicture}
\end{center}
\choiceTF
{Hàm số đã cho nghịch biến trên khoảng $\left(-2;0\right)$}
{Đồ thị hàm số đã cho có tiệm cận ngang}
{Hàm số có giá trị lớn nhất trên $\mathbb{R}$}
{Đồ thị hàm số đã cho có hai đường tiệm cận đứng}
\loigiai{
\begin{itemchoice}
\itemch Hàm số đã cho nghịch biến trên các khoảng $(-2;-1)$ và $(-1;3)$.
\itemch Ta có $\heva{&\lim \limits_{x\to-\infty}f(x)=-\infty\\&\lim \limits_{x\to+\infty}f(x)=+\infty}$ nên hàm số không có tiệm cận ngang.
\itemch Ta có $\lim \limits_{x\to\left(-1\right)^{+}}f(x)=+\infty$ nên hàm số không có giá trị lớn nhất trên $\mathbb{R}$.
\itemch Hàm số đã cho có tập xác định là $\mathscr{D}=\mathbb{R}\setminus\{-1\}$.\\
Vì $\lim \limits_{x\to\left(-1\right)^{-}}f(x)=-\infty$. Do đó
hàm số có đúng một tiệm cận đứng là đường thẳng $x=-1$.
\end{itemchoice}
}
\end{ex}

\begin{ex}%[2H5H2-7]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$, cho đường thẳng $\Delta \colon \heva{&x=3+t\\&y=4+2t\\&z=-3-t}{,}\,t\in \mathbb{R}$ và mặt phẳng $(P)$ có phương trình $2x+y+z-1=0$.
\choiceTF
{Giao điểm của $\Delta$ và $(P)$ là $M(3;4;-3)$}
{$\sin \left(\Delta ,(P)\right)=\dfrac{\sqrt{3}}{2}$}
{\True Góc giữa $\Delta$ và $(P)$ là $30^\circ$}
{Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u}=(3;4;-3)$}
\loigiai{
\begin{itemchoice}
\itemch Vì $M\in \Delta \Rightarrow M(3+t;4+2t;-3-t)$.\\
Mà $M\in (P)$ nên
\[2\left(3+t\right)+\left(4+2t\right)+\left(-3-t\right)-1=0\Rightarrow 3t+6=0\Rightarrow t=-2.\]
Vậy $\Delta \cap (P)=M(1;0;-1)$.
\itemch Đường thẳng $\Delta$ có một vectơ chỉ phương là $\overrightarrow{u}=(1;2;-1)$.\\
Mặt phẳng $(P)$ có một vectơ pháp tuyến là $\overrightarrow{n}=(2;1;1)$.\\
Do dó
\[\sin \left(\Delta {,}(P)\right)=\left|\cos \left(\overrightarrow{u}{,}\overrightarrow{n}\right)\right|=\dfrac{|1\cdot 2+2\cdot 1+(-1)\cdot 1|}{\sqrt{1^2+2^2+(-1)^2}\cdot \sqrt{2^2+1^2+1^2}}=\dfrac{1}{2}.\]
\itemch Vì $\sin \left(\Delta {,}(P)\right)=\dfrac{1}{2}\Rightarrow \left(\Delta {,}(P)\right)=30^\circ$.
\itemch Đường thẳng $\Delta$ có một vectơ chỉ phương là $\overrightarrow{u}=(1;2;-1)$.
\end{itemchoice}
}
\end{ex}
\begin{ex}%[2D6H2-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong một khu bảo tồn động vật hoang dã, người ta đang nghiên cứu $600$ con vật, trong đó có $360$ con báo đốm và $240$ con sư tử. Sau khi thống kê, người ta thấy có $60\%$ số báo đốm đã được tiêm phòng và $45\%$ số sư tử đã được tiêm phòng.
\choiceTF
{\True Số con báo đốm đã được tiêm phòng là $216$ con}
{Số con sư tử chưa được tiêm phòng là $108$ con}
{Chọn ra ngẫu nhiên một con vật trong số đó. Xác suất để chọn ra được một con sư tử đã được tiêm phòng là $0{,}4$}
{\True Chọn ra ngẫu nhiên một con vật trong số đó. Xác suất để chọn ra được một con vật chưa được tiêm phòng là $0{,}46$}
\loigiai{
\begin{itemchoice}
\itemch Số con báo đốm đã được tiêm phòng là $360\cdot 60\%=216$ con.
\itemch Số con sư tử chưa được tiêm phòng là $240\cdot (100\%-45\%)=132$ con.
\itemch Xét các biến cố:
\begin{itemize}
\item $A$: \lq\lq Chọn $1$ con sư tử bất kì\rq\rq.
\item $B$: \lq\lq Chọn $1$ con vật đã được tiêm phòng\rq\rq.
\end{itemize}
Số con sư tử đã được tiêm phòng là $240\cdot 45\%=108$ con.\\
Tổng số con vật đã được tiêm phòng là $216+108=324$ con.\\
Xác suất để chọn ra được một con sư tử đã được tiêm phòng là \[\mathrm{P}(A\mid B)=\dfrac{n(A\cap B)}{n(B)}=\dfrac{108}{324}=\dfrac{1}{3}.\]
\itemch
Ta có $\mathrm{P}(A)=\dfrac{240}{600}=\dfrac{2}{5}$;  $\mathrm{P}(B\mid A)=\dfrac{45}{100}=\dfrac{9}{20}$; $\mathrm{P}(\overline{A})=\dfrac{3}{5}$;  $\mathrm{P}(B\mid \overline{A})=\dfrac{60}{100}=\dfrac{3}{5}$.\\
Theo công thức xác suất toàn phần ta có \[\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}(B|A)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B|\overline{A}\right)=\dfrac{27}{50}=0{,}54.\]
Vậy xác suất để chọn được một con vật chưa tiêm phòng là $\mathrm{P}\left(\overline{B}\right)=1-P(B)=0{,}46$.
\end{itemchoice}
}
\end{ex}
\Closesolutionfile{ans}

\caukq
\Opensolutionfile{ans}[ans/SA-De-TB-Yeu-So-8]
\begin{ex}%[2D4H3-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Thể tích khối tròn xoay do hình phẳng giới hạn bởi các đường $x+y-2=0$; $y=2\sqrt{x}-1$; $y=0$ quay quanh trục $Ox$ bằng $\dfrac{a\pi}{b}$. Tính giá trị của biểu thức $a+b$.
\shortans[]{13}
\loigiai{
Hình phẳng đã cho được chia làm $2$ phần sau:
\begin{center}
\begin{tikzpicture}[scale=1,line join=round, line cap=round,>=stealth]
\tikzset{declare function={f(\x)=(2*sqrt(\x)-1);g(\x)=2-(\x);
xmin=-1; xmax=4;
ymin=-1;ymax=3;},
smooth,samples=100
}
\fill[opacity=.6,pattern = north east lines]plot[domain=0.25:1] (\x,{f(\x)})--plot[domain=1:2] (\x,{g(\x)})--cycle;
\draw[->] (xmin,0)--(0,0) node[shift={(-135:9pt)}]{$O$} --(xmax,0) node[shift={(-100:7pt)}] {$x$};
\draw[->] (0,ymin)--(0,ymax) node[shift={(200:7pt)}] {$y$};
\fill (0,0) circle (1pt);
\begin{scope}
\clip (xmin,ymin) rectangle (xmax,ymax);
\draw[red,domain=0:xmax] plot (\x,{f(\x)});
\draw[blue,domain=xmin:xmax] plot (\x,{g(\x)});
\end{scope}
\foreach \x/\goc in {1/-90,2/-125}{
\fill (\x,0) circle (1pt) node[shift={(\goc:7pt)}]{$\x$};}
\fill (0.25,0) circle (1pt) node[shift={(-75:12pt)}]{$\frac{1}{4}$};
\draw[dashed](1,0)--(1,1);
\end{tikzpicture}
\end{center}
Xét phương trình hoành độ giao điểm của đường thẳng $x+y-2=0$ và $y=2\sqrt{x}-1$, ta có
\[2\sqrt{x}-1=2-x\Rightarrow x=1.\]
Xét phương trình hoành độ giao điểm của đường thẳng $x+y-2=0$ và trục hoành, ta có
\[2\sqrt{x}-1=0\Rightarrow x=\dfrac{1}{4}\]
\begin{itemize}
\item Phần $1$: Hình phẳng giới hạn bởi các đường $y=2\sqrt{x}-1$; $y=0$; $x=\dfrac{1}{4}$; $x=1$.\\
Khi quay trục $Ox$ phần $1$ ta được khối tròn xoay có thể tích\\ \[V_1=\pi\displaystyle\int \limits_{\frac{1}{4}}^1\left(2\sqrt{x}-1\right)^2\mathrm{d}x=\pi\left(4x-4\sqrt{x}+1\right)\bigg|_{\frac{1}{4}}^1=\dfrac{7\pi}{24}.\]
\item Phần $2$: Hình phẳng giới hạn bởi các đường $y=2-x$; $y=0$; $x=1$; $x=2$.\\
Khi quay trục $Ox$ phần $2$ ta được khối tròn xoay có thể tích
\[V_2=\pi\displaystyle\int \limits_1^2\left(2-x\right)^2\mathrm{d}x=\pi\dfrac{\left(x-2\right)^3}{3}\bigg|_1^2=\dfrac{\pi}{3}.\]
\end{itemize}
Do đó, thể tích khối tròn xoay cần tính là $V=V_1+V_2=\dfrac{7\pi}{24}+\dfrac{\pi}{3}=\dfrac{5\pi}{8}$.\\
Suy ra $a=5$, $b=8$.\\
Vậy $a+b=5+8=13$.
}
\end{ex}

\begin{ex}%[2H2N1-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Nếu vật chuyển động thẳng đều dưới tác dụng của một lực $\overrightarrow{F}$ thì vật đó đang chịu tác dụng của lực ma sát $\overrightarrow{F}_{ms}$ có độ lớn bằng lực tác dụng $\overrightarrow{F}$ và có hướng ngược với hướng của $\overrightarrow{F}$. Công thức tính lực ma sát $F_{ms}=\mu\cdot N$, trong đó $\mu$ là hệ số ma sát, $N$ là độ lớn của áp lực. Giả sử một thùng gỗ đang chuyển động thẳng đều trên mặt phẳng nằm ngang có trọng lượng $N=150$\,(N), hệ số ma sát giữa vật và mặt phẳng là $\mu=0{,}25$. Tính lực tác dụng lên thùng gỗ để thùng chuyển động thẳng đều?
\shortans[]{37,5}
\loigiai{
Lực ma sát mặt phẳng tác dụng lên vật là
\[F_{ms}=\mu\cdot N=0{,}25\cdot 150=37{,}5\;\text{(N)}.\]
Vật chuyển động thẳng đều nên lực tác dụng lên vật là $F=F_{ms}=37{,}5$\,(N).
}
\end{ex}

\begin{ex}%[2D1V3-6]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Một công ty muốn làm một đường ống dẫn dầu từ một kho $A$ ở trên bờ biển đến một vị trí $B$ trên một hòn đảo. Hòn đảo cách bờ biển $6$\,km. Gọi $C$ là điểm trên bờ sao cho $BC$ vuông góc với bờ biển. Khoảng cách từ $A$ đến $C$ là $9$\,km. Người ta cần xác định một ví trí $D$ trên $AC$ để lắp ống dẫn theo đường gấp khúc $ADB$. Tính khoảng cách $AD$ để số tiền chi phí thấp nhất, biết rằng giá để lắp đặt mỗi km đường ống trên bờ là $100\,000\,000$ đồng và dưới nước là $260\,000\,000$ đồng.
\shortans[]{6,5}
\loigiai{
\begin{center}
\begin{tikzpicture}[scale=0.8, font=\footnotesize, line join=round, line cap=round, >=stealth]
\tikzset{declare function={a=3;}}
\path (0:0) coordinate (C)
(1.2*a,0) coordinate (D)
(3*a,0) coordinate (A)
(0,1.5*a) coordinate (B)
pic[draw,angle radius=2mm]{right angle= B--C--D};
\draw (D)--(B)--(C)--(A);
\foreach \x /\gN in {A/0,B/90,C/-130,D/40}
\fill (\x) circle (1pt)($(\x)+(\gN:2.5mm)$) node {$\x$};
\draw[<->] ($(C)+(-0.2,0)$)--($(B)+(-0.2,0)$)node[pos=0.5,left]{$6$\,km};
\draw[<->] ($(C)+(0,-0.2)$)--($(A)+(0,-0.2)$)node[pos=0.5,below]{$9$\,km};
\end{tikzpicture}
\end{center}
Đặt $AD=x$\,km, $x>0$ suy ra $CD=9-x$;\\
Tam giác $BCD$ vuông tại $C$ có
$BD=\sqrt{36+\left(9-x\right)^2}$.\\
Giá thành lắp đặt là \[100\cdot 10^6x+\sqrt{36+\left(9-x\right)^2}\cdot 260\cdot 10^6=10^7\left[10x+26\sqrt{36+\left(9-x\right)^2}\right].\]
Xét hàm số $f(x)=10x+26\sqrt{36+\left(9-x\right)^2}$ với ($0<x<9$).\\
Ta có
\[f'(x)=10-26\cdot \dfrac{9-x}{\sqrt{36+\left(9-x\right)^2}}.\]
Khi đó
\begin{eqnarray*}
&&f'(x)=0\\&\Leftrightarrow &10-26\cdot \dfrac{9-x}{\sqrt{36+\left(9-x\right)^2}}=0\\&\Leftrightarrow &10\sqrt{36+\left(9-x\right)^2}-26\left(9-x\right)=0\\&\Leftrightarrow &\heva{&x\le9\\&-576x^2+10368x-43056=0}\\&\Rightarrow &x=\dfrac{13}{2}.
\end{eqnarray*}
Lập bảng biến thiên của hàm số $f(x)$ trên $\left(0;9\right)$.
\begin{center}
\begin{tikzpicture}
\tkzTabInit[nocadre=true, lgt=1.2, espcl=4, deltacl=0.5]
{$x$/0.7,$f’(x)$/0.7,$f(x)$/2}
{$0$,$\tfrac{13}{2}$,$9$}
\tkzTabLine{,-,0,+,}
\tkzTabVar{+/,-/,+/}
\end{tikzpicture}
\end{center}
Quan sát bảng biến thiên, ta thấy hàm số đạt giá trị nhỏ nhất khi $x=\dfrac{13}{2}$.\\
Vậy $AD=6{,}5$\,(km).
}
\end{ex}

\begin{ex}%[2H5H3-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
\immini[thm]{
Trong không gian $Oxyz$, một vòm được thiết kế có bề mặt là mặt cầu tâm $I(1;2;20)$, bán kính bằng $50$\,m và có đáy nằm trên mặt phẳng $\left(Oxy\right)$. Chiều cao của vòm là bao nhiêu?
\shortans[]{70}
}
{
\begin{tikzpicture} [scale=.5, transform shape]
\tikzset{declare function={R=3;d=-1.5;theta=65;         r=sqrt(R*R-d*d);betacrit=asin(d/r*cot(theta));},samples=200,smooth}
\tdplotsetmaincoords{theta}{0}
\path (0,R) coordinate (S);
\draw (0,0) coordinate (I) circle (R);
\begin{scope}[tdplot_main_coords,line join=round]
\draw[dashed,dash pattern = on 2pt off 1.5pt]
(S)--(0,0,d) coordinate (H)
--({r*cos(betacrit)},{r*sin(betacrit)},d) coordinate (M) -- cycle
plot[variable=\t,domain=betacrit:180-betacrit]({r*cos(\t)},{r*sin(\t)},d)
plot[variable=\t,domain=0:180]({R*cos(\t)},{R*sin(\t)},0);
\draw plot[variable=\t,domain=betacrit:-180-betacrit]({r*cos(\t)},{r*sin(\t)},d);
\draw plot[variable=\t,domain=180:360]({R*cos(\t)},{R*sin(\t)},0);
\end{scope}
\foreach \x /\g in {H/-90,I/180,M/0,S/90}
\fill[black] (\x) circle (1.2pt)
($(\x)+(\g:3mm)$) node {$\x$};
\end{tikzpicture}
}
\loigiai{
Gọi $H$ là hình chiếu vuông góc của $I$ trên mặt phẳng $\left(Oxy\right)\Rightarrow H(0;0;20)$.\\
Khi đó, khoảng cách từ tâm $I$ đến mặt phẳng $\left(Oxy\right)$ là $IH=20$\,m.\\
Vậy chiều cao của vòm là $SH=IH+IS=20+50=70$\,(m).
}
\end{ex}

\begin{ex}%[2D6H2-4]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong hội thảo, xác suất chọn được một người trình bày báo cáo bằng tiếng Anh là $0{,}6$. Xác suất để chọn một người trình bày là nữ là $0{,}4$. Xác xuất để chọn được một người trình bày báo cáo bằng tiếng Anh biết người đó là nữ là $0{,}3$. Tính xác suất để chọn được một người là nữ sao cho người đó có thể trình bày báo cáo bằng tiếng Anh.
\shortans[]{0,2}
\loigiai{
Gọi $A$ là biến cố \lq\lq Chọn được người trình bày báo cáo bằng tiếng Anh\rq\rq $\Rightarrow \mathrm{P}\left(A\right)=0{,}6$.\\
Gọi $B$ là biến cố \lq\lq Chọn được người trình bày nữ\rq\rq $\Rightarrow P\left(B\right)=0{,}4$.\\
Theo đề bài ta có $\mathrm{P}\left(A\mid B\right)=0{,}3$.\\
Áp dụng công thức Bayes ta có
\[\mathrm{P}\left(B|A\right)=\dfrac{\mathrm{P}\left(B\right)\cdot \mathrm{P}\left(A|B\right)}{\mathrm{P}\left(A\right)}=\dfrac{0{,}4\cdot 0{,}3}{0{,}6}=0{,}2.\]
}
\end{ex}

\begin{ex}%[1C2V2-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Xe xúc tuyết phải dọn tuyết bằng cách lái xe dọc tất cả các con đường được hiển thị như hình vẽ bên.
\begin{center}
\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round, >=stealth]
\tikzset{declare function={a=1;}}
\path (0:0) coordinate (C)
(5*a,0) coordinate (F)
(0,2*a) coordinate (B)++(-a,0)coordinate (A)
(B)++(0,1)coordinate (I)++(2*a,0)coordinate (H)
($(H)!1/3!(F)$)coordinate (G);
\draw (A)--(B)node[pos=0.5,above]{$1$}--(I)node[pos=0.5,right]{$1$}--(H)node[pos=0.5,above]{$2$}--(G)node[pos=0.5,right]{$1$}--(F)node[pos=0.5,right]{$2$}--(C)node[pos=0.5,above]{$5$}--(B)node[pos=0.5,left]{$2$}--(G)node[pos=0.5,above]{$3$}--(C)node[pos=0.5,above]{$4$};
\foreach \x /\gN in {A/180,B/-40,C/180,I/90,H/90,G/30,F/0}
\fill (\x) circle (1pt)($(\x)+(\gN:2.5mm)$) node {$\x$};
\end{tikzpicture}
\end{center}
Quãng đường ngắn nhất xe xúc tuyết phải đi là
\shortans[]{21}
\loigiai{
Nhận thấy đây là đồ thị vô hướng có hai đỉnh bậc lẻ. Do đó, có đường đi Euler.\\
Để xe xúc tuyết đi được quãng đường ngắn nhất thì xe chỉ đi qua các con đường đúng một lần.\\
Một trong số các cách đi của xe là
\[A\toB\toI\toH\toG\toF\toC\toB\toG\toC.\]
Quãng đường ngắn nhất xe xúc tuyết phải đi là
\[1+1+2+1+3+4+2+2+5=21\text{ (km)}.\]
}
\end{ex}


\Closesolutionfile{ans}
