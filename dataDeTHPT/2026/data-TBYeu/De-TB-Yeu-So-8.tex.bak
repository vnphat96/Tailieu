\begin{ex}%[2D1H4-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hàm số $y=f(x)$ có bảng biến thiên như hình vẽ.
\begin{center}
\begin{tikzpicture}
\tkzTabInit[lgt=1.2, espcl=3.2, deltacl=0.5]
{$x$/0.7,$f’(x)$/0.7,$f(x)$/2}
{$-\infty$,$-2$,$0$,$+\infty$}
\tkzTabLine{,,d, +, d, -}
\tkzTabVar{//, D-//$-\infty$, +D+/$+\infty$/$1$, -/$0$}
\fill[pattern = north east lines](T11) rectangle (N23);
\end{tikzpicture}
\end{center}
Hỏi đồ thị hàm số đã cho có bao nhiêu đường tiệm cận?
\choice
{\True $3$}
{$2$}
{$1$}
{$4$}
\loigiai{
Ta có
\begin{itemize}
\item $\lim \limits_{x\to0^{-}}f(x)=+\infty$ nên đường thẳng $x=0$ là tiệm cận đứng của đồ thị hàm số đã cho.
\item $\lim \limits_{x\to-2^{+}}f(x)=-\infty$ nên đường thẳng $x=-2$ là tiệm cận đứng của đồ thị hàm số đã cho.
\item $\lim \limits_{x\to+\infty}f(x)=0$ nên đường thẳng $y=0$ là tiệm cận ngang của đồ thị hàm số đã cho.
\end{itemize}
Vậy đồ thị hàm số đã cho có $3$ đường tiệm cận.
}
\end{ex}

\begin{ex}%[2D4N1-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Tính $F(x)=\displaystyle\int \mathrm{e}^2\mathrm{\,d}x$.
\choice
{$F(x)=\dfrac{\mathrm{e}^2x^2}{2}+C$}
{\True $F(x)=\mathrm{e}^2x+C$}
{$F(x)=\dfrac{\mathrm{e}^3}{3}+C$}
{$F(x)=2\mathrm{e}x+C$}
\loigiai{
Ta có $F(x)=\displaystyle\int \mathrm{e}^2\mathrm{\,d}x=\mathrm{e}^2x+C$.
}
\end{ex}

\begin{ex}%[2H5H3-3]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$, phương trình mặt cầu tâm $I\left(2;-1;3\right)$ và đi qua điểm $A\left(1;2;-1\right)$ là
\choice
{\True $\left(x-2\right)^2+\left(y+1\right)^2+\left(z-3\right)^2=26$}
{$\left(x-2\right)^2+\left(y+1\right)^2+\left(z-3\right)^2=\sqrt{26}$}
{$\left(x+2\right)^2+\left(y-1\right)^2+\left(z+3\right)^2=26$}
{$\left(x-1\right)^2+\left(y-2\right)^2+\left(z+1\right)^2=26$}
