\begin{ex}%[2H5H1-5]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Trong không gian $Oxyz$, cho mặt phẳng $(P)\colon 2x-2y+z+5=0$. Khoảng cách từ $M\left(-1;2;-3\right)$ đến mặt phẳng $(P)$ bằng
\choice
{$\dfrac{2}{3}$}
{\True $\dfrac{4}{3}$}
{$-\dfrac{4}{3}$}
{$\dfrac{4}{9}$}
\loigiai{
Ta có $\mathrm{d}\left(M,\left(P\right)\right)=\dfrac{\left|2\cdot \left(-1\right)-2\cdot 2-3+5\right|}{\sqrt{2^2+\left(-2\right)^2+1^2}}=\dfrac{4}{3}$.
}
\end{ex}

\begin{ex}%[1D5N1-1]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Khảo sát thời gian đọc sách trong ngày của một số học sinh khối 11 thu được mẫu số liệu ghép nhóm sau
\begin{longtable}{|l|c|c|c|c|c|}
	\hline
	Thời gian (phút) & $[0;30)$ & $[30;60)$ & $[60;90)$ & $[90;120)$ & $[120;150)$ \\ \hline
	Số học sinh&$2$&$5$&$12$&$15$&$6$  \\ 
	\hline
\end{longtable}
Giá trị đại diện của nhóm $\left[30;60\right)$ là
\choice
{$40$}
{\True $45$}
{$60$}
{$30$}
\loigiai{
Giá trị đại diện của nhóm $\left[30;60\right)$ là $\dfrac{30+60}{2}=45$.
}
\end{ex}

\begin{ex}%[1D6H2-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Đặt $\log _{15}3=a$. Hãy biểu diễn $\log _{25}15$ theo $a$.
\choice
{$\log _{25}15=\dfrac{1-a}{a}$}
{$\log _{25}15=\dfrac{1}{1-a}$}
{$\log _{25}15=\dfrac{2}{1-a}$}
{\True $\log _{25}15=\dfrac{1}{2\left(1-a\right)}$}
\loigiai{
Ta có
\[\log _{15}3=\dfrac{1}{\log _315}=\dfrac{1}{1+\log _35}\Rightarrow \log _35=\dfrac{1-a}{a}.\]
Khi đó
\[\log _{25}15=\dfrac{\log _315}{\log _325}=\dfrac{1+\log _35}{2\log _35}=\dfrac{1}{2(1-a)}.\]
}
\end{ex}

\begin{ex}%[1D6H4-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Phương trình $2^{x+3}=1$ có nghiệm thuộc khoảng nào dưới đây
\choice
{$\left(-1;0\right)$}
{$\left(1;+\infty\right)$}
{\True $\left(-4;0\right)$}
{$\left(-\infty;-4\right)$}
\loigiai{
Ta có $2^{x+3}=1\Leftrightarrow x+3=0\Leftrightarrow x=-3$.\\
Vậy phương trình có nghiệm thuộc khoảng $\left(-4;0\right)$.
}
\end{ex}

\begin{ex}%[2D1N2-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho hàm số $y=f(x)$ xác định, liên tục trên $\mathbb{R}$ và có bảng biến thiên:
