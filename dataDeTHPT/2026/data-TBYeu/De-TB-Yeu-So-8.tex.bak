\begin{ex}%[2D6H1-2]%[DuAn-HS-TB-Yeu]%[Vũ Hồng Toàn]
Cho $A$ và $B$ là hai biến cố của cùng một phép thử. Biết $P\left(A\mid B\right)=0{,}3$; $P\left(AB\right)=0{,}2$. Khi đó $P\left(B\right)$ bằng
\choice
{$\dfrac{1}{3}$}
{$\dfrac{3}{50}$}
{$\dfrac{1}{2}$}
{\True $\dfrac{2}{3}$}
\loigiai{
Ta có $P\left(A\mid B\right)=\dfrac{P\left(AB\right)}{P\left(B\right)}\Rightarrow P\left(B\right)=\dfrac{P\left(AB\right)}{P\left(A\mid B\right)}=\dfrac{0{,}2}{0{,}3}=\dfrac{2}{3}$.
}
\end{ex}


