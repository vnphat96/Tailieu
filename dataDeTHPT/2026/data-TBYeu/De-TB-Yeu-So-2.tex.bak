\begin{ex}
	\immini[thm]
	{An đã tạo ra một cầu thang $3$ bậc bằng $18$ que tăm như hình minh họa. Vậy An cần thêm bao nhiêu que tăm để hoàn thành một cầu thang $5$ bậc?
	\shortans[]{22}
	}
	{
	\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round]
		
		% 1. Vẽ các đường ngang
		\draw[thick] (0,0) -- (3,0);
		\draw[thick] (0,1) -- (3,1);
		\draw[thick] (0,2) -- (2,2);
		\draw[thick] (0,3) -- (1,3);
		
		% 2. Vẽ các đường dọc
		\draw[thick] (0,0) -- (0,3);
		\draw[thick] (1,0) -- (1,3);
		\draw[thick] (2,0) -- (2,2);
		\draw[thick] (3,0) -- (3,1);
		
		% 3. Chấm điểm 1.5pt tại các giao điểm (đỉnh của các ô vuông)
		\foreach \x/\y in {
			0/0, 1/0, 2/0, 3/0, 
			0/1, 1/1, 2/1, 3/1, 
			0/2, 1/2, 2/2, 
			0/3, 1/3%
		} {
			\fill (\x,\y) circle (1.5pt);
		}
		
	\end{tikzpicture}
	}
	\loigiai{
		Cầu thang $1$ bậc cần $4$ tăm.\\
		Cầu thang $2$ bậc cần $10$ tăm.\\
		Để đi từ cầu thang $1$ bậc đến $2$ bậc cần thêm $6$ tăm và để đi từ cầu thang $2$ bậc đến $3$ bậc cần thêm $8$ tăm.\\
		Áp dụng mô hình này, để đi từ cầu thang $3$ bậc đến $4$ bậc cần thêm $10$ tăm và để đi từ cầu thang $4$ bậc đến $5$ bậc cần thêm $12$ tăm.\\
		Vậy bạn An cần thêm là $10+12=22$ tăm.
	}
\end{ex}

\begin{ex}
	\immini[thm]
	{Cho $(H)$ là hình phẳng được tô đậm trong hình vẽ và được giới hạn bởi các đường có phương trình $y=\dfrac{10}{3}x-x^2$, $y=\hoac{&-x&&\text{khi }x\le1\\&x-2&&\text{khi }x>1}$. Diện tích của $(H)$ bằng bao nhiêu?}
	{\begin{tikzpicture}[scale=0.75, font=\footnotesize, line join=round, line cap=round, >=stealth]
			
			% 1. Khai báo các điểm giao cắt và điểm đặc biệt
			\path 
			(0,0) coordinate (O)
			(1,-1) coordinate (V)
			(3,1) coordinate (I)
			;
			
			% 2. Tô kín vùng giới hạn bởi parabol và hàm trị tuyệt đối (Tô màu xám)
			\fill[gray,opacity=.3] (0,0) plot[domain=0:3, samples=100] (\x, {10*\x/3 - \x*\x}) -- (3,1) -- (1,-1) -- cycle;
			
			% 3. Vẽ các trục tọa độ
			\draw[->, thick] (-1.5,0) -- (4.5,0) node[below] {$x$};
			\draw[->, thick] (0,-1.5) -- (0,3.5) node[left] {$y$};
			
			% 4. Vẽ các đồ thị (đường nét thick, màu cyan theo quy định 25)
			% Parabol y = 10x/3 - x^2
			\draw[black, domain=-0.4:3.5, samples=100] plot (\x, {10*\x/3 - \x*\x});
			
			% Hàm trị tuyệt đối y = |x-1| - 1
			\draw[black] (-1.2, 1.2) -- (1, -1) -- (4.2, 2.2);
			
			% 5. Vẽ các đường gióng (nét đứt)
			\draw[dashed, thin] (1,0) -- (1,-1) -- (0,-1);
			\draw[dashed, thin] (3,0) -- (3,1);
			
			% 6. Ghi chú các giá trị trên trục
			\node[below left] at (0,0) {$O$};
			\node[above right] at (1,0) {$1$};
			\node[below right] at (2,0) {$2$}; 
			\node[below] at (3,0) {$3$};
			\node[below right] at (0,-1) {$-1$};
			
			%% 7. Chấm điểm 1pt màu đỏ tại các điểm đặc biệt
			%\fill[red] (O) circle (1pt);
			%\fill[red] (V) circle (1pt);
			%\fill[red] (I) circle (1pt);
			
	\end{tikzpicture}}
	\shortans[]{6,5}
	\loigiai{
		Hoành độ giao điểm của hai đồ thị hàm số $y=-x$ và $y=x-2$ là $-x=x-2\Leftrightarrow x=1$.\\
		Diện tích hình phẳng cần tính là
		\begin{eqnarray*}
S&=&\displaystyle\int \limits_{0}^{1}\left(\dfrac{10}{3}x-x^2+x\right)\mathrm{\,d}x+\displaystyle\int \limits_{1}^{3}\left(\dfrac{10}{3}x-x^2-x+2\right)\mathrm{\,d}x\\&=&\displaystyle\int \limits_{0}^{1}\left(\dfrac{13}{3}x-x^2\right)\mathrm{\,d}x+\displaystyle\int \limits_{1}^{3}\left(\dfrac{7}{3}x-x^2+2\right)\mathrm{\,d}x\\&=&\left.\left(\dfrac{13}{6}x^2-\dfrac{x^3}{3}\right)\right|_{0}^{1}+\left.\left(\dfrac{7}{6}x^2-\dfrac{x^3}{3}+2x\right)\right|_{1}^{3}\\&=&\dfrac{13}{2}.
\end{eqnarray*}
	}
\end{ex}

\begin{ex}
	Cho đồ thị hàm số $f(x)=5x-1+\dfrac{8}{x-1}$ có tâm đối xứng là $I(a;b)$. Giá trị của biểu thức $C=a+3b$ là bao nhiêu?
	\shortans[]{13}
	\loigiai{
		Tiệm cận đứng: $x=1$.\\
		Ta có $\lim \limits_{x\rightarrow\pm\infty}[f(x)-(5x-1)]=\lim \limits_{x\rightarrow\pm\infty}\dfrac{8}{x-1}=0$. \\
		Suy ra tiệm cận xiên là $y=5x-1$.\\
		Đồ thị hàm số đã cho có tâm đối xứng là giao điểm của tiệm cận đứng và tiệm cận xiên nên $I(1;4)$.\\
		Suy ra $a=1$, $b=4$.\\ 
		Vậy $C=1+3\cdot 4=13$.
	}
\end{ex}

\begin{ex}
	Số khán giả đến xem buổi biểu diễn âm nhạc ngoài trời phụ thuộc vào thời tiết. Giả sử, nếu trời không mưa thì xác suất để bán hết vé là $0{,}85$; còn nếu trời mưa thì xác suất để bán hết vé là $0{,}45$. Dự báo thời tiết cho thấy xác suất để trời mưa vào buổi biểu diễn là $0{,}6$. Tính xác suất để nhà tổ chức sự kiện bán hết vé.
	\shortans[]{0,61}
	\loigiai{
		Xét hai biến cố $A$: \lq\lq Nhà tổ chức sự kiện bán hết vé\rq\rq\, và $B$: \lq\lq Trời mưa vào buổi biểu diễn\rq\rq.\\
		Khi đó, ta có $\mathrm{P}(B)=0{,}6$; $\mathrm{P}(\overline{B})=1-\mathrm{P}(B)=0{,}4$; $\mathrm{P}(A|B)=0{,}45$; $\mathrm{P}(A|\overline{B})=0{,}85$.\\
		Áp dụng công thức xác suất toàn phần, ta có
		\[\mathrm{P}(A)=\mathrm{P}(B)\cdot \mathrm{P}(A|B)+\mathrm{P}(\overline{B})\cdot \mathrm{P}(A|\overline{B})=0{,}6\cdot 0{,}45+0{,}4\cdot 0{,}85=0{,}61.\]
	}
\end{ex}

\begin{ex}
	Một chiếc khinh khí cầu bay lên từ địa điểm cho trước. Sau khoảng thời gian bay, chiếc khinh khí cầu cách địa điểm xuất phát $2{,}5$\,km về hướng nam và $1{,}7$\,km về hướng đông, đồng thời cách mặt đất là $0{,}6$\,km. Chọn hệ trục toạ độ $Oxyz$ với gốc $O$ đặt tại điểm xuất phát của chiếc khinh khí cầu, mặt phẳng $(Oxy)$ trùng với mặt đất, trục $Ox$ hướng về nam, trục $Oy$ hướng về phía đông và trục $Oz$ hướng thẳng đứng lên trời, đơn vị đo lấy theo kilomet. Tính khoảng cách từ địa điểm xuất phát đến địa điểm hiện tại của khinh khí cầu.
	\shortans[]{3,08}
	\loigiai{
		Với hệ trục toạ độ đã chọn thì vị trí hiện tại của khinh khí cầu là $A(2{,}5;1{,}7;0{,}6)$.\\
		Khi đó khoảng cách từ địa điểm xuất phát đến địa điểm hiện tại của khinh khí cầu là
		\[OA=\sqrt{2{,}5^2+1{,}7^2+0{,}6^2}\approx3{,}08\,\text{(km)}.\]
	}
\end{ex}

\begin{ex}
	Giá đỡ ba chân như hình đang được mở sao cho ba gốc chân cách đều nhau một khoảng cách bằng $80$\,cm. Tính chiều cao của giá đỡ, biết các chân của giá đỡ dài $100$\,cm.
	\shortans[]{88,7}
	\loigiai{
		Chiều cao của giá đỡ là
		\[h=\sqrt{100^2-\left(\dfrac{\sqrt{3}}{3}\cdot 80\right)^2}\approx88{,}7\,\text{(cm)}.\]
	}
\end{ex}


\Closesolutionfile{ans}
