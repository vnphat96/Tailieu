\begin{ex}
	Cho hai biến cố $A$ và $B$ có $\mathrm{P}(A)=0{,}3$; $\mathrm{P}(B)=0{,}6$; $\mathrm{P}(A\cap B)=0{,}2$. Xác suất $\mathrm{P}(A|B)$ là
	\choice
	{$\dfrac{2}{3}$}
	{\True $\dfrac{1}{3}$}
	{$\dfrac{1}{6}$}
	{$\dfrac{1}{2}$}
	\loigiai{
		Theo định nghĩa xác suất có điều kiện ta có $\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)}=\dfrac{0{,}2}{0{,}6}=\dfrac{1}{3}$.
	}
\end{ex}

\begin{ex}
	Cho $a$ là số thực dương tùy ý. Mệnh đề nào sau đây đúng?
	\choice
	{$\log _{3}\dfrac{3}{a^2}=3-\dfrac{1}{2}\log _{3}a$}
	{\True $\log _{3}\dfrac{3}{a^2}=1-2\log _{3}a$}
	{$\log _{3}\dfrac{3}{a^2}=3-2\log _{3}a$}
	{$\log _{3}\dfrac{3}{a^2}=1+2\log _{3}a$}
	\loigiai{
		Với $a>0$, ta có $\log _{3}\dfrac{3}{a^2}=\log _{3}3-\log _{3}a^2=1-2\log _{3}a$.
	}
\end{ex}

\begin{ex}
	Doanh thu bán hàng trong $20$ ngày được lựa chọn ngẫu nhiên của một cửa hàng được ghi lại ở bảng sau
	\begin{longtable}{|l|c|c|c|c|c|}
		\hline
		Doanh thu & $[5;7)$ & $[7;9)$ & $[9;11)$ & $[11;13)$ & $[13;15)$ \\
		\hline
		Số ngày & $7$ & $7$ & $2$ & $3$ & $1$ \\
		\hline
	\end{longtable}
	Trung vị của mẫu số liệu trên thuộc nhóm nào dưới đây?
	\choice
	{$[11;13)$}
	{$[13;15)$}
	{\True $[9;11)$}
	{$[7;9)$}
	\loigiai{
		Cỡ mẫu là $20$.\\
		Số trung vị là $M_{e}=\dfrac{x_{9}+x_{10}}{2}$.\\
		Nhóm chứa trung vị của mẫu số liệu trên là $[9;11)$.
	}
\end{ex}

\begin{ex}
	Trong không gian $Oxyz$, mặt cầu $(S)\colon x^2+y^2+z^2-2x-4y+6z+10=0$ có tâm và bán kính lần lượt là
	\choice
	{$I(-1;-2;3)$, $R=4$}
	{$I(-1;-2;3)$, $R=2$}
	{\True $I(1;2;-3)$, $R=2$}
	{$I(1;2;-3)$, $R=4$}
	\loigiai{
		Ta có $(S)\colon x^2+y^2+z^2-2x-4y+6z+10=0\Leftrightarrow (x-1)^2+(y-2)^2+(z+3)^2=4$.\\
		Vậy mặt cầu $(S)$ có tâm là $I(1;2;-3)$, bán kính $R=2$.
	}
\end{ex}

\begin{ex}
	Nghiệm của phương trình $\sin x+1=0$ là
	\choice
	{$x=k\pi\ (k\in \mathbb{Z})$}
	{$x=\dfrac{\pi}{2}+k2\pi\ (k\in \mathbb{Z})$}
	{$x=-\dfrac{\pi}{2}+k\pi\ (k\in \mathbb{Z})$}
	{\True $x=-\dfrac{\pi}{2}+k2\pi\ (k\in \mathbb{Z})$}
	\loigiai{
		Ta có $\sin x+1=0\Leftrightarrow \sin x=-1\Leftrightarrow x=-\dfrac{\pi}{2}+k2\pi\ (k\in \mathbb{Z})$.
	}
\end{ex}

\begin{ex}
	Nếu $\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x=3$ và $\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x=6$ thì $\displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x$ bằng
	\choice
	{\True $3$}
	{$-3$}
	{$18$}
	{$9$}
	\loigiai{
		Ta có $\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x=\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x+\displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x\Leftrightarrow \displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x=\displaystyle\int \limits_{0}^{5}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{0}^{2}f(x)\mathrm{\,d}x=6-3=3$.\\
		Vậy $\displaystyle\int \limits_{2}^{5}f(x)\mathrm{\,d}x=3$.
	}
\end{ex}

\begin{ex}
	Biết rằng hàm số $f(x)=x^3-3x^2-9x+28$ đạt giá trị nhỏ nhất trên đoạn $[0;4]$ tại $x_0$. Tính $P=x_0+2025$.
	\choice
	{\True $2028$}
	{$2025$}
	{$2029$}
	{$2026$}
	\loigiai{
		Ta có $f(0)=28$; $f(3)=1$; $f(4)=8$.\\
		Có $f'(x)=3x^2-6x-9$, $f'(x)=0\Leftrightarrow 3x^2-6x-9=0\Leftrightarrow \hoac{&x=-1\notin[0;4]\\&x=3\in [0;4]}$.\\
		Hàm số đạt giá trị nhỏ nhất trên đoạn $[0;4]$ tại $x_0=3$.\\
		Vậy $P=x_0+2025=3+2025=2028$.
	}
\end{ex}

\begin{ex}
	Cho hàm số $y=f(x)$ có bảng biến thiên như hình vẽ bên. Hàm số $y=f(x)$ nghịch biến trên khoảng nào trong các khoảng sau đây?
	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[nocadre=false, lgt=1.0, espcl=2.5, deltacl=0.5]
			{$x$/0.6, $y'$/0.6, $y$/2.5}
			{$-\infty$, $-1$, $0$, $1$, $+\infty$}
			\tkzTabLine{ , +, 0, -, d, -, 0, +, }
			\tkzTabVar{-/ $-\infty$, +/ , -D+/ $-\infty$ / $+\infty$, -/ , +/ $+\infty$}
		\end{tikzpicture}
	\end{center}
	\choice
	{\True $(-1;0)$}
	{$(0;+\infty)$}
	{$(-\infty;-1)$}
	{$(-1;1)$}
	\loigiai{
		Trong khoảng $(-1;0)$ đạo hàm $y'<0$ nên hàm số nghịch biến trên khoảng $(-1;0)$.
	}
\end{ex}

\begin{ex}
	Nghiệm của phương trình $\log _{3}x=\dfrac{1}{3}$ là
	\choice
	{$x=\dfrac{1}{27}$}
	{\True $x=\sqrt[3]{3}$}
	{$x=27$}
	{$x=\dfrac{1}{3}$}
	\loigiai{
		Ta có $\log _{3}x=\dfrac{1}{3}\Leftrightarrow \heva{&x>0\\&x=3^{\tfrac{1}{3}}}\Leftrightarrow x=\sqrt[3]{3}$.
	}
\end{ex}

\begin{ex}
	Biết $f(x)$ có một nguyên hàm là $17^x$. Xác định biểu thức $f(x)$.
	\choice
	{$f(x)=17^x\ln 17+C$}
	{\True $f(x)=17^x\ln 17$}
	{$f(x)=\dfrac{17^x}{\ln 17}$}
	{$f(x)=x\cdot 17^{x-1}$}
	\loigiai{
		Ta có $(17^x)'=17^x\ln 17$ nên $f(x)=17^x\ln 17$.
	}
\end{ex}

\begin{ex}
	Cho hình chóp $S.ABCD$ có đáy $ABCD$ là tứ giác lồi và $SA\perp (ABCD)$. Góc giữa $SB$ và mặt phẳng $(ABCD)$ là
	\choice
	{$\widehat{SAB}$}
	{\True $\widehat{SBA}$}
	{$\widehat{SCA}$}
	{$\widehat{SDA}$}
	\loigiai{
		Ta có $SB\cap (ABCD)=\{B\}$ và $SA\perp (ABCD)\Rightarrow (SB,(ABCD))=\widehat{SBA}$.
	}
\end{ex}

\begin{ex}
	Trong các dãy số được cho dưới đây, dãy số nào là cấp số cộng?
	\choice
	{$u_n=\dfrac{9}{2^n}$}
	{\True $u_n=9-2n$}
	{$u_n=9\cdot 2^n$}
	{$u_n=9-2^n$}
	\loigiai{
		Xét dãy số $u_n=9-2n$.\\
		Ta có $u_{n+1}-u_n=9-2(n+1)-(9-2n)=-2$.\\
		Suy ra dãy số $u_n=9-2n$ là cấp số cộng.
	}
\end{ex}


