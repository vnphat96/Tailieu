\begin{ex}
	Một nhà máy có hai phân xưởng $X$ và $Y$ cùng sản xuất một loại sản phẩm. Phân xưởng $X$ sản xuất $60\%$ và phân xưởng $Y$ sản xuất $40\%$ tổng số sản phẩm của cả nhà máy. Tỉ lệ phế phẩm của phân xưởng $X$, phân xưởng $Y$ lần lượt là $10\%$ và $5\%$. Lấy ngẫu nhiên một sản phẩm trong kho hàng của nhà máy.
	\choiceTF
	{Giả sử đã lấy được phế phẩm, xác suất phế phẩm đó do phân xưởng $Y$ sản xuất bằng $75\%$}
	{Xác suất lấy được phế phẩm là $10\%$}
	{Xác suất lấy được sản phẩm phẩm tốt, biết sản phẩm đó do phân xưởng $X$ sản xuất bằng $95\%$}
	{\True Nếu lấy được sản phẩm tốt, khả năng sản phẩm đó do phân xưởng $X$ sản xuất cao hơn khả năng sản phẩm đó do phân xưởng $Y$ sản xuất}
	\loigiai{
		\begin{itemchoice}
			\itemch Xét phép thử lấy ngẫu nhiên một sản phẩm trong kho hàng của nhà máy.\\
			Gọi $A$ là biến cố \lq\lq Lấy được sản phẩm do phân xưởng $X$ sản xuất\rq\rq.\\
			$\overline{A}$ là biến cố \lq\lq Lấy được sản phẩm do phân xưởng $Y$ sản xuất\rq\rq.\\
			$B$ là biến cố \lq\lq Lấy được phế phẩm\rq\rq.\\
			$\overline{B}$ là biến cố \lq\lq Lấy được sản phẩm tốt\rq\rq.\\
			Theo bài ra ta có $\mathrm{P}(A)=60\%$, $\mathrm{P}(\overline{A})=40\%$, $\mathrm{P}(B|A)=10\%$, $\mathrm{P}(B|\overline{A})=5\%$.\\
			Giả sử đã lấy được phế phẩm, xác suất phế phẩm đó do phân xưởng $Y$ sản xuất là xác suất có điều kiện $\mathrm{P}(\overline{A}|B)$. Ta có $\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}(B|A)}{\mathrm{P}(B)}=\dfrac{60\%\cdot 10\%}{8\%}=75\%$, suy ra $\mathrm{P}(\overline{A}|B)=25\%$. 
			\itemch Xác suất lấy được phế phẩm là $\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}(B|A)+\mathrm{P}(\overline{A})\cdot \mathrm{P}(B|\overline{A})=60\%\cdot 10\%+40\%\cdot 5\%=8\%$. 
			\itemch Xác suất lấy được sản phẩm tốt, biết sản phẩm đó do phân xưởng $X$ sản xuất là xác suất có điều kiện $\mathrm{P}(\overline{B}|A)=1-\mathrm{P}(B|A)=90\%$. 
			\itemch Ta có $\mathrm{P}(\overline{B})=1-\mathrm{P}(B)=1-8\%=92\%$; $\mathrm{P}(\overline{B}|A)=90\%$; $\mathrm{P}(\overline{B}|\overline{A})=1-\mathrm{P}(B|\overline{A})=1-5\%=95\%$.\\
			Nếu lấy được sản phẩm tốt thì xác suất sản phẩm đó do phân xưởng $X$ sản xuất là $\mathrm{P}(A|\overline{B})=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}(\overline{B}|A)}{\mathrm{P}(\overline{B})}=\dfrac{60\%\cdot 90\%}{92\%}=\dfrac{27}{46}$.\\
			Xác suất sản phẩm đó do phân xưởng $Y$ sản xuất là $\mathrm{P}(\overline{A}|\overline{B})=\dfrac{\mathrm{P}(\overline{A})\cdot \mathrm{P}(\overline{B}|\overline{A})}{\mathrm{P}(\overline{B})}=\dfrac{40\%\cdot 95\%}{92\%}=\dfrac{19}{46}$.\\
			Vì $\dfrac{27}{46}>\dfrac{19}{46}$ nên nếu lấy được sản phẩm tốt, khả năng sản phẩm đó do phân xưởng $X$ sản xuất cao hơn. 
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Trong không gian $Oxyz$, cho mặt cầu $(S)$ có phương trình $(x-2)^2+(y+1)^2+z^2=9$.
	\choiceTF
	{\True $(S)$ có tâm $I(2;-1;0)$ và bán kính $R=3$}
	{\True $(S)$ cắt trục $Oz$ tại các điểm có tọa độ $(0;0;2)$ và $(0;0;-2)$}
	{Điểm $M(1;-2;4)$ nằm trong mặt cầu $(S)$}
	{$(S)$ đi qua gốc tọa độ $O$}
	\loigiai{
		\begin{itemchoice}
			\itemch Mặt cầu $(S)\colon (x-a)^2+(y-b)^2+(z-c)^2=R^2$ có tâm $I(a;b;c)$ và bán kính $R$. Suy ra $(S)$ có tâm $I(2;-1;0)$ và bán kính $R=3$.
			\itemch Gọi $A(0;0;a)$ là giao điểm của $(S)$ với trục $Oz$.\\ 
			Vì $A\in (S)$ nên $(0-2)^2+(0+1)^2+a^2=9\Leftrightarrow a^2=4\Leftrightarrow \hoac{&a=-2\\&a=2}$. \\
			Vậy $(S)$ cắt trục $Oz$ tại các điểm có tọa độ $(0;0;2)$ và $(0;0;-2)$.
			\itemch Vì $IM=\sqrt{(1-2)^2+(-2-(-1))^2+(4-0)^2}=3\sqrt{2}>R=3$ nên $M$ nằm ngoài $(S)$.
			\itemch Thay $x=y=z=0$ vào phương trình của $(S)$, được $(0-2)^2+(0+1)^2+0^2=9$ (vô lí).\\ 
			Vậy $(S)$ không đi qua gốc tọa độ $O$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Một vật chuyển động theo phương trình $s(t)=-\dfrac{1}{3}t^3+6t^2$ với $t$ tính bằng giây (s) và $s(t)$ được tính bằng mét (m) là quãng đường vật di chuyển được.
	\choiceTF
	{\True Sau $3$ giây vật đi được quãng đường dài $45$\,m}
	{\True Vận tốc lớn nhất của vật trong $8$ giây đầu tiên là $36$\,m/s}
	{\True Vận tốc của vật được tính bởi công thức $v(t)=-t^2+12t$}
	{Gia tốc tức thời của vật tại thời điểm $t=7$ giây bằng $2$\,m/s$^2$}
	\loigiai{
		\begin{itemchoice}
			\itemch Thay $t=3$, ta có quãng đường vật đi được là $s(3)=-\dfrac{1}{3}\cdot 3^3+6\cdot 3^2=45$\,(m).
			\itemch Ta có $v(t)=-t^2+12t=-(t-6)^2+36$. Do $-(t-6)^2\le0$, $\forall t\in [0;8]$ nên $v(t)\le36$, $\forall t\in [0;8]$. Dấu \lq\lq=\rq\rq\, xảy ra khi $t=6$\,(s). Suy ra vận tốc lớn nhất của vật trong $8$ giây đầu tiên là $36$\,m/s.
			\itemch Vận tốc tức thời của vật là $v(t)=s'(t)=-t^2+12t$.
			\itemch Gia tốc tức thời của vật là $a(t)=v'(t)=-2t+12$. Thay $t=7$ được $a(7)=-2\cdot 7+12=-2$\,(m/s$^2$).
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	\immini[thm]
	{Một vật chuyển động với vận tốc $v(t)$ được cho bởi đồ thị như hình vẽ.
		\choiceTF
		{\True Quãng đường vật đi được trong $4$ giây đầu tiên là $3$\,m}
		{\True Quãng đường vật đi được từ lúc $t=1$\,(s) đến lúc $t=3$\,(s) là $2$\,m}
		{\True Hàm số $v(t)$ được cho bởi công thức $v(t)=\heva{&t&&\text{khi }0\le t<1\\&1&&\text{khi }1\le t<3\\&-t+4&&\text{khi }3\le t\le4}$}
		{Vận tốc của vật tại thời điểm $t=1$\,(s) là $3$\,m/s}}
	{\begin{tikzpicture}[scale=1, font=\footnotesize,line join=round, line cap=round, >=stealth]
			% 1. Khai báo điểm
			% Tọa độ được phóng to (x nhân 1.5, y nhân 2) để hình có tỉ lệ đẹp, giống với ảnh gốc
			\path 
			(0,0) coordinate (O)
			(1.5,0) coordinate (t1)
			(4.5,0) coordinate (t3)
			(6.0,0) coordinate (t4)
			(0,2.0) coordinate (v1)
			(1.5,2.0) coordinate (A)
			(4.5,2.0) coordinate (B)
			;
			
			% 2. Vẽ các trục tọa độ
			\draw[->, thick] (-0.8,0) -- (7.2,0) node[below] {$t$ (s)};
			\draw[->, thick] (0,-0.8) -- (0,3.5) node[right] {$v$ (m/s)};
			
			% 3. Vẽ đồ thị chính
			\draw (O) -- (A) -- (B) -- (t4);
			
			% 4. Vẽ các đường gióng tọa độ (nét đứt)
			\draw[dashed, thin] (v1) -- (A) -- (t1);
			\draw[dashed, thin] (B) -- (t3);
			
			% 5. Chấm điểm 1.5pt và điền các giá trị trên trục
			\fill (O) circle (1.5pt) node[below left] {$O$};
			\fill (t1) circle (1.5pt) node[below=1mm] {$1$};
			\fill (t3) circle (1.5pt) node[below=1mm] {$3$};
			\fill (t4) circle (1.5pt) node[below=1mm] {$4$};
			\fill (v1) circle (1.5pt) node[left=1mm] {$1$};
	\end{tikzpicture}}
	\loigiai{
		\begin{itemchoice}
			\itemch Quãng đường vật đi được trong $4$ giây đầu tiên là \[s=\displaystyle\int \limits_{0}^{4}v(t)\mathrm{\,d}t=\displaystyle\int \limits_{0}^{1}t\mathrm{\,d}t+\displaystyle\int \limits_{1}^{3}1\mathrm{\,d}t+\displaystyle\int \limits_{3}^{4}(4-t)\mathrm{\,d}t=\left.\left(\dfrac{t^2}{2}\right)\right|_{0}^{1}+\left.t\right|_{1}^{3}+\left.\left(4t-\dfrac{t^2}{2}\right)\right|_{3}^{4}=\dfrac{1}{2}+2+\dfrac{1}{2}=3\,\text{(m)}.\]
			\itemch Quãng đường vật đi được từ lúc $t=1$\,(s) đến lúc $t=3$\,(s) là $s=\displaystyle\int \limits_{1}^{3}v(t)\mathrm{\,d}t=\displaystyle\int \limits_{1}^{3}1\mathrm{\,d}t=2$\,(m).
			\itemch Dựa vào đồ thị hàm số, ta xác định được phương trình của $v(t)$ trên từng khoảng.
			\itemch Dựa vào đồ thị hàm số, ta thấy vận tốc của vật tại thời điểm $t=1$\,(s) là $1$\,m/s.
		\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


