\begin{ex}
	Số lượng xe máy điện bán được của một cửa hàng bán xe máy điện trong địa bàn thành phố Vinh trong tháng thứ $x$ được tính theo công thức $f(x)=50-\dfrac{30}{2+x}$, trong đó $x\ge1$. Khi $x$ càng lớn thì số lượng xe bán ra càng tiến gần đến mức bao nhiêu xe một tháng?
	\shortans[]{50}
	\loigiai{
		Ta có $\lim _{x\to+\infty}f(x)=\lim _{x\to+\infty}\left(50-\dfrac{30}{2+x}\right)=50$\\
		Số lượng xe máy bán ra 50 xe một tháng.
	}
\end{ex}

\begin{ex}
	Một doanh nghiệp có $45\%$ nhân viên là nữ. Tỉ lệ nhân viên nữ và tỉ lệ nhân viên nam mua bảo hiểm nhân thọ lần lượt là $7\%$ và $5\%$. Chọn ngẫu nhiên một nhân viên của doanh nghiệp, Tính xác suất nhân viên được chọn có mua bảo hiểm nhân thọ (làm tròn kết quả đến hàng phần trăm).
	\shortans[]{0,06}
	\loigiai{
		Gọi: $A\colon$ \lq\lq nhân viên được chọn là nữ\rq\rq ; $B\colon$ \lq\lq nhân viên được chọn mua bảo hiểm nhân thọ\rq\rq\\
		Ta có: $\mathrm{P}(A)=0{,}45$; $\mathrm{P}(B|A)=0{,}07$; $\mathrm{P}(B|\overline{A})=0{,}05$. Suy ra $\mathrm{P}(\overline{A})=0{,}55$ \\
		Áp dụng công thức xác suất toàn phần: \\
		$\mathrm{P}(B)=\mathrm{P}(A)\mathrm{P}(B|A)+\mathrm{P}(\overline{A})\mathrm{P}(B|\overline{A})=0{,}45\cdot 0{,}07+0{,}55\cdot 0{,}05=0{,}059\approx0{,}06$ \\
		Xác suất chọn được nhân viên có mua bảo hiểm nhân thọ là $0{,}06$.
	}
\end{ex}

\begin{ex}
	Một ô tô đang chạy với vận tốc $20$ m/s thì người lái xe phát hiện có hàng rào chắn ngang đường ở phía trước cách xe $45$ m (tính từ đầu xe tới hàng rào) nên người lái đạp phanh. Từ thời điểm đó, xe chuyển động chậm dần đều với vận tốc $v(t)=-5t+20$ (m/s), trong đó $t$ là thời gian được tính từ lúc người lái đạp phanh. Khi xe dừng hẳn, khoảng cách từ xe đến hàng rào là bao nhiêu?
	\shortans[]{5}
	\loigiai{
		Xe dừng lại khi $v(t)=0\Leftrightarrow -5t+20=0\Leftrightarrow t=4$ (s). \\
		Quãng đường xe đi được kể từ lúc đạp phanh đến khi dừng lại là \\
		$\displaystyle\displaystyle\int \limits_{0}^{4}v(t)\mathrm{\,d}xt=\displaystyle\displaystyle\int \limits_{0}^{4}(-5t+20)\mathrm{\,d}xt=\left(20t-\dfrac{5t^2}{2}\right)\Bigg|_{0}^{4}=40$ m \\
		Khi xe dừng hẳn, khoảng cách từ xe đến hàng rào là: $45-40=5$ m.
	}
\end{ex}

\begin{ex}
	Có một tấm gỗ hình vuông có độ dài cạnh là $2$ m. Cắt tấm gỗ đó thành tấm gỗ có hình dạng là một tam giác vuông sao cho tổng của một cạnh tam giác vuông và cạnh huyền của tấm gỗ tam giác vuông đó bằng $1,2$ m. Hỏi cạnh huyền của tấm gỗ tam giác vuông đó bằng bao nhiêu để tam giác vuông có diện tích lớn nhất.
	\shortans[]{0,8}
	\loigiai{
		Giả sử tấm gỗ cắt có hình dạng tam giác vuông là $ABC$, $BC$ là cạnh huyền. Vì cạnh $AB$, $AC$ là như nhau nên ta có thể đặt $AB=x$, $(0<x<0,6)$ \\
		Khi đó, cạnh huyền $BC=1,2-x$ \\
		Cạnh góc vuông còn lại là: $AC=\sqrt{(1{,}2-x)^2-x^2}=\sqrt{1{,}44-2{,}4x}$ \\
		Ta có diện tích tam giác $ABC$: $S(x)=\dfrac{1}{2}x\sqrt{1{,}44-2{,}4x}$ \\
		Bài toán trở thành tìm $x$ để $S(x)$ đạt GTLN. \\
		$S'(x)=\dfrac{1}{2}\cdot \sqrt{1{,}44-2{,}4x}-\dfrac{1}{2}\cdot \dfrac{1{,}2x}{\sqrt{1{,}44-2{,}4x}}=\dfrac{1}{2}\cdot \dfrac{1{,}44-3{,}6x}{\sqrt{1{,}44-2{,}4x}}$ \\
		$S'(x)=0\Leftrightarrow 1{,}44-3{,}6x=0\Leftrightarrow x=0{,}4$\\
		Bảng biến thiên\\
		\centerline{
			\begin{tikzpicture}
				\tikzset{double style/.append style={double distance=1.5pt}}
				\tkzTabInit[nocadre=false,lgt=1.2,espcl=2.5,deltacl=0.6]
				{$x$ /0.6,$S'(x)$ /0.6,$S(x)$ /2}
				{$0$,$0{,}4$,$0{,}6$}
				\tkzTabLine{,+,$0$,-,}
				\tkzTabVar{-/,+/$S_{max}$,-/}
			\end{tikzpicture}
		}
		Suy ra $BC=1{,}2-0{,}4=0{,}8$\\
		Vậy để tấm gỗ hình tam giác có diện tích lớn nhất thì cạnh huyền có độ dài bằng $0,8$ m
	}
\end{ex}

\begin{ex}
	An đã tạo ra một cầu thang $3$ bậc bằng $18$ que tăm như hình minh họa. Vậy An cần thêm bao nhiêu que tăm để hoàn thành một cầu thang $5$ bậc?\\
	\centerline{
		\begin{tikzpicture}[quediem/.style={line width=1pt, line cap=round, shorten <=1.5pt, shorten >=1.5pt}]
			% Vẽ ngang: Cột 0(y=0,1,2,3), Cột 1(y=0,1,2), Cột 2(y=0,1)
			\foreach \x/\y in {0/{0,...,3}, 1/{0,1,2}, 2/{0,1}}
			\foreach \i in \y \draw[quediem] (\x,\i) -- ++(1,0);
			% Vẽ dọc: Hàng 0(x=0,1,2,3), Hàng 1(x=0,1,2), Hàng 2(x=0,1)
			\foreach \y/\x in {0/{0,...,3}, 1/{0,1,2}, 2/{0,1}}
			\foreach \i in \x \draw[quediem] (\i,\y) -- ++(0,1);
		\end{tikzpicture}	
	}
	\shortans[]{22}
	\loigiai{
		+ Cách 1: Chúng ta có thể thấy rằng cầu thang $1$ bậc cần $4$ tăm và cầu thang $2$ bậc cần $10$ tăm. Do đó, để đi từ cầu thang $1$ bậc đến $2$ bậc cần thêm $6$ tăm và để đi từ cầu thang $2$ bậc đến $3$ bậc cần thêm $8$ tăm. Áp dụng mô hình này, để đi từ cầu thang $3$ bậc đến $4$ bậc cần thêm $10$ tăm và để đi từ cầu thang $4$ bậc đến $5$ bậc cần thêm $12$ tăm.\\
		Vậy bạn An cần thêm là $10+12=22$ tăm.\\
		+ Cách 2: Ngoài ra, chúng ta có thể thấy với cầu thang $3$ bậc có $2\cdot [2\cdot 3+2+1]=18$ tăm. \\
		Tổng quát, chúng ta thấy rằng cầu thang có $x$ bậc có $2\cdot [2x+(x-1)+(x-2)+...+1]$ tăm. \\
		Vì vậy, đối với $x=5$ bậc, chúng ta có $2\cdot [2\cdot 5+4+3+2+1]=40$ tăm. \\
		Vậy bạn An cần thêm là $40-18=22$ tăm.
	}
\end{ex}

\begin{ex}
	\immini[thm]{Một chiếc máy bay không người lái bay lên tại một điểm. Sau một thời gian chiếc máy bay cách điểm xuất phát về phía Bắc $30km$ và phía Tây $40km$, đồng thời cách mặt đất $1{,}5km$. Chọn hệ trục tọa độ $Oxyz$, với gốc đặt tại điểm xuất phát của chiếc máy bay, mặt phẳng $Oxy$ trùng với mặt đất, trục $Ox$ hướng về phía Bắc, trục $Oy$ hướng về phía Tây, trục $Oz$ hướng thẳng đứng lên trời, đơn vị đo lấy theo kilomet. Khoảng cách của chiếc máy bay với vị trí tại điểm xuất phát gần nhất với giá trị nào dưới đây? (Làm tròn kết quả đến hàng đơn vị)
		\shortans[]{50}
	}{\begin{tikzpicture}[>=stealth,line join=round,line cap=round,font=\scriptsize,scale=1]
			\def\x{2};
			\def\y{3};
			\def\z{3};
			\def\g{-120};
			\path
			(0,0) coordinate (O)
			(\g:\x) coordinate (x)
			(0:\y) coordinate (y)
			(90:\z) coordinate (z)
			($(O)!4/5!(x)$) coordinate (A)
			($(O)!4/5!(y)$) coordinate (B)
			($(O)!4/5!(z)$) coordinate (S)
			($(A)+(B)-(O)$) coordinate (C)
			($(S)+(C)-(O)$) coordinate (D);
			\draw[-latex] (O)--(x) node[right]{$x$} node[above left]{Bắc};
			\draw[-latex] (O)--(y) node[below]{$y$} node[above left]{Tây};
			\draw[-latex] (O)--(z) node[right]{$z$};
			\draw[dashed] (S)--(D)--(C)--(A)
			(C)--(B);
			\foreach \x/\g in {O/170}\fill (\x) circle (1pt) +(\g:3mm) node {$\x$};
		\end{tikzpicture}
	}
	\loigiai{
		Với cách chọn hệ trục tọa độ như trên ta có khoảng cách so với vị trí xuất phát của máy bay là $$\sqrt{40^2+30^2+1{,}5^2}\approx50$$
	}
\end{ex}


\Closesolutionfile{ans}
