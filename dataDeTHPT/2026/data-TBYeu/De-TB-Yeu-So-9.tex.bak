\begin{ex}
	Cho hàm số $y=f(x)=\dfrac{x^2+4x-1}{x-1}$ có đồ thị là $(C)$.
	\choiceTF
	{\True Số khoảng đồng biến và nghịch biến của hàm số là bằng nhau}
	{\True Hàm số $f(x)$ đạt cực đại tại điểm có toạ độ $(-1;2)$}
	{\True Đường thẳng $x=1$ là đường tiệm cận đứng của đồ thị hàm số $f(x)$}
	{Phương trình đường tiệm cận xiên của đồ thị hàm số $f(x)$ là $y=2x+5$}
	\loigiai{Hàm số $y=\dfrac{x^2+4x-1}{x-1}$ có tập xác định $D=\mathbb{R}\setminus\{1\}$.\\
		Xét đạo hàm $y'=\dfrac{x^2-2x-3}{(x-1)^2}=0\Leftrightarrow x^2-2x-3=0\Leftrightarrow \hoac{&x=-1\\&x=3}$.
		\begin{center}
			\begin{tikzpicture}
				\tikzset{double style/.append style={double distance=1.5pt}}
				\tkzTabInit[nocadre=false,lgt=1.2,espcl=2.5,deltacl=0.6]
				{$x$ /0.6,$f'(x)$ /0.6,$f(x)$ /2}
				{$-\infty$,$-1$,$1$,$3$,$+\infty$}
				\tkzTabLine{,+,$0$,-,d,-,$0$,+,}
				\tkzTabVar{-/$-\infty$,+/$2$,-D+/$-\infty$/$+\infty$,-/$10$,+/$+\infty$}
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Đúng. Hàm số đồng biến trên các khoảng $(-\infty;-1)$ và $(3;+\infty)$ và nghịch biến trên các khoảng $(-1;1)$ và $(1;3)$
			\itemch Đúng. Đồ thị hàm số đạt cực đại tại điểm $(-1;2)$
			\itemch Đúng. Xét $\lim \limits_{x\to1^-}y=-\infty$ và $\lim \limits_{x\to1^+}y=+\infty$ nên đường thẳng $x=1$ là tiệm cận đứng của đồ thị hàm số $y=\dfrac{x^2+4x-1}{x-1}$
			\itemch Sai. Xét $\lim \limits_{x\to\infty}[y-(x+5)]=\lim \limits_{x\to\infty}\left[\dfrac{x^2+4x-1}{x-1}-(x+5)\right]=\lim \limits_{x\to\infty}\dfrac{x^2+4x-1-(x+5)(x-1)}{x-1}$\\
			$=\lim \limits_{x\to\infty}\dfrac{x^2+4x-1-(x^2+4x-5)}{x-1}=\lim \limits_{x\to\infty}\dfrac{4}{x-1}=0$ nên đường thẳng $y=x+5$ là tiệm cận xiên của đồ thị hàm số $y=\dfrac{x^2+4x-1}{x-1}$
	\end{itemchoice}}
\end{ex}

\begin{ex}
	Sau khi xuất phát, ô tô di chuyển với tốc độ $v(t)=2{,}01t-0{,}025t^2$ $(0\let\le10)$. Trong đó $v$ tính theo m/s, thời gian $t$ tính theo $s$ với $t=0$ là thời điểm xe xuất phát.
	\choiceTF
	{\True Quãng đường xe di chuyển được trong $3s$ là $8{,}82$ m}
	{\True Trong khoảng thời gian không quá $10$ s đầu, khi vận tốc đạt giá trị lớn nhất thì gia tốc của xe là $1{,}51$ m/s$^2$}
	{\True Quãng đường xe di chuyển được trong giây thứ $9$ xấp xỉ $15{,}277$ m}
	{Quãng đường xe di chuyển được tính theo công thức là $s(t)=2{,}01-0{,}05t$ $(0\let\le10)$}
	\loigiai{
		\begin{itemchoice}
			\itemch Đúng. Quãng đường xe di chuyển được trong $3s$ là $\displaystyle\displaystyle\int \limits_0^3\left(2{,}01t-0{,}025t^2\right)\mathrm{\,d}xt=8{,}82m$.
			\itemch Đúng. $v(t)=2{,}01t-0{,}025t^2(0\let\le10)\Rightarrow \max _{[0;10]}v(t)=17{,}6m/s$ khi $t=10s$.\\
			Gia tốc vật khi đó là $a(10)=v'(10)=2{,}01-0{,}05\cdot 10=1{,}51m/s^2$.
			\itemch Đúng. Quãng đường xe di chuyển được trong giây thứ $9\colon s(9)-s(8)=\displaystyle\displaystyle\int \limits_8^9(2{,}01t-0{,}025t^2)\mathrm{\,d}xt\approx15{,}277m$
			\itemch Sai. Quãng đường xe di chuyển được phải là nguyên hàm của $v$, $v'(t)=2{,}01-0{,}05t$ $(0\let\le10)$ là công thức tính gia tốc của vật.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Trong không gian $Oxyz$, cho điểm $A(1;-1;2)$ và đường thẳng $d\colon \heva{&x=1+2t\\&y=2-t&(t\in \mathbb{R}).\\&z=-1+t}$
	\choiceTF
	{\True Điểm $M(1;2;-1)$ thuộc đường thẳng $d$}
	{\True Đường thẳng $d$ có một véc-tơ chỉ phương $\vec{u}=(2;-1;1)$}
	{Đường thẳng $\Delta$ đi qua điểm $A$ và song song với đường thẳng $d$ là $\dfrac{x+1}{2}=\dfrac{y-1}{-1}=\dfrac{z+2}{1}$}
	{\True Hình chiếu vuông góc của điểm $A$ lên đường thẳng $d$ là $H(3;1;0)$
	}
	\loigiai{
		\begin{itemchoice}
			\itemch đúng. Thay tọa độ điểm $M(1;2;-1)$ vào phương trình đường thẳng $d$ ta được:\\
			$\heva{&1=1+2t\\&2=2-t\\&-1=-1+t}\Leftrightarrow t=0\Rightarrow M(1;2;-1)\in d$.
			\itemch đúng. Đường thẳng $d$ có một véc-tơ chỉ phương $\vec{u}=(2;-1;1)$.
			\itemch sai. Đường thẳng $\Delta$ qua $A$ và song song với đường thẳng $d$ nên có một véc-tơ chỉ phương\\ $\vec{u_\Delta }=\vec{u}=(2;-1;1)$.\\
			Suy ra phương trình đường thẳng $\Delta \colon \dfrac{x-1}{2}=\dfrac{y+1}{-1}=\dfrac{z-2}{1}$.
			\itemch đúng. $H$ là hình chiếu vuông góc của $A$ lên $d\Rightarrow H\in d$ nên $H(1+2t;2-t;-1+t)$.\\
			Ta có: $\vec{AH}=(2t;3-t;-3+t)$, $\vec{AH}\perp d\Rightarrow \vec{AH}\cdot \vec{u}=0\Leftrightarrow 2\cdot 2t-1\cdot (3-t)+1\cdot (-3+t)=0\Leftrightarrow t=1$.
			Vậy $H(3;1;0)$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Cho hình lập phương $ABCD.A'B'C'D'$. Đáy $ABCD$ có tâm $O$, cạnh bằng $a$. Khi đó
	\choiceTF
	{\True $AC\perp BD$}
	{\True $(A'BO)\perp (A'AO)$}
	{Thể tích khối chóp $O.A'AB$ bằng $\dfrac{a^3}{4}$}
	{Khoảng cách từ điểm $A$ tới mặt phẳng $(A'BD)$ bằng $\dfrac{a\sqrt{3}}{4}$}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[>=stealth,line join=round,line cap=round,font=\footnotesize,scale=1]
				\def\a{3};
				\def\cao{3};
				\def\g{30};
				\path
				(0,0) coordinate (B)
				(\a,0) coordinate (C)
				(\g:{\a/2}) coordinate (A)
				($(C)+(A)-(B)$) coordinate (D)
				($(A)+(90:\cao)$) coordinate (A')
				($(B)+(90:\cao)$) coordinate (B')
				($(C)+(90:\cao)$) coordinate (C')
				($(D)+(90:\cao)$) coordinate (D')
				($(A)!0.5!(C)$) coordinate (O)
				($(A')!0.6!(O)$) coordinate (H);
				\draw
				(A')--(B')--(C')--(D')--cycle (B)--(C)
				(B')--(B)--(C)--(D)--(D')--(B')
				(C)--(C');
				\draw[dashed] (A)--(D)--(C)
				(A')--(A)--(B)
				(A')--(B)--(D)
				(C)--(A)--(H)
				(A')--(O);
				\foreach \x/\g in {A/160,B/-135,C/-45,D/0,A'/135,B'/180,C'/-35,D'/45,O/-90,H/30}\fill(\x) circle (1pt) +(\g:2mm) node {$\x$};
				\foreach \x/\y/\z in {A/H/A'}{\draw pic[draw,angle radius=2mm]{right angle=\x--\y--\z};}
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Đúng.Vì $ABCD$ là hình vuông nên $AC\perp BD$.
			\itemch Đúng. Ta có $\heva{&BD\perp AC\\&BD\perp AA'}\Rightarrow BD\perp (A'AO)$\\
			Lại có $BD\subset (A'BO)\Rightarrow (A'BO)\perp (A'AO)$.
			\itemch Sai. Ta có $S_{ABO}=\dfrac{1}{4}S_{ABCD}=\dfrac{a^2}{4}$.\\
			$V_{O.A'AB}=V_{A'.ABO}=\dfrac{1}{3}\cdot S_{ABO}\cdot AA'=\dfrac{1}{3}\cdot \dfrac{a^2}{4}\cdot a=\dfrac{a^3}{12}$.
			\itemch Sai. Ta có $OA=\dfrac{1}{2}AC=\dfrac{a\sqrt{2}}{2}$. Gọi $H$ là hình chiếu vuông góc của $A$ lên $A'O$. Khi đó\\
			$AH=\dfrac{AO\cdot AA'}{\sqrt{A'A^2+OA^2}}\Rightarrow AH=\dfrac{\dfrac{a\sqrt{2}}{2}\cdot a}{\sqrt{a^2+\dfrac{2a^2}{4}}}=\dfrac{a\sqrt{3}}{3}$.\\
			Vậy $d(A,(A'BD))=\dfrac{a\sqrt{3}}{3}$.
		\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


