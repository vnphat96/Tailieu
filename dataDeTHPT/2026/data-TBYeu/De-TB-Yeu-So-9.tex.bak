	\choice
	{$\mathscr{D}=\mathbb{R}\setminus\left\{\pm\dfrac{1}{3}\right\}$}
	{$\mathscr{D}=\left(-\dfrac{1}{3};\dfrac{1}{3}\right)$}
	{$\mathscr{D}=\left(-\infty;\dfrac{1}{3}\right]\cup \left[\dfrac{1}{3};+\infty\right)$}
	{\True $\mathscr{D}=\left(-\infty;-\dfrac{1}{3}\right)\cup \left(\dfrac{1}{3};+\infty\right)$}
	\loigiai{Điều kiện: $9x^2-1>0\Leftrightarrow \hoac{&x<-\dfrac{1}{3}\\&x>\dfrac{1}{3}}$. \\
		Tập xác định $D=\left(-\infty;-\dfrac{1}{3}\right)\cup \left(\dfrac{1}{3};+\infty\right)$}
\end{ex}

\begin{ex}
	Cho hai biến cố $A$ và $B$ xung khắc, biết rằng $\mathrm{P}(B)=\dfrac{1}{5}$, $\mathrm{P}(A\cup B)=\dfrac{3}{8}$. Tính $\mathrm{P}(A)$.
	\choice
	{$\dfrac{23}{40}$}
	{$\dfrac{3}{40}$}
	{$\dfrac{8}{15}$}
	{\True $\dfrac{7}{40}$}
	\loigiai{Do hai biến cố $A$ và $B$ xung khắc nên $\mathrm{P}(A\cup B)=\mathrm{P}(A)+\mathrm{P}(B)$. \\
		$\Rightarrow \mathrm{P}(A)=\mathrm{P}(A\cup B)-\mathrm{P}(B)=\dfrac{3}{8}-\dfrac{1}{5}=\dfrac{15-8}{40}=\dfrac{7}{40}$}
\end{ex}

