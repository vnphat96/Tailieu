\begin{ex}%[2D5H1-2]
	Gieo hai con xúc xắc cân đối và đồng chất. Gọi $A$ là biến cố:\, \lq\lq Tích số chấm xuất hiện trên hai con xúc xắc là số chẵn\rq\rq, $B$ là biến cố:\, \lq\lq Có đúng một con xúc xắc xuất hiện mặt $3$ chấm\rq\rq.
	\choiceTF
	{\True $\mathrm{P}(AB)=\dfrac{1}{6}$ }
	{\True  $\mathrm{P}(B)=\dfrac{11}{36}$ }
	{ $\mathrm{P}(A\mid B)=\dfrac{5}{6}$ }
	{\True $\mathrm{P}\left(\overline{A}\mid B\right)=\dfrac{4}{11}$ }
	\loigiai{
		\begin{itemchoice}
			\itemch $n(\Omega)=6\cdot 6=36$.\\
			Ta có $AB=\{(3,2);(3,4);(3,6);(2,3);(4,3);(6,3)\}\Rightarrow n(AB)=6$.\\
			Do đó $\mathrm{P}(AB)=\dfrac{6}{36}=\dfrac{1}{6}$.
			\itemch Ta có $\overline{B}=\{(i;j)\mid i,j\in \{1,2,4,5,6\}\}\Rightarrow n\left(\overline{B}\right)=5\cdot 5=25\Rightarrow n(B)=36-n\left(\overline{B}\right)=11$.\\
			Do đó 	$\mathrm{P}(B)=\dfrac{11}{36}$.
			\itemch
			Ta có $\mathrm{P}(A\mid B)=\dfrac{\mathrm{P}(AB)}{\mathrm{P}(B)}=\dfrac{\frac{1}{6}}{\frac{11}{36}}=\dfrac{6}{11}$.
			\itemch
			Ta có $\overline{A}B=\{(3,1);(3,5);(1,3);(5,3)\}\Rightarrow n\left(\overline{A}B\right)=4$.\\
			Do đó $\mathrm{P}\left(\overline{A}\mid B\right)=\dfrac{n\left(\overline{A}B\right)}{n(B)}=\dfrac{4}{11}$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2H5V2-3]
	Trong không gian $Oxyz$, cho điểm $A(4;-1;3)$ và đường thẳng $d\colon \dfrac{x-1}{2}=\dfrac{y+1}{-1}=\dfrac{z-3}{1}$.
	\choiceTF
	{\True Hình chiếu vuông góc của $A$ xuống đường thẳng $d$ có toạ độ là $H(3;-2;4)$}
	{Gọi $H$ là hình chiếu vuông góc của $A$ xuống đường thẳng $d$ khi đó $AH=\sqrt{29}$}
	{\True Điểm đối xứng với điểm $A$ qua đường thẳng $d$ có toạ độ là $M(2;-3;5)$}
	{Gọi $M$ là điểm đối xứng với điểm $A$ qua đường thẳng $d$ khi đó $OM=\sqrt{30}$ với $O$ là gốc toạ độ}
	\loigiai{
		Gọi $H$ là hình chiếu của $A$ lên đường thẳng $d$ ta có $H(1+2t;-1-t;3+t)\Rightarrow \overrightarrow{AH}=(-3+2t;-t;t)$.\\
		$d$ có một vectơ chỉ phương $\vec{u}=(2;-1;1)$.\\
		Ta có $\overrightarrow{AH}\perp \vec{u}\Leftrightarrow \overrightarrow{AH}\cdot \vec{u}=0\Leftrightarrow 2(-3+2t)+t+t=0\Leftrightarrow t=1\Rightarrow H(3;-2;4)$.\\
		Gọi $M$ là điểm đối xứng của $A$ qua $d$ thì $M$ là điểm đối xứng của $A$ qua $H$ nên
		$$\heva{&x_M=2x_H-x_A=2\\&y_M=2y_H-y_A=-3\\&z_M=2z_H-z_A=5}\Rightarrow M(2;-3;5).$$
		Khi đó ta có
		\begin{itemchoice}
			\itemch Vì hình chiếu vuông góc của $A$ xuống đường thẳng $d$ có toạ độ là $H(3;-2;4)$.
			\itemch Ta có $\overrightarrow{AH}=(1;1;1)\Rightarrow AH=\sqrt{3}$.
			\itemch Vì điểm đối xứng với điểm $A$ qua đường thẳng $d$ có toạ độ là $M(2;-3;5)$.
			\itemch Vì điểm đối xứng với điểm $A$ qua đường thẳng $d$ có toạ độ là \[M(2;-3;5)\Rightarrow \overrightarrow{OM}=(2;-3;5)\Rightarrow OM=\sqrt{38}.\]
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D1V3-6]
	Sau khi xuất phát, ô tô di chuyển với tốc độ $v(t)=2{,}01t-0{,}025t^2$ ($0\let\le10$). Trong đó $v$ tính theo m/s, thời gian $t$ tính theo s với $t=0$ là thời điểm xe xuất phát.
	\choiceTF
	{Quãng đường xe di chuyển được tính theo công thức là $s(t)=2{,}01-0{,}05t$ ($0\let\le10$)}
	{\True Quãng đường xe di chuyển được trong $3$ s là $8{,}82$ m}
	{\True Quãng đường xe di chuyển được trong giây thứ $9$ xấp xỉ $15{,}277$ m}
	{\True Trong khoảng thời gian không quá $10$ s đầu, khi vận tốc đạt giá trị lớn nhất thì gia tốc của xe là $1{,}51$ m/s$^2$}
	\loigiai{
		\begin{itemchoice}
			\itemch	Quãng đường xe di chuyển được phải là nguyên hàm của $v$, $v'(t)=2{,}01-0{,}05t$ ($0\let\le10$) là công thức tính gia tốc của vật.
			\itemch	Quãng đường xe di chuyển được trong $3$ s là
			$$\displaystyle\int \limits_0^3(2{,}01t-0{,}025t^2)\mathrm{\,d}t=8{,}82\text{ m.}$$
			\itemch  Quãng đường xe di chuyển được trong giây thứ $9$ là
			$$s(9)-s(8)=\displaystyle\int \limits_8^9(2{,}01t-0{,}025t^2)\mathrm{\,d}t\approx15{,}277\text{ m.}$$
			\itemch 	$v(t)=2{,}01t-0{,}025t^2$ ($0\let\le10$) $\Rightarrow \max \limits_{[0;10]}v(t)=17{,}6$ m/s khi $t=10$s.\\
			Gia tốc vật khi đó là $a(10)=v'(10)=2{,}01-0{,}05\cdot 10=1{,}51$ m/s$^2$.
		\end{itemchoice}
	}
\end{ex}

