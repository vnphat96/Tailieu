	\choice
	{$\displaystyle\int f(x)\mathrm{\,d}x=\mathrm{e}^x+C$}
	{$\displaystyle\int f(x)\mathrm{\,d}x=\mathrm{e}^x+1+C$}
	{\True $\displaystyle\int f(x)\mathrm{\,d}x=\mathrm{e}^x+x+C$}
	{$\displaystyle\int f(x)\mathrm{\,d}x=-\mathrm{e}^x+x+C$}
