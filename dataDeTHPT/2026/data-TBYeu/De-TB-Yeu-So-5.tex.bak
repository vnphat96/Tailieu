	{$\widehat{ASC}$}
	{$\widehat{SCB}$}
	{$\widehat{CAS}$}
	{\True $\widehat{SCA}$}
	\loigiai{
		Từ giả thiết ta có $SA\perp (ABCD)$ suy ra $AC$ là hình chiếu của $SC$ trên mặt phẳng $(ABCD)$.\\
		Do đó $(SC,(ABCD))=(SC,AC)=\widehat{SCA}$.
	}
\end{ex}

\begin{ex}%[1D6H2-2]
