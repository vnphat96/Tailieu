	}}
\end{ex}

\begin{ex}%[1D9N1-3]
	Cho hai biến cố độc lập $A$ và $B$ với $0<\mathrm{P}(A)<1$, $0<\mathrm{P}(B)<1$. Chọn khẳng định \textbf{đúng} trong các khẳng định sau
	\choice
	{\True $\mathrm{P}(A)=\mathrm{P}\left(A\mid \overline{B}\right)$}
	{$\mathrm{P}(A)=\mathrm{P}\left(\overline{B}\mid A\right)$}
	{$\mathrm{P}(A)=\mathrm{P}(B\mid A)\cdot \mathrm{P}(A\cap B)$}
	{$\mathrm{P}(A)=\mathrm{P}(A\mid B)\cdot \mathrm{P}(B)$}
	\loigiai{
		Cho hai biến cố độc lập $A$ và $B$ với $0<\mathrm{P}(A)<1$, $0<\mathrm{P}(B)<1$ thì $\mathrm{P}(A)=\mathrm{P}(A\mid B)=\mathrm{P}\left(A\mid \overline{B}\right)$.
	}
\end{ex}


