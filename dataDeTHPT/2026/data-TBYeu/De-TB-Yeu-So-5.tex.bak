\begin{ex}%[2H5H3-3]
	Trong không gian với hệ tọa độ $Oxyz$, viết phương trình chính tắc của mặt cầu có đường kính $AB$ với $A(2;1;0)$, $B(0;1;2)$.
	\choice
	{$(x-1)^2+(y-1)^2+(z-1)^2=4$}
	{\True $(x-1)^2+(y-1)^2+(z-1)^2=2$}
	{$(x+1)^2+(y+1)^2+(z+1)^2=4$}
	{$(x+1)^2+(y+1)^2+(z+1)^2=2$}
	\loigiai{
		Tâm mặt cầu chính là trung điểm $I$ của $AB$, với $I(1;1;1)$.\\
		Bán kính mặt cầu là $R=\dfrac{AB}{2}=\dfrac{1}{2}\sqrt{(-2)^2+2^2}=\sqrt{2}$.\\
		Suy ra phương trình mặt cầu là $(x-1)^2+(y-1)^2+(z-1)^2=2$.
	}
\end{ex}

\begin{ex}%[1H8N6-1]
