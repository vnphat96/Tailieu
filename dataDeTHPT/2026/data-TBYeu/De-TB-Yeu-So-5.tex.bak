\begin{ex}%[1H8V5-4]
	Cho hình chóp tứ giác đều $S.ABCD$, có cạnh đáy bằng $2$, cạnh bên bằng $2\sqrt{2}$. Tính khoảng cách giữa hai đường thẳng $AB$ và $SD$ (kết quả làm tròn đến hàng phần mười).
	\shortans[]{1,9}
	\loigiai{
		Gọi $O$ là giao điểm của $AC$ và $BD$.\\
		Ta có $AB\parallel (SCD)\Rightarrow \mathrm{d}(AB;SD)=\mathrm{d}(AB;(SCD))=\mathrm{d}(A;(SCD))=2\mathrm{d}(O;(SCD))$.\\
		Trong $(ABCD)$ dựng $OM\perp CD=M$, trong $(SOM)$, gọi $H$ là hình chiếu vuông góc của $O$ lên $SM$.\\
		Ta có $\heva{&OH\perp SM\\&OH\perp CD}\Rightarrow OH\perp (SCD)\Rightarrow \mathrm{d}(O;(SCD))=OH$.\\
		Có $OM=1;SO=\sqrt{6}$. Tam giác $SOM$ vuông tại $O$, đường cao $OH$ nên
		$$\dfrac{1}{OH^2}=\dfrac{1}{OM^2}+\dfrac{1}{SO^2}=\dfrac{7}{6}\Rightarrow OH=\dfrac{\sqrt{42}}{7}$$
		Vậy $\mathrm{d}(AB;SD)=2\mathrm{d}(O;(SCD))=2OH=\dfrac{2\sqrt{42}}{7}\approx1{,}9$.
	}
\end{ex}

\begin{ex}%[1C2V3-1]
	Một công ty vận tải cần giao hàng đến tất cả các thành phố A, B, C, D, E (hình vẽ bên dưới). Chi phí di chuyển giữa các thành phố được mô tả trên hình. Xe giao hàng của công ty xuất phát từ một thành phố trong năm thành phố trên đi qua tất cả các thành phố còn lại đúng một lần sau đó trở lại thành phố ban đầu. Tìm chi phí thấp nhất của xe giao hàng.
	\shortans[]{53}
	\loigiai{
		Ta liệt kê các chu trình Hamilton và tính tổng chi phí:
		\begin{center}
			\begin{tabular}{|c|c|}
				\hline
				Đường đi & Tổng số chi phí \\
				\hline
				A $\to$ B $\to$ C $\to$ E $\to$ D $\to$ A & $9+14+12+14+11=60$ \\
				\hline
				A $\to$ B $\to$ E $\to$ C $\to$ D $\to$ A & $9+8+12+13+11=53$ \\
				\hline
				A $\to$ E $\to$ B $\to$ C $\to$ D $\to$ A & $10+8+14+13+11=56$ \\
				\hline
				A $\to$ E $\to$ D $\to$ C $\to$ B $\to$ A & $10+14+13+14+9=60$ \\
				\hline
				A $\to$ D $\to$ C $\to$ E $\to$ B $\to$ A & $11+13+12+8+9=53$ \\
				\hline
				A $\to$ D $\to$ E $\to$ C $\to$ B $\to$ A & $11+14+12+14+9=60$ \\
				\hline
			\end{tabular}
		\end{center}
		Do đó, tổng chi phí của đường đi nhận giá trị nhỏ nhất là $53$.
	}
\end{ex}

\begin{ex}%[2H5H2-5]
	Khi gắn hệ tọa độ $Oxyz$ (đơn vị trên mỗi trục tính theo kilômét) vào một sân bay, mặt phẳng $(Oxy)$ trùng với mặt sân bay. Một máy bay bay theo đường thẳng từ vị trí $A(5;0;5)$ đến vị trí $B(10;10;3)$ và hạ cánh tại vị trí $M(a;b;0)$. Giá trị của $a+b$ bằng bao nhiêu (\textit{viết kết quả dưới dạng số thập phân})?
	\shortans[]{42,5}
	\loigiai{
		Phương trình đường thẳng $AB$ là $\dfrac{x-5}{5}=\dfrac{y}{10}=\dfrac{z-5}{-2}$.\\
		Vì $M$ thuộc $AB$ nên tồn tại số thực $t$ sao cho $M(5t+5;10t;-2t+5)$.\\
		Ngoài ra, $M$ thuộc mặt phẳng $(Oxy)$ nên $-2t+5=0\Leftrightarrow t=\dfrac{5}{2}$.\\
		Suy ra $M(17{,}5;25;0)$.\\
		Vậy $a+b=17{,}5+25=42{,}5$.
	}
\end{ex}

\begin{ex}%[2D4V3-2]
	\immini[thm]{
		Một chiếc cổng có hình dạng là một Parabol có khoảng cách giữa hai chân cổng là $AB=8$ m. Người ra treo một tâm phông hình chữ nhật có hai đỉnh $M$, $N$ nằm trên Parabol và hai đỉnh $P$, $Q$ nằm trên mặt đất (như hình vẽ bên). Ở phần phía ngoài phông (phần không tô đen) người ta mua hoa để trang trí hoa, biết $MN=4$ m, $MQ=6$ m. Diện tích phần phía ngoài phông để trang trí hoa (phần không tô đen) là bao nhiêu mét vuông? (Kết quả làm tròn đến hàng phần mười).
		\shortans[]{18,7}
		}{
		\begin{tikzpicture}[scale=0.5, line join=round, line cap=round, >=stealth, font=\footnotesize]
			
			% Định nghĩa các tọa độ dựa trên phương trình y = -1/2 x^2 + 8
			\coordinate (A) at (-4, 0);
			\coordinate (B) at (4, 0);
			\coordinate (Q) at (-2, 0);
			\coordinate (P) at (2, 0);
			\coordinate (M) at (-2, 6);
			\coordinate (N) at (2, 6);
			% Tô màu xám nhạt cho hình chữ nhật MNPQ
			\fill[gray!30] (Q) rectangle (N);
			% Vẽ Parabol y = -0.5*x^2 + 8 với tập xác định [-4; 4]
			\draw[black!85] plot[domain=-4:4, samples=100] (\x, {-0.5*\x*\x + 8});
			% Vẽ đường thẳng đáy AB và khung hình chữ nhật
			\draw (A) -- (B);
			\draw (M) -- (Q);
			\draw (N) -- (P);
			\draw (M) -- (N);
			% Vẽ các dấu chấm tròn tại các đỉnh
			\foreach \point in {A, Q, P, B, M, N} {
				\fill (\point) circle (2pt);
			}
			
			% Thêm nhãn tên các điểm
			\node[below,  yshift=-2pt] at (A) {$A$};
			\node[below,  yshift=-2pt] at (Q) {$Q$};
			\node[below,  yshift=-2pt] at (P) {$P$};
			\node[below,  yshift=-2pt] at (B) {$B$};
			
			\node[left,  xshift=-2pt, yshift=4pt] at (M) {$M$};
			\node[right,  xshift=2pt, yshift=4pt] at (N) {$N$};
			
		\end{tikzpicture}
	}
	\loigiai{
		Diện tích của phần phía ngoài phông (phần không tô đen) bằng diện tích hình giới hạn bởi parabol trừ đi diện tích phông hình chữ nhật $MNPQ$.\\
		Diện tích của hình chữ nhật là $4\cdot 6=24$ (m$^2$).
		\immini{
			Chọn hệ trục tọa độ $Oxy$ như hình vẽ (trục $Oy$ đi qua đỉnh Parabol, trục $Ox$ đi qua $A,B$).
			
			Parabol đối xứng qua $Oy$ nên có dạng $(P)\colon y=ax^2+c$. \\
			Vì $(P)$ đi qua $B(4;0)$ và $N(2;6)$ nên $(P)\colon y=-\dfrac{1}{2}x^2+8$.\\
			Diện tích hình phẳng giới hạn bởi $(P)$ và trục $Ox$ là
			$$S_1=2\displaystyle\int \limits_{0}^{4}\left(-\dfrac{1}{2}x^2+8\right)\mathrm{\,d}x=\dfrac{128}{3}\ (\text{m}^2).$$
			Diện tích phần phía ngoài phông để trang trí hoa là
			$$S=S_1-S_{MNPQ}=\dfrac{128}{3}-24=\dfrac{56}{3}\approx18{,}7\text{ (m}^2\text{)}.$$}{
			\begin{tikzpicture}[scale=0.6, line join=round, line cap=round, >=stealth, font=\footnotesize]
				
				% Định nghĩa các tọa độ dựa trên phương trình y = -1/2 x^2 + 8
				\coordinate (A) at (-4, 0);
				\coordinate (B) at (4, 0);
				\coordinate (Q) at (-2, 0);
				\coordinate (P) at (2, 0);
				\coordinate (M) at (-2, 6);
				\coordinate (N) at (2, 6);
				\coordinate (O) at (0, 0);
				% Tô màu xám nhạt cho hình chữ nhật MNPQ
				\fill[gray!30] (Q) rectangle (N);
				% Vẽ Parabol y = -0.5*x^2 + 8 với tập xác định [-4; 4]
				\draw[line width=1.2pt, black!85] plot[domain=-4:4, samples=100] (\x, {-0.5*\x*\x + 8});
				% Vẽ đường thẳng đáy AB và khung hình chữ nhật
				\draw (A) -- (B);
				\draw (M) -- (Q);
				\draw (N) -- (P);
				\draw (M) -- (N);
				\draw(-5,0)--(A);
				\draw[->](B)--(5,0) node[right]{$x$};
				\draw[->](0,0) node[below ]{$O$}--(0,9) node[right]{$y$};
				% Vẽ các dấu chấm tròn tại các đỉnh
				\foreach \point in {A, Q, P, B, M, N,O} {
					\fill (\point) circle (2pt);
				}
				
				% Thêm nhãn tên các điểm
				\node[below,  yshift=-2pt] at (A) {$A$};
				\node[below,  yshift=-2pt] at (Q) {$Q$};
				\node[below,  yshift=-2pt] at (P) {$P$};
				\node[below,  yshift=-2pt] at (B) {$B$};
				
				\node[left,  xshift=-2pt, yshift=4pt] at (M) {$M$};
				\node[right,  xshift=2pt, yshift=4pt] at (N) {$N$};
				
		\end{tikzpicture}}
	}
\end{ex}

\begin{ex}%[2D1H3-6]
	Nhà máy A chuyên sản xuất một loại sản phẩm cho nhà máy B. Hai nhà máy thỏa thuận rằng, hằng tháng A cung cấp cho B số lượng sản phẩm theo đơn đặt hàng của B (tối đa 100 tấn sản phẩm). Nếu số lượng đặt hàng là $x$ tấn sản phẩm thì giá bán cho mỗi sản phẩm là $P(x)=45-0{,}001x^2$ (triệu đồng). Chi phí để A sản xuất $x$ tấn sản phẩm trong một tháng là $C(x)=100+30x$ triệu đồng (gồm $100$ triệu đồng chi phí cố định và $30$ triệu đồng cho mỗi tấn sản phẩm). Nhà máy A bán cho B bao nhiêu tấn sản phẩm để lợi nhuận thu được là lớn nhất? (làm tròn kết quả đến hàng phần mười).
	\shortans[]{70,7}
	\loigiai{
		Lợi nhuận của nhà máy A khi sản xuất $x$ tấn sản phẩm là
		$$H(x)=xP(x)-C(x)=x(45-0{,}001x^2)-(100+30x)=-0{,}001x^3+15x-100\text{, }0\lex\le100.$$
		Ta có $H'(x)=-0{,}003x^2+15$.
		$$H'(x)=0\Leftrightarrow -0{,}003x^2+15=0\Rightarrow x=50\sqrt{2}\text{ (chọn)}.$$
		Ta có $H(0)=-100$; $H(50\sqrt{2})=500\sqrt{2}-100$; $H(100)=400$.\\
		Do đó $\max \limits_{[0;100]}H(x)=H(50\sqrt{2})=500\sqrt{2}-100$.\\
		Vậy nhà máy A nên sản xuất $x=50\sqrt{2}\approx70{,}7$ tấn sản phẩm để lợi nhuận thu được là lớn nhất.
	}
\end{ex}

\begin{ex}%[2D5V2-3]
	Một căn bệnh có $1\%$ dân số mắc phải. Một phương pháp chẩn đoán được phát triển có tỷ lệ chính xác là $99\%$. Với những người bị bệnh, phương pháp này sẽ đưa ra kết quả dương tính $99\%$ số trường hợp. Với người không mắc bệnh, phương pháp này cũng chuẩn đoán đúng $99$ trong $100$ trường hợp. Nếu một người kiểm tra và kết quả là dương tính (bị bệnh), xác suất để người đó thực sự bị bệnh là bao nhiêu?
	\shortans[]{0,5}
	\loigiai{
		Gọi $A$ là biến cố\, \lq\lq người đó mắc bệnh\rq\rq.\\
		Gọi $B$ là biến cố\, \lq\lq kết quả kiểm tra người đó là dương tính (bị bệnh)\rq\rq.\\
		Ta cần tính $\mathrm{P}\left(A\mid B\right)$.\\
		Theo công thức Bayes, ta có
		$$\mathrm{P}\left(A\mid B\right)=\dfrac{\mathrm{P}\left(A\right)\cdot \mathrm{P}\left(B\mid A\right)}{\mathrm{P}\left(A\right)\cdot \mathrm{P}\left(B\mid A\right)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B\mid \overline{A}\right)}.$$
		Ta có xác suất để người đó mắc bệnh khi chưa kiểm tra là $\mathrm{P}\left(A\right)=1\%=0{,}01$.\\
		Do đó xác suất để người đó không mắc bệnh khi chưa kiểm tra là $\mathrm{P}\left(\overline{A}\right)=1-0{,}01=0{,}99$.\\
		Xác suất kết quả dương tính nếu người đó mắc bệnh là là $\mathrm{P}\left(B\mid A\right)=99\%=0{,}99$.\\
		Xác suất kết quả dương tính nếu người đó không mắc bệnh là $\mathrm{P}\left(B\mid \overline{A}\right)=1-0{,}99=0{,}01$.\\
		Thế vào công thức ta được
		$$\mathrm{P}\left(A\mid B\right)=\dfrac{0{,}01\cdot 0{,}99}{0{,}01\cdot 0{,}99+0{,}99\cdot 0{,}01}=0{,}5.$$
		Vậy xác suất để người đó thực sự mắc bệnh nếu kết quả kiểm tra là dương tính là $0{,}5$.
	}
\end{ex}


\Closesolutionfile{ans}
