\begin{ex}%[Văn Minh Thoại]%[2D4N1-1]
	Cho $f(x)$, $g(x)$ là các hàm số xác định và liên tục trên $\mathbb{R}$. Trong các mệnh đề sau, mệnh đề nào \textbf{sai}?
	\choice
	{$\displaystyle\int [f(x)+g(x)]\mathrm{\,d}x=\displaystyle\int f(x)\mathrm{\,d}x+\displaystyle\int g(x)\mathrm{\,d}x$}
	{\True $\displaystyle\int f(x)g(x)\mathrm{\,d}x=\displaystyle\int f(x)\mathrm{\,d}x\cdot \displaystyle\int g(x)\mathrm{\,d}x$}
	{$\displaystyle\int 2f(x)\mathrm{\,d}x=2\displaystyle\int f(x)\mathrm{\,d}x$}
	{$\displaystyle\int [f(x)-g(x)]\mathrm{\,d}x=\displaystyle\int f(x)\mathrm{\,d}x-\displaystyle\int g(x)\mathrm{\,d}x$}
	\loigiai{
		Tính chất của nguyên hàm không có tích các nguyên hàm bằng nguyên hàm của một tích. \\
		Do đó mệnh đề $\displaystyle\int f(x)g(x)\mathrm{\,d}x=\displaystyle\int f(x)\mathrm{\,d}x\cdot \displaystyle\int g(x)\mathrm{\,d}x$ là \textbf{sai}. \\
		Các mệnh đề còn lại đều đúng theo tính chất cơ bản của nguyên hàm.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5N3-2]
	Trong không gian với hệ tọa độ $Oxyz$, cho phương trình mặt cầu $(S)\colon (x-3)^2+(y+1)^2+(z+2)^2=8$. Khi đó tâm $I$ và bán kính $R$ của mặt cầu là
	\choice
	{$I(-3;1;2)$, $R=2\sqrt{2}$}
	{$I(3;-1;-2)$, $R=4$}
	{\True $I(3;-1;-2)$, $R=2\sqrt{2}$}
	{$I(-3;1;2)$, $R=4$}
	\loigiai{
