\begin{ex}%[Văn Minh Thoại]%[1D6N4-2]
	Nghiệm của phương trình $4^{x-4}=16$ là
	\choice
	{\True $x=6$}
	{$x=15$}
	{$x=0$}
	{$x=9$}
	\loigiai{
		Ta có $4^{x-4}=16\Leftrightarrow 4^{x-4}=4^2\Leftrightarrow x-4=2\Leftrightarrow x=6$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5N1-2]
	Một véc-tơ pháp tuyến của mặt phẳng $(\alpha)\colon 2x-y+2z-3=0$ là
	\choice
	{$\overrightarrow{n}=(1;-2;1)$}
	{$\overrightarrow{n}=(4;2;-4)$}
	{$\overrightarrow{n}=(2;1;2)$}
	{\True $\overrightarrow{n}=(-2;1;-2)$}
	\loigiai{
		Mặt phẳng $(\alpha)\colon 2x-y+2z-3=0$ có một véc-tơ pháp tuyến là $\overrightarrow{n}_1=(2;-1;2)$.\\
		Ta thấy $\overrightarrow{n}=(-2;1;-2)=-1\cdot (2;-1;2)$ cũng là một véc-tơ pháp tuyến của mặt phẳng $(\alpha)$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1N4-1]
	Đồ thị hàm số $y=\dfrac{2x-3}{x-1}$ có đường tiệm cận đứng $x=a$ và tiệm cận ngang $y=b$. Khi đó $a+b$ bằng
	\choice
	{$4$}
	{$2$}
	{\True $3$}
	{$1$}
	\loigiai{
		Ta có $\lim \limits_{x\to\pm\infty}\dfrac{2x-3}{x-1}=2\Rightarrow$ Đồ thị hàm số có đường tiệm cận ngang $y=2\Rightarrow b=2$.\\
		Ta có $\lim \limits_{x\to1^+}\dfrac{2x-3}{x-1}=+\infty$ và $\lim \limits_{x\to1^-}\dfrac{2x-3}{x-1}=-\infty\Rightarrow$ Đồ thị hàm số có đường tiệm cận đứng $x=1\Rightarrow a=1$.\\
		Vậy $a+b=1+2=3$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H2N2-1]
	Trong không gian $Oxyz$, cho $\overrightarrow{a}=(0;-3;2)$. Mệnh đề nào dưới đây đúng?
	\choice
	{$\overrightarrow{a}=-3\overrightarrow{i}+2\overrightarrow{j}$}
	{\True $\overrightarrow{a}=-3\overrightarrow{j}+2\overrightarrow{k}$}
	{$\overrightarrow{a}=-3\overrightarrow{i}+2\overrightarrow{j}+\overrightarrow{k}$}
	{$\overrightarrow{a}=-3\overrightarrow{i}+2\overrightarrow{k}$}
	\loigiai{
		Ta có $\overrightarrow{a}=(0;-3;2)=0\overrightarrow{i}-3\overrightarrow{j}+2\overrightarrow{k}=-3\overrightarrow{j}+2\overrightarrow{k}$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1N1-2]
