\begin{ex}%[Văn Minh Thoại]%[2D1V4-2]
	Cho hàm số $y=\dfrac{mx^2+(3m^2-2)x-2}{x+3m}$ với $m$ là số thực.
	\choiceTF
	{Khi $m=1$, đồ thị hàm số có đường tiệm cận xiên là $y=x-2$}
	{Khi $m=1$, giao điểm của đường tiệm cận xiên và tiệm cận đứng của đồ thị hàm số là $I(3;-5)$}
	{\True Khi $m=1$, đồ thị hàm số có $2$ điểm cực trị}
	{\True Có $2$ giá trị $m$ để góc giữa hai tiệm cận của đồ thị hàm số bằng $45^\circ$}
	\loigiai{
		Ta có $y=\dfrac{mx^2+(3m^2-2)x-2}{x+3m}=mx-2+\dfrac{6m-2}{x+3m}$.
		\begin{itemchoice}
			\itemch Khi $m=1\Rightarrow y=x-2+\dfrac{4}{x+3}$. \\
			Đồ thị hàm số có đường tiệm cận xiên là $y=x-2$.
			\itemch Khi $m=1$, đồ thị hàm số có tiệm cận đứng là $x=-3$ và tiệm cận xiên là $y=x-2$.\\ Giao điểm của hai đường tiệm cận là nghiệm của hệ $\heva{&x=-3\\&y=x-2}\Leftrightarrow \heva{&x=-3\\&y=-5.}$\\
			Vậy giao điểm là $I(-3;-5)$.
			\itemch Khi $m=1\Rightarrow y=x-2+\dfrac{4}{x+3}\Rightarrow y'=1-\dfrac{4}{(x+3)^2}$. \\
			Cho $y'=0\Leftrightarrow (x+3)^2=4\Leftrightarrow \hoac{&x+3=2\\&x+3=-2}\Leftrightarrow \hoac{&x=-1\\&x=-5.}$ \\
			Phương trình $y'=0$ có hai nghiệm phân biệt và đổi dấu qua các nghiệm này nên hàm số có $2$ điểm cực trị.
			\itemch
			\begin{itemize}
				\item Nếu $m=\dfrac{1}{3}$, ta có $y=\dfrac{1}{3}x-2$, đồ thị hàm số không có tiệm cận đứng và tiệm cận xiên.
				\item Nếu $m\ne\dfrac{1}{3}$, đồ thị hàm số có đường tiệm cận đứng $d_1\colon x=-3m\Leftrightarrow x+3m=0$ và tiệm cận xiên $d_2\colon y=mx-2\Leftrightarrow mx-y-2=0$.
			\end{itemize}
			Các đường thẳng $d_1$ và $d_2$ có véc-tơ pháp tuyến lần lượt là $\overrightarrow{n}_1=(1;0)$ và $\overrightarrow{n}_2=(m;-1)$.\\
			Góc giữa $d_1$ và $d_2$ bằng $45^\circ$, khi đó
			\allowdisplaybreaks
			\begin{eqnarray*}
&&\left|\cos (\overrightarrow{n}_1,\overrightarrow{n}_2)\right|=\cos 45^\circ\\&\Leftrightarrow &\dfrac{\left|\overrightarrow{n}_1\cdot \overrightarrow{n}_2\right|}{\left|\overrightarrow{n}_1\right|\cdot \left|\overrightarrow{n}_2\right|}=\dfrac{\sqrt{2}}{2}\\&\Leftrightarrow &\dfrac{|1\cdot m+0\cdot (-1)|}{\sqrt{1^2+0^2}\cdot \sqrt{m^2+(-1)^2}}=\dfrac{\sqrt{2}}{2}\\&\Leftrightarrow &\dfrac{|m|}{\sqrt{m^2+1}}=\dfrac{\sqrt{2}}{2}\\&\Leftrightarrow &2m^2=m^2+1\\&\Leftrightarrow &m^2=1\\&\Leftrightarrow &m=\pm1.
\end{eqnarray*}
			Vậy có $2$ giá trị của $m$ thỏa mãn.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H5H2-4]
	Cho đường thẳng $\Delta \colon \heva{&x=-mt\\&y=2-3t\\&z=1+(2m+1)t}$ và $d\colon \dfrac{x+3}{-1}=\dfrac{y-1}{2m}=\dfrac{z-2}{3}$ trong không gian $Oxyz$, với $m\in \mathbb{R}\setminus\{0\}$.
	\choiceTF
	{\True Đường thẳng $\Delta$ đi qua điểm $A(0;2;1)$}
	{\True Đường thẳng $d$ đi qua điểm $B(-3;1;2)$}
	{Đường thẳng $\Delta$ có véc-tơ chỉ phương $\overrightarrow{u}_{\Delta }=(m;3;2m+1)$}
	{\True $m=-3$ thì $\Delta \perp d$}
	\loigiai{
		\begin{itemchoice}
			\itemch Thay $t=0$ vào phương trình của $\Delta$ ta được $\heva{&x=0\\&y=2\\&z=1.}$\\
			Suy ra $\Delta$ đi qua điểm $A(0;2;1)$.
			\itemch Dựa vào phương trình chính tắc của $d$, ta thấy $d$ đi qua điểm $B(-3;1;2)$.
			\itemch Từ phương trình tham số của $\Delta$, ta có véc-tơ chỉ phương của $\Delta$ là $\overrightarrow{u}_{\Delta }=(-m;-3;2m+1)$.
			\itemch véc-tơ chỉ phương của $d$ là $\overrightarrow{u}_d=(-1;2m;3)$, khi đó
			\allowdisplaybreaks
			\begin{eqnarray*}
&&\Delta \perp d\\&\Leftrightarrow &\overrightarrow{u}_{\Delta }\cdot \overrightarrow{u}_d=0\\&\Leftrightarrow &(-m)\cdot (-1)+(-3)\cdot 2m+(2m+1)\cdot 3=0\\&\Leftrightarrow &m-6m+6m+3=0\\&\Leftrightarrow &m=-3.
\end{eqnarray*}
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D4V2-6]
	Trong $5$ giây đầu tiên, một chất điểm chuyển động với vận tốc $v(t)=-2t^2+12t+1$ (m/s). Gọi $s(t)$ là quãng đường chuyển động của chất điểm theo thời gian $t$.
	\choiceTF
	{\True Vận tốc của vật tại thời điểm $t=2$ là $v(2)=17$ (m/s)}
	{\True Trong $5$ giây đầu tiên, vận tốc lớn nhất của chất điểm là $19$ (m/s)}
	{Trong khoảng thời gian từ $t=2$ đến $t=5$, vận tốc của chất điểm giảm dần}
	{\True Quãng đường chuyển động của chất điểm trong $5$ giây đầu tiên là $\dfrac{215}{3}$ (m)}
	\loigiai{
		\begin{itemchoice}
			\itemch Tại $t=2$, vận tốc của vật là $v(2)=-2\cdot 2^2+12\cdot 2+1=17$ (m/s).
			\itemch Xét hàm số $v(t)=-2t^2+12t+1$ trên đoạn $[0;5]$.\\
			Ta có $v'(t)=-4t+12$; $v'(t)=0\Leftrightarrow t=3\in [0;5]$.\\
			Khi đó,
			\begin{itemize}
				\item $v(0)=1$;
				\item $v(3)=19$;
				\item $v(5)=-2\cdot 5^2+12\cdot 5+1=11$.
			\end{itemize}
			Trong $5$ giây đầu tiên, vận tốc lớn nhất của chất điểm là $\max \limits_{[0;5]}v(t)=v(3)=19$ (m/s).
			\itemch Hàm số $v(t)$ là hàm số bậc hai có hệ số $a=-2<0$, đồ thị là parabol bề lõm hướng xuống, đỉnh có hoành độ $t=3$.\\
			Do đó hàm số $v(t)$ đồng biến trên khoảng $(-\infty;3)$ và nghịch biến trên khoảng $(3;+\infty)$.\\
			Suy ra trong khoảng thời gian từ $t=2$ đến $t=5$, vận tốc của chất điểm tăng dần trên $(2;3)$ và giảm dần trên $(3;5)$.
			\itemch Phương trình $v(t)=0\Leftrightarrow -2t^2+12t+1=0\Leftrightarrow t=\dfrac{6\pm\sqrt{38}}{2}$.\\
			Hai nghiệm này đều không thuộc đoạn $[0;5]$. Do đó trên đoạn $[0;5]$, ta luôn có $v(t)>0$.\\
			Quãng đường mà vật di chuyển trong khoảng thời gian từ $t=0$ đến $t=5$ là
			\[s=\displaystyle\int \limits_{0}^{5}|v(t)|\mathrm{\,d}t=\displaystyle\int \limits_{0}^{5}(-2t^2+12t+1)\mathrm{\,d}t=\left.\left(-\dfrac{2}{3}t^3+6t^2+t\right)\right|_0^5=\dfrac{215}{3}\;\text{(m)}.\]
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1H8V5-4]
	Cho hình lăng trụ tam giác đều $ABC.A'B'C'$ có tất cả các cạnh bằng $a$. Gọi $M$ là trung điểm của $AA'$.
	\choiceTF
	{\True Khoảng cách giữa hai đường thẳng $AB$ và $A'B'$ là $a$}
	{Khoảng cách giữa hai đường thẳng $AB$ và $B'C'$ là $a\sqrt{2}$}
	{Khoảng cách giữa hai đường thẳng $AA'$ và $B'C'$ là $a$}
	{\True Khoảng cách giữa hai đường thẳng $MB'$ và $BC$ là $\dfrac{a\sqrt{3}}{2}$}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[declare function={goc=-45; a=5; b=0.65*a; h=5;},line join=round,line cap=round,>=stealth,scale=1]
				\path
				(0,0) coordinate (A)
				(a,0) coordinate (C)
				(goc:b) coordinate (B)
				(0,h) coordinate (A')
				(a,h) coordinate (C')
				($(B)+(0,h)$) coordinate (B')
				($(B')!0.5!(C')$) coordinate (I)
				($(B)!0.5!(C)$) coordinate (J)
				($(A)!0.5!(A')$) coordinate (M)
				($(M)!(A')!(I)$) coordinate (H);
				\draw[dashed] (A)--(C)
				(M)--(I)
				(A')--(H)
				(M)--(C')
				(A)--(J)
				(M)--(J)
				(I)--(J);
				\draw (A)--(B)--(C)--(C')--(A')--(B')--(B)
				(A)--(A')
				(B')--(C')
				(A')--(I)
				(M)--(B');
				\foreach \x/\goc in {A/-180,B/-90,C/0,A'/-180,B'/-30,C'/0,I/-60,M/180,H/160,J/-60}
				\fill (\x) node[shift={(\goc:12pt)},font = \footnotesize]{$\x$} circle (1pt);
				
				\foreach \x/\y/\z in {A'/H/I, A'/I/B'}{
					\path (\y) pic[draw,angle radius=5pt]{right angle = \x--\y--\z};
				}
				
				\foreach \x/\y in {I/B',I/C',A'/M,M/A}{
					\path (\x)--(\y) node[midway,sloped]{\tikz{\draw (240:2pt)--(60:2pt);}};
				}
			\end{tikzpicture}
		\end{center}
		\begin{itemchoice}
			\itemch Vì $ABC.A'B'C'$ là hình lăng trụ đều nên $ABB'A'$ là hình vuông cạnh $a$.\\
			Ta có $AB\parallel A'B'$ nên $\mathrm{d}\big(AB,A'B'\big)=\mathrm{d}\big(A,A'B'\big)=AA'=a$.
			\itemch Ta có $AB\subset (ABC)$ và $B'C'\subset (A'B'C')$, mà $(ABC)\parallel (A'B'C')$.\\
			Nên $\mathrm{d}\big(AB,B'C'\big)=\mathrm{d}\big((ABC),(A'B'C')\big)=BB'=a\nea\sqrt{2}$.
			\itemch Gọi $I$ là trung điểm của $B'C'$. Tam giác $A'B'C'$ đều nên $A'I\perp B'C'$.\\
			Ta có $AA'\perp (A'B'C')\Rightarrow AA'\perp A'I$.\\
			Do đó $A'I$ là đoạn vuông góc chung của $AA'$ và $B'C'$.\\
			Khoảng cách giữa hai đường thẳng $AA'$ và $B'C'$ bằng $A'I=\dfrac{a\sqrt{3}}{2}\nea$.
			\itemch Gọi $I$, $J$ lần lượt là trung điểm của $B'C'$ và $BC$.\\
			Ta có $BC\parallel B'C'$ và $B'C'\subset (MB'C')$ nên $BC\parallel (MB'C')$.\\
			Khi đó $\mathrm{d}\big(MB',BC\big)=\mathrm{d}\big(BC,(MB'C')\big)=\mathrm{d}\big(J,(MB'C')\big)$.\\
			Do tam giác $A'B'C'$ và $ABC$ là các tam giác đều nên $A'I\perp B'C'$ và $AJ\perp BC$.\\ Khi đó mặt phẳng $(AA'IJ)$ vuông góc với $B'C'$ (và $BC$).\\
			Suy ra $(AA'IJ)\perp (MB'C')$ theo giao tuyến $MI$.\\
			Trong mặt phẳng $(AA'IJ)$, kẻ $JK\perp MI$ tại $K$, suy ra $JK\perp (MB'C')$.\\
			Khi đó $\mathrm{d}\big(J,(MB'C')\big)=JK$.\\
			Tứ giác $AA'IJ$ là hình chữ nhật có $AA'=a$ và $A'I=AJ=\dfrac{a\sqrt{3}}{2}$.\\
			Diện tích hình chữ nhật là $S_{AA'IJ}=a\cdot \dfrac{a\sqrt{3}}{2}=\dfrac{a^2\sqrt{3}}{2}$.\\
			Diện tích tam giác $MJI$ nằm trong hình chữ nhật này được tính bằng
			\begin{eqnarray*}
S_{\triangle MJI}&=&S_{AA'IJ}-S_{\triangle A'MI}-S_{\triangle AMJ}\\&=&\dfrac{a^2\sqrt{3}}{2}-\dfrac{1}{2}\cdot \dfrac{a}{2}\cdot \dfrac{a\sqrt{3}}{2}-\dfrac{1}{2}\cdot \dfrac{a}{2}\cdot \dfrac{a\sqrt{3}}{2}\\&=&\dfrac{a^2\sqrt{3}}{4}.
\end{eqnarray*}
			Lại có độ dài đoạn $MI=\sqrt{A'M^2+A'I^2}=\sqrt{\left(\dfrac{a}{2}\right)^2+\left(\dfrac{a\sqrt{3}}{2}\right)^2}=a$.\\
			Mặt khác, $S_{\triangle MJI}=\dfrac{1}{2}MI\cdot JK\Rightarrow JK=\dfrac{2S_{\triangle MJI}}{MI}=\dfrac{2\cdot \dfrac{a^2\sqrt{3}}{4}}{a}=\dfrac{a\sqrt{3}}{2}$.\\
			Vậy $\mathrm{d}\big(MB',BC\big)=JK=\dfrac{a\sqrt{3}}{2}$.
		\end{itemchoice}
	}
\end{ex}


