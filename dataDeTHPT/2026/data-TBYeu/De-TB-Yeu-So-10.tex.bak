\begin{ex}%[Văn Minh Thoại]%[1D9H2-3]
	Cho $A$, $B$ là hai biến cố không xung khắc. Biết $\mathrm{P}(A)=0{,}4$; $\mathrm{P}(B)=0{,}5$; $\mathrm{P}\left(A\cap B\right)=0{,}2$. Tính $\mathrm{P}\left(A\cup B\right)$.
	\choice
	{$0{,}9$}
	{$1$}
	{\True $0{,}7$}
	{$0{,}6$}
	\loigiai{
		Theo công thức cộng xác suất, ta có
		\[\mathrm{P}\left(A\cup B\right)=\mathrm{P}(A)+\mathrm{P}(B)-\mathrm{P}\left(A\cap B\right)=0{,}4+0{,}5-0{,}2=0{,}7.\]
	}
\end{ex}

