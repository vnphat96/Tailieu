\begin{ex}%[Văn Minh Thoại]%[2D6V2-3]
	Một loại linh kiện do hai nhà máy I, II cùng sản xuất. Tỉ lệ phế phẩm của nhà máy I, II lần lượt là $0{,}04$; $0{,}03$. Trong một lô linh kiện để lẫn lộn $80$ sản phẩm của nhà máy I và $120$ sản phẩm của nhà máy II. Một khách hàng lấy ngẫu nhiên một linh kiện của lô hàng đó. Giả sử linh kiện được chọn là phế phẩm. Tính xác suất linh kiện này thuộc nhà máy I.
	\shortans[]{0,47}
	\loigiai{
		Ta xét các biến cố\\
		\begin{itemize}
			\item $A$ \lq\lq Linh kiện được lấy ra là phế phẩm\rq\rq;
			\item $B$ \lq\lq Linh kiện lấy ra từ nhà máy I\rq\rq;
			\item $\overline{B}$ \lq\lq Linh kiện lấy ra từ nhà máy II\rq\rq.
		\end{itemize}
		Theo giả thiết ta có \begin{itemize}
			\item $\mathrm{P}(B)=\dfrac{80}{200}=0{,}4$;
			\item $\mathrm{P}\left(\overline{B}\right)=\dfrac{120}{200}=0{,}6$;
			\item $\mathrm{P}(A\mid B)=0{,}04$; $\mathrm{P}\left(A\mid \overline{B}\right)=0{,}03$.
		\end{itemize}
		Theo công thức xác suất toàn phần, xác suất lấy ra linh kiện là phế phẩm là
		\[\mathrm{P}(A)=\mathrm{P}(B)\cdot \mathrm{P}(A\mid B)+\mathrm{P}\left(\overline{B}\right)\cdot \mathrm{P}\left(A\mid \overline{B}\right)=0{,}4\cdot 0{,}04+0{,}6\cdot 0{,}03=0{,}034.\]
		Mặt khác, theo công thức Bayes, xác suất linh kiện phế phẩm do nhà máy I sản xuất là
		\[\mathrm{P}(B\mid A)=\dfrac{\mathrm{P}(B)\cdot \mathrm{P}(A\mid B)}{\mathrm{P}(A)}=\dfrac{0{,}4\cdot 0{,}04}{0{,}034}=\dfrac{8}{17}\approx0{,}47.\]
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D4V2-6]
	Giả sử nhiệt độ (tính bằng $^\circ\mathrm{C}$) tại thời điểm $t$ giờ trong khoảng thời gian từ $6$ giờ sáng đến $12$ giờ trưa ở một địa phương vào một ngày nào đó được mô hình hoá bởi hàm số \break $T(t)=20+1{,}5(t-6)$, $6\let\le12$. Tìm nhiệt độ trung bình vào ngày đó trong khoảng thời gian từ $6$ giờ sáng đến $12$ giờ trưa.
	\shortans[]{24,5}
	\loigiai{
		Giá trị trung bình của hàm số liên tục $f(x)$ trên đoạn $[a;b]$ được định nghĩa là $\dfrac{1}{b-a}\displaystyle\int \limits_a^bf(x)\mathrm{\,d}x$.\\
		Do đó, nhiệt độ trung bình vào ngày đó trong khoảng thời gian từ $6$ giờ sáng đến $12$ giờ trưa là
		\[\dfrac{1}{12-6}\displaystyle\int \limits_{6}^{12}\left(20+1{,}5(t-6)\right)\mathrm{\,d}t=24{,}5^\circ\mathrm{C}.\]
	}
\end{ex}
\begin{ex}%[Văn Minh Thoại]%[2D6V2-4]
	Một công ty có hai chi nhánh. Sản phẩm của chi nhánh I chiếm $60$\% còn chi nhánh II chiếm $40$\% tổng sản phẩm của công ty. Tỉ lệ sản phẩm bị lỗi của chi nhánh I chiếm $1$\% còn của chi nhánh II chiếm $2$\% tổng sản phẩm công ty. Chọn ngẫu nhiên một sản phẩm của công ty. Tính xác suất để sản phẩm đó bị lỗi.
	\shortans[]{0,03}
	\loigiai{
		Gọi $A_1$ là biến cố \lq\lq Sản phẩm được chọn thuộc chi nhánh I và bị lỗi\rq\rq.\\
		Gọi $A_2$ là biến cố \lq\lq Sản phẩm được chọn thuộc chi nhánh II và bị lỗi\rq\rq.\\
		Gọi $B$ là biến cố \lq\lq Sản phẩm được chọn bị lỗi\rq\rq.\\
		Ta có $B=A_1\cup A_2$, trong đó $A_1$ và $A_2$ là hai biến cố xung khắc.\\
		Theo giả thiết, tỉ lệ sản phẩm bị lỗi của chi nhánh I và chi nhánh II chiếm tương ứng $1$\% và $2$\% so với tổng sản phẩm của công ty, do đó
		\[\mathrm{P}\left(A_1\right)=1\%=0{,}01\quad\text{và}\quad\mathrm{P}\left(A_2\right)=2\%=0{,}02.\]
		Xác suất để chọn ngẫu nhiên một sản phẩm của công ty bị lỗi là
		\[\mathrm{P}(B)=\mathrm{P}\left(A_1\right)+\mathrm{P}\left(A_2\right)=0{,}01+0{,}02=0{,}03.\]
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2D1H3-6]
	Theo kết quả thăm dò trước một buổi biểu diễn văn nghệ ngoài trời, nếu giá bán mỗi vé là $p$ nghìn đồng thì sẽ có $x$ người mua vé xem biểu diễn, giữa $p$ và $x$ có mối liên hệ $p=489\cdot \mathrm{e}^{-0{,}001x}$. Đơn vị tổ chức nên bán vé với giá bao nhiêu nghìn đồng thì đạt được doanh thu (tổng số tiền bán vé) cao nhất?\textit{ (Làm tròn kết quả đến hàng đơn vị).}
	\shortans[]{180}
	\loigiai{
		Doanh thu $R$ được tính bằng công thức $R=x\cdot p=x\cdot 489\cdot \mathrm{e}^{-0{,}001x}$.\\
		Ta có
		\[R'(x)=489\cdot \mathrm{e}^{-0{,}001x}+x\cdot 489\cdot (-0{,}001)\cdot \mathrm{e}^{-0{,}001x}489\cdot \mathrm{e}^{-0{,}001x}\cdot (1-0{,}001x).\]
		$R'(x)=0\Leftrightarrow 1-0{,}001x=0\Leftrightarrow x=1\,000$.\\
		Với $x=1\,000$, giá vé tương ứng là $p=489\cdot \mathrm{e}^{-0{,}001\cdot 1\,000}=489\cdot \mathrm{e}^{-1}=\dfrac{489}{e}$.\\
		Làm tròn đến hàng đơn vị, ta được $p\approx180$.\\
		Vậy đơn vị tổ chức nên bán vé với giá $180$ nghìn đồng.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[2H2V2-2]
	Người ta muốn chế tạo một chiếc hộp hình hộp chữ nhật bằng tôn có nắp, có thể tích $400$ (cm$^3$) với yêu cầu dùng ít vật liệu nhất. Biết chiều cao của hình hộp chữ nhật là $4$ (cm). Chọn hệ trục tọa độ $Oxyz$ sao cho điểm $A$ trùng với gốc tọa độ $O$, các véc-tơ $\overrightarrow{AB},\overrightarrow{AD},\overrightarrow{AA'}$ lần lượt cùng hướng với $\overrightarrow{i},\overrightarrow{j},\overrightarrow{k}$. Gọi $G(x;y;z)$ là trọng tâm của tam giác $A'BD$. Tính $x+y+3z$ \textit{(kết quả làm tròn đến phần phần mười)}
	\shortans[]{10,7}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[line join=round,line cap=round,>=stealth,scale=1]
				\path
				(0,0) coordinate (A)
				(-1.5,-1.5) coordinate (B)
				(3,0) coordinate (D)
				($(B)+(D)$) coordinate (C)
				(0,3) coordinate (A')
				($(B)+(A')$) coordinate (B')
				($(C)+(A')$) coordinate (C')
				($(D)+(A')$) coordinate (D')
				(barycentric cs:A'=1,B=1,D=1) coordinate (G)
				($(B)!0.5!(D)$) coordinate (M);
				\draw[dashed] (A) -- (B);
				\draw[->] (B) -- ($(A)!1.5!(B)$) node[below left] {$x$};
				\draw[dashed] (A) -- (D);
				\draw[->] (D) -- ($(A)!1.3!(D)$) node[below] {$y$};
				\draw[dashed] (A) -- (A');
				\draw[->] (A') -- ($(A)!1.3!(A')$) node[left] {$z$};
				\draw[dashed] (B) -- (D)
				(A') -- (B)
				(A') -- (D)
				(A') -- (M);
				\draw (B) -- (C) -- (D)
				(B') -- (C') -- (D') -- (A') -- (B')
				(B) -- (B')
				(C) -- (C')
				(D) -- (D');
				\foreach \t/\g in {A/145,B/180,D/45,C/0,G/0,M/-90,A'/145,B'/90,C'/90,D'/90}{
					\fill (\t) circle (1pt) node[shift={(\g:9pt)},font = \footnotesize]{$\t$};
				}
			\end{tikzpicture}
		\end{center}
		Gọi $a$, $b$ ($a>0$, $b>0$) lần lượt là chiều dài và chiều rộng của đáy hộp chữ nhật $ABCD$ (đơn vị: cm).\\
		Theo giả thiết, thể tích của hộp là $V=a\cdot b\cdot 4=400\Rightarrow ab=100\Rightarrow b=\dfrac{100}{a}$.\\
		Diện tích toàn phần của hình hộp chữ nhật (vì hộp có nắp) là
		\[S=2ab+2\cdot 4a+2\cdot 4b=200+8a+8b=200+8a+\dfrac{800}{a}.\]
		Để dùng ít vật liệu nhất thì diện tích toàn phần $S$ phải nhỏ nhất.\\
		Áp dụng bất đẳng thức AM-GM cho hai số dương $8a$ và $\dfrac{800}{a}$, ta có
		\[8a+\dfrac{800}{a}\ge2\sqrt{8a\cdot \dfrac{800}{a}}=2\sqrt{6\,400}=160.\]
		Suy ra $S\ge200+160=360$.\\
		Dấu \lq\lq=\rq\rq\ xảy ra khi $8a=\dfrac{800}{a}\Leftrightarrow a^2=100\Rightarrow a=10$ (do $a>0$).\\
		Khi đó $b=\dfrac{100}{10}=10$. Vậy đáy hộp là hình vuông cạnh $10$ (cm).\\
		Không mất tính tổng quát, trên hệ trục tọa độ $Oxyz$ với $A(0;0;0)$, do $\overrightarrow{AB},\overrightarrow{AD},\overrightarrow{AA'}$ lần lượt cùng hướng với $\overrightarrow{i},\overrightarrow{j},\overrightarrow{k}$ và $AB=10$, $AD=10$, $AA'=4$, ta có
		\[B(10;0;0),\quadD(0;10;0),\quadA'(0;0;4).\]
		Trọng tâm $G(x;y;z)$ của tam giác $A'BD$ có tọa độ là
		\[\heva{&x=\dfrac{10+0+0}{3}=\dfrac{10}{3}\\&y=\dfrac{0+10+0}{3}=\dfrac{10}{3}\\&z=\dfrac{0+0+4}{3}=\dfrac{4}{3}.}\]
		Vậy $x+y+3z=\dfrac{10}{3}+\dfrac{10}{3}+3\cdot \dfrac{4}{3}=\dfrac{32}{3}\approx10{,}7$.
	}
\end{ex}

\begin{ex}%[Văn Minh Thoại]%[1C2V3-1]
	\immini[thm]
	{Đồ thị trong hình vẽ kí hiệu tất cả các vị trí: $A$, $B$, $C$, $D$, $E$, $Z$ trên mạng lưới giao thông công cộng. Số trên cạnh nối các ví trí biểu thị trọng số về chi phí đi lại giữa các tuyến giao thông. Một người xuất phát từ $B$ phải đi qua tất cả các tuyến đường và cuối cùng quay trở lại $B$. Tìm tổng chi phí (theo trọng số) tối ưu nhất mà người ấy có thể đi.
	\shortans[]{50}}
	{\begin{tikzpicture}[line join=round,line cap=round,>=stealth,scale=0.65]
			\tikzset{
				vertex/.style={circle,draw,thick,minimum size=8mm,inner sep=0pt,font=\large}}
			\node[vertex] (A) at (0,2) {$A$};
			\node[vertex] (B) at (2,4) {$B$};
			\node[vertex] (C) at (2.2,1) {$C$};
			\node[vertex] (D) at (5.5,4) {$D$};
			\node[vertex] (E) at (5.5,0) {$E$};
			\node[vertex] (Z) at (8,2) {$Z$};
			\draw[thick] (A) -- (B) node[midway,above left] {$4$};
			\draw[thick] (A) -- (C) node[midway,below left] {$2$};
			\draw[thick] (B) -- (C) node[midway,left] {$1$};
			\draw[thick] (B) -- (D) node[midway,above] {$5$};
			\draw[thick] (C) -- (D) node[midway,above left,pos=0.4] {$8$};
			\draw[thick] (C) -- (E) node[midway,below] {$10$};
			\draw[thick] (D) -- (E) node[midway,left] {$2$};
			\draw[thick] (D) -- (Z) node[midway,above right] {$6$};
			\draw[thick] (E) -- (Z) node[midway,below right] {$5$};
	\end{tikzpicture}}
	\loigiai{
	 Bài toán yêu cầu tìm chu trình đi qua tất cả các cạnh của đồ thị ít nhất một lần với tổng trọng số nhỏ nhất (Bài toán người đưa thư).
	\\
	Tổng trọng số của tất cả các cạnh trên đồ thị là
	\[W=4+2+1+5+8+10+2+6+5=43.\]
	Ta xét bậc của các đỉnh (số các cạnh nối với đỉnh đó) trong đồ thị
	\begin{itemize}
		\item Đỉnh $A$ có bậc $2$ (chẵn).
		\item Đỉnh $B$ có bậc $3$ (lẻ).
		\item Đỉnh $C$ có bậc $4$ (chẵn).
		\item Đỉnh $D$ có bậc $4$ (chẵn).
		\item Đỉnh $E$ có bậc $3$ (lẻ).
		\item Đỉnh $Z$ có bậc $2$ (chẵn).
	\end{itemize}
	Đồ thị có đúng hai đỉnh bậc lẻ là $B$ và $E$. Để người đó có thể xuất phát từ $B$, đi qua tất cả các tuyến đường và quay trở về $B$, đồ thị phải có dạng một chu trình Euler (tất cả các đỉnh đều phải có bậc chẵn). 
	\\
	Do đó, người này bắt buộc phải đi lặp lại một số tuyến đường nối giữa hai đỉnh bậc lẻ $B$ và $E$ để \lq\lq chẵn hóa\rq\rq\ bậc của chúng.
	\\
	Để tổng chi phí là tối ưu nhất, ta cần tìm đường đi ngắn nhất từ $B$ đến $E$ để đi lặp lại.
	\\
	Ta xét các đường đi từ $B$ đến $E$, khi đó
	\begin{itemize}
		\item Đường $B\toC\toE$ có tổng chi phí là $1+10=11$.
		\item Đường $B\toD\toE$ có tổng chi phí là $5+2=7$.
		\item Đường $B\toA\toC\toE$ có tổng chi phí là $4+2+10=16$.
	\end{itemize}
	Nhận thấy đường đi ngắn nhất từ $B$ đến $E$ là $B\toD\toE$ với chi phí là $7$.\\
	Vậy tổng chi phí (theo trọng số) tối ưu nhất mà người ấy có thể đi là $43+7=50$.
	}
\end{ex}




\Closesolutionfile{ans}
