	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[nocadre=false,lgt=1.2,espcl=2.5]{$x$ /0.6,$f'(x)$ /0.6,$f(x)$ /2}{$-\infty$,$0$,$2$,$+\infty$}
			\tkzTabLine{,+,0,-,0,+,}
			\tkzTabVar{-/ $-\infty$ ,+/ $3$ ,-/ $-1$ ,+/ $+\infty$}
		\end{tikzpicture}
	\end{center}
	Hàm số đã cho đồng biến trên khoảng nào dưới đây?
	\choice
	{$(0;2)$}
	{$(0;+\infty)$}
	{\True $(3;7)$}
	{$(-\infty;1)$}
	\loigiai{
		Theo bảng biến thiên, ta có $f'(x)>0$ trên khoảng $(2;+\infty)$ nên hàm số $f(x)$ đồng biến trên khoảng $(2;+\infty)$.\\
		Vì $(3;7)\subset (2;+\infty)$ nên hàm số đồng biến trên khoảng $(3;7)$.
	}
