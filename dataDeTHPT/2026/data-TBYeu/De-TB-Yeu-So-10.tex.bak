	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[nocadre=false,lgt=1.2,espcl=2]{$x$ /0.6,$f'(x)$ /0.6,$f(x)$ /2}{$-3$,$-1$,$0$,$1$,$2$}
			\tkzTabLine{,+,0,-,0,+,0,-,}
			\tkzTabVar{-/ $-2$ ,+/ $3$ ,-/ $0$ ,+/ $2$ ,-/ $1$}
		\end{tikzpicture}
	\end{center}
	Gọi $M$, $m$ lần lượt là giá trị lớn nhất và nhỏ nhất của hàm số $y=f(x)$ trên đoạn $[-1;2]$. Giá trị của $2M+m$ bằng
	\choice
	{$8$}
	{\True $6$}
	{$7$}
	{$4$}
	\loigiai{
		Quan sát bảng biến thiên ta thấy, xét trên đoạn $[-1;2]$ hàm số $y=f(x)$ có giá trị lớn nhất $M=3$ (tại $x=-1$) và giá trị nhỏ nhất $m=0$ (tại $x=0$).\\
