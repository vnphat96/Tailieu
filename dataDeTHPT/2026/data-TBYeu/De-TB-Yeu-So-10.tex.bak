\begin{ex}%[Văn Minh Thoại]%[1D2H2-3]
	Cho cấp số cộng $(u_n)$, biết số thứ mười $u_{10}=30$, công sai $d=2$. Số hạng đầu của cấp số cộng là
	\choice
	{$u_1=15$}
	{\True $u_1=12$}
	{$u_1=28$}
	{$u_1=10$}
	\loigiai{
		Do $(u_n)$ là cấp số cộng nên ta có công thức số hạng tổng quát là
		\begin{eqnarray*}
&&u_n=u_1+(n-1)d\\&\Rightarrow &u_{10}=u_1+9d\\&\Leftrightarrow &30=u_1+9\cdot 2\\&\Leftrightarrow &u_1=12.
\end{eqnarray*}
	}
\end{ex}


