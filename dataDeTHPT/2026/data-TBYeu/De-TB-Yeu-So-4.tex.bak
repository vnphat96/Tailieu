\begin{ex}
	Lớp $12$A$1$ có $48$ bạn đều giỏi ít nhất một trong hai môn Toán và Lý, trong đó có $36$ bạn giỏi Toán, $24$ bạn giỏi Lý. Chọn ngẫu nhiên $1$ bạn. Xác suất chọn được bạn giỏi Toán, biết bạn đó giỏi Lý là bao nhiêu?
	\shortans[]{0,5}
	\loigiai{
		Xét các biến cố:\\
		$A$: \lq\lq Chọn được bạn giỏi Toán\rq\rq.\\
		$B$: \lq\lq Chọn được bạn giỏi Lý\rq\rq.\\
		Khi đó, $\mathrm{P}(A)=\dfrac{36}{48}=0{,}75$; $\mathrm{P}(B)=\dfrac{24}{48}=0{,}5$; $\mathrm{P}(A\cup B)=1$.\\
		Suy ra $\mathrm{P}(A\cap B)=\mathrm{P}(A)+\mathrm{P}(B)-\mathrm{P}(A\cup B)=0{,}75+0{,}5-1=0{,}25$.\\
		Vậy xác suất cần tìm là
		\[\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)}=\dfrac{0{,}25}{0{,}5}=0{,}5.\]
	}
\end{ex}

\begin{ex}
	Một chiếc đèn chùm có khối lượng $m=10$ kg được thiết kế với đĩa đèn được giữ bởi bốn đoạn cáp $SA$, $SB$, $SC$, $SD$ cùng chất liệu và không đàn hồi sao cho $S.ABCD$ là hình chóp tứ giác đều. Biết rằng gia tốc rơi tự do là $g=10$ m/s$^2$. Tìm độ lớn của lực căng của mỗi sợi dây cáp (đơn vị N).
\shortans[]{25}
	\loigiai{
		Ta có độ lớn của trọng lực $\overrightarrow{P}$ tác động lên chiếc đèn chùm là $\big|\overrightarrow{P}\big|=m\cdot g=100$ (N).\\
		Gọi $O$ là tâm hình chữ nhật $ABCD$. Theo bài toán thì hình chóp $S.ABCD$ có đường cao là $SO$.\\
		Gọi $\overrightarrow{F}_1$, $\overrightarrow{F}_2$, $\overrightarrow{F}_3$, $\overrightarrow{F}_4$ lần lượt là lực căng trên các dây $S\!A$, $S\!B$, $S\!C$, $S\!D$.\\
		Theo quy tắc hình bình hành: $\overrightarrow{F}_1+\overrightarrow{F}_3=2\overrightarrow{SO}$; $\overrightarrow{F}_2+\overrightarrow{F}_4=2\overrightarrow{SO}$.\\
		Suy ra $\overrightarrow{F}_1+\overrightarrow{F}_3+\overrightarrow{F}_2+\overrightarrow{F}_4=4\overrightarrow{SO}$.\\
		Vì chiếc đèn ở vị trí cân bằng nên $\overrightarrow{P}=\overrightarrow{F}_1+\overrightarrow{F}_2+\overrightarrow{F}_3+\overrightarrow{F}_4=4\overrightarrow{SO}$.\\
		Độ lớn của lực căng trên mỗi dây bằng nhau và bằng $\big|\overrightarrow{F}_i\big|=\dfrac{\big|\overrightarrow{P}\big|}{4}$.\\
		Suy ra $\big|\overrightarrow{F}_1\big|=\dfrac{\big|\overrightarrow{P}\big|}{4}=\dfrac{100}{4}=25$ (N).
	}
\end{ex}

\begin{ex}
	Giả sử hàm số $f(x)=x^3-6x^2+9x-1$ đạt cực đại tại $x=a$ và đạt cực tiểu tại $x=b$. Giá trị của biểu thức $A=2a+b$ là bao nhiêu?
	\shortans[]{5}
	\loigiai{
		Ta có $f'(x)=3x^2-12x+9$.\\
		Cho $f'(x)=0\Leftrightarrow 3x^2-12x+9=0\Leftrightarrow \hoac{&x=1\\&x=3.}$\\
		Hàm số đã cho đạt cực đại tại $x=1$ và cực tiểu tại $x=3$.\\
		Khi đó $\heva{&a=1\\&b=3}\Rightarrow A=2\cdot 1+3=5$.
	}
\end{ex}

\begin{ex}
	\immini[thm]{
	Cho hàm số $f(x)$ liên tục trên $\mathbb{R}$. Đồ thị hàm số $y=f'(x)$ được cho như hình bên. Diện tích các hình phẳng $(K)$, $(H)$ lần lượt là $\dfrac{5}{12}$ và $\dfrac{8}{3}$. Biết $f(-1)=\dfrac{19}{12}$, biết $f(2)=-\dfrac{a}{b}$ với $\dfrac{a}{b}$ là phân số tối giản, $a>0$ và $b>0$. Tính $a+b$.
	\shortans[]{5}
	}
	{
	\begin{tikzpicture}[scale=0.85, font=\footnotesize, line join=round, line cap=round, >=stealth]
		% 1. Khai báo hàm số f(x) = x^3 - x^2 - 2x
		\def\f(#1){(#1)^3-(#1)^2-2*(#1)}
		
		% 2. Tô nền miền K và H bằng mẫu gạch sọc (north east lines)
		% Miền K (từ x = -1 đến x = 0)
		\fill[pattern=north east lines, smooth] (-1,0) plot[domain=-1:0, samples=100] (\x, {\f(\x)}) -- (0,0) -- cycle;
		% Miền H (từ x = 0 đến x = 2)
		\fill[pattern=north east lines, smooth] (0,0) plot[domain=0:2, samples=100] (\x, {\f(\x)}) -- (2,0) -- cycle;
		
		% 3. Vẽ hệ trục tọa độ Oxy
		\draw[->] (-2,0) -- (3,0) node[below] {$x$};
		\draw[->] (0,-2.5) -- (0,2) node[right] {$y$};
		
		% 4. Chú thích các điểm trên trục
		\path 
		(0,0) node[below left] {$O$}
		(-1,0) node[above left] {$-1$}
		(2,0) node[below right] {$2$}
		;
		
		% 5. Đặt tên miền K và H
		\path 
		(-0.5, 0.25) node[fill=white] {$K$}
		(1, -1) node[fill=white] {$H$}
		;
		
		% 6. Vẽ đường cong đồ thị hàm số
		\draw[smooth,domain=-1.4:2.3, samples=150] plot (\x, {\f(\x)});
	\end{tikzpicture}
	}
	\loigiai{
		Ta có $S_K=\displaystyle\int \limits_{-1}^{0}f'(x)\mathrm{\,d}x=f(0)-f(-1)=\dfrac{5}{12}\Rightarrow f(0)=\dfrac{5}{12}+f(-1)=\dfrac{5}{12}+\dfrac{19}{12}=2$.\\
		Lại có $S_H=\displaystyle\int \limits_{0}^{2}\big|f'(x)\big|\mathrm{\,d}x=-\displaystyle\int \limits_{0}^{2}f'(x)\mathrm{\,d}x=f(0)-f(2)=\dfrac{8}{3}$.\\
		Suy ra $f(2)=f(0)-\dfrac{8}{3}=2-\dfrac{8}{3}=-\dfrac{2}{3}$.\\
		Vậy $a+b=5$.
	}
\end{ex}

\begin{ex}
	Chào đón năm mới $2025$, Thành phố trang trí đèn led cho biểu tượng hình chữ V được ghép từ các thanh $AB=4$ m, $AC=5$ m sao cho tam giác $ABC$ vuông tại $B$. Để tăng hiệu ứng, các kỹ sư đã thiết kế một chuỗi led chạy từ $B$ xuống $A$ với vận tốc $4$ m/phút và một chuỗi led chạy từ $A$ lên $C$ với vận tốc $10$ m/phút. Sau khi đóng nguồn điện thì cả hai chuỗi led đồng thời xuất phát. Hỏi sau bao nhiêu giây từ thời điểm đóng nguồn điện thì khoảng cách giữa hai điểm sáng đầu tiên của hai chuỗi led là nhỏ nhất?
	\shortans[]{16}
	\loigiai{
		\begin{center}
			\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round, >=stealth]
				% Khai báo các điểm
				\path 
				(0,-3) coordinate (A)
				(0,0) coordinate (B) node[below left] {$O$}
				(2,0) coordinate (C)
				;
				
				% Khai báo điểm D trên đoạn AB và điểm E trên đoạn AC
				\path ($(A)!.6!(B)$) coordinate (D);
				\path ($(A)!.6!(C)$) coordinate (E);
				
				% Vẽ trục tọa độ
				\draw[->, thick] (-1,0) -- (4,0) node[above right] {$x$};
				\draw[->, thick] (0,-3.5) -- (0,1) node[right] {$y$};
				
				% Vẽ các đoạn thẳng
				\draw[thick] (A) -- (C);
				\draw[thick] (A) -- (B);
				\draw[densely dotted] (D) -- (E);
				
				% Hiển thị tên điểm
				\foreach \x/\g in {A/-135, B/135, C/90, D/180, E/0}
				\fill (\x) circle (1pt) +(\g:3mm) node{$\x$};
			\end{tikzpicture}
		\end{center}
		Đặt hệ trục tọa độ $Oxy$ như hình vẽ, với mỗi đơn vị trên trục là $1$ m.\\
		Ta có $B(0;0)$, $A(0;-4)$, $C(3;0)$.\\
		Gọi $D$ là điểm sáng đầu tiên của chuỗi led $B\!A$ và $E$ là điểm sáng đầu tiên của chuỗi led $AC$ sau khi đóng nguồn điện.\\
		Vì $D\in Oy$ và chuỗi led chạy từ $B$ xuống $A$ với vận tốc $4$ m/phút nên $D(0;-4t)$ với $t$ là thời gian được tính bằng phút.\\
		Vì $E\in AC$ và chuỗi led chạy từ $A$ lên $C$ với vận tốc $10$ m/phút nên $E(6t;8t-4)$ với $t$ là thời gian được tính bằng phút.\\
		Ta có khoảng cách giữa hai điểm sáng đầu tiên của hai chuỗi led là
		\[DE=\sqrt{(6t)^2+(12t-4)^2}=\sqrt{180t^2-96t+16}=\sqrt{180\left(t-\dfrac{4}{15}\right)^2+\dfrac{4}{225}}\ge\dfrac{4\sqrt{5}}{15}.\]
		Dấu \lq\lq $=$\rq\rq\ xảy ra khi $t=\dfrac{4}{15}$ phút $=16$ giây.\\
		Vậy sau $16$ giây từ thời điểm đóng nguồn điện thì khoảng cách giữa hai điểm sáng đầu tiên của hai chuỗi led là nhỏ nhất.
	}
\end{ex}

\Closesolutionfile{ans}
