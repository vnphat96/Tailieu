\begin{ex}
	Trong không gian với hệ toạ độ $Oxyz$, cho hai vectơ $\overrightarrow{a}=(2;-3;1)$ và $\overrightarrow{b}=(-1;0;4)$. Toạ độ vectơ $\overrightarrow{u}=-2\overrightarrow{a}+3\overrightarrow{b}$ là
	\choice
	{$\overrightarrow{u}=(-7;6;-10)$}
	{$\overrightarrow{u}=(7;6;10)$}
	{\True $\overrightarrow{u}=(-7;6;10)$}
	{$\overrightarrow{u}=(-7;-6;10)$}
	\loigiai{
		Ta có $\overrightarrow{u}=-2\overrightarrow{a}+3\overrightarrow{b}=\big(-2\cdot 2+3\cdot (-1);-2\cdot (-3)+3\cdot 0;-2\cdot 1+3\cdot 4\big)=(-7;6;10)$.
	}
\end{ex}

\begin{ex}
	Cho hàm số $y=f(x)$ có bảng biến thiên như sau:
	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[nocadre=false, lgt=1.2, espcl=2, deltacl=0.5]
			{$x$/0.6,$f'(x)$/0.6,$f(x)$/2.5}
			{$-\infty$,$-2$,$0$,$2$,$+\infty$}
			\tkzTabLine{,+,0,-,0,+,0,-,}
			\tkzTabVar{-/$-\infty$,+/$3$,-/$0$,+/$3$,-/$-\infty$}
		\end{tikzpicture}
	\end{center}
	Hàm số đã cho đồng biến trong khoảng nào sau đây?
	\choice
	{$(-\infty;0)$}
	{\True $(0;2)$}
	{$(0;+\infty)$}
	{$(-2;0)$}
	\loigiai{
		Dựa vào bảng biến thiên ta thấy, hàm số đã cho đồng biến trong khoảng $(-\infty;-2)$ và $(0;2)$.
	}
\end{ex}

\begin{ex}
	Nghiệm của phương trình $\sin x=\dfrac{1}{2}$ là
	\choice
	{$\hoac{&x=\dfrac{\pi}{3}+k2\pi\\&x=\dfrac{2\pi}{3}+k2\pi}$}
	{\True $\hoac{&x=\dfrac{\pi}{6}+k2\pi\\&x=\dfrac{5\pi}{6}+k2\pi}$}
	{$x=\dfrac{2\pi}{3}+k2\pi$}
	{$x=\dfrac{\pi}{3}+k\pi$}
	\loigiai{
		Ta có $\sin x=\dfrac{1}{2}\Leftrightarrow \sin x=\sin \dfrac{\pi}{6}\Leftrightarrow \hoac{&x=\dfrac{\pi}{6}+k2\pi\\&x=\dfrac{5\pi}{6}+k2\pi}.$ 
	}
\end{ex}

\begin{ex}
	Giá trị lớn nhất của hàm số $f(x)=2x^3+3x^2-12x+2$ trên đoạn $[-1;2]$ là
	\choice
	{$10$}
	{$11$}
	{\True $15$}
	{$6$}
	\loigiai{
		Hàm số đã xác định và liên tục trên $[-1;2]$.\\
		Ta có $f'(x)=6x^2+6x-12$; $\heva{&x\in (-1;2)\\&f'(x)=0}\Leftrightarrow x=1$.\\
		Tính được $f(-1)=15$; $f(2)=6$; $f(1)=-5\Rightarrow \max \limits_{[-1;2]}f(x)=15$.
	}
\end{ex}

\begin{ex}
	Cho hai biến cố $A$ và $B$ có $\mathrm{P}(A)=0{,}3$; $\mathrm{P}(B)=0{,}6$; $\mathrm{P}(A\cap B)=0{,}2$. Xác suất $\mathrm{P}(A|B)$ là
	\choice
	{\True $\dfrac{1}{3}$}
	{$\dfrac{1}{2}$}
	{$\dfrac{1}{6}$}
	{$\dfrac{2}{3}$}
	\loigiai{
		Theo định nghĩa xác suất có điều kiện ta có $\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)}=\dfrac{0{,}2}{0{,}6}=\dfrac{1}{3}$.
	}
\end{ex}

\begin{ex}
	Cho $f(x)$ và $g(x)$ là các hàm số liên tục bất kì trên đoạn $[a;b]$. Mệnh đề nào sau đây đúng?
	\choice
	{$\left|\displaystyle\int \limits_{a}^{b}\big(f(x)-g(x)\big)\mathrm{\,d}x\right|=\displaystyle\int \limits_{a}^{b}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{a}^{b}g(x)\mathrm{\,d}x$}
	{$\displaystyle\int \limits_{a}^{b}\big(f(x)-g(x)\big)\mathrm{\,d}x=\left|\displaystyle\int \limits_{a}^{b}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{a}^{b}g(x)\mathrm{\,d}x\right|$}
	{$\displaystyle\int \limits_{a}^{b}\big|f(x)-g(x)\big|\mathrm{\,d}x=\displaystyle\int \limits_{a}^{b}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{a}^{b}g(x)\mathrm{\,d}x$}
	{\True $\displaystyle\int \limits_{a}^{b}\big(f(x)-g(x)\big)\mathrm{\,d}x=\displaystyle\int \limits_{a}^{b}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{a}^{b}g(x)\mathrm{\,d}x$}
	\loigiai{
		Theo tính chất của tích phân ta có $\displaystyle\int \limits_{a}^{b}\big(f(x)-g(x)\big)\mathrm{\,d}x=\displaystyle\int \limits_{a}^{b}f(x)\mathrm{\,d}x-\displaystyle\int \limits_{a}^{b}g(x)\mathrm{\,d}x$ là mệnh đề đúng.
	}
\end{ex}

\begin{ex}
	Trong các dãy số sau, dãy số nào là một cấp số cộng?
	\choice
	{$1;3;1;3;1$}
	{$1;3;7;10;13$}
	{\True $1;4;7;10;13$}
	{$2;4;5;6;8$}
	\loigiai{
		Dãy số $(u_n)$ có tính chất $u_{n+1}=u_n+d$ thì được gọi là một cấp số cộng.\\
		Ta thấy dãy số $1;4;7;10;13$ là một cấp số cộng có số hạng đầu là $u_1=1$ và công sai bằng $d=3$.
	}
\end{ex}

\begin{ex}
	Họ nguyên hàm của hàm số $f(x)=\sin x-1$ là
	\choice
	{$-\cos x+C$}
	{$\cos x-x+C$}
	{$\cos x+C$}
	{\True $-\cos x-x+C$}
	\loigiai{
		Ta có $\displaystyle\int (\sin x-1)\mathrm{\,d}x=-\cos x-x+C$.
	}
\end{ex}

\begin{ex}
	Cho mẫu số liệu ghép nhóm sau
	\begin{longtable}{|l|c|c|c|c|}
