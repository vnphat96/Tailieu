	Trung vị của mẫu số liệu trên là
	\choice
	{$40$}
	{$55$}
	{$45$}
	{\True $50$}
	\loigiai{
		Ta có $\dfrac{n}{2}=15\Rightarrow k=2\Rightarrow r=45$; $n_k=11$; $cf_{k-1}=4$; $d=5\Rightarrow M_{\text{e}}=45+\dfrac{15-4}{11}\cdot 5=50$.
	}
\end{ex}

\begin{ex}
	Cho hình chóp $S.ABC$ có cạnh bên $S\!A$ vuông góc mặt đáy $(ABC)$. Góc tạo bởi $S\!B$ và đáy tương ứng là
	\choice
	{$\widehat{SCA}$}
	{\True $\widehat{SBA}$}
	{$\widehat{SAB}$}
	{$\widehat{SBC}$}
