\begin{ex}
	Trong một kì thi tốt nghiệp trung học phổ thông, một tỉnh $X$ có $50\%$ học sinh lựa chọn tổ hợp B00. Biết rằng, nếu một học sinh chọn tổ hợp B00 thì xác suất để học sinh đó đỗ đại học là $0{,}6$; còn nếu một học sinh không chọn tổ hợp B00 thì xác suất để học sinh đó đỗ đại học là $0{,}7$. Chọn ngẫu nhiên một học sinh của tỉnh $X$ đã tốt nghiệp trung học phổ thông trong kì thi trên. Biết rằng học sinh này đã đỗ đại học. Gọi $A$ là biến cố: \lq\lq Học sinh đó chọn tổ hợp B00\rq\rq; $B$ là biến cố: \lq\lq Học sinh đó đỗ đại học\rq\rq.
	Xét tính đúng-sai của các mệnh đề sau:
	\choiceTF
	{\True $\dfrac{\mathrm{P}(A|B)}{\mathrm{P}(B|A)}$ lớn hơn $\dfrac{2}{3}$}
	{Xác suất $\mathrm{P}(B|A)=0{,}4$}
	{\True Xác suất $\mathrm{P}\left(\overline{A}\right)=0{,}5$}
	{Xác suất $\mathrm{P}\left(B|\overline{A}\right)$ thuộc khoảng $(0{,}2;0{,}5)$}
	\loigiai{
		
		
		\begin{itemchoice}
			\itemch Đúng. 
			Ta có $\mathrm{P}(A)=0{,}5\Rightarrow \mathrm{P}\left(\overline{A}\right)=1-0{,}5=0{,}5$.\\
			Xác suất học sinh đỗ đại học với điều kiện chọn tổ hợp B00 là $\mathrm{P}(B|A)=0{,}6$.\\
			Xác suất học sinh đỗ đại học với điều kiện không chọn tổ hợp B00 là $\mathrm{P}\left(B|\overline{A}\right)=0{,}7$.\\
			Xác suất học sinh đỗ đại học là:
			\[\mathrm{P}(B)=\mathrm{P}(A)\cdot \mathrm{P}(B|A)+\mathrm{P}\left(\overline{A}\right)\cdot \mathrm{P}\left(B|\overline{A}\right)=0{,}5\cdot 0{,}6+0{,}5\cdot 0{,}7=0{,}65.\]
			Theo công thức Bayes, xác suất học sinh chọn tổ hợp B00 biết rằng học sinh đó đỗ đại học là:
			\[\mathrm{P}(A|B)=\dfrac{\mathrm{P}(A)\cdot \mathrm{P}(B|A)}{\mathrm{P}(B)}=\dfrac{0{,}5\cdot 0{,}6}{0{,}65}=\dfrac{0{,}3}{0{,}65}=\dfrac{6}{13}.\]
			
			Xét tỉ số $\dfrac{\mathrm{P}(A|B)}{\mathrm{P}(B|A)}=\dfrac{6/13}{0{,}6}=\dfrac{10}{13}$. Vì $\dfrac{10}{13}>\dfrac{2}{3}$ nên phát biểu này đúng.
			\itemch Sai. Theo giả thiết, xác suất để học sinh đỗ đại học nếu chọn tổ hợp B00 là $0{,}6$, do đó $\mathrm{P}(B|A)=0{,}6$.
			\itemch Đúng. Ta tính được $\mathrm{P}\left(\overline{A}\right)=0{,}5$.
			\itemch Sai. Theo giả thiết, xác suất để học sinh đỗ đại học nếu không chọn tổ hợp B00 là $0{,}7$, do đó $\mathrm{P}\left(B|\overline{A}\right)=0{,}7\notin(0{,}2;0{,}5)$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Tại một nhà máy sản xuất một loại phân bón, gọi $P$ là lợi nhuận thu được từ việc bán $x$ sản phẩm trong một tuần. Khi đó đạo hàm $P'$ gọi là lợi nhuận cận biên, cho biết tốc độ tăng lợi nhuận theo lượng sản phẩm bán được. Giả sử lợi nhuận cận biên của nhà máy được ước lượng bởi công thức $P'(x)=17-0{,}025x$ với $0\le x\le100$. Biết nhà máy lỗ $24$ triệu đồng nếu không bán được lượng sản phẩm nào trong tuần.
	\choiceTF
	{\True Lợi nhuận nhà máy thu được khi bán $80$ tấn sản phẩm trong tuần là $1$ tỉ $256$ triệu đồng}
	{Công thức lợi nhuận thu được từ việc bán $x$ sản phẩm trong một tuần là $P(x)=17x-0{,}0125x^2+C$ với $C$ là một hằng số bất kỳ}
	{Nếu nhà máy bán được từ $1{,}3$ tấn sản phẩm trên tuần trở lên thì nhà máy luôn có lãi}
	{Có thể tính được lợi nhuận của nhà máy thu được khi bán $120$ tấn sản phẩm trong tuần}
	\loigiai{
	
		\begin{itemchoice}
			\itemch Đúng. Ta có hàm lợi nhuận:
			\[P(x)=\displaystyle\int P'(x)\mathrm{\,d}x=\displaystyle\int (17-0{,}025x)\mathrm{\,d}x=17x-0{,}0125x^2+C.\]
			Vì nhà máy lỗ $24$ triệu đồng nếu không bán được sản phẩm nào nên $P(0)=-24\Rightarrow C=-24$.\\
			Vậy $P(x)=17x-0{,}0125x^2-24$ (áp dụng với $0\le x\le100$).\\
			Khi bán $80$ tấn sản phẩm ($x=80$), lợi nhuận là $P(80)=17\cdot 80-0{,}0125\cdot 80^2-24=1\,256$ (triệu đồng), tương đương $1$ tỉ $256$ triệu đồng.
			\itemch Sai. Hằng số $C$ được xác định cụ thể là $C=-24$, không phải là một hằng số bất kỳ.
			\itemch Sai. Nhà máy có lãi khi $P(x)>0\Leftrightarrow 17x-0{,}0125x^2-24>0\Leftrightarrow 1{,}41<x<1\,358{,}5$. Nếu bán $1{,}3$ tấn ($x=1{,}3$) thì $P(1{,}3)<0$, nhà máy vẫn bị lỗ.
			\itemch Sai. Công thức lợi nhuận $P(x)$ được cho chỉ áp dụng với điều kiện $0\le x\le100$. Do đó, không thể dùng công thức này để tính chính xác lợi nhuận khi bán $120$ tấn sản phẩm.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Trong không gian $Oxyz$, cho đường thẳng $(d)\colon \dfrac{x+1}{1}=\dfrac{y+3}{2}=\dfrac{z+2}{2}$ và mặt cầu $(S)$ có tâm $I(3;2;0)$. Đường thẳng $(d)$ cắt mặt cầu $(S)$ tại hai điểm $A$, $B$ sao cho $AB=8$. Các khẳng định sau đây đúng hay sai?
	\choiceTF
	{Gọi $H$ là hình chiếu vuông góc của $I$ lên $(d)$. Khi đó $H(1;-1;2)$}
	{\True Phương trình mặt phẳng $(P)$ đi qua $I(3;2;0)$ và vuông góc với đường thẳng $(d)$ là $x+2y+2z-7=0$}
	{\True Phương trình mặt cầu $(S)$ là $(x-3)^2+(y-2)^2+z^2=25$}
	{\True Mặt cầu $(S)$ có bán kính $R=5$}
	\loigiai{
		\begin{itemchoice}
			\itemch Sai. Mặt phẳng $(P)$ đi qua $I(3;2;0)$ và vuông góc với $(d)$ nhận $\overrightarrow{u}_d=(1;2;2)$ làm vectơ pháp tuyến. \\
			Phương trình $(P)$ là: $1(x-3)+2(y-2)+2(z-0)=0\Leftrightarrow x+2y+2z-7=0$.\\
			Tọa độ hình chiếu vuông góc $H$ của $I$ lên $(d)$ là giao điểm của $(d)$ và $(P)$.\\
			Đường thẳng $(d)$ có phương trình tham số: $\heva{&x=-1+t\\&y=-3+2t\\&z=-2+2t}$. Thay vào $(P)$ ta được:
			\[(-1+t)+2(-3+2t)+2(-2+2t)-7=0\Leftrightarrow 9t-18=0\Leftrightarrow t=2.\]
			Suy ra tọa độ điểm $H(1;1;2)$.
			\itemch Đúng. Phương trình mặt phẳng $(P)$ là $x+2y+2z-7=0$.
			\itemch Đúng. Khoảng cách từ $I$ đến $(d)$ là $IH=\sqrt{(1-3)^2+(1-2)^2+(2-0)^2}=\sqrt{4+1+4}=3$.\\
			Bán kính mặt cầu $(S)$ là $R=\sqrt{IH^2+\left(\dfrac{AB}{2}\right)^2}=\sqrt{3^2+4^2}=5$.\\
			Phương trình mặt cầu $(S)$ là: $(x-3)^2+(y-2)^2+z^2=25$.
			\itemch Đúng. Mặt cầu $(S)$ có bán kính $R=5$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}
	Sau khi phát hiện một bệnh dịch lở mồm long móng ở đàn gia súc của một xã vùng cao, cán bộ y tế ước tính số gia súc nhiễm bệnh kể từ ngày xuất hiện gia súc nhiễm bệnh đầu tiên đến ngày thứ $t$ là $G(t)=45t^2-t^3$.
	\choiceTF
	{\True Nếu xem $G'(t)$ là tốc độ truyền bệnh tại thời điểm $t$ thì tốc độ truyền bệnh lớn nhất sẽ vào ngày thứ $15$}
	{\True $G'(t)=90t-3t^2$}
	{Tốc độ truyền bệnh giảm trong khoảng $(0;30)$}
	{$G(0)=0;G(15)=625$}
	\loigiai{
		
		\begin{itemchoice}
			\itemch Đúng. Ta có tốc độ truyền bệnh tại thời điểm $t$ là hàm số: $G'(t)=\left(45t^2-t^3\right)'=90t-3t^2$.\\
			Xét đạo hàm $G''(t)=90-6t$. Cho $G''(t)=0\Leftrightarrow t=15$.\\
			Xét bảng biến thiên của $G'(t)$
			\begin{center}
				\begin{tikzpicture}
					\tkzTabInit[nocadre=true, lgt=1.2, espcl=4, deltacl=0.5]
					{$t$/0.7, $G''(t)$/0.7, $G'(t)$/2}
					{$0$, $15$, $+\infty$}
					\tkzTabLine{, +, 0, -,}
					\tkzTabVar{-/$0$, +/$675$, -/$-\infty$}
				\end{tikzpicture}
			\end{center}
			Hàm số $G'(t)$ đồng biến trên khoảng $(0;15)$, nghịch biến trên khoảng $(15;+\infty)$ và đạt cực đại tại $t=15$.\\
			Dựa vào sự biến thiên của hàm $G'(t)$, tốc độ truyền bệnh đạt lớn nhất tại $t=15$ (tức ngày thứ $15$).
			\itemch Đúng. Ta có $G'(t)=90t-3t^2$.
			\itemch Sai. Tốc độ truyền bệnh tăng trong khoảng $(0;15)$ và giảm trong khoảng $(15;30)$ thay vì giảm trên toàn khoảng $(0;30)$.
			\itemch Sai. Ta tính được $G(0)=0$ nhưng $G(15)=45\cdot 15^2-15^3=6\,750\neq625$.
		\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


