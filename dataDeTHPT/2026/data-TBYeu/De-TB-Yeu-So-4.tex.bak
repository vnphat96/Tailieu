\begin{ex}
	Nghiệm của phương trình $\log _2(x+1)=\log _2(1-3x)$ là
	\choice
	{$x=1$}
	{$x=3$}
	{\True $x=0$}
	{$x=2$}
	\loigiai{
		Điều kiện: $\heva{&x+1>0\\&1-3x>0}\Leftrightarrow \heva{&x>-1\\&x<\dfrac{1}{3}}\Leftrightarrow -1<x<\dfrac{1}{3}$.\\
		Ta có $\log _2(x+1)=\log _2(1-3x)\Leftrightarrow \heva{&-1<x<\dfrac{1}{3}\\&x+1=1-3x}\Leftrightarrow \heva{&-1<x<\dfrac{1}{3}\\&4x=0}\Leftrightarrow x=0$.\\
		Vậy nghiệm của phương trình đã cho là $x=0$.
	}
\end{ex}


