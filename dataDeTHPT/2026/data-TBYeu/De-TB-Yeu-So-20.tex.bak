\begin{ex}%[2H5H2-3]
	Trong không gian $Oxyz$, cho điểm $M(1;0;1)$ và đường thẳng $d\colon \dfrac{x-1}{1}=\dfrac{y-2}{2}=\dfrac{z-3}{3}$. Gọi $\Delta$ là đường thẳng đi qua $M$, vuông góc với $d$ và cắt $Oz$.
	\choiceTF
	{Đường thẳng $\Delta$ có phương trình $\dfrac{x-1}{-3}=\dfrac{y}{0}=\dfrac{z-1}{1}$}
	{Đường thẳng $\Delta$ đi qua điểm $K(4;-1;0)$}
	{\True Đường thẳng $\Delta$ có phương trình $\heva{&x=1-3t\\ &y=0 \qquad (t\in\mathbb{R})\\ &z=1+t}$}
	{\True Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u}=(-3;0;1)$}
	\loigiai{
		\begin{itemchoice}
			\itemch Gọi $N = \Delta \cap Oz \Rightarrow N \in Oz \Rightarrow N(0;0;c)$. \\
			Đường thẳng $\Delta$ đi qua $M$ và $N$ nên $\Delta$ có $1$ vectơ chỉ phương là $\overrightarrow{MN}=(-1;0;c-1)$. \\
			Đường thẳng $d$ có $1$ vectơ chỉ phương $\overrightarrow{u}_d=(1;2;3)$. \\
			Ta có $\Delta \perp d \Leftrightarrow \overrightarrow{u}_d \cdot \overrightarrow{MN} = 0 \Leftrightarrow 1\cdot(-1)+2\cdot 0+3(c-1)=0 \Leftrightarrow c=\dfrac{4}{3}$. \\
			Suy ra $\Delta$ có $1$ vectơ chỉ phương $\overrightarrow{u}_\Delta = 3\overrightarrow{MN}=(-3;0;1)$. \\
			Do đó, đường thẳng $\Delta$ không tồn tại phương trình chính tắc do $\overrightarrow{u}_\Delta=(-3;0;1)$ có tung độ bằng $0$.
			\itemch Thay tọa độ điểm $K(4;-1;0)$ vào phương trình đường thẳng $\Delta$ không thỏa mãn.
			\itemch Đường thẳng $\Delta$ đi qua $M(1;0;1)$ và có $\overrightarrow{u}_\Delta=(-3;0;1)$ nên có phương trình tham số $$\heva{&x=1-3t\\ &y=0\\ &z=1+t.}$$
			\itemch Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u}=(-3;0;1)$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D1H4-1]
	Cho hàm số $y=\dfrac{-x^2+x+1}{x+1}$ có đồ thị $(C)$.
	\choiceTF
	{Đồ thị $(C)$ không cắt trục $Ox$}
	{\True Hàm số có hai điểm cực trị}
	{Đồ thị $(C)$ có tiệm cận xiên đi qua điểm $A(1;2)$}
	{\True Hàm số đồng biến trên các khoảng $(-2;-1)$ và $(-1;0)$}
	\loigiai{
		\begin{itemchoice}
			\itemch Từ phương trình hoành độ giao điểm $\dfrac{-x^2+x+1}{x+1}=0$ suy ra $-x^2+x+1=0$ $(*)$. \\
			Nhận thấy $x=-1$ không phải là nghiệm của phương trình $(*)$ và phương trình $(*)$ luôn có hai nghiệm phân biệt.\\
Vậy $(C)$ luôn cắt $Ox$ tại hai điểm phân biệt.
			\itemch Ta có $y = \dfrac{-x^2+x+1}{x+1} = -x+2-\dfrac{1}{x+1}$. \\
			Đạo hàm $y' = \dfrac{-x^2-2x}{(x+1)^2}$. Khi đó, 
			$y'=0 \Leftrightarrow \hoac{&x=0\\ &x=-2.}$ \\
Bảng biến thiên \begin{center}
\begin{tikzpicture}
\tkzTabInit[nocadre=false, lgt=1.2, espcl=2.5, deltacl=0.6]{$x$/0.6,$y'$/0.6,$y$/2}
{$-\infty$, $-2$, $-1$, $0$, $+\infty$}
\tkzTabLine {,-,0,+,d,+,0,-,}
\tkzTabVar{+/$+\infty$, -/, +D- /$+\infty$/ $-\infty$,+/,-/$-\infty$}
\end{tikzpicture}
\end{center}
			Bảng biến thiên cho thấy hàm số có hai điểm cực trị (một cực đại và một cực tiểu).
			\itemch Tiệm cận xiên của đồ thị là $y=-x+2$. Thay tọa độ điểm $A(1;2)$ vào phương trình ta được $2 = -1+2$ (vô lý). Vậy đường tiệm cận xiên của đồ thị $(C)$ không đi qua điểm $A(1;2)$.
			\itemch Bảng biến thiên cho thấy hàm số  hàm số đồng biến trên các khoảng $(-2;-1)$ và $(-1;0)$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D4H2-6]
	Trong $5$ giây đầu tiên, một chất điểm chuyển động với vận tốc $v(t)=-3t^2+12t+1$ (m/s). Gọi $s(t)$ là quãng đường chuyển động của chất điểm theo thời gian (giây). Trong các khẳng định sau, khẳng định nào đúng hay sai?
	\choiceTF
	{Trong $5$ giây đầu tiên, vận tốc lớn nhất của chất điểm là $3$ (m/s)}
	{\True Trong khoảng thời gian từ $t=2$ đến $t=5$ vận tốc của chất điểm giảm dần}
	{\True Quãng đường chuyển động của chất điểm trong $5$ giây đầu tiên là $30$ (m)}
	{Vận tốc của vật tại thời điểm $t=2$ là $v(2)=1$ (m/s)}
	\loigiai{
		\begin{itemchoice}
			\itemch Ta có $v'(t)=-6t+12$ và $v'(t)=0 \Leftrightarrow t=2$. \\
Bảng biến thiên
\begin{center}
\begin{tikzpicture}
\tkzTabInit[nocadre=false, lgt=1.2, espcl=2.5, deltacl=0.6]{$t$/0.6,$v'(t)$/0.6,$v(t)$/2}
{$0$, $2$, $5$}
\tkzTabLine {,+,0,-,}
\tkzTabVar{-/$1$, +/$13$, -/$-14$}
\end{tikzpicture}
\end{center}
Bảng biến thiên cho thấy trong $5$ giây đầu tiên, vận tốc lớn nhất của chất điểm là $13$ (m/s).
			\itemch Bảng biến thiên cho thấy trong khoảng thời gian từ $t=2$ đến $t=5$ vận tốc của chất điểm giảm dần.
			\itemch Quãng đường mà vật di chuyển trong khoảng thời gian từ $t=0$ đến $t=5$ là $$s = \displaystyle\int\limits_0^5 \left(-3t^2+12t+1\right)\,\mathrm{d}t = \left(-t^3+6t^2+t\right)\bigg|_0^5 = -125+150+5 = 30\ (\mathrm{m}).$$
			\itemch Vận tốc của vật tại thời điểm $t=2$ là $v(2)=13$ (m/s).
		\end{itemchoice}
	}
\end{ex}

\begin{ex}%[2D5H1-4]
	Ở cửa ra vào của nhà sách Nguyễn Văn Cừ có một thiết bị cảnh báo hàng hóa chưa được thanh toán khi qua cửa. Thiết bị phát chuông cảnh báo với $99\%$ các hàng hóa ra cửa mà chưa thanh toán và $0{,}1\%$ các hàng hóa đã thanh toán. Tỷ lệ hàng hóa qua cửa không được thanh toán là $0{,}1\%$. Chọn ngẫu nhiên một hàng hóa đi qua cửa. Xét tính đúng sai của các mệnh đề sau?
	\choiceTF
	{\True Xác suất để hàng qua cửa đã thanh toán là $99{,}9\%$}
	{Xác suất để hàng qua cửa chưa thanh toán và thiết bị phát chuông cảnh báo là $1\%$}
	{\True Xác suất để hàng qua cửa chưa thanh toán và thiết bị không phát chuông cảnh báo là $0{,}001\%$}
	{Xác suất để hàng qua cửa đã thanh toán và thiết bị phát chuông cảnh báo là $0{,}1\%$}
	\loigiai{
		\begin{itemchoice}
			\itemch Gọi $A$ là biến cố \lq\lq Hàng qua cửa đã được thanh toán\rq\rq\ và $B$ là biến cố \lq\lq Thiết bị phát chuông cảnh báo\rq\rq. \\
			Tỷ lệ hàng qua cửa không được thanh toán là $0{,}1\%$ tức là $\mathrm{P}\left(\overline{A}\right)=0{,}1\%$, suy ra $$\mathrm{P}(A) = 100\% - 0{,}1\% = 99{,}9\%.$$
			\itemch Ta có $\mathrm{P}(B\mid A)=0{,}1\%$ và $\mathrm{P}\left(B|\overline{A}\right)=99\%$. \\
			Xác suất để hàng qua cửa chưa thanh toán và thiết bị phát chuông cảnh báo là $$\mathrm{P}\left(\overline{A}\cap B\right) = \mathrm{P}\left(\overline{A}\right) \cdot \mathrm{P}\left(B|\overline{A}\right) = 0{,}001 \cdot 0{,}99 = 0{,}00099 = 0{,}099\%.$$
			\itemch Ta có $\mathrm{P}\left(\overline{B}\mid\overline{A}\right) = 100\% - \mathrm{P}\left(B|\overline{A}\right) = 1\%$. \\
			Xác suất để hàng qua cửa chưa thanh toán và thiết bị không phát chuông cảnh báo là $$\mathrm{P}\left(\overline{A}\cap\overline{B}\right) = \mathrm{P}\left(\overline{A}\right) \cdot \mathrm{P}\left(\overline{B}\mid\overline{A}\right) = 0{,}001 \cdot 0{,}01 = 0{,}00001 = 0{,}001\%.$$
			\itemch Xác suất để hàng hóa qua cửa đã thanh toán và thiết bị phát chuông cảnh báo là $$\mathrm{P}(A\cap B) = \mathrm{P}(A) \cdot \mathrm{P}(B\mid A) = 0{,}999 \cdot 0{,}001 = 0{,}000999 \approx 0{,}0999\%.$$
		\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


