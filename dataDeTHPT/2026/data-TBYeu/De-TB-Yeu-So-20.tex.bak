\begin{ex}%[1D6H2-2]
	Đặt $a=\log_3 5$, $b=\log_2 5$. Giá trị $\log_{15} 20$ theo $a, b$ là
	\choice
	{$\dfrac{b+ab}{2a+ab}$}
	{\True $\dfrac{2a+ab}{b+ab}$}
	{$\dfrac{b^2+2b}{b^2+a}$}
	{$\dfrac{b^2+a}{b^2+2b}$}
	\loigiai{
		Ta có $\log_{15} 20 = \log_{15}(4\cdot 5) = \log_{15} 4 + \log_{15} 5 = 2\log_{15} 2 + \log_{15} 5$. \\
		Lại có $\log_{15} 2 = \dfrac{1}{\log_2 15} = \dfrac{1}{\log_2 3 + \log_2 5} = \dfrac{1}{\dfrac{1}{\log_3 2} + \log_2 5} = \dfrac{1}{\dfrac{\log_2 5}{\log_3 5} + \log_2 5} = \dfrac{1}{\dfrac{b}{a} + b} = \dfrac{a}{b(1+a)}$. \\
		Và $\log_{15} 5 = \dfrac{1}{\log_5 15} = \dfrac{1}{\log_5 3 + 1} = \dfrac{1}{\dfrac{1}{\log_3 5} + 1} = \dfrac{1}{\dfrac{1}{a} + 1} = \dfrac{a}{1+a}$. \\
		Do đó $\log_{15} 20 = \dfrac{2a}{b(1+a)} + \dfrac{a}{a+1} = \dfrac{2a+ab}{b+ab}$.
	}
\end{ex}

\begin{ex}%[1D2N2-2]
