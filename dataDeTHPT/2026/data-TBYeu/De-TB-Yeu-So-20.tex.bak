\begin{ex}%[1H8H5-4]
	Cho hình lăng trụ đứng $ABC.A'B'C'$ có $AB=5$, $AC=6$, $\widehat{A}=60^\circ$. Tính khoảng cách giữa hai đường thẳng $AA'$ và $BC$ ({\it làm tròn kết quả đến hàng phần mười}).
	\par\shortans[oly]{$4{,}7$}
	\loigiai{
\immini{Kẻ $AH \perp BC$, ta được $AH$ là đường vuông góc chung của $AA'$ và $BC$. \\
		Suy ra $\mathrm{d}(AA',BC) = AH$. \\
		Ta có
\begin{itemize}
\item $S_{\Delta ABC} = \dfrac{1}{2} \cdot AB \cdot AC \cdot \sin A = \dfrac{1}{2} \cdot 5 \cdot 6 \cdot \sin 60^\circ = \dfrac{15\sqrt{3}}{2}$. 
\item $BC = \sqrt{5^2+6^2-2\cdot 5\cdot 6\cdot \cos 60^\circ} = \sqrt{31}$.
\end{itemize}
Vậy	$AH = \dfrac{2S_{\Delta ABC}}{BC} = \dfrac{2\cdot\dfrac{15\sqrt{3}}{2}}{\sqrt{31}} = \dfrac{15\sqrt{93}}{31} \approx 4{,}7$.}{\begin{tikzpicture}[scale=1, font=\footnotesize, line join=round, line cap=round,>=stealth,declare function={h=3;}]
\path (0,0)coordinate (A)++(3,0) coordinate (C) (1,-1) coordinate (B) ($(B)!0.4!(C)$) coordinate (H);
\foreach \p in {A,B,C} {\draw (\p)--(\p)--+(0,h) coordinate (\p');}
\draw (A')--(B')--(C')--cycle (A)--(B)--(C);
\draw[dashed] (H)--(A)--(C);
\foreach \p/\g in {A/180,B/-90,C/0,A'/180,B'/-30,C'/0,H/-45} \fill[black] (\p) circle(1pt)+(\g:0.3) node{$\p$};
\foreach \x/\y/\z in {A'/A/B,A'/A/C,A/H/C} \draw pic[draw, angle radius=0.2cm]{right angle=\x--\y--\z};
\end{tikzpicture}}
	}
\end{ex}

\begin{ex}%[1C2H3-1]
	\immini{Công ty giao hàng nhanh có $4$ kho hàng $A, B, C$ và $D$. Quản lý muốn lên kế hoạch cho xe giao hàng đi qua tất cả các kho hàng để lấy hàng và quay lại kho hàng ban đầu, với điều kiện là mỗi kho hàng chỉ ghé qua một lần. Khoảng cách giữa các kho hàng (km) được mô tả trong hình bên. Quãng đường ngắn nhất để xe giao hàng hoàn thành việc lấy hàng ở các kho và quay trở lại kho hàng ban đầu là bao nhiêu?}{\begin{tikzpicture}[
    vertex/.style={
        circle, 
        draw=black, 
        thick,  
        inner sep=2pt, 
        font=\bfseries, 
        text=blue
    },
    weight/.style={
        font=\bfseries, 
        text=blue,
        inner sep=4pt 
    },
    edge/.style={
        semithick
    }
]
    \foreach \name/\x/\y in {
        A/1/4.5,
        B/2/2,
        C/0/0,
        D/6/1%
    } {
        \node[vertex] (\name) at (\x, \y) {$\name$};
    }
    \foreach \u/\v/\w/\pos in {
        A/C/3/left,
        A/B/3/below left,
        C/B/2/above,
        A/D/7/above right,
        B/D/4/above,
        C/D/5/below%
    } {
        \draw[edge] (\u) -- node[weight, \pos] {$\w$} (\v);
    }

\end{tikzpicture}}
	\par\shortans[oly]{$15$}
	\loigiai{
		Xe giao hàng có thể xuất phát từ một trong $4$ kho hàng $A, B, C, D$. \\
		Giả sử xe giao hàng xuất phát từ kho $A$. \\
		Để đi qua tất cả các kho hàng và quay trở về $A$, xe giao hàng có thể đi theo một trong các chu trình: 
\begin{itemize}
\item $A \rightarrow B \rightarrow C \rightarrow D \rightarrow A$: Tổng quãng đường $3+2+5+7=17$. 
\item $A \rightarrow B \rightarrow D \rightarrow C \rightarrow A$: Tổng quãng đường $3+4+5+3=15$. 
\item $A \rightarrow C \rightarrow B \rightarrow D \rightarrow A$: Tổng quãng đường $3+2+4+7=16$.
\item $A \rightarrow C \rightarrow D \rightarrow B \rightarrow A$: Tổng quãng đường $3+5+4+3=15$.
\item $A \rightarrow D \rightarrow B \rightarrow C \rightarrow A$: Tổng quãng đường $7+4+2+3=16$. 
\item $A \rightarrow D \rightarrow C \rightarrow B \rightarrow A$: Tổng quãng đường $7+5+2+3=17$.
\end{itemize}
		Nếu xuất phát từ đỉnh khác thì chỉ là phép thay thế bước đi trong sơ đồ trên. \\
		Vậy quãng đường ngắn nhất để xe giao hàng hoàn thành việc lấy hàng ở các kho và quay trở lại kho hàng ban đầu là $15$ km.
}
\end{ex}

\begin{ex}%[2H2H2-6]
	Hệ thống định vị toàn cầu GPS là một hệ thống cho phép xác định vị trí của một vật thể trong không gian. Trong cùng một thời điểm, vị trí của một điểm $M$ trong không gian sẽ được xác định bởi bốn vệ tinh cho trước nhờ các bộ thu phát tín hiệu đặt trên các vệ tinh. Giả sử trong không gian với hệ tọa độ $Oxyz$, có bốn vệ tinh lần lượt đặt tại các điểm $A(3;1;0)$, $B(3;6;6)$, $C(4;6;2)$, $D(6;2;14)$; vị trí $M(a;b;c)$ thỏa mãn $MA=3$, $MB=6$, $MC=5$, $MD=13$. Khoảng cách từ điểm $M$ đến gốc tọa độ $O$ bằng bao nhiêu?
	\par\shortans[oly]{$3$}
	\loigiai{
		Ta có hệ phương trình
		$$\heva{&MA=3 \\ &MB=6 \\ &MC=5 \\ &MD=13} \Leftrightarrow \heva{&(a-3)^2+(b-1)^2+c^2=9 \\ &(a-3)^2+(b-6)^2+(c-6)^2=36 \\ &(a-4)^2+(b-6)^2+(c-2)^2=25 \\ &(a-6)^2+(b-2)^2+(c-14)^2=169}\Leftrightarrow \heva{&a^2+b^2+c^2-6a-2b=-1 \\ &a^2+b^2+c^2-6a-12b-12c=-45 \\ &a^2+b^2+c^2-8a-12b-4c=-31 \\ &a^2+b^2+c^2-12a-4b-28c=-67.}$$
		Đặt $d=a^2+b^2+c^2$ ta được
		$$\heva{&d-6a-2b=-1 \\ &d-6a-12b-12c=-45 \\ &d-8a-12b-4c=-31 \\ &d-12a-4b-28c=-67.}$$
		Giải hệ phương trình này, ta tìm được $a=1, b=2, c=2, d=9 \Rightarrow M(1;2;2)$. \\
		Do đó, khoảng cách từ điểm $M$ đến gốc tọa độ $O$ là $OM = \sqrt{a^2+b^2+c^2} = \sqrt{d} = 3$.
	}
\end{ex}

\begin{ex}%[2D4H3-2]
\immini{	Một kiến trúc sư thiết kế một khu sinh hoạt cộng đồng có dạng hình vuông với mỗi cạnh dài $120$ m. Phần sân chơi nằm ở giữa, và phần còn lại để trồng cây xanh. Các đường biên của khu vực trồng cây xanh là các đoạn parabol, với đỉnh của parabol nằm cách trung điểm của mỗi cạnh hình vuông $25$ m. Tính diện tích phần trồng cây xanh.}{\begin{tikzpicture}[line join=round, line cap=round,>=stealth]
    \def\RongReal{120}
    \def\CaoReal{120}
    \def\LomReal{25}
    % Sửa 2 số này để hình to/nhỏ trên giấy A4
    \def\RongView{4} 
    \def\CaoView{4}  
    % Tự động tính toán độ lõm thu nhỏ trên bản vẽ
    \pgfmathsetmacro{\LomView}{\LomReal * (\RongView / \RongReal)}
    \tikzset{
        declare function={
            % Phương trình Parabol lõm dưới
            f(\x) = -\LomView/((\RongView/2)^2) * (\x-\RongView/2)^2 + \LomView;
        }
    }

    \fill[gray!40] 
        (0,0) -- (0, \CaoView) -- 
        plot[domain=0:\RongView, samples=50] (\x, {\CaoView - f(\x)}) -- 
        (\RongView, \CaoView) -- (\RongView, 0) -- 
        plot[domain=\RongView:0, samples=50] (\x, {f(\x)}) -- cycle;
    \foreach \sign/\offset in {-1/0, 1/\CaoView} {
       \draw (0, \offset) -- (\RongView, \offset);
       \draw plot[domain=0:\RongView, samples=50] (\x, {\offset - \sign*f(\x)});
       \draw[<->] (\RongView/2, \offset) -- (\RongView/2, {\offset - \sign*\LomView}) 
            node[pos=0.5, right] {\LomReal\,m};
    }
    \draw (0,0) -- (0, \CaoView) (\RongView, 0) -- (\RongView, \CaoView);
    \draw[dashed] (\RongView/2, \LomView) -- (\RongView/2, \CaoView-\LomView);
    \node at (\RongView/2, -0.6) {\RongReal\,m};
    \node[rotate=-90] at (\RongView + 0.6, \CaoView/2) {\CaoReal\,m};
\end{tikzpicture}}
	\par\shortans[oly]{$2000$}
	\loigiai{
\immini{Chọn hệ trục tọa độ $Oxy$ như hình vẽ, với trung điểm của cạnh hình vuông nằm tại gốc tọa độ $O(0;0)$. \\
		Diện tích của phần trồng hoa bằng $2$ lần diện tích giới hạn bởi một parabol và trục hoành. \\
		Đỉnh của parabol nằm tại điểm $(0; 25)$ và đi qua hai điểm trên cạnh đáy $(-60;0)$ và $(60;0)$ (vì cạnh hình vuông là $120$ m). \\
		Phương trình parabol có dạng: $y=ax^2+25$. \\
		Vì parabol đi qua điểm $(60;0)$ nên ta có
		$$0=a\cdot 60^2+25 \Rightarrow a=-\dfrac{1}{144}.$$
		Phương trình parabol là $y=-\dfrac{1}{144}x^2+25$.}{\begin{tikzpicture}[line join=round, line cap=round,>=stealth]
    \def\RongReal{120}
    \def\CaoReal{120}
    \def\LomReal{25}
    % Sửa 2 số này để hình to/nhỏ trên giấy A4
    \def\RongView{4} 
    \def\CaoView{4}  
    % Tự động tính toán độ lõm thu nhỏ trên bản vẽ
    \pgfmathsetmacro{\LomView}{\LomReal * (\RongView / \RongReal)}
    \tikzset{
        declare function={
            % Phương trình Parabol lõm dưới
            f(\x) = -\LomView/((\RongView/2)^2) * (\x-\RongView/2)^2 + \LomView;
        }
    }

    \fill[gray!40] 
        (0,0) -- (0, \CaoView) -- 
        plot[domain=0:\RongView, samples=50] (\x, {\CaoView - f(\x)}) -- 
        (\RongView, \CaoView) -- (\RongView, 0) -- 
        plot[domain=\RongView:0, samples=50] (\x, {f(\x)}) -- cycle;
    \foreach \sign/\offset in {-1/0, 1/\CaoView} {
       \draw (0, \offset) -- (\RongView, \offset);
       \draw plot[domain=0:\RongView, samples=50] (\x, {\offset - \sign*f(\x)});
       \draw[<->] (\RongView/2, \offset) -- (\RongView/2, {\offset - \sign*\LomView}) 
            node[pos=0.5, right] {\LomReal\,m};
    }
    \draw (0,0) -- (0, \CaoView) (\RongView, 0) -- (\RongView, \CaoView);
    \draw[dashed] (\RongView/2, \LomView) -- (\RongView/2, \CaoView-\LomView);
    %\node at (\RongView/2, -0.6) {\RongReal\,m};
    \node[rotate=-90] at (\RongView + 0.6, \CaoView/2) {\CaoReal\,m};
\draw[->] (\RongView/2,0)node[below]{$O$}--++(3,0)node[anchor=north]{$x$};
\draw[->] (\RongView/2,0)--++(0,5)node[anchor=east]{$y$};
\end{tikzpicture}}\noindent
		Diện tích của phần trồng cây xanh bằng $S = 2\displaystyle\int\limits_{-60}^{60} \left(-\dfrac{1}{144}x^2+25\right)\,\mathrm{d}x = 2 \cdot 1000 = 2000$ (m$^2$). 	}
\end{ex}

\begin{ex}%[2D1H3-6]
	Độ giảm huyết áp của một bệnh nhân được xác định bởi công thức $G(x)=0{,}024x^2(30-x)$, trong đó $x$ là liều lượng thuốc tiêm cho bệnh nhân cao huyết áp ($x$ được tính bằng mg). Tìm lượng thuốc để tiêm cho bệnh nhân cao huyết áp để huyết áp giảm nhiều nhất.
	\par\shortans[oly]{$20$}
	\loigiai{
	Ta có $G'(x) = -\dfrac{9}{125}x^2+\dfrac{36}{25}x$ và
		$G'(x)=0 \Leftrightarrow \hoac{&x=0\\ &x=20 \in [0;30]}$. \\
		Ta tính được $G(0)=0$; $G(20)=96$; $G(30)=0$. \\
		Vậy $G(x)$ đạt giá trị lớn nhất là $96$ khi $x=20$.
	}
\end{ex}

\begin{ex}%[2D5H1-4]
	Có hai hộp đựng bi: hộp I có $6$ viên bi vàng và $4$ viên bi đỏ; hộp II có $7$ viên bi vàng và $3$ viên bi đỏ. Chọn ngẫu nhiên một viên bi từ hộp I và chuyển nó sang hộp II. Sau đó, chọn ngẫu nhiên một viên bi từ hộp II. Tính xác suất để viên bi được chọn từ hộp II là viên bi đã được chuyển từ hộp I, biết rằng viên bi đó là viên bi vàng.
	\par\shortans[oly]{$0{,}08$}
	\loigiai{
		Gọi biến cố $A$: \lq\lq Viên bi được chọn từ hộp II là viên bi đã được chuyển từ hộp I\rq\rq. \\
		Gọi biến cố $B$: \lq\lq Viên bi được chọn từ hộp II là viên bi vàng\rq\rq. \\
		Cần tính xác suất $\mathrm{P}(A|B) = \dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)}$. \\
		Xác suất chọn một viên bi vàng từ hộp I là $\dfrac{6}{10}=0{,}6$. \\
		Nếu viên bi vàng được chuyển từ hộp I sang hộp II, thì số viên bi vàng trong hộp II sẽ tăng lên thành $8$ viên bi. \\
		Khi đó, xác suất để chọn được đúng viên bi vàng đã chuyển từ hộp I (trong tổng số $11$ viên bi ở hộp II) là $\dfrac{1}{11}$. \\
		Suy ra $\mathrm{P}(A\cap B) = \dfrac{6}{10} \cdot \dfrac{1}{11} = \dfrac{6}{110}$. \\
		$\mathrm{P}(B)$ là xác suất để chọn được một viên bi vàng từ hộp II. Có hai khả năng xảy ra: \\
		TH1: Chuyển một viên bi vàng từ hộp I sang hộp II: \\
		Xác suất để chọn một viên bi vàng từ hộp II khi đó là $\mathrm{P}(B_1) = \dfrac{6}{10} \cdot \dfrac{8}{11}$. \\
		TH2: Chuyển một viên bi đỏ từ hộp I sang hộp II: \\
		Xác suất để chọn một viên bi vàng từ hộp II khi đó là $\mathrm{P}(B_2) = \dfrac{4}{10} \cdot \dfrac{7}{11}$. \\
		Tổng xác suất để chọn được một viên bi vàng từ hộp II là 
		$$\mathrm{P}(B) = \mathrm{P}(B_1) + \mathrm{P}(B_2) = \dfrac{6}{10} \cdot \dfrac{8}{11} + \dfrac{4}{10} \cdot \dfrac{7}{11} = \dfrac{76}{110}.$$
		Áp dụng công thức xác suất có điều kiện thì 
		$\mathrm{P}(A|B) = \dfrac{\mathrm{P}(A\cap B)}{\mathrm{P}(B)} = \dfrac{\dfrac{6}{110}}{\dfrac{76}{110}} = \dfrac{6}{76} = \dfrac{3}{38} \approx 0{,}08$. \\
		Vậy xác suất cần tìm là khoảng $0{,}08$.
	}
\end{ex}


\Closesolutionfile{ans}
