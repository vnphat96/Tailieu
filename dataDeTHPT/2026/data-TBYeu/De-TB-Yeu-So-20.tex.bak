\begin{ex}%[2D1N4-1]
	Cho hàm số $f(x)$ có bảng biến thiên như hình vẽ.
	\begin{center}
	\begin{tikzpicture}
		\tkzTabInit[nocadre=false, lgt=1.2, espcl=3.0, deltacl=0.6]{$x$/0.6,$y'$/0.6,$y$/2}
		{$-\infty$, $-1$, $+\infty$}
		\tkzTabLine {,+,d,+,}
		\tkzTabVar{-/ $2$, +D-/ $+\infty$ / $-\infty$, +/ $+\infty$}
	\end{tikzpicture}
	\end{center}
	Đường thẳng nào sau đây là tiệm cận đứng của đồ thị hàm số?
	\choice
	{$y=2$}
	{$x=2$}
	{$y=-1$}
	{\True $x=-1$}
	\loigiai{
		Vì $\lim\limits_{x\to -1^+}y=-\infty$ và $\lim\limits_{x\to -1^-}y=+\infty$ nên đồ thị hàm số đã cho nhận đường thẳng $x=-1$ làm tiệm cận đứng.
	}
\end{ex}

\begin{ex}%[1D6H4-2]
	Nghiệm của phương trình $3^{x+1}=27$ là
	\choice
	{$x=3$}
	{$x=4$}
	{\True $x=2$}
	{$x=1$}
	\loigiai{
		Ta có $3^{x+1}=27 \Leftrightarrow 3^{x+1}=3^3 \Leftrightarrow x+1=3 \Leftrightarrow x=2$.
	}
\end{ex}

