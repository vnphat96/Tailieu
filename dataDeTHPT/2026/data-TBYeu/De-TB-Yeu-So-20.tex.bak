\begin{ex}%[2H5N1-5]
	Trong không gian $Oxyz$, cho mặt phẳng $(\alpha)\colon 2x-2y+z+5=0$. Khoảng cách $h$ từ điểm $A(1;1;1)$ đến mặt phẳng $(\alpha)$ bằng
	\choice
	{$h=\dfrac{6}{\sqrt{5}}$}
	{$h=6$}
	{\True $h=2$}
	{$h=\dfrac{10}{3}$}
	\loigiai{
		Ta có $h = \mathrm{d}(A,(\alpha)) = \dfrac{|2\cdot 1-2\cdot 1+1+5|}{\sqrt{2^2+(-2)^2+1^2}} = \dfrac{6}{3} = 2$.
	}
\end{ex}

\begin{ex}%[2D5H1-1]
	Cho hai biến cố $A$ và $B$ với $\mathrm{P}(A)=0{,}3$; $\mathrm{P}(B)=0{,}5$; $\mathrm{P}(B\mid A)=0{,}9$. Khi đó xác suất của biến cố $A\cap B$ là
	\choice
	{\True $\dfrac{27}{100}$}
	{$\dfrac{3}{20}$}
	{$\dfrac{9}{20}$}
	{$\dfrac{1}{3}$}
	\loigiai{
		Ta có $\mathrm{P}(A\cap B) = \mathrm{P}(B\mid A)\cdot\mathrm{P}(A) = 0{,}9 \cdot 0{,}3 = 0{,}27 = \dfrac{27}{100}$.
	}
\end{ex}

\begin{ex}%[2D4H1-1]
	Nếu $\displaystyle\int f(x)\,\mathrm{d}x = 4x^3+x^2+C$ thì hàm số $f(x)$ là hàm số nào trong các hàm số dưới đây?
	\choice
	{$f(x)=x^4+\dfrac{x^3}{3}$}
	{$f(x)=12x^2+2x+C$}
	{$f(x)=x^4+\dfrac{x^3}{3}+Cx$}
	{\True $f(x)=12x^2+2x$}
	\loigiai{
		Ta có $f(x) = (4x^3+x^2+C)' = 12x^2+2x$.
	}
\end{ex}

\begin{ex}%[1H8N7-2]
	Cho hình chóp $S.ABC$, cạnh bên $SA$ vuông góc với mặt phẳng đáy, $SA=\dfrac{3a}{2}$, diện tích đáy bằng $\dfrac{a^2\sqrt{3}}{4}$. Thể tích khối chóp $S.ABC$ bằng
