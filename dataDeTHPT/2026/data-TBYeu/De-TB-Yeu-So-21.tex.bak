\begin{ex} %[2D1H4-1]
	Tiệm cận ngang, tiệm cận đứng của đồ thị hàm số $y = \dfrac{x-1}{2x+2}$ là
	\choice
	{Tiệm cận ngang $x = -1$, tiệm cận đứng $y = \dfrac{1}{2}$}
	{Tiệm cận ngang $y = -\dfrac{1}{2}$, tiệm cận đứng $x = -1$}
	{\True Tiệm cận ngang $y = \dfrac{1}{2}$, tiệm cận đứng $x = -1$}
	{Tiệm cận ngang $y = \dfrac{1}{2}$, tiệm cận đứng $x = 1$}
	\loigiai{
		Ta có $\lim\limits_{x \to (-1)^+} \dfrac{x-1}{2x+2} = -\infty$, $\lim\limits_{x \to (-1)^-} \dfrac{x-1}{2x+2} = +\infty$.\\ 
		Suy ra đường thẳng $x = -1$ là tiệm cận đứng của đồ thị hàm số.\\
		Ta có $\lim\limits_{x \to \infty} \dfrac{x-1}{2x+2} = \dfrac{1}{2}$. Suy ra đường thẳng $y = \dfrac{1}{2}$ là tiệm cận ngang của đồ thị hàm số.
	}
\end{ex}

\begin{ex} %[2D1H1-2]
	Cho hàm số có bảng biến thiên sau:
	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[lgt=1.3,espcl=2]
			{$x$/1,$f'(x)$/1,$f(x)$/2.5}
			{$-\infty$,$-2$,$1$,$4$,$+\infty$}
			
			\tkzTabLine{,+,0,-,d,-,d,+}
			\tkzTabVar{-/$-\infty$,+/$3$,-D+/$-\infty$/$+\infty$,-/$-2$,+/$+\infty$}
		\end{tikzpicture}
	\end{center}
	Hàm số đã cho nghịch biến trên khoảng nào dưới đây
	\choice
	{$(-\infty;4]$}
	{$(3;-\infty)$}
	{\True $(-1;0)$}
	{$(-2;1]$}
	\loigiai{
		Dựa vào bảng biến thiên ta thấy hàm số nghịch biến trên $(-2;1)$; $(1;4)$ suy ra hàm số nghịch biến trên khoảng $(-1;0)$.
	}
\end{ex}

\begin{ex} %[2D1H3-1]
	Cho hàm số $y = f(x)$ xác định trên đoạn $[-\sqrt{3};\sqrt{5}]$ và có bảng biến thiên như hình vẽ sau:
	\begin{center}
		\begin{tikzpicture}
			\tkzTabInit[lgt=1.3,espcl=2.4]
			{$x$/1,$y'$/1,$y$/2.2}
			{$-\sqrt{3}$,$-1$,$1$,$\sqrt{5}$}
			
			\tkzTabLine{,+,0,-,0,+}
			\tkzTabVar{-/$0$,+/$2$,-/$-2$,+/$2\sqrt{5}$}
		\end{tikzpicture}
	\end{center}
	Khẳng định nào sau đây là đúng?
	\choice
	{\True $\min\limits_{[-\sqrt{3};\sqrt{5})} y = -2$}
	{$\min\limits_{[-\sqrt{3};\sqrt{5})} y = 0$}
	{$\max\limits_{[-\sqrt{3};\sqrt{5})} y = 2\sqrt{5}$}
	{$\max\limits_{[-\sqrt{3};\sqrt{5})} y = 2$}
	\loigiai{
		Trên $[-\sqrt{3};\sqrt{5})$ hàm số không có giá trị lớn nhất, giá trị nhỏ nhất của hàm số bằng $-2$.
	}
\end{ex}

\begin{ex} %[1D9H2-4]
	Cho $A$ và $B$ là hai biến cố, biết $\mathrm{P}(A) = \dfrac{1}{2}$, $\mathrm{P}(B) = \dfrac{1}{10}$, $\mathrm{P}(A \cap B) = \dfrac{1}{20}$. Tính $\mathrm{P}(A \cup B)$
	\choice
	{$\dfrac{13}{20}$}
	{\True $\dfrac{11}{20}$}
	{$\dfrac{1}{5}$}
	{$\dfrac{1}{10}$}
	\loigiai{
		Áp dụng quy tắc cộng xác suất ta có $\mathrm{P}(A \cup B) = \mathrm{P}(A) + \mathrm{P}(B) - \mathrm{P}(A \cap B) = \dfrac{1}{2} + \dfrac{1}{10} - \dfrac{1}{20} = \dfrac{11}{20}$.
	}
\end{ex}

\begin{ex} %[1D6H4-2]
	Nghiệm của phương trình $2^x = \dfrac{1}{8}$ là:
	\choice
	{\True $x = -3$}
	{$x = \dfrac{1}{4}$}
	{$x = -4$}
	{$x = \dfrac{1}{3}$}
	\loigiai{
		Ta có $2^x = \dfrac{1}{8} \Leftrightarrow 2^x = 2^{-3} \Leftrightarrow x = -3$.
	}
\end{ex}

\begin{ex} %[2H5H3-2]
	Trong không gian với hệ tọa độ $Oxyz$, cho mặt cầu $(S)$ có phương trình $x^2 + y^2 + z^2 - 2x + 4y - 4z - m = 0$ có bán kính $R = 5$. Tìm giá trị của $m$.
	\choice
	{\True $m = 16$}
	{$m = -4$}
	{$m = -16$}
	{$m = 4$}
	\loigiai{
		Mặt cầu $(S)$ có tâm $I(1;-2;2)$ và có bán kính $R = \sqrt{1^2 + (-2)^2 + 2^2 + m} = 5$\\
		$\Leftrightarrow \sqrt{m+9} = 5 \Rightarrow m = 16$.
	}
\end{ex}

\begin{ex} %[1D5H2-2]
	Cho mẫu số liệu ghép nhóm sau:
	\begin{center}
		\begin{tabular}{|c|c|c|c|c|c|}
			\hline
			\textbf{Nhóm} & $[a_1;a_2)$ & $\cdots$ & $[a_i;a_{i+1})$ & $\cdots$ & $[a_k;a_{k+1})$ \\
			\hline
			\textbf{Tần số} & $m_1$ & $\cdots$ & $m_i$ & $\cdots$ & $m_k$ \\
			\hline
		\end{tabular}
	\end{center}
	Giả sử nhóm chứa trung vị là nhóm thứ $p$: $[a_p;a_{p+1})$.
	Với $n$ là cỡ mẫu, $m_p$ là tần số nhóm $p$. Với $p = 1$, ta quy ước $m_1 +.. + m_{p-1} = 0$.
	Khi đó công thức tính trung vị của mẫu số liệu ghép nhóm trên là
	\choice
	{$M_e = a_p + \dfrac{\dfrac{n}{4} - (m_1 +.. + m_{p-1})}{m_p}\cdot(a_{p+1} - a_p)$}
	{$M_e = a_p + \dfrac{\dfrac{n}{2} - (m_1 +.. + m_{p-1})}{m_p}\cdot(a_{p+1} + a_p)$}
	{\True $M_e = a_p + \dfrac{\dfrac{n}{2} - (m_1 +.. + m_{p-1})}{m_p}\cdot(a_{p+1} - a_p)$}
	{$M_e = a_p + \dfrac{\dfrac{3n}{4} - (m_1 +.. + m_{p-1})}{m_p}\cdot(a_{p+1} - a_p)$}
	\loigiai{
		Ta có công thức tính trung vị của mẫu số liệu ghép nhóm
		$M_e = a_p + \dfrac{\dfrac{n}{2} - (m_1 +.. + m_{p-1})}{m_p}\cdot(a_{p+1} - a_p)$.
	}
\end{ex}

\begin{ex} %[2H5N1-2]
