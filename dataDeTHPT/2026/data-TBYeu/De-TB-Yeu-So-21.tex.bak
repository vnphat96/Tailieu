\begin{ex} %[2D1H4-1] [1D7V2-3]
	Cho hàm số $y = x-\dfrac{1}{x+1}$
	\choiceTF
	{Đồ thị của hàm số có tiệm cận đứng là $x =1$}
	{\True Để đường thẳng $y = k$ cắt $(C)$ tại hai điểm phân biệt A và B sao cho $OA \perp OB$ khi đó $k$ là nghiệm của phương trình $k^2-k-1=0$}
	{\True Đồ thị hàm số cắt trục $Oy$ tại $M$. Phương trình tiếp tuyến của $(C)$ tại $M$ là $y=2x-1$}
	{Tồn tại hai tiếp tuyến của đồ thị vuông góc với nhau}
	\loigiai{
		\begin{itemchoice}
			\itemch Tập xác định $D = \mathbb{R} \setminus \{-1\}$\\
			$\lim\limits_{x \to -1^{-}} y = \lim\limits_{x \to -1^{-}} \left(x-\dfrac{1}{x+1}\right)=+\infty$, $\lim\limits_{x \to -1^{+}} y = \lim\limits_{x \to -1^{+}} \left(x-\dfrac{1}{x+1}\right)=-\infty$.\\
			Suy ra đường thẳng $x=-1$ là tiệm cận đứng của đồ thị hàm số.
			\itemch Ta có $y=x-\dfrac{1}{x+1} = \dfrac{x^2+x-1}{x+1}$.\\
			Phương trình hoành độ giao điểm của $(C)$ và đường thẳng $y = k$ là \\
			$\dfrac{x^2+x-1}{x+1} = k \Leftrightarrow \hoac{&x \ne -1\\ &x^2-(k-1)x-(k+1)=0 &(*)}$\\
			Suy ra $\heva{&A(x_A;k)\\&B(x_B;k)}$ và  $\heva{&x_A+x_B =k-1\\ &x_A\cdot x_B =-(k+1)}$.\\
			Ta có $\overrightarrow{OA} = (x_A;k)$, $\overrightarrow{OB} = (x_B;k)$.
			\begin{eqnarray*}
				\text{Theo đề, ta có }& &OA \perp OB\\ &\Leftrightarrow& \overrightarrow{OA} \cdot \overrightarrow{OB} = 0\\
				&\Leftrightarrow& x_A\cdot x_B + k^2 = 0\\ &\Leftrightarrow& -(k+1)+k^2 = 0\\ &\Leftrightarrow& k^2-k-1=0.
			\end{eqnarray*}
			
			\itemch $y'=1+\dfrac{1}{(x+1)^2}$.\\
			Vì đồ thị hàm số cắt trục $Oy$ tại điểm $M$ nên $M(0;-1)$.\\
			Ta có $x_0=0$, $y_0=-1$, $y'(x_0)=1+\dfrac{1}{(0+1)^2}=2$.\\
			Phương trình tiếp tuyến của $(C)$ tại điểm $M$ là\\
			 \begin{eqnarray*}
			 	&&y = y'(0)(x-x_0)+y_0 \\
			 	&\Leftrightarrow& y=2(x-0)-1\\
			 	&\Leftrightarrow& y=2x-1.
			 \end{eqnarray*}
			\itemch Tiếp tuyến $(T_1)$ của $(C)$ tại $P(x_1;y_1)$ có hệ số góc
			$k_1 = y'_{x_1} =1+\dfrac{1}{(x_1+1)^2} > 0$.\\
			Tiếp tuyến $(T_2)$ của $(C)$ tại $Q(x_2;y_2)$ có hệ số góc
			$k_2 = y'_{x_2} =1+\dfrac{1}{(x_2+1)^2} > 0$.\\
			Do $y'_{x_1} > 0$, $y'_{x_2} > 0$ nên không thể có $2$ tiếp tuyến của (C) vuông góc nhau.
		\end{itemchoice}
	}
\end{ex}

\begin{ex} %[2D4V2-6]
	Sau khi xuất phát, ô tô di chuyển với tốc độ $v(t) = 2{,}01t-0{,}025t^2 \,(0 \le t \le 10)$. Trong đó $v$ tính theo m/s, thời gian $t$ tính theo $s$ với $t = 0$ là thời điểm xe xuất phát.
	\choiceTF
	{\True Quãng đường xe di chuyển được trong $3$ s là $8{,}82$ m}
	{\True Trong khoảng thời gian không quá $10$s đầu, khi vận tốc đạt giá trị lớn nhất thì gia tốc của xe là $1{,}51$m/s$^2$}
	{\True Quãng đường xe di chuyển được trong giây thứ $9$ xấp xỉ $15{,}277$m}
	{Quãng đường xe di chuyển được tính theo công thức là $s(t)=2{,}01-0{,}05t \,(0 \le t \le 10)$}
	\loigiai{
		\begin{itemchoice}
			\itemch Quãng đường xe di chuyển được trong $3$s là $\displaystyle\int\limits_0^3 (2{,}01t-0{,}025t^2)\mathrm{\,d}t = 8{,}82$ (m).
			\itemch $v'(t)=2{,}01-0{,}05t$\\
			$v'(t)=0 \Leftrightarrow 2{,}01-0{,}05t=0 \Leftrightarrow t=40{,}2 \notin (1;10)$.\\
			Bảng biến thiên \begin{center}
				\begin{tikzpicture}[font=\normalsize,t style/.style={style=solid}]
					\tkzTabInit[nocadre=false, lgt=1.2, espcl=4.5, deltacl=0.5]
					{$t$/0.75, $v(t)$/0.75, $v(t)$/3}
					{$0$, $10$}
					\tkzTabLine{ , +}
					\tkzTabVar{-/$0$, +/$17{,}6$}
				\end{tikzpicture}
			\end{center}
			Suy ra $\max\limits_{[0;10]} v(t)=17{,6}$ khi $t=10$. \\
			Do đó gia tốc của xe tại thời điểm $t=10$ là $a(10)=v'(10)=2{,}01 - 0{,}05\cdot 10=1{,51}$ (m/s$^2$). 
			\itemch Quãng đường xe di chuyển được trong giây thứ $9$ là \\
			$s(9)-s(8) = \displaystyle\int\limits_8^9 (2{,}01t-0{,}025t^2)\mathrm{\,d}t\approx 15{,}277$ (m).
			\itemch Ta có $s(t)=\displaystyle\int v(t) \mathrm{\,d}t=\displaystyle\int \left(2{,}01t-0{,}025t^2\right)\mathrm{\,d}t=1{,}005t^2 -\dfrac{1}{120}t^3 + C$.\\
			Mà $s(0)=0\Leftrightarrow 1{,}005\cdot 0^2 -\dfrac{1}{120}\cdot 0^3+ C=0\Leftrightarrow C=0$.\\
			Suy ra $s(t) = 1{,}005t^2 -\dfrac{1}{120}t^3$.
		\end{itemchoice}
	}
\end{ex}

\begin{ex} %[2H5N2-2] [2H5H2-7] [2H5N1-2]
	Trong không gian $Oxyz$, cho đường thẳng $\Delta\colon \dfrac{x-2}{-1}=\dfrac{y-1}{-2}=\dfrac{z+3}{1}$ và mặt phẳng $(P)$ có phương trình $3x+6y-3z+ 2024 = 0$.
	\choiceTF
	{\True Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u} = (-1;-2;1)$}
	{Lấy tuỳ ý hai điểm phân biệt $A$, $B \in \Delta$. Gọi $A'$, $B'$ lần lượt là hình chiếu của $A$, $B$ lên $(P)$. Khi đó $A'B'$ = $2024$}
	{\True Góc giữa $\Delta$ và $(P)$ là $90^\circ$}
	{Một vectơ pháp tuyến của $(P)$ là $\overrightarrow{n} = (1;2;-1)$}
	\loigiai{
		\begin{itemchoice}
		\itemch Một vectơ chỉ phương của $\Delta$ là $\overrightarrow{u} = (-1;-2;1)$.
		\itemch $(P)$ có vectơ pháp tuyến là $\overrightarrow{n}=(1;2;-1)$.\\
		 Vì $\overrightarrow{n}=-\overrightarrow{u}$ nên $\overrightarrow{n}$ cùng phương với $\overrightarrow{u}$. Suy ra $\Delta\perp (P)$.\\
		Do đó hình chiếu vuông góc của mọi điểm nằm trên $\Delta$ đều hội tụ tại một điểm duy nhất trên $(P)$. Suy ra $A'B'$ = $0$.
		\itemch Vì $\Delta\perp (P)$ nên $(\Delta{,}(P))=90^\circ$.
		\itemch $(P)$ có vectơ pháp tuyến là $\overrightarrow{n} = (1;2;-1)$.
	\end{itemchoice}
}
\end{ex}

\begin{ex} %[1H8V5-5]
Cho hình lập phương $ABCD.A'B'C'D'$ cạnh $a$.
\choiceTF
{Khoảng cách giữa $AB$ và $C'D'$ bằng $2a$}
{Khoảng cách giữa $B'D'$ và $AB$ bằng $a\sqrt{2}$}
{\True Khoảng cách giữa $BC'$ và $CD'$ bằng $\dfrac{a\sqrt{3}}{3}$}
{\True Khoảng cách giữa $AD'$ và $CC'$ bằng $a$}
\loigiai{
	\begin{center}
		\begin{tikzpicture}[scale=1.2,declare function={r=2.5;},font=\scriptsize]
			\path 
			(0:0) coordinate (A)
			(0:r) coordinate (B)
			++(37:{0.65*r}) coordinate (C)
			++(180:r) coordinate (D);
			
			\foreach \x in {A,B,C,D}{
				\path (\x) ++(90:r) coordinate (\x_1);
			}
			
			\path[name path=AC] (A)--(C);
			\path[name path=BD] (B)--(D);
			\path[name intersections={of=AC and BD, by=O}];
			
			% Điểm E đặt cao lên một chút
			\coordinate (E) at ($(D_1)!0.58!(O)+(0,0.18)$);
			
			\draw[dashed] (D_1)--(D)--(A) (D)--(C)--(A) (B)--(D) (D_1)--(O);
			\draw[dashed] (D)--(E);
			\draw (A)--(B)--(C) (A)--(A_1) (B)--(B_1) (C)--(C_1) (A_1)--(B_1)--(C_1)--(D_1)--cycle;
			
			\foreach \x/\y/\z in {D/E/O}{
				\path (\y) pic[draw,angle radius=6pt]{right angle = \x--\y--\z};
			}
			\foreach \x/\goc/\t in {
				A/255/A, B/-75/B, C/10/C, D/170/D, O/240/O, E/120/E,
				A_1/135/A', B_1/90/B', C_1/45/C', D_1/90/D'
			}{
				\draw[fill=black] (\x) circle (1pt) node[shift={(\goc:9pt)}]{$\t$};
			}
		\end{tikzpicture}
	\end{center}
	\begin{itemchoice}
	\itemch Ta có $\heva{&AB \perp A'D'\, (\text{do }A'D'\perp(ABB'A'))\\ &A'D' \perp A'D'\,(\text{do }AB\perp(CDD'C'))}$. \\
	Suy ra $A'D'$ là đường vuông góc chung của hai đường thẳng $AB$ và $C'D'$.\\
	Do đó $d(AB{,\,}C'D')= A'D'=a$.
	\itemch Ta có $\heva{&BB' \perp AB\\ &BB' \perp B'D'\,(\text{do }BB'\perp(A'B'C'D'))}$. \\
	Suy ra $BB'$ là đường vuông góc chung của hai đường thẳng $AB$ và $B'D'$.\\
	Do đó $d(AB{,\,}B'D')= BB'=a$.
	\itemch Trong $(ABCD)$, gọi $O = AC \cap BD$.\\
	Vì $BC'\parallel (AD'C)$ nên $d(BC'{,\,} CD')= d(BC'{,\,} (AD'C))= d(B{,\,} (AD'C))= d(D{,\,} (AD'C))$.\\
	Trong $(AD'C)$, kẻ $DE\perp D'O \,(E\in D'O)$.\\
	Ta có $\heva{&AC\perp DO\\& AC\perp DD'}$. Suy ra $AC\perp DE$.\\
	Lại có $\heva{&DE\perp AC\\& DE\perp D'O}$. Suy ra $DE\perp (AD'C)$.\\
	Do đó $d(D{,\,} (AD'C))=DE$.\\
	Xét tam giác $DD'O$ vuông tại $D$
	\begin{eqnarray*}
		&&\dfrac{1}{DE^2}=\dfrac{1}{DD'^2}+\dfrac{1}{DO^2}\\
		&\Leftrightarrow& DE^2=\dfrac{DD'^2\cdot DO^2}{DD'^2+DO^2}\\
		&\Leftrightarrow& DE^2=\dfrac{a^2\cdot \left(\dfrac{a\sqrt{2}}{2}\right)^2}{a^2+\left(\dfrac{a\sqrt{2}}{2}\right)^2}\\
		&\Leftrightarrow& DE^2=\dfrac{a^2}{3}\\
		&\Leftrightarrow& DE = \dfrac{a\sqrt{3}}{3}.
	\end{eqnarray*}
	Vậy $d(BC'{,\,} CD')=\dfrac{a\sqrt{3}}{3}$.
	\itemch Ta có $\heva{&CD \perp CC'\\ &CD \perp AD'\,(\text{do }CD\perp(ADD'A'))}$. \\
	Suy ra $CD$ là đường vuông góc chung của hai đường thẳng $AD'$ và $CC'$.\\
	Do đó $d(AD'{,\,}CC')= CD=a$.
\end{itemchoice}
	}
\end{ex}


\Closesolutionfile{ans}


\caukq
\Opensolutionfile{ans}[ans/SA-De-TB-Yeu-So-21]
\begin{ex} %[2D1H4-4]
	Số lượng sản phẩm của công ty bán được trong $x$ được tính bởi công thức $S(x) = 300\left(2+\dfrac{4}{x+2}\right)$ với $x \ge 1$. Xem $y = S(x)$ là một hàm số xác định trên $[1;+\infty)$, khi đó tiệm cận ngang của đồ thị hàm số là
	\shortans{$600$}
	\loigiai{
	Ta có $\lim\limits_{x\to -\infty} S(x)=\lim\limits_{x\to -\infty} 300\left(2+\dfrac{4}{x+2}\right)= 300(2+0)=600$.\\
	Vậy tiệm cận ngang của hàm số là đường thẳng $y=600$.
}
\end{ex}

