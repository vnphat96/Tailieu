\begin{ex} %[2H5V2-8]
	Trong không gian $Oxyz$, một cabin cáp treo ở Bà Nà Hill xuất phát từ điểm $A(-2;1;5)$ và chuyển động đều theo đường cáp có vectơ chỉ phương là $\overrightarrow{u} = (0;-2;6)$ với tốc độ là $4$ m/s (đơn vị trên mỗi trục toạ độ là mét). Giả sử sau $5$ giây kể từ lúc xuất phát, cabin đến điểm $M$. Gọi tọa độ $M (a;b; c)$. Tính $a+3b+c$.
	\shortans{$6$}
	\loigiai{
	Phương trình tham số của đường cáp là $d\colon\heva{&x = -2\\ &y=1-2k\\ &z = 5+6k}$.\\
	Vì $M \in d$ nên $M(-2;1-2k;5+6k)$, $\overrightarrow{AM} (0;-2k; 6k)$.\\
	Vì sau $5$ (s) kể từ lúc xuất phát, cabin đến điểm $M$ thì $AM = 4 \cdot 5 = 20$ (m).\\
	Do $2$ vectơ $\overrightarrow{AM}$ và $\overrightarrow{u}$ cùng hướng nên $k>0$
	\begin{eqnarray*}
		\text{Ta có }&& AM = 20 \\
		&\Leftrightarrow& \sqrt{0^2 + (-2k)^2 + (6k)^2} = 20 \\
		&\Leftrightarrow& \sqrt{4k^2 + 36k^2} = 20\\ 
		&\Leftrightarrow& \sqrt{40k^2} = 20\\
		&\Leftrightarrow& 40k^2 = 400\\
		&\Leftrightarrow& k^2 = 10\\
		&\Leftrightarrow& k = \pm\sqrt{10}
	\end{eqnarray*}
	Vì $k > 0 \Rightarrow k = \sqrt{10}$. Suy ra $M(-2;1-2\sqrt{10};5+6\sqrt{10})$. \\
	Vậy $a+3b+c=-2+3\cdot (1-2\sqrt{10})+5+6\sqrt{10} = 6$.
}
\end{ex}

\begin{ex} %[2D4V3-2]
	Một gia đình thiết kế chiếc cổng có dạng là một parabol $(P)$ biết chiều cao cổng bằng chiều rộng của cổng và bằng $4$ m (xem hình vẽ). Người ta thiết kế cửa đi là một hình chữ nhật $CDEF$ sao cho chiều cao cửa đi là $CD = 2$ m, phần còn lại dùng để trang trí. Biết chi phí phần tô đậm là $1{,}5$ triệu đồng/m$^2$. Tính số tiền (triệu đồng) gia đình đó phải trả để trang trí phần tô đậm (làm tròn kết quả đến hàng phần chục).
	\begin{center}
		\begin{tikzpicture}[>=latex, font=\sffamily]
			\def\base{2}
			\def\height{4}
			\def\rectx{1.2}
			\def\recty{2.56} % y = 4 - x^2 = 4 - 1.2^2 = 2.56
			\fill[brown!20] plot[domain=-\base:\base, samples=100] (\x, {4-\x*\x}) -- cycle;
			\fill[white] (-\rectx, 0) rectangle (\rectx, \recty);
			\draw[thick, brown!80!black] plot[domain=-\base:\base, samples=100] (\x, {4-\x*\x});
			\draw[thick] (-2.2, 0) -- (2.2, 0);
			\draw[thick, brown!80!black] (-\rectx, 0) -- (-\rectx, \recty) -- (\rectx, \recty) -- (\rectx, 0);
			\node[below] at (-\rectx, -0.1) {\textbf{F}};
			\node[below] at (\rectx, -0.1) {\textbf{C}};
			\node[above left] at (-\rectx, \recty) {\textbf{E}};
			\node[above right] at (\rectx, \recty) {\textbf{D}};
			\node[right] at (0.8, 3.6) {$(P)$};
			\draw[<->, thick] (-2, -0.8) -- (2, -0.8) node[midway, fill=white] {$4m$};
			\draw[<->, thick] (2.8, 0) -- (2.8, 4) node[midway, fill=white] {$4m$};
		\end{tikzpicture}
	\end{center}
	\shortans{$7{,}5$}
	\loigiai{
	Chọn hệ trục tọa độ $Oxy$ như hình vẽ
	\begin{center}
		\begin{tikzpicture}[>=stealth, scale=1]
			\def\c{1.4142}
			\fill[brown!20] (-2,0) -- plot[domain=-2:2, smooth] (\x, {4-\x*\x}) -- (2,0) -- cycle;
			\fill[white] (-\c, 0) rectangle (\c, 2);
			\draw[->, thick] (-2.8, 0) -- (2.8, 0) node[below] {$x$};
			\draw[->, thick] (0, -1.2) -- (0, 4.8) node[right] {$y$};
			\draw[thick, brown!80!black, smooth, domain=-2.3:2.3] plot (\x, {4-\x*\x});
			\draw[thick] (-\c, 0) -- (-\c, 2) -- (\c, 2) -- (\c, 0);
			\foreach \x in {-1, 1} {
				\draw[thick] (\x, 0.05) -- (\x, -0.05) node[below, font=\footnotesize] {$\x$};
			}
			\draw[thick] (-2, 0.05) -- (-2, -0.05) node[below left, font=\footnotesize] {$-2$};
			\draw[thick] (2, 0.05) -- (2, -0.05) node[below left, font=\footnotesize] {$2$};
			\foreach \y in {-1, 1} {
				\draw[thick] (0.05, \y) -- (-0.05, \y) node[right, font=\footnotesize, xshift=1pt] {$\y$};
			}
			\draw[thick] (0.05, 3) -- (-0.05, 3); % Điểm chia y = 3
			\node[above right, font=\footnotesize, xshift=1pt, yshift=-1pt] at (0,2) {$2$};
			\node[below right, font=\footnotesize, xshift=1pt, yshift=1pt] at (0,0) {$O$};
			\draw (0, 0.15) -- (0.15, 0.15) -- (0.15, 0);
			\foreach \x/\y/\name/\pos/\xsh in {
				-\c/0/F/above left/3pt,
				\c/0/C/above right/-1pt,
				\c/2/D/above right/-1pt,
				-\c/2/E/above right/-1pt%
			} {
				\fill (\x, \y) circle (1.2pt) node[\pos, font=\footnotesize, xshift=\xsh] {$\name$};
			}
			
		\end{tikzpicture}
	\end{center}
	Giả sử parabol $(P)$ có dạng: $y = ax^2 +bx+c \,(a\ne 0)$.\\
	Do $(P)$ có đồ thị là parabol có đỉnh $(0;4)$ và đi qua hai điểm có tọa độ là $(-2; 0)$ và $(2;0)$ \\
	nên $\heva{&b=0\\ &4a+2b+c=0\\ &c=4} \Leftrightarrow \heva{&a=-1\\ &b=0\\ &c=4}$.
	Suy ra $(P)\colon y = -x^2 + 4$.\\
	Ta có điểm $D\in(P)$ có tung độ bằng $2$ suy ra $-x^2 +4=2 \Leftrightarrow x=\pm\sqrt{2}$.\\
	Theo đồ thị, điểm $D$ có hoành độ dương nên $D(\sqrt{2};2)$.\\
	Chiều dài của cửa là $CF = 2 \cdot OC = 2\sqrt{2}$ (m).\\
	Diện tích hình chữ nhật $CDEF$ là $S_{CDEF} = 2 \cdot 2\sqrt{2} = 4\sqrt{2}$.\\
	Diện tích của chiếc cổng parabol là $S = \displaystyle\int\limits_{-2}^{2} (-x^2+4)\mathrm{\,d}x = \dfrac{32}{3}$ (m$^2$).\\
	Diện tích phần tô đậm là $S- S_{CDEF}=\dfrac{32}{3}-4\sqrt{2}$ m$^2$.\\
	Số tiền gia đình đó phải trả để trang trí phần tô đậm là $\left(\dfrac{32}{3}-4\sqrt{2}\right)\cdot 1{,}5\approx 7{,}5$ (triệu đồng).
	
}
\end{ex}

\begin{ex} %[2D1V3-6]
	Một cơ sở sản xuất khăn mặt đang bán mỗi chiếc khăn với giá $30\,000$ đồng một chiếc và mỗi tháng cơ sở bán được trung bình $3\,000$ chiếc khăn. Cơ sở sản xuất đang có kế hoạch tăng giá bán để có lợi nhuận tốt hơn. Sau khi tham khảo thị trường, người quản lý thấy rằng nếu từ mức giá $30\,000$ đồng mà cứ tăng giá thêm $1\,000$ đồng thì mỗi tháng sẽ bán ít hơn $100$ chiếc. Biết vốn sản xuất một chiếc khăn không thay đổi là $18\,000$. Để đạt lợi nhuận lớn nhất thì mỗi chiếc khăn cần bán với giá bao nhiêu nghìn đồng?
	\shortans{$39$}
	\loigiai{
	Vì cứ tăng giá thêm $1$ (nghìn đồng) thì số khăn bán ra giảm $100$ chiếc nên tăng $x$ (nghìn đồng) thì số xe khăn bán ra giảm $100x$ chiếc.\\
	Do đó tổng số khăn bán ra mỗi tháng là $3\,000-100x$ chiếc.\\
	Lúc đầu bán với giá $30$ (nghìn đồng), mỗi chiếc khăn có lãi $12$ (nghìn đồng).\\ 
	Sau khi tăng giá, mỗi chiếc khăn thu được số lãi là $12+x$ (nghìn đồng).\\
	Do đó tổng số lợi nhuận một tháng thu được sau khi tăng giá là
	$$f(x) = (3\,000-100x)(12+x)\, (\text{nghìn đồng})$$
	Xét hàm số $f(x) = (3\,000-100x)(12+x)$ trên $(0;30)$.\\
	Ta có $f(x) = -100x^2 +1\,800x +36\,000$.\\
	$f'(x) = -200x+1\,800$.\\
	$f'(x) = 0 \Leftrightarrow -200x +1\,800 = 0 \Leftrightarrow x = 9$.\\
	Bảng biến thiên
	\begin{center}
		\begin{tikzpicture}[font=\normalsize,t style/.style={style=solid}]
			\tkzTabInit[nocadre=false, lgt=1.2, espcl=2.5, deltacl=1]
			{$x$/0.75, $f'(x)$/0.75, $f(x)$/3}
			{$0$, $9$, $30$}
			\tkzTabLine{ , +, 0, -}
			\tkzTabVar{-/$36\,000$, +/$44\,100$, -/$-28\,800$}
		\end{tikzpicture}
	\end{center}
	Dựa vào bảng biến thiên, để thu được lợi nhuận cao nhất thì cơ sở sản xuất cần tăng giá bán mỗi chiếc khăn là $9$ nghìn đồng, tức là mỗi chiếc khăn bán với giá mới là $39$ nghìn đồng.
}
\end{ex}

\begin{ex} %[2D6V2-4]
	Một trường học có $20$\% học sinh tham gia câu lạc bộ âm nhạc, trong số học sinh đó có $85$\% học sinh biết chơi đàn guitar. Ngoài ra, có $10$\% số học sinh không tham gia câu lạc bộ âm nhạc cũng biết chơi đàn guitar. Chọn ngẫu nhiên $1$ học sinh của trường. Giả sử học sinh đó biết chơi đàn guitar. Xác suất chọn được học sinh thuộc câu lạc bộ âm nhạc là bao nhiêu?
	\shortans{$0{,}68$}
	\loigiai{
	Gọi biến cố
	$A\colon$ \lq\lq Chọn được học sinh thuộc câu lạc bộ âm nhạc\rq\rq;\\
	$B\colon$ \lq\lq Chọn được học sinh biết chơi đàn guitar\rq\rq.\\
	Khi đó $P(A) = 0{,}2$, $P(\overline{A}) = 0{,}8$, $P(B|A) = 0{,}85$, $P(B|\overline{A}) = 0{,}1$.\\
	Ta có
	$P(B) = P(A) \cdot P(B|A) + P(\overline{A}) \cdot P(B|\overline{A}) = 0{,}2 \cdot 0{,}85 + 0{,}8 \cdot 0{,}1 = 0{,}25$.\\
	Xác suất chọn được học sinh thuộc câu lạc bộ âm nhạc, biết học sinh đó chơi được đàn guitar là
	$$P(A|B) = \dfrac{P(A) \cdot P(B|A)}{P(B)} = \dfrac{0{,}2 \cdot 0{,}85}{0{,}25} = 0{,}68.$$ 
}
\end{ex}


\Closesolutionfile{ans}
