\begin{ex} %[2D4H3-1]
	Diện tích $S$ của hình phẳng giới hạn bởi đồ thị hàm số $y = x^2-2019$ và hai đường thẳng $x = -3$, $x = 4$ với trục hoành được tính bởi biểu thức
	\choice
	{$S = \displaystyle\int\limits_{-3}^{4} (x^2 - 2019)^2 \mathrm{\,d}x$}
	{$S = \displaystyle\int\limits_{-3}^{4} (x^2 - 2019) \mathrm{\,d}x$}
	{\True $S = \displaystyle\int\limits_{-3}^{4} \left|x^2 - 2019\right| \mathrm{\,d}x$}
	{$S = \displaystyle\int\limits_{4}^{-3} \left|x^2 - 2019\right| \mathrm{\,d}x$}
	\loigiai{
		Diện tích hình phẳng cần tìm là $S = \displaystyle\int\limits_{-3}^{4} \left|x^2 - 2019\right| \mathrm{\,d}x$.
	}
\end{ex}

\begin{ex} %[2D4H1-2]
	Cho biết $F(x)$ là một nguyên hàm của hàm số $f(x)$ trên $\mathbb{R}$. Tìm $I = \displaystyle\int\limits [2f(x)-1]\mathrm{\,d}x$.
	\choice
	{$I = 2F(x)-1+C$}
	{$I = 2xF(x)-1+C$}
	{\True $I = 2F(x)-x+C$}
	{$I = 2xF(x)-x+C$}
	\loigiai{
		Ta có $I = \displaystyle\int\limits [2f(x)-1]\mathrm{\,d}x = 2 \displaystyle\int\limits f(x)\mathrm{\,d}x - \displaystyle\int\limits 1 \mathrm{\,d}x = 2F(x)-x+C$.
	}
\end{ex}

\begin{ex} %[1D2H2-2]
	Cho cấp số cộng $(u_n)$ với $u_1 = 3$ và $u_2 = 9$. Công sai của cấp số cộng đã cho bằng
	\choice
	{$2$}
	{\True $6$}
	{$3$}
	{$4$}
	\loigiai{
		Công sai của cấp số cộng đã cho bằng $u_2 - u_1 = 9 - 3 = 6$.
	}
\end{ex}

\begin{ex} %[1D6H1-3]
	Tập xác định của hàm số $y = (x-3)^{-\pi}$ là
	\choice
	{$(-\infty;3)$}
	{\True $(3;+\infty)$}
	{$\mathbb{R} \setminus \{3\}$}
	{$\mathbb{R}$}
	\loigiai{
		Hàm số $y = (x-3)^{-\pi}$ xác định khi và chỉ khi $x-3 > 0 \Leftrightarrow x > 3$.\\
		Vậy tập xác định của hàm số là $\mathscr{D} = (3;+\infty)$.
	}
\end{ex}


